from torch import nn


class SimpleBinaryClassifier(nn.Module):
    """Very small fully‑connected network.
    Input size = number of engineered features (default = 11)
    Output: single logit → torch.nn.BCEWithLogitsLoss
    """

    def __init__(self, in_features: int = 11, hidden_dim: int = 256):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(in_features, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, 1), 
        )

    def forward(self, x):
        """x: Tensor of shape (batch, in_features)
        returns: Tensor of shape (batch, 1) (logits)
        """
        return self.net(x)

