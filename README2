import argparse
import json
import pathlib

import pandas as pd
import torch

from lm_ai_susceptibility_modeling.dataset import ThreatAssetDataset
from lm_ai_susceptibility_modeling.model import SimpleBinaryClassifier


def load_checkpoint(ckpt_path: pathlib.Path, device):
    ckpt = torch.load(str(ckpt_path), map_location=device)
    feature_names = ckpt["feature_names"]
    model = SimpleBinaryClassifier(in_features=len(feature_names)).to(device)
    model.load_state_dict(ckpt["model_state_dict"])
    model.eval()
    return model, feature_names


def preprocess_row(row: pd.Series, feature_names):
    threat_loc = ThreatAssetDataset._parse_list(row["threat_location"])
    threat_heading = float(row["threat_heading_deg"])
    threat_speed = float(row["threat_speed_mps"])
    assets_name = ThreatAssetDataset._parse_list(row["assets_name"])
    assets_loc = ThreatAssetDataset._parse_list(row["assets_location"])
    assets_heading = ThreatAssetDataset._parse_list(row["assets_heading_deg"])
    assets_bearing = ThreatAssetDataset._parse_list(row["assets_bearing_deg"])
    assets_speed = ThreatAssetDataset._parse_list(row["assets_speed_mps"])

    tgt_idx = ThreatAssetDataset._target_index(assets_name)

    try:
        asset_loc = assets_loc[tgt_idx]
    except Exception:
        asset_loc = [0.0, 0.0, 0.0]

    asset_heading = float(assets_heading[tgt_idx]) if assets_heading else 0.0
    asset_bearing = float(assets_bearing[tgt_idx]) if assets_bearing else 0.0
    asset_speed = float(assets_speed[tgt_idx]) if assets_speed else 0.0

    feature_vals = (
        threat_loc
        + [threat_heading, threat_speed]
        + asset_loc
        + [asset_heading, asset_bearing, asset_speed]
    )
    assert len(feature_vals) == len(feature_names)

    return torch.tensor([feature_vals], dtype=torch.float32)  # shape (1, F)


def predict(model, tensor, device):
    with torch.no_grad():
        logits = model(tensor.to(device))
        prob = torch.sigmoid(logits).cpu().item()
        pred = "HIT" if prob >= 0.5 else "MISS"
    return prob, pred


def main(args):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model, feature_names = load_checkpoint(args.ckpt, device)

    if args.input.suffix.lower() == ".csv":
        df = pd.read_csv(str(args.input))
        results = []
        for idx, row in df.iterrows():
            feats = preprocess_row(row, feature_names)
            prob, pred = predict(model, feats, device)
            results.append(
                {
                    "row_index": int(idx),
                    "probability_hit": prob,
                    "prediction": pred,
                }
            )
        out = pd.DataFrame(results)
        out.to_csv(str(args.output), index=False)
        print(f"Saved predictions for {len(df)} rows → {args.output}")

    else:
        with open(args.input) as f:
            data = json.load(f)
        row = pd.Series(data)
        feats = preprocess_row(row, feature_names)
        prob, pred = predict(model, feats, device)
        out = {"probability_hit": prob, "prediction": pred}
        with open(args.output, "w") as f:
            json.dump(out, f, indent=2)
        print(f"Prediction saved to {args.output}")
        print(out)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Run inference with the saved model"
    )
    parser.add_argument(
        "--ckpt",
        type=pathlib.Path,
        required=True,
        help="Path to the checkpoint produced by train.py (best_model.pt)",
    )
    parser.add_argument(
        "--input",
        type=pathlib.Path,
        required=True,
        help="CSV with rows OR a JSON file containing ONE row",
    )
    parser.add_argument(
        "--output",
        type=pathlib.Path,
        required=True,
        help="Where to write predictions (CSV for batch, JSON for single)",
    )
    args = parser.parse_args()
    main(args)

