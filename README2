import argparse
import pathlib
import time

import torch
from torch.nn import BCEWithLogitsLoss
from torch.optim import Adam
from torch.utils.data import DataLoader

from lm_ai_susceptibility_modeling.dataset import ThreatAssetDataset
from lm_ai_susceptibility_modeling.model import SimpleBinaryClassifier


def train_one_epoch(model, loader, criterion, optimizer, device):
    model.train()
    epoch_loss = 0.0
    for feats, lbl in loader:
        feats = feats.to(device)
        lbl = lbl.to(device)

        optimizer.zero_grad()
        logits = model(feats)  # (B,1)
        loss = criterion(logits, lbl)
        loss.backward()
        optimizer.step()

        epoch_loss += loss.item() * feats.size(0)
    return epoch_loss / len(loader.dataset)


def evaluate(model, loader, criterion, device):
    model.eval()
    epoch_loss = 0.0
    correct = 0
    with torch.no_grad():
        for feats, lbl in loader:
            feats = feats.to(device)
            lbl = lbl.to(device)

            logits = model(feats)
            loss = criterion(logits, lbl)
            epoch_loss += loss.item() * feats.size(0)

            preds = torch.sigmoid(logits) >= 0.5
            correct += (preds.float() == lbl).sum().item()
    avg_loss = epoch_loss / len(loader.dataset)
    acc = correct / len(loader.dataset)
    return avg_loss, acc


def main(args):
    dataset = ThreatAssetDataset(str(args.data))
    train_set, val_set = dataset.train_val_split(val_ratio=args.val_split)

    train_loader = DataLoader(
        train_set,
        batch_size=args.batch,
        shuffle=True,
        num_workers=args.workers,
        pin_memory=True,
    )

    val_loader = DataLoader(
        val_set,
        batch_size=args.batch,
        shuffle=False,
        num_workers=args.workers,
        pin_memory=True,
    )

    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model = SimpleBinaryClassifier(in_features=len(dataset.FEATURE_NAMES)).to(
        device
    )

    criterion = BCEWithLogitsLoss()
    optimizer = Adam(model.parameters(), lr=args.lr)

    best_val_acc = 0.0
    out_dir = pathlib.Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)

    for epoch in range(1, args.epochs + 1):
        start = time.time()
        train_loss = train_one_epoch(
            model, train_loader, criterion, optimizer, device
        )
        val_loss, val_acc = evaluate(model, val_loader, criterion, device)
        epoch_time = time.time() - start

        print(
            f"Epoch {epoch:02d} | "
            f"train loss {train_loss:.4f} | "
            f"val loss {val_loss:.4f} | val acc {val_acc:.4f} | "
            f"time {epoch_time:.1f}s"
        )

        # simple checkpoint, keep the best validation accuracy
        if val_acc > best_val_acc:
            best_val_acc = val_acc
            ckpt_path = out_dir / "best_model.pt"
            torch.save(
                {
                    "epoch": epoch,
                    "model_state_dict": model.state_dict(),
                    "optimizer_state_dict": optimizer.state_dict(),
                    "val_acc": val_acc,
                    "val_loss": val_loss,
                    "feature_names": dataset.FEATURE_NAMES,
                },
                ckpt_path,
            )
            print(f"   >>> saved new best model to {ckpt_path}")

    print(f"\nTraining finished – best val acc: {best_val_acc:.4f}")
    print(f"Best model stored at: {out_dir / 'best_model.pt'}")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Train a tiny threat‑vs‑asset binary classifier"
    )
    parser.add_argument(
        "--data",
        type=pathlib.Path,
        required=True,
        help="Path to the CSV containing the rows (e.g. data.csv)",
    )
    parser.add_argument(
        "--out-dir",
        type=pathlib.Path,
        default="outputs",
        help="Directory where the best checkpoint will be saved",
    )
    parser.add_argument("--epochs", type=int, default=30)
    parser.add_argument("--batch", type=int, default=64)
    parser.add_argument("--lr", type=float, default=1e-3)
    parser.add_argument(
        "--val-split",
        type=float,
        default=0.2,
        help="Fraction of data used for validation",
    )
    parser.add_argument(
        "--workers", type=int, default=0, help="Number of DataLoader workers"
    )
    args = parser.parse_args()
    main(args)

