import ast
import random

import pandas as pd
import torch
from torch.utils.data import Dataset, random_split


def _parse_list(col):
    # if pd.isna(col):
    #     return []
    column_after = ast.literal_eval(col)
    return column_after


def add_noise(
    values: list[float], noise_pct: float, *, seed: int | None = None
) -> list[float]:
    """Return a new list where each element has random noise applied.

    Args
    values
        Original numeric values (e.g., threat locations).
    noise_pct
        Maximum noise magnitude expressed as a percentage of each value.
        For example, 5.0 adds noise in the range [-5 %, +5 %] of the value.

    Returns:
        Values with noise applied.

    """
    if seed is not None:
        random.seed(seed)

    noisy = []
    for v in values:
        factor = 1 + random.uniform(-noise_pct, noise_pct) / 100.0
        noisy.append(v * factor)
    return noisy


class ThreatAssetDataset(Dataset):
    """Each row of the CSV yields:
    - feature Tensor (float32) of shape (11,)
    - label Tensor (float32) of shape (1,)
    """

    FEATURE_NAMES = [
        "threat_loc_x",
        "threat_loc_y",
        "threat_loc_z",
        "threat_heading_deg",
        "threat_speed_mps",
        "asset_loc_x",
        "asset_loc_y",
        "asset_loc_z",
        "asset_heading_deg",
        "asset_bearing_deg",
        "asset_speed_mps",
    ]

    def __init__(self, csv_path: str):
        self.df = pd.read_csv(csv_path)

    def __len__(self):
        return len(self.df)

    @staticmethod
    def _target_index(assets_name: list[str]) -> int:
        for i, name in enumerate(assets_name):
            if "target" in str(name).lower():
                return i
        return 0

    def __getitem__(self, idx: int) -> tuple[torch.Tensor, torch.Tensor]:
        row = self.df.iloc[idx]

        threat_loc = _parse_list(row["threat_location"])  # [x,y,z]
        threat_heading = float(row["threat_heading_deg"])
        threat_heading = 0
        threat_speed = float(row["threat_speed_mps"])
        threat_loc = add_noise(threat_loc, 0)

        assets_name = _parse_list(row["assets_name"])
        assets_loc = _parse_list(
            row["assets_location"]
        )  # [[x,y,z], [x,y,z], ...]
        assets_heading = _parse_list(row["assets_heading_deg"])
        assets_bearing = _parse_list(row["assets_bearing_deg"])
        assets_speed = _parse_list(row["assets_speed_mps"])

        tgt_idx = self._target_index(assets_name)

        try:
            asset_loc = assets_loc[tgt_idx]  # [x,y,z]
        except Exception:
            raise Exception
            asset_loc = [0.0, 0.0, 0.0]

        asset_heading = (
            float(assets_heading[tgt_idx]) if assets_heading else 0.0
        )
        asset_bearing = (
            float(assets_bearing[tgt_idx]) if assets_bearing else 0.0
        )
        asset_speed = float(assets_speed[tgt_idx]) if assets_speed else 0.0

        feature_vals = (
            threat_loc
            + [threat_heading, threat_speed]
            + asset_loc
            + [asset_heading, asset_bearing, asset_speed]
        )  # length == 11

        if len(feature_vals) != len(self.FEATURE_NAMES):
            raise ValueError(
                f"Feature length mismatch (got {len(feature_vals)}) "
                f"expected {len(self.FEATURE_NAMES)}"
            )

        features = torch.tensor(feature_vals, dtype=torch.float32)

        outcome_raw = str(row["outcome"]).strip().upper()
        label = 1 if outcome_raw == "HIT" else 0.0
        label = torch.tensor([label], dtype=torch.float32)

        return features, label

    def train_val_split(self, val_ratio: float = 0.2, seed: int = 42):
        total = len(self)
        val_len = int(total * val_ratio)
        train_len = total - val_len
        generator = torch.Generator().manual_seed(seed)
        train_set, val_set = random_split(
            self, [train_len, val_len], generator=generator
        )
        return train_set, val_set

