def analyze_root_cause(log_path):
    """
    REFACTORED: Now serves as the diagnostic heart for Epic 3.
    Parses hostdaemon files to determine app health and environment stability.
    """
    if not os.path.exists(log_path):
        return {
            "category": "CRITICAL", 
            "detail": "Host log file missing - System visibility lost",
            "status": "FAIL"
        }
    
    try:
        with open(log_path, 'r') as f:
            logs = f.read()
            
        # Environmental Checks (Epic 4.1 readiness)
        if "Network unreachable" in logs or "Disk I/O error" in logs:
            return {"category": "Environmental", "detail": "Connectivity/Storage failure detected.", "status": "FAIL"}
        
        # Application Logic Checks
        elif "IndexError" in logs or "ValueError" in logs:
            return {"category": "Logic", "detail": "Internal application code error detected.", "status": "FAIL"}
        
        # Check for G: Drive Volume Health
        if not os.path.exists("C:/app/reports"):
            return {"category": "Infrastructure", "detail": "G: Drive volume mount is unresponsive.", "status": "FAIL"}

        return {"category": "Healthy", "detail": "All system checks passed.", "status": "PASS"}
        
    except Exception as e:
        return {"category": "Unknown", "detail": f"Log read error: {str(e)}", "status": "FAIL"}

