def render_sidebar_controls():
    """
    Renders UI sidebar layout controls and captures configuration criteria.
    Wired directly to the Epic 3 Unified Reporting Engine.
    """
    st.sidebar.title("Dashboard Controls")
    
    # ... [Existing configurations like Contamination Slider or Model Selectors] ...

    st.sidebar.markdown("---")
    st.sidebar.header("Step 4: Finalize & Export")

    # Establish descriptive header context as requested by stakeholder requirements
    st.sidebar.write("Analyze active results against background connection trace files to identify root-causes.")

    # Unique trigger key avoids Streamlit auto-generated element ID collision bugs
    if st.sidebar.button("Generate Unified Test Analysis Report", key="unified_test_report_btn"):
        
        # CANONICAL TRUTH INPUT CHECK: Verify dataset is loaded into system memory
        # Looks for the active dataframe generated during UI rendering loop
        if "active_df" in st.session_state and st.session_state.active_df is not None:
            active_dataset = st.session_state.active_df
            
            with st.spinner("Executing cross-file log correlation pipeline..."):
                try:
                    # STRICT VOLUME ENVIRONMENT RULES:
                    # Map directly to internal paths backed by persistent G:\docker-storage mounts
                    persistent_log_dir = "C:/app/logs"
                    persistent_report_dir = "C:/app/reports"

                    # Ensure target directory structure exists on persistent storage array
                    os.makedirs(persistent_report_dir, exist_ok=True)

                    # TRIGGER ENGINE pipeline operation
                    pdf_filename, csv_filename = generate_comprehensive_unified_report(
                        active_dataframe=active_dataset,
                        trace_log_dir=persistent_log_dir,
                        output_directory=persistent_report_dir
                    )

                    # High-fidelity actionable feedback displayed in the sidebar
                    st.sidebar.success("Analysis complete! Artifacts safely written to persistent storage.")
                    
                    # Provide direct file visibility paths for lab engineers
                    st.sidebar.markdown(f"**Executive Report:** `{pdf_filename}`")
                    st.sidebar.markdown(f"**Analytical CSV:** `{csv_filename}`")
                    
                    # On-Demand file downloads directly inside the air-gapped container instance view
                    pdf_full_path = os.path.join(persistent_report_dir, pdf_filename)
                    if os.path.exists(pdf_full_path):
                        with open(pdf_full_path, "rb") as pdf_file:
                            st.sidebar.download_button(
                                label="📥 Download PDF Audit Summary",
                                data=pdf_file,
                                file_name=pdf_filename,
                                mime="application/pdf",
                                key="pdf_download_control"
                            )

                except Exception as e:
                    st.sidebar.error(f"Reporting Module Execution Failure: {str(e)}")
                    st.sidebar.warning("Verify that persistent folder mounts match expected container directories.")
        else:
            # Prevent silent or empty execution failures when pipeline arrays are empty
            st.sidebar.error("Pipeline context missing. Please upload and process a DART CSV file in the main panel first.")

