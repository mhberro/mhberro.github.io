def make_fr_segments(df: pd.DataFrame, threshold: float = 0.5) -> pd.Series:
    """
    Segment runs into two FR-based groups using a fixed threshold:

        - Low FR  : FR < threshold
        - High FR : FR >= threshold

    Also computes:
        - Percentage of runs in each segment and stores them in 
        st.session_state["FR_quartile_stats"].

    Parameters
    ----------
    df : pd.DataFrame
        DataFrame that must contain an 'FR' column.
    threshold : float, optional (default=0.5)
        Failure rate threshold that separates Low FR from High FR.
    """
    if "FR" not in df.columns:
        return None

    fr = df["FR"].astype(float)
    fr_clean = fr.dropna()
    if fr_clean.empty:
        return None

    seg = pd.Series(index=df.index, dtype=object)

    low_mask = fr < threshold
    high_mask = ~low_mask

    seg[low_mask] = "Low FR"
    seg[high_mask] = "High FR"

    total = len(seg)
    pct_low = 100.0 * low_mask.sum() / total if total > 0 else 0.0
    pct_high = 100.0 * high_mask.sum() / total if total > 0 else 0.0

    st.session_state["FR_quartile_stats"] = {
        "strategy": "fixed_threshold",
        "threshold": float(threshold),
        "Low FR %": round(pct_low, 2),
        "High FR %": round(pct_high, 2),
        "min_FR": float(fr_clean.min()),
        "max_FR": float(fr_clean.max()),
    }

    return seg

def segment_diff_numeric_bar(df: pd.DataFrame) -> go.Figure:
    """
    Top-5 numeric features (from FEATURES_FOR_ANALYSIS) that differ between
    High-FR and Low-FR segments, using mean z-score difference (High − Low).
    """
    fig = go.Figure()
    seg = make_fr_segments(df)
    if "FR" not in df.columns or seg is None:
        fig.update_layout(title="Numeric drivers (FR data unavailable)")
        return fig

    low_df = df[seg == "Low FR"]
    high_df = df[seg == "High FR"]

    diffs: dict[str, float] = {}

    for feat in FEATURES_FOR_ANALYSIS:
        if feat not in df.columns:
            continue
        s = df[feat]

        if not np.issubdtype(s.dtype, np.number):
            # Skip non-numeric here. handled by categorical chart
            continue

        # Standardize across all rows
        std = s.std(ddof=0)
        if std == 0 or np.isnan(std):
            continue
        z = (s - s.mean()) / std

        high_mean = z[high_df.index].mean() if not high_df.empty else 0.0
        low_mean = z[low_df.index].mean() if not low_df.empty else 0.0
        diffs[feat] = high_mean - low_mean  

    if not diffs:
        fig.update_layout(
            title="Numeric drivers (no numeric features in FEATURES_FOR_ANALYSIS)",
            height=220,
            margin=dict(l=10, r=10, t=40, b=40),
        )
        return fig

    # Top 5 by absolute z-score difference
    top5 = dict(sorted(diffs.items(), key=lambda kv: abs(kv[1]), reverse=True)[:5])

    fig.add_bar(x=list(top5.keys()), y=list(top5.values()))
    fig.update_layout(
        title="Top-5 Numeric Drivers (High FR − Low FR, z-score)",
        xaxis_title="Numeric Feature",
        yaxis_title="Delta z-score (High − Low)",
        height=360,
        margin=dict(l=10, r=10, t=40, b=80),
    )
    return fig


def segment_diff_categorical_bar(df: pd.DataFrame) -> go.Figure:
    """
    Top-5 categorical values from FEATURES_FOR_ANALYSIS that differ between
    High-FR and Low-FR segments, using percentage share difference (High − Low).

    Bars are labeled like 'Feature=Value'.
    """
    fig = go.Figure()
    seg = make_fr_segments(df)
    if "FR" not in df.columns or seg is None:
        fig.update_layout(title="Categorical drivers (FR data unavailable)")
        return fig

    low_df = df[seg == "Low FR"]
    high_df = df[seg == "High FR"]

    diffs: dict[str, float] = {}

    for feat in FEATURES_FOR_ANALYSIS:
        if feat not in df.columns:
            continue
        s = df[feat]

        # Only treat non-numeric as categorical here
        if np.issubdtype(s.dtype, np.number):
            continue

        # % share in each segment
        high_pct = high_df[feat].value_counts(normalize=True)
        low_pct = low_df[feat].value_counts(normalize=True)

        all_vals = set(high_pct.index) | set(low_pct.index)
        for val in all_vals:
            diff = high_pct.get(val, 0.0) - low_pct.get(val, 0.0)  # High − Low in percentage points
            diffs[f"{feat}={val}"] = diff

    if not diffs:
        fig.update_layout(
            title="Categorical drivers (no categorical features in FEATURES_FOR_ANALYSIS)",
            height=220,
            margin=dict(l=10, r=10, t=40, b=40),
        )
        return fig

    # Top-5 by absolute percentage-point difference
    top5 = dict(sorted(diffs.items(), key=lambda kv: abs(kv[1]), reverse=True)[:5])

    fig.add_bar(x=list(top5.keys()), y=list(top5.values()))
    fig.update_layout(
        title="Top-5 Categorical Drivers (High FR − Low FR, % share)",
        xaxis_title="Feature = Value",
        yaxis_title="Delta share (High − Low)",
        height=360,
        margin=dict(l=10, r=10, t=40, b=80),
    )
    return fig

def fr_correlation_heatmap(df: pd.DataFrame) -> go.Figure:
    """
    Shows correlation of features to High/Low FR.
    Calculates: Given Feature=X, what % were High FR vs Low FR
    """
    fig = go.Figure()
    
    # Segment the data
    seg = make_fr_segments(df)
    if seg is None or seg.isna().all():
        fig.update_layout(title="FR representation (segments unavailable)",
                          height=200, margin=dict(l=10, r=10, t=40, b=40))
        return fig

    # Attach Segment to a copy of the DF to guarantee alignment. fixes the index misalignment issue)
    df_analysis = df.copy()
    df_analysis["_FR_Segment"] = seg

    # Filter down to only high and low for binary comparison
    mask_binary = df_analysis["_FR_Segment"].isin(["High FR", "Low FR"])
    df_binary = df_analysis.loc[mask_binary].copy()
    
    if df_binary.empty:
        fig.update_layout(title="No High/Low FR data found", height=200)
        return fig

    rep_dict_high = {}
    rep_dict_low = {}

    for feat in FEATURES_FOR_ANALYSIS:
        if feat not in df_binary.columns:
            continue

        # Handle numeric features by binning
        if np.issubdtype(df[feat].dtype, np.number):
            # Calculate quartiles on the FULL dataset to ensure stable bins
            try:
                q = pd.qcut(df[feat].rank(method="first"), 4, labels=["Q1","Q2","Q3","Q4"])
                df_binary[f"_bin_{feat}"] = q
                target_col = f"_bin_{feat}"
                is_numeric = True
            except ValueError:
                continue
        else:
            target_col = feat
            is_numeric = False

        counts = df_binary.groupby([target_col, "_FR_Segment"]).size().unstack(fill_value=0)
        if "High FR" not in counts.columns: counts["High FR"] = 0
        if "Low FR" not in counts.columns:  counts["Low FR"] = 0

        for val in counts.index:
            count_high = counts.loc[val, "High FR"]
            count_low = counts.loc[val, "Low FR"]
            total = count_high + count_low

            if total == 0:
                continue

            pct_high = (count_high / total) * 100.0
            pct_low = (count_low / total) * 100.0

            if is_numeric:
                label = f"{feat}:{val}" 
            else:
                label = f"{feat}={val}" 

            rep_dict_high[label] = pct_high
            rep_dict_low[label] = pct_low

    if not rep_dict_high:
        fig.update_layout(title="FR representation (no valid features)", height=220)
        return fig

    df_rep = pd.DataFrame({
        "High_FR": pd.Series(rep_dict_high),
        "Low_FR": pd.Series(rep_dict_low)
    }).fillna(0.0)

    top_idx = df_rep["High_FR"].sort_values(ascending=False).head(15).index
    df_top = df_rep.loc[top_idx]
    mat = df_top.T  

    fig.add_trace(go.Heatmap(
        z=mat.values,
        x=mat.columns.tolist(),
        y=mat.index.tolist(),
        text=mat.round(1).astype(str) + "%",
        texttemplate="%{text}",
        zmin=0, zmax=100,
        colorscale=[
            [0.0, "red"],
            [0.5, "white"],
            [1.0, "green"],
        ],
        colorbar=dict(title="% Correlation"),
    ))

    fig.update_layout(
        title="High vs Low Failure Rate Percentages",
        height=350,
        margin=dict(l=10, r=10, t=50, b=10),
    )
    return fig



def fr_feature_plot(
    df: pd.DataFrame,
    selected_features: list[str],
    mode: str = "2D",
    top_n: int = 25,
) -> go.Figure:
    """
    Visualize Failure Rate as a function of up to 2 features.

    2D mode:
        - 1 feature:
            - Bar chart of average FR by raw feature value.
        - 2 features:
            - Two side-by-side bar charts, same rules.

    3D mode:
        - Exactly 2 features required.
        - Aggregate by (feature1, feature2) pairs
    """
    fig = go.Figure()

    if "FR" not in df.columns:
        fig.update_layout(
            title="FR not available",
            height=250,
            margin=dict(l=10, r=10, t=40, b=40),
        )
        return fig

    FR = df["FR"].astype(float)

    # No features selected
    if not selected_features:
        fig.update_layout(
            title="Select 1 or 2 features to view their relationship to FR",
            height=200,
            margin=dict(l=10, r=10, t=40, b=40),
        )
        return fig

    if mode == "3D":
        if len(selected_features) != 2:
            fig.update_layout(
                title="3D FR plot requires exactly 2 selected features",
                height=220,
                margin=dict(l=10, r=10, t=40, b=40),
            )
            return fig

        f1, f2 = selected_features
        if f1 not in df.columns or f2 not in df.columns:
            fig.update_layout(
                title="Selected features not in DataFrame",
                height=220,
                margin=dict(l=10, r=10, t=40, b=40),
            )
            return fig

        # Aggregate FR by (f1, f2) combination
        grouped = (
            df.groupby([f1, f2])["FR"]
            .agg(["mean", "count"])
            .reset_index()
            .rename(columns={"mean": "FR_mean", "count": "n"})
        )

        grouped = grouped.sort_values("FR_mean", ascending=False).head(top_n)

        s1_vals = grouped[f1]
        s2_vals = grouped[f2]
        fr_vals = grouped["FR_mean"].values
        counts = grouped["n"].values

        # Map raw values -> integer positions for equal spacing
        uniq1 = list(pd.unique(s1_vals))
        uniq2 = list(pd.unique(s2_vals))

        map1 = {v: i for i, v in enumerate(uniq1)}
        map2 = {v: i for i, v in enumerate(uniq2)}

        x_idx = s1_vals.map(map1).astype(float).values
        y_idx = s2_vals.map(map2).astype(float).values

        tickvals_x = list(range(len(uniq1)))
        ticktext_x = [str(v) for v in uniq1]

        tickvals_y = list(range(len(uniq2)))
        ticktext_y = [str(v) for v in uniq2]

        hovertext = [
            f"{f1}: {v1}<br>{f2}: {v2}<br>Avg FR: {fr:.3f}<br>Count: {n}"
            for v1, v2, fr, n in zip(s1_vals, s2_vals, fr_vals, counts)
        ]

        fig.add_trace(
            go.Scatter3d(
                x=x_idx,
                y=y_idx,
                z=fr_vals,
                mode="markers",
                marker=dict(
                    size=6,
                    color=fr_vals,
                    colorscale="RdYlGn_r",  # low FR = green, high FR = red
                    colorbar=dict(title="Avg FR"),
                ),
                hovertext=hovertext,
                hoverinfo="text",
            )
        )

        fig.update_layout(
            title=f"Average FR by (top-{top_n}) {f1} × {f2} combinations",
            scene=dict(
                xaxis=dict(
                    title=f1,
                    tickmode="array",
                    tickvals=tickvals_x,
                    ticktext=ticktext_x,
                ),
                yaxis=dict(
                    title=f2,
                    tickmode="array",
                    tickvals=tickvals_y,
                    ticktext=ticktext_y,
                ),
                zaxis=dict(title="Average FR"),
            ),
            height=600,
            margin=dict(l=10, r=10, t=40, b=10),
        )
        return fig

    # Helper: average FR by raw value, equal spacing, top-N by FR
    def avg_fr_by_feature(feature: str) -> tuple[np.ndarray, list[str], np.ndarray]:
        grouped = df.groupby(feature)["FR"].mean()
        grouped_sorted = grouped.sort_values(ascending=False).head(top_n)

        labels = [str(idx) for idx in grouped_sorted.index]  
        y_vals = grouped_sorted.values
        x_vals = np.arange(len(labels))

        return x_vals, labels, y_vals

    # 2D, 1 feature
    if len(selected_features) == 1:
        f = selected_features[0]
        if f not in df.columns:
            fig.update_layout(
                title="Selected feature not in DataFrame",
                height=220,
                margin=dict(l=10, r=10, t=40, b=40),
            )
            return fig

        x_vals, x_labels, y = avg_fr_by_feature(f)

        fig.add_trace(go.Bar(x=x_vals, y=y))

        fig.update_layout(
            title=f"Average FR by top-{top_n} {f}",
            xaxis=dict(
                title=f,
                tickmode="array",
                tickvals=x_vals,
                ticktext=x_labels,
                tickangle=45,
            ),
            yaxis=dict(title="Average FR"),
            height=400,
            margin=dict(l=10, r=10, t=40, b=80),
        )
        return fig

    # 2D, 2 features => two side-by-side bar charts
    f1, f2 = selected_features[:2]
    if f1 not in df.columns or f2 not in df.columns:
        fig.update_layout(
            title="Selected features not in DataFrame",
            height=220,
            margin=dict(l=10, r=10, t=40, b=40),
        )
        return fig

    x1_vals, x1_labels, y1 = avg_fr_by_feature(f1)
    x2_vals, x2_labels, y2 = avg_fr_by_feature(f2)

    fig = make_subplots(
        rows=1,
        cols=2,
        subplot_titles=[
            f"Average FR by top-{top_n} {f1}",
            f"Average FR by top-{top_n} {f2}",
        ],
    )

    fig.add_trace(go.Bar(x=x1_vals, y=y1, name=f1), row=1, col=1)
    fig.add_trace(go.Bar(x=x2_vals, y=y2, name=f2), row=1, col=2)

    fig.update_xaxes(
        title_text=f1,
        tickmode="array",
        tickvals=x1_vals,
        ticktext=x1_labels,
        tickangle=45,
        row=1,
        col=1,
    )
    fig.update_yaxes(title_text="Average FR", row=1, col=1)

    fig.update_xaxes(
        title_text=f2,
        tickmode="array",
        tickvals=x2_vals,
        ticktext=x2_labels,
        tickangle=45,
        row=1, col=2,
    )
    fig.update_yaxes(title_text="Average FR", row=1, col=2)

    fig.update_layout(
        title="Average FR by selected features",
        showlegend=False,
        height=450,
        margin=dict(l=10, r=10, t=40, b=80),
    )
    return fig

def per_point_contribution_bar(df: pd.DataFrame, row_pos: int) -> go.Figure:
    """
    For a selected run (row_pos), show the top-5 deviations (z-scores) across
    all analysis features (numeric + one-hot encoded).

    Bars may be labeled by:
      - base numeric features (e.g., "FR", "Num_Tests"), or
      - one-hot encoded categories (e.g., "Capability_A", "Simulation_Host_node1").
    """
    fig = go.Figure()
    Z, labels = zscore_matrix(df)

    if row_pos < 0 or row_pos >= len(Z):
        row_pos = 0

    # Use signed z-scores. rank by absolute deviation
    row_z = Z.iloc[row_pos]
    top = row_z.abs().sort_values(ascending=False).head(5)
    signed = row_z[top.index]

    fig.add_trace(go.Bar(x=top.index.tolist(), y=signed.values))
    fig.update_layout(
        title="Why this run? Top deviations (z-scores)",
        xaxis_title="Feature / Category (one-hot)",
        yaxis_title="Deviation (±σ)",
        height=300,
        margin=dict(l=10, r=10, t=40, b=40),
    )
    return fig

def _render_table_and_plot(
    df: pd.DataFrame,
    PCs: np.ndarray,
    scores01: np.ndarray,
    raw_scores: np.ndarray,
    method_label: str,
    key_prefix: str,
    pca,          
    pca_arrow_features: list[str], 
):
    """
    Renders, for a given anomaly scoring method:

      1) Top anomalies table with row selection
      2) PCA scatter plot (3D) with optional highlight and PCA driver arrows
      3) Secondary tab set:
           - Storyboard:
               * Feature-wise FR viewer (2D/3D)
               * 'Why this run?' bar chart for selected run
           - Anomaly Influence Network:
               * Feature co-movement network among top-K features
    """
    # breakpoint()
    df = df.copy()
    df["anomaly_score"] = scores01
    df["raw_anomaly_score"] = raw_scores
    # breakpoint()
    st.markdown(f"### {method_label}")

    highlight_pos: int | None = None
    show_top = st.session_state.get("show_top", 10)

    if show_top > 0:
        cols_keep = [
            "Test_Run_ID",
            "FR",
            "Num_Tests",
            "total_init_time",
            "anomaly_score",
            "raw_anomaly_score",
            "Simulation_Host",
            "Simulation_Node",
            "Capability",
            "Script_File",
            "V",
            "s_number",
            "Build",
        ]
        cols_keep = [c for c in cols_keep if c in df.columns]

        top = df.sort_values("anomaly_score", ascending=False).head(show_top)

        st.markdown("**Top anomalies**")
        editable = top[cols_keep].copy()
        editable.insert(0, "Select", False)

        edited = st.data_editor(
            editable,
            use_container_width=True,
            num_rows="fixed",
            disabled={c: True for c in editable.columns if c != "Select"},
            key=f"{key_prefix}-table",
        )

        # Map selected row back to original df index
        selected_original_idxs = edited.index[edited["Select"]].tolist()
        if selected_original_idxs:
            pos = df.index.get_indexer([selected_original_idxs[0]])
            if len(pos) and pos[0] != -1:
                highlight_pos = int(pos[0])

    label_choice = st.session_state.get("label_choice", "Failure Rate")

    fig = plot_for_df(
        df,
        PCs,
        selected_label_name=label_choice,
        scores01=scores01,
        highlight_pos=highlight_pos,
    )

    show_biplot = st.session_state.get("show_biplot", True)
    if show_biplot and PCs.shape[1] >= 2 and pca is not None:
        from typing import cast
        default_arrow_feats = cast(list[str], globals().get("PCA_FEATURES", []))
        arrow_feats = st.session_state.get("pca_arrow_features", pca_arrow_features) or default_arrow_feats

        show_global_pca_arrows = st.session_state.get("show_global_pca_arrows", True)
        show_low_fr_arrows = st.session_state.get("show_low_fr_arrows", True)
        show_high_fr_arrows = st.session_state.get("show_high_fr_arrows", True)

        if show_global_pca_arrows:
            try:
                add_pca_loadings_3d(fig, pca, arrow_feats, scale=2.0)
            except Exception:
                pass

        # Segment-anchored arrows near Low-FR and High-FR bands
        try:
            seg = make_fr_segments(df)

            if seg is not None:
                if show_low_fr_arrows:
                    low_mask = (seg == "Low FR").values
                    if np.any(low_mask):
                        low_anchor = PCs[low_mask].mean(axis=0)
                        add_biplot_arrows_at_anchor_3d(
                            fig,
                            pca,
                            arrow_feats,
                            low_anchor,
                            scale=1.2,
                            color="green",
                            name_prefix="Low FR ",
                            showlegend=False,
                        )

                if show_high_fr_arrows:
                    high_mask = (seg == "High FR").values
                    if np.any(high_mask):
                        high_anchor = PCs[high_mask].mean(axis=0)
                        add_biplot_arrows_at_anchor_3d(
                            fig,
                            pca,
                            arrow_feats,
                            high_anchor,
                            scale=1.2,
                            color="red",
                            name_prefix="High FR ",
                            showlegend=False,
                        )
        except Exception:
            pass

    st.plotly_chart(fig, use_container_width=True, key=f"{key_prefix}-plot")

    sub_story, sub_net = st.tabs(["Storyboard", "Anomaly Influence Network"])

    with sub_story:
        st.session_state["active_secondary"] = "Storyboard"

        show_segment_compare = st.session_state.get("show_segment_compare", True)
        show_selection_why = st.session_state.get("show_selection_why", True)

        if show_segment_compare:
            st.markdown("#### Feature-wise Failure Rate Viewer")

            available_feats = [
                f for f in globals().get("FEATURES_FOR_ANALYSIS", [])
                if f in df.columns
            ]
            st.caption("Select up to 2 features.")

            selected_features = st.multiselect(
                "Features",
                options=available_feats,
                default=available_feats[:1] if available_feats else [],
                max_selections=2,
                key=f"{key_prefix}-frfeat-select",
            )

            dim_col, n_col = st.columns([2, 1])

            with dim_col:
                dim_choice = st.radio(
                    "Plot dimension",
                    options=["2D", "3D"],
                    index=0,
                    horizontal=True,
                    key=f"{key_prefix}-frfeat-dim",
                )

            with n_col:
                top_n = st.number_input(
                    "Top-N values",
                    min_value=1,
                    max_value=50,
                    value=25,
                    step=1,
                    key=f"{key_prefix}-frfeat-topn",
                )

            seg_fig = fr_feature_plot(
                df=df,
                selected_features=selected_features,
                mode=dim_choice,
                top_n=top_n,
            )
            st.plotly_chart(seg_fig, use_container_width=True, key=f"{key_prefix}-segplot")

            st.markdown("#### Failure Rate Correlation")
            st.plotly_chart(
                fr_correlation_heatmap(df),
                use_container_width=True,
                key=f"{key_prefix}-frcorr",
            )

    with sub_net:
        st.session_state["active_secondary"] = "Anomaly Influence Network"

        show_influence_network = st.session_state.get("show_influence_network", True)
        if show_influence_network:
            subset = st.session_state.get("influence_subset", "Anomalous (top 5%)")
            top_k = st.session_state.get("influence_topk", 10)
            edge_thresh = st.session_state.get("influence_edge_thresh", 0.40)
            corr_method = st.session_state.get("influence_corr_method", "pearson")

            net_fig = anomaly_influence_network_figure(
                df,
                scores01,
                subset=subset,
                q=0.95,
                top_k=top_k,
                edge_thresh=edge_thresh,
                corr_method=corr_method,
            )
            st.plotly_chart(
                net_fig,
                use_container_width=True,
                key=f"{key_prefix}-influence",
            )

def render_one(path: Path):
    """
    Load one dataset, engineer features, run PCA + IF + LOF,
    and render three primary tabs:

        - Principal Component Analysis
        - Isolation Forest
        - Local Outlier Factor
        - Autoencoder (reconstruction)

    Each primary tab reuses `_render_table_and_plot`, which adds:
        - Top anomalies table
        - PCA visualization (with driver arrows)
        - Storyboard subtab (segment comparison, FR representation)
        - Anomaly Influence Network subtab
    """
    try:
        raw = load_csv(path)
        # breakpoint()
        df = engineer_features(raw)
        # breakpoint()

        # Build feature matrices
        X = build_features(df).to_numpy(dtype=float)      
        Xz, _ = scale_features(df)                        # scaled version for anomaly models

        scaler_viz, pca_viz, _, PCs = fit_pca_scaled(X, n_components=3)
        pca_dist_raw = compute_anomaly_scores(PCs)
        pca_s01 = normalize_scores(pca_dist_raw)

        if_contam = st.session_state.get("if_contam", 0.02)
        if_trees = st.session_state.get("if_trees", 300)

        _, if_raw = score_isolation_forest(
            Xz,
            contamination=if_contam,
            n_estimators=if_trees,
        )
        if_s01 = normalize_scores(if_raw)

        lof_k = st.session_state.get("lof_k", 20)

        _, lof_raw = score_lof(
            Xz,
            n_neighbors=lof_k,
        )

        ae_w1 = st.session_state.get("ae_w1", 16)
        ae_w2 = st.session_state.get("ae_w2", 8)
        ae_w3 = st.session_state.get("ae_w3", 16)                
        ae_iter = st.session_state.get("ae_iter", 400)
        _, ae_raw  = score_autoencoder(Xz, hidden=(ae_w1, ae_w2, ae_w3), max_iter=ae_iter)

        lof_s01 = normalize_scores(lof_raw)
        ae_s01 = normalize_scores(ae_raw)
        
        st.subheader(f"{path.name} · Anomaly Analysis")
        # tab_pca, tab_if, tab_lof = st.tabs(
        #     ["Principal Component Analysis", "Isolation Forest", "Local Outlier Factor"]
        # )
        tab_pca, tab_if, tab_lof, tab_ae = st.tabs(
            ["Principal Component Analysis", "Isolation Forest", "Local Outlier Factor", "Autoencoder"]
        )



        with tab_pca:
            st.session_state["active_primary"] = "PCA"
            pca_arrow_features = st.session_state.get(
                "pca_arrow_features",
                globals().get("PCA_FEATURES", []),
            )
            _render_table_and_plot(
                df=df,
                PCs=PCs,
                scores01=pca_s01,
                raw_scores=pca_dist_raw,
                method_label="Principal Component Analysis",
                key_prefix=f"{path.name}-PCA",
                pca=pca_viz,
                pca_arrow_features=pca_arrow_features,
            )

        with tab_if:
            st.session_state["active_primary"] = "Isolation Forest"

            pca_arrow_features = st.session_state.get(
                "pca_arrow_features",
                globals().get("PCA_FEATURES", []),
            )

            _render_table_and_plot(
                df=df,
                PCs=PCs,
                scores01=if_s01,
                raw_scores=if_raw,
                method_label="Isolation Forest",
                key_prefix=f"{path.name}-IF",
                pca=pca_viz,
                pca_arrow_features=pca_arrow_features,
            )

        with tab_lof:
            st.session_state["active_primary"] = "Local Outlier Factor"

            pca_arrow_features = st.session_state.get(
                "pca_arrow_features",
                globals().get("PCA_FEATURES", []),
            )

            _render_table_and_plot(
                df=df,
                PCs=PCs,
                scores01=lof_s01,
                raw_scores=lof_raw,
                method_label="Local Outlier Factor",
                key_prefix=f"{path.name}-LOF",
                pca=pca_viz,
                pca_arrow_features=pca_arrow_features,
            )
        
        with tab_ae:
            _render_table_and_plot(
                df,
                PCs,
                ae_s01,
                ae_raw,
                "Autoencoder (Reconstruction)",
                key_prefix=f"{path.name}-AE",
                pca=pca_viz,
                pca_arrow_features=pca_arrow_features,
            )

    except Exception as e:
        st.error(f"Failed to process {path.name}: {e}")

