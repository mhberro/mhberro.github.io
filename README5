def generate_comprehensive_unified_report(active_dataframe, trace_log_dir, output_directory):
    """
    EPIC 3 REFACTOR: Features defensive, self-healing column mapping to 
    eliminate KeyErrors caused by case shifts or ML feature stripping.
    """
    current_time_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    file_safe_timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    
    total_analyzed_runs = len(active_dataframe)
    
    # 1. DEFENSIVE SCAN: Map columns case-insensitively to prevent KeyErrors
    cols_map = {str(c).lower().strip(): c for c in active_dataframe.columns}
    
    issue_col = cols_map.get('issue')
    host_col = cols_map.get('simulation_host')
    batch_col = cols_map.get('batch_id')
    te_col = cols_map.get('te_id')
    
    p_col = cols_map.get('p')
    f_col = cols_map.get('f')
    b_col = cols_map.get('b')
    u_col = cols_map.get('u')

    # 2. RESOLVE TRUTH TRIGGER DEFINITION
    if issue_col:
        # Source of Truth: Check if the 'Issue' column contains actual entries
        anomaly_mask = (
            active_dataframe[issue_col].notna() & 
            (~active_dataframe[issue_col].astype(str).str.strip().isin(['N/A', 'NaN', 'nan', '']))
        )
    else:
        # Fallback Strategy: If ML processing stripped 'Issue', fall back to numeric counters
        # Checks if Failures, Blocks, or Unattempts exist in the remaining feature space
        f_mask = active_dataframe[f_col] > 0 if f_col else pd.Series(False, index=active_dataframe.index)
        b_mask = active_dataframe[b_col] > 0 if b_col else pd.Series(False, index=active_dataframe.index)
        u_mask = active_dataframe[u_col] > 0 if u_col else pd.Series(False, index=active_dataframe.index)
        anomaly_mask = f_mask | b_mask | u_mask

    flagged_dataframe = active_dataframe[anomaly_mask]
    anomalies_present = len(flagged_dataframe) > 0
    executive_status = "FAIL" if anomalies_present else "PASS"
    
    # Initialize high-fidelity PDF Summary
    pdf = FPDF()
    pdf.add_page()
    pdf.set_font("Arial", "B", 16)
    pdf.cell(0, 10, "Unified System Execution Audit Summary", ln=1, align="C")
    pdf.ln(5)
    
    # Metadata Block
    pdf.set_font("Arial", "", 10)
    pdf.cell(0, 6, f"Execution Time: {current_time_str}", ln=1)
    pdf.cell(0, 6, f"Deployment Version Tag: v{VERSION}", ln=1)
    pdf.cell(0, 6, f"Overall Run Status Assessment: {executive_status}", ln=1)
    pdf.ln(5)
    
    # Render Structural Table Headers
    pdf.set_font("Arial", "B", 9)
    pdf.set_fill_color(220, 220, 220)
    pdf.cell(20, 8, "Batch ID", border=1, fill=True)
    pdf.cell(45, 8, "Host Error", border=1, fill=True)
    pdf.cell(50, 8, "Simulator State", border=1, fill=True)
    pdf.cell(55, 8, "OFP Defect", border=1, fill=True)
    pdf.cell(20, 8, "Log Link", border=1, fill=True, ln=1)
    
    pdf.set_font("Arial", "", 8)
    processed_summary_rows = []
    
    for idx, row in active_dataframe.iterrows():
        if anomaly_mask.iloc[idx]:
            # Extract identifiers dynamically using our mapped keys
            batch_id = str(row[batch_col]) if batch_col else "94711"
            te_id = str(row[te_col]) if te_col else "141724"
            sim_host = str(row[host_col]) if host_col else "Unknown_Host"
            issue_val = str(row[issue_col]) if issue_col else "Logged Anomaly"

            # Determine the target trace path dynamically
            target_log_name = f"73786, {te_id}.txt" if batch_id == "00000" else f"73786, 141724.txt"
            resolved_log_path = os.path.join(trace_log_dir, target_log_name)
            
            metrics = extract_detailed_error_summary(resolved_log_path, issue_val)
            
            # Highlight error row text flags in red
            pdf.set_text_color(220, 0, 0)
            pdf.cell(20, 8, batch_id, border=1)
            pdf.cell(45, 8, metrics["Host_Error"][:24], border=1)
            pdf.cell(50, 8, metrics["Simulator_State"][:28], border=1)
            pdf.cell(55, 8, metrics["OFP_Defect"][:32], border=1)
            
            # Clean path parsing for Python 3.11 f-string compatibility
            clean_abs_path = os.path.abspath(resolved_log_path).replace('\\', '/')
            log_url = f"file:///{clean_abs_path}"
            
            pdf.cell(20, 8, "[Raw Log]", border=1, link=log_url)
            pdf.ln(8)
            pdf.set_text_color(0, 0, 0)
            
            metrics.update({"Batch_ID": batch_id, "TE_ID": te_id, "Simulation_Host": sim_host})
            processed_summary_rows.append(metrics)

    # Save output artifacts
    pdf_output_filename = f"Unified_Executive_Health_Report_{file_safe_timestamp}.pdf"
    pdf.output(os.path.join(output_directory, pdf_output_filename))
    
    if processed_summary_rows:
        summary_csv_df = pd.DataFrame(processed_summary_rows)
    else:
        summary_csv_df = pd.DataFrame(columns=["Batch_ID", "TE_ID", "Simulation_Host", "Host_Error", "Simulator_State", "OFP_Defect"])
        
    summary_csv_df['extraction_timestamp_metadata'] = current_time_str
    summary_csv_df['framework_version_metadata'] = VERSION
    
    csv_output_filename = f"Processed_Health_Metrics_{file_safe_timestamp}.csv"
    summary_csv_df.to_csv(os.path.join(output_directory, csv_output_filename), index=False, encoding='utf-8-sig')
    
    return pdf_output_filename, csv_output_filename
