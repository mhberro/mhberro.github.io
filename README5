    pdf.set_font("Arial", "", 10)
    pdf.cell(0, 10, f"Execution Timestamp: {timestamp}", ln=1)
    
    # 2. Add Root Cause Correlation
    category, detail = analyze_root_cause("C:/app/logs/hostdaemon.log")
    pdf.set_font("Arial", "I", 10)
    pdf.multi_cell(0, 10, f"Root Cause Analysis: [{category}] - {detail}")
    
    # Save PDF
    pdf_filename = f"Report_{datetime.now().strftime('%Y%m%d_%H%M')}.pdf"
    pdf.output(os.path.join(output_path, pdf_filename))
    
    # 3. On-Demand CSV Export
    csv_filename = f"RawData_{datetime.now().strftime('%Y%m%d_%H%M')}.csv"
    data.to_csv(os.path.join(output_path, csv_filename), index=False)
    
    return pdf_filename, csv_filename



