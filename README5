def get_system_health_metrics(log_path):
    """
    Analyzes hostdaemon.log to generate health metrics for the report.
    """
    if not os.path.exists(log_path):
        return {"status": "FAIL", "reason": "Host logs missing", "error_count": 0}
    
    with open(log_path, 'r') as f:
        log_content = f.read()
    
    # Calculate health indicators
    error_count = log_content.count("ERROR") + log_content.count("CRITICAL")
    warn_count = log_content.count("WARNING")
    
    health_status = "PASS" if error_count == 0 else "FAIL"
    
    return {
        "status": health_status,
        "error_count": error_count,
        "warn_count": warn_count,
        "disk_check_g": "Available" if os.path.exists("C:/app/logs") else "Disconnected"
    }
