def generate_unified_report(output_path):
    """
    REFACTORED: Generates App Health artifacts (PDF/CSV) as per Epic 3.
    Replaces sensor data analysis with system diagnostic metrics.
    """
    # 1. Gather Health Metrics (Metadata Integration - Story 3.3)
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    health_info = analyze_root_cause("C:/app/logs/hostdaemon.log")
    
    # 2. PDF Generation (Story 3.1)
    pdf = AnomalyReport()
    pdf.add_page()
    pdf.set_font("Arial", "B", 14)
    pdf.cell(0, 10, f"App Health Audit: {health_info['status']}", ln=1)
    
    pdf.set_font("Arial", "", 10)
    pdf.cell(0, 10, f"Execution Timestamp: {timestamp}", ln=1)
    pdf.cell(0, 10, f"System Version: {VERSION}", ln=1) # Story 3.3
    pdf.ln(5)
    
    pdf.set_font("Arial", "B", 11)
    pdf.cell(0, 10, "Diagnostic Breakdown:", ln=1)
    pdf.set_font("Arial", "", 10)
    pdf.multi_cell(0, 10, f"Category: {health_info['category']}\nDetails: {health_info['detail']}")
    
    pdf_filename = f"AppHealth_Audit_{datetime.now().strftime('%Y%m%d_%H%M')}.pdf"
    pdf.output(os.path.join(output_path, pdf_filename))
    
    # 3. CSV Metrics Export (Story 3.2)
    # Exports a structured row for long-term health tracking
    health_df = pd.DataFrame([health_info])
    health_df['timestamp'] = timestamp
    health_df['version'] = VERSION
    
    csv_filename = f"Health_Metrics_{datetime.now().strftime('%Y%m%d_%H%M')}.csv"
    health_df.to_csv(os.path.join(output_path, csv_filename), index=False)
    
    return pdf_filename, csv_filename

