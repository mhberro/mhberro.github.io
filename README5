import os
import pytest
import pandas as pd
from nbf_anomaly_detection import extract_detailed_error_summary, generate_comprehensive_unified_report

@pytest.fixture
def mock_environment_setup(tmp_path):
    """
    Sets up a temporary directory structure mimicking the air-gapped container mapping.
    """
    log_dir = tmp_path / "logs"
    report_dir = tmp_path / "reports"
    log_dir.mkdir()
    report_dir.mkdir()
    return log_dir, report_dir


def test_scenario_one_simulator_state_dead_nodes(mock_environment_setup):
    """
    SCENARIO 1: Validates detection of hardware/environment component degradation (Dead Nodes).
    """
    log_dir, _ = mock_environment_setup
    target_log = log_dir / "73786, 141724.txt"
    
    # Populate the mock file with the exact environmental footprint found in 73786, 141724.txt
    with open(target_log, "w", encoding="utf-8") as f:
        f.write("01:41:45 AM CST : INFO : systemHealth.py : Identifying dead nodes...\n")
        f.write("01:41:48 AM CST : WARNING : systemHealth.py : The following nodes are currently dead: ['MPA3A0', 'MPA3A1']\n")
        
    metrics = extract_detailed_error_summary(str(target_log))
    assert "Degraded - Dead Nodes" in metrics["Simulator_State"]
    assert "MPA3A0" in metrics["Simulator_State"]
    assert "MPA3A1" in metrics["Simulator_State"]


def test_scenario_two_ofp_defect_validation_mismatch(mock_environment_setup):
    """
    SCENARIO 2: Validates operational detection of validation mismatch faults (OFP Defect).
    """
    log_dir, _ = mock_environment_setup
    target_log = log_dir / "73786, 141724.txt"
    
    with open(target_log, "w", encoding="utf-8") as f:
        f.write("02:40:48 AM CST : ERROR : reporter.py : [-6] - [F] - 7b2 - FAIL [UNEXPECTED]: Ownship symbol is NOT displayed in cyan.\n")
        
    metrics = extract_detailed_error_summary(str(target_log))
    assert "Ownship symbol is NOT displayed in cyan" in metrics["OFP_Defect"]


def test_scenario_three_host_error_sim_abortion(mock_environment_setup):
    """
    SCENARIO 3: Validates immediate processing of a terminal host runtime crash or system abort.
    """
    log_dir, _ = mock_environment_setup
    target_log = log_dir / "73786, 141724.txt"
    
    with open(target_log, "w", encoding="utf-8") as f:
        f.write("02:46:52 AM CST : INFO : hostrunner.py : Attempting to execute function 'abortSim'...\n")
        f.write("02:46:52 AM CST : INFO : utils.py : Sending Simulation to Terminate...\n")
        
    metrics = extract_detailed_error_summary(str(target_log))
    assert "Aborted/Terminated" in metrics["Host_Error"]


def test_e2e_reporting_pipeline_trigger_on_issue_column(mock_environment_setup):
    """
    SCENARIO 4: Verifies the pipeline ignores N/A strings and accurately generates 
    artifacts only when active rows are populated in the 'Issue' column.
    """
    log_dir, report_dir = mock_environment_setup
    
    # Create the corresponding text log anchor
    target_log = log_dir / "73786, 141724.txt"
    with open(target_log, "w") as f:
        f.write("WARNING : The following nodes are currently dead: ['MPA3A0']\n")
        f.write("ERROR : FAIL [UNEXPECTED]: Verification fault.\n")

    # Construct mock DART Dataframe with explicit variation profiles
    mock_data = pd.DataFrame([
        {"Batch_ID": "94711", "TE_ID": "141724", "Simulation_Host": "mvdl-m08-h01", "P": 6, "F": 1, "B": 0, "U": 0, "Issue": "{'1': {'step': '3a'}}"},
        {"Batch_ID": "94832", "TE_ID": "147435", "Simulation_Host": "adc-svr-vl535", "P": 7, "F": 0, "B": 0, "U": 0, "Issue": "N/A"}
    ])
    
    pdf_out, csv_out = generate_comprehensive_unified_report(mock_data, str(log_dir), str(report_dir))
    
    assert os.path.exists(os.path.join(report_dir, pdf_out))
    assert os.path.exists(os.path.join(report_dir, csv_out))
    
    # Read output CSV to verify only the active issue row triggered log parsing
    output_csv = pd.read_csv(os.path.join(report_dir, csv_out))
    assert len(output_csv) == 1
    assert output_csv.iloc[0]["Batch_ID"] == 94711

