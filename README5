def generate_health_audit(output_path):
    """
    EPIC 3: Generates a Unified Health Report based on app diagnostics.
    """
    metrics = get_system_health_metrics("C:/app/logs/hostdaemon.log")
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    # 1. Generate PDF Report
    pdf = AnomalyReport() # Using the existing class
    pdf.add_page()
    pdf.set_font("Arial", "B", 16)
    pdf.cell(0, 10, f"App Health Status: {metrics['status']}", ln=1)
    
    pdf.set_font("Arial", "", 10)
    pdf.cell(0, 10, f"Version: {VERSION} | Timestamp: {timestamp}", ln=1)
    pdf.ln(5)
    
    pdf.cell(0, 10, f"Critical Errors Detected: {metrics['error_count']}", ln=1)
    pdf.cell(0, 10, f"System Warnings: {metrics['warn_count']}", ln=1)
    pdf.cell(0, 10, f"G: Drive Volume Status: {metrics['disk_check_g']}", ln=1)

    pdf_filename = f"Health_Audit_{datetime.now().strftime('%Y%m%d_%H%M')}.pdf"
    pdf.output(os.path.join(output_path, pdf_filename))
    
    # 2. Generate Metrics CSV (For Epic 3.2/3.3)
    metrics_df = pd.DataFrame([metrics])
    metrics_df['timestamp'] = timestamp
    csv_filename = f"Health_Metrics_{datetime.now().strftime('%Y%m%d_%H%M')}.csv"
    metrics_df.to_csv(os.path.join(output_path, csv_filename), index=False)
    
    return pdf_filename, csv_filename

