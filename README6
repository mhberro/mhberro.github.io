# gru_ode.py
# (Showing only modified GRUODEFunc code blocks for scannability; all other cells remain intact)

class GRUODEFunc(nn.Module):
    """GRU-ODE vector field over an *augmented* state ``[h ; y_read]``."""

    ORDER = "y_first"

    def __init__(
        self,
        n_features: int,
        hidden_size: int = 64,
        cell: str = "full",
        couple_state: bool = True,
        n_derivative_pairs: int | None = None,
        couple_indices: tuple[int, ...] | None = None,
        identity_mode: str = "raw",
        pos_scale: torch.Tensor | None = None,
        vel_scale: torch.Tensor | None = None,
        vel_mean: torch.Tensor | None = None,
        encoder_dropout: float = 0.1,
    ):
        super().__init__()
        self.n_features = n_features
        self.hidden_size = hidden_size
        self.couple_state = couple_state

        if n_derivative_pairs is None:
            n_derivative_pairs = 0
        if not (0 <= n_derivative_pairs * 2 <= n_features):
            raise ValueError(f"Incompatible n_derivative_pairs={n_derivative_pairs} for n_features={n_features}")
        self.n_derivative_pairs = n_derivative_pairs
        self.n_leaving_learned = n_features - n_derivative_pairs  # Adjusted to prevent shadow-naming conflicts
        self.n_learned = n_features - n_derivative_pairs

        if identity_mode not in ("raw", "scaled"):
            raise ValueError(f"identity_mode must be 'raw' or 'scaled', got {identity_mode!r}")
        self.identity_mode = identity_mode

        if n_derivative_pairs > 0 and identity_mode == "scaled":
            pos_scale_t = torch.as_tensor(pos_scale, dtype=torch.float32).reshape(-1)
            vel_scale_t = torch.as_tensor(vel_scale, dtype=torch.float32).reshape(-1)
            vel_mean_t = torch.zeros_like(vel_scale_t) if vel_mean is None else torch.as_tensor(vel_mean, dtype=torch.float32).reshape(-1)
            kin_a = vel_scale_t / pos_scale_t
            kin_b = vel_mean_t / pos_scale_t
        else:
            kin_a = torch.ones(max(n_derivative_pairs, 1))
            kin_b = torch.zeros(max(n_derivative_pairs, 1))
        self.register_buffer("kin_a", kin_a)
        self.register_buffer("kin_b", kin_b)

        if couple_state:
            if couple_indices is None:
                couple_indices = tuple(range(n_derivative_pairs, n_features))
            self.couple_indices = tuple(couple_indices)
            input_size = len(self.couple_indices)
        else:
            self.couple_indices = ()
            input_size = 0

        if cell == "full":
            self.ode_cell = FullGRUODECell(hidden_size, input_size=input_size)
        elif cell == "minimal":
            self.ode_cell = MinimalGRUODECell(hidden_size, input_size=input_size)
        else:
            raise ValueError(f"unknown GRU-ODE cell type: {cell!r}")

        if encoder_dropout and encoder_dropout > 0.0:
            self.encoder = nn.Sequential(
                nn.Linear(n_features, hidden_size),
                nn.SiLU(),
                nn.Dropout(p=encoder_dropout),
                nn.Linear(hidden_size, hidden_size),
                nn.Tanh(),
            )
        else:
            self.encoder = nn.Sequential(
                nn.Linear(n_features, hidden_size),
                nn.SiLU(),
                nn.Linear(hidden_size, hidden_size),
                nn.Tanh(),
            )
        self.encoder_dropout = float(encoder_dropout)
        
        # Deep Capacity Expansion via sequential linear-normalization structures 
        # Resolves high-frequency kinematic trajectory mapping distortions over expanded windows
        self.obs_head = nn.Sequential(
            nn.Linear(hidden_size, hidden_size),
            nn.LayerNorm(hidden_size),
            nn.SiLU(),
            nn.Linear(hidden_size, hidden_size),
            nn.LayerNorm(hidden_size),
            nn.SiLU(),
            nn.Linear(hidden_size, self.n_learned),
        )
        self.nfe = 0

    def _couple_input(self, y_read: torch.Tensor) -> torch.Tensor | None:
        if not self.couple_state:
            return None
        return y_read[..., list(self.couple_indices)]

    def _assemble_dstate(self, y_read: torch.Tensor, dy_learned: torch.Tensor, dh: torch.Tensor) -> torch.Tensor:
        if self.n_derivative_pairs > 0:
            k = self.n_derivative_pairs
            v_norm = y_read[..., k : 2 * k]
            dp = self.kin_a[:k] * v_norm + self.kin_b[:k]
            dy = torch.cat((dp, dy_learned), dim=-1)
        else:
            dy = dy_learned
        return torch.cat((dy, dh), dim=-1)

    def build_initial_state(self, x0_phys: torch.Tensor) -> torch.Tensor:
        h0 = self.encoder(x0_phys)
        return torch.cat((x0_phys, h0), dim=-1)

    def forward(self, t, state: torch.Tensor) -> torch.Tensor:
        self.nfe += 1
        y_read = state[..., : self.n_features]
        h = state[..., self.n_features : self.n_features + self.hidden_size]

        h = torch.tanh(h)
        x_in = self._couple_input(y_read)
        dh = self.ode_cell(t, h, x_in)
        dy_learned = self.obs_head(h)

        return self._assemble_dstate(y_read, dy_learned, dh)

