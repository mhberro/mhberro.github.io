# ---------------------------------------------------------------------
# Tiny runnable helper you can import if you prefer, instead of inlining
# the shape parse (used by Option A):
# ---------------------------------------------------------------------
def encoder_state_size(enc_sess) -> int:
    """Physical-state width = encoder graph input width. Authoritative."""
    shape = enc_sess.get_inputs()[0].shape
    ints = [d for d in shape if isinstance(d, int)]
    if not ints:
        raise ValueError(f"Encoder input shape {shape} has no static dim to read state_size from")
    return int(ints[-1])
