    # NOTE: Change the 122.0 to 61.0 for the LowE
    truth_states_sr_cut = np.asarray(
        tuple(x for x in truth_states if x[TIME_INDEX] < 122.0 and not np.allclose(x[VEL_SLICE], [0, 0, 0])),
        dtype=np.float64,
    )

    # start sim clock at truth firm track range
    firm_track_time = truth_states_sr_cut[0][0]
    sim_time = deepcopy(firm_track_time)
    trajs = []
    truth_trajs = []

    # sim to the end of the truth
    while sim_time <= impact_time - measurement_dt:
        # print("sim time step", sim_time, impact_time, measurement_dt)
        # grab the current target state
        tgt_state_ecef_index = np.where(truth_states_sr_cut[:, 0] == sim_time)
        tgt_state_ecef_index_forward = np.where(truth_states_sr_cut[:, 0] >= sim_time)
        if len(tgt_state_ecef_index[0]) == 0:
            # missed a truth point at that time. grab the next one in the chain and update sim time for that step
            try:
                tgt_state_ecef_index = np.array(tgt_state_ecef_index_forward[0][0])
            except IndexError:
                # ran out of states in the truth
                return truth_states_sr_cut, trajs, truth_trajs
            sim_time = truth_states_sr_cut[tgt_state_ecef_index].squeeze()[0]
        tgt_state_ecef = truth_states_sr_cut[tgt_state_ecef_index]
        truth_traj_forward = truth_states_sr_cut[tgt_state_ecef_index_forward]

        x0 = tgt_state_ecef.squeeze()
        traj = NEXT_tactical_interface(x0[0:7], impact_ecef, extrapolation_dt, max_traj_states, args)
        if traj is not None:
            if isinstance(traj, int) and traj == -1:
                # got a stop sim signal for the algorithm under test
                break
            trajs.append(traj)
            truth_trajs.append(truth_traj_forward)
        # step sim time by measurement dt and repeat
        sim_time += measurement_dt
    return truth_states_sr_cut, trajs, truth_trajs


def bound(low, high, x):
    return max(low, min(high, x))


def round_to(x, base):
    return base * round(x / base)


ort_sess_stash = None  # TODO: Stop cheating with a global variable. Only used for GRDTH models


def NEXT_tactical_interface(initial_state_ecef, guide_point_ecef, dt, n_steps, args):
    # initial state ecef is expected to be a 1d vector for time in seconds, position x3, and velocity x3 in ECEF
    # guide point ecef is expected to be...

    # check if target is too close
    initial_state_slant_range = np.linalg.norm(initial_state_ecef[POS_SLICE] - guide_point_ecef)
    if initial_state_slant_range < args.sr_min:
        print("target too close", initial_state_slant_range, args.sr_min)
        return -1

    # transform into NEXT frame
    use_grdth = "_grdth_" in os.path.basename(args.model)
    use_geodesic = "_geod_" in os.path.basename(args.model)
    global ort_sess_stash
    if use_grdth:
        initial_state_NEXT_frame, initial_point_heading = ecef_to_next_grdth(initial_state_ecef, guide_point_ecef)
        initial_state_slant_range = np.hypot(initial_state_NEXT_frame[GR_INDEX], initial_state_NEXT_frame[DOWN_INDEX])
        if ort_sess_stash:
            ort_sess = ort_sess_stash
        else:
            # load NEXT model
            ort_sess = onnxruntime.InferenceSession(args.model)
            ort_sess_stash = ort_sess
    elif use_geodesic:
        _, initial_point_heading = ecef_to_next_grdth(initial_state_ecef, guide_point_ecef)
        initial_state_NEXT_frame = ecef_to_local_geodesic_vec(
            np.atleast_2d(initial_state_ecef[POS_SLICE]),
            np.atleast_2d(initial_state_ecef[VEL_SLICE]),
            np.zeros_like(
                np.atleast_2d(initial_state_ecef[VEL_SLICE])
            ),  # TODO: better handling of acceleration being in the transform functions
            guide_point_ecef,
        )
        # Prepend time and only include pos and vel
        initial_state_NEXT_frame = np.hstack(
            [np.atleast_2d(initial_state_ecef[TIME_INDEX]), initial_state_NEXT_frame[:, :6]]
        )[0]
        initial_state_slant_range = np.linalg.norm(initial_state_NEXT_frame[POS_SLICE])
        if ort_sess_stash:
            ort_sess = ort_sess_stash
        else:
            # load NEXT model
            ort_sess = onnxruntime.InferenceSession(args.model)
            ort_sess_stash = ort_sess
    else:
        initial_state_NEXT_frame, initial_point_heading, flip_c = ecef_to_next_dcu(initial_state_ecef, guide_point_ecef)
        initial_state_slant_range = np.linalg.norm(initial_state_NEXT_frame[POS_SLICE])
        bucket_range = 100000
        rounded_sr = int(bound(bucket_range, args.sr_max, round_to(initial_state_slant_range, bucket_range)) / 1e3)
        model_name_to_load = re.sub(r"_\d{1,3}sr_", f"_{rounded_sr}sr_", args.model)
        scalar_name_to_load = os.path.join(
            os.path.dirname(args.scalar), re.sub(r"_\d{1,3}sr_", f"_{rounded_sr}sr_", os.path.basename(args.scalar))
        )
        args.scalar = scalar_name_to_load
        ort_sess = onnxruntime.InferenceSession(model_name_to_load)

    # call the extrapolator
    try:
        NEXT_extrap = NEXT_extrapolation(
            initial_state_NEXT_frame, dt, n_steps, initial_point_heading, use_grdth, args, ort_sess
        )
    except ValueError as e:
        print("Extrap failed", traceback.format_exc())
        return None

    # get back to ECEF
    if use_grdth:
        NEXT_extrap_ecef = next_grdth_to_ecef(NEXT_extrap, guide_point_ecef, initial_point_heading)
    elif use_geodesic:
        NEXT_extrap_ecef = np.hstack(
            [
                NEXT_extrap[:, TIME_INDEX][..., np.newaxis],
                local_geodesic_to_ecef_vec(
                    np.hstack([NEXT_extrap[:, 1:], np.zeros_like(NEXT_extrap[:, VEL_SLICE])]), guide_point_ecef
                ),
            ],
        )[:, :7]
    else:
        NEXT_extrap_ecef = next_dcu_to_ecef(NEXT_extrap, guide_point_ecef, initial_point_heading, flip_c)

    # use numpy gradient (second order inner. first order on boundary) for a numerical derivative
    a = np.gradient(NEXT_extrap_ecef[:, VEL_SLICE], axis=0)

    # TODO: move this to outside the model loop
    def get_acc(x):
        a = np.zeros_like(x)
        # TODO: Fix this
        # for j in range(3):
        #     # inner points
        #     a[1:-1, j] = (x[2:, j] - x[:2, j]) / 2
        #     # boundary points
        #     a[0, j] = x[1, j] - x[0, j]
        #     a[-1, j] = x[-1, j] - x[-2, j]
        return a

    a_test = get_acc(NEXT_extrap_ecef[:, VEL_SLICE])
    # if not np.allclose(a, a_test):
    #     print("WOAH! Numerical method did not work")

    NEXT_extrap_ecef = np.hstack([NEXT_extrap_ecef, a])

    # output ECEF traj
    return NEXT_extrap_ecef


def NEXT_extrapolation(
    initial_state_next_frame,
    dt: float,
    n_steps: int,
    ref_angle,
    use_grdth: bool,
    args,
    ort_sess: onnxruntime.InferenceSession,
):
    # print("initial_state_next_frame", initial_state_next_frame)

    # ort_sess_scalar = onnxruntime.InferenceSession(args.scalar)  # switch to using ONNX for scalar (update: can't)
    use_scalar = "_scalarOn" in os.path.basename(args.model)
    if use_scalar:
        with open(args.scalar, "rb") as scalar_pickle:
            NEXT_scalar = pickle.load(scalar_pickle)
    state_size = 6
    if use_grdth:
        state_size = 5

    # infer at extrapolation dt
    # keep going until the termination criteria is met
    # the initial point will be the initial state
    model_augmentation_dim = int(re.findall(r"_(\d)aug_", args.model)[-1])
    extrap = np.array([np.hstack([initial_state_next_frame])])
    if model_augmentation_dim > 0:
        augmentation_state = torch.zeros(
            1, model_augmentation_dim
        )  # TODO: is there a data driven when to find how many zeros to add? filename
    validity_time = deepcopy(initial_state_next_frame[0])

    # n_steps = 5
    temp_iter = 0
    # NOTE: the 122.0 thing is for SBI HighE HGV
    while temp_iter < n_steps and float(validity_time) < 122.0:
        temp_iter = temp_iter + 1
        validity_time += dt

        if use_scalar:
            # print("\nstartig step", temp_iter)
            pos_vel = np.asarray([extrap[-1][1 : state_size + 1]])
            # print("pos_vel", pos_vel)
            # TODO: No need to cast to a tensor. change this to use numpy
            scaled_pos_vel = torch.Tensor(NEXT_scalar.transform(pos_vel))
            # print("scaled_pos_vel", scaled_pos_vel)
            if model_augmentation_dim > 0:
                # print("aug state", augmentation_state)
                temp_state = torch.cat((scaled_pos_vel, augmentation_state), dim=1)
            else:
                temp_state = scaled_pos_vel
            # print("temp state", temp_state)
            model_input = temp_state[0].detach().numpy()
            # print("model_input", model_input)
            model_output = ort_sess.run(["output"], {"input": model_input})[-1].reshape(1, -1)
            # print("model_output", model_output)
            next_state_raw = model_output * dt + temp_state.detach().numpy()
            # print("next_state raw", next_state_raw)
            augmentation_state = torch.Tensor(next_state_raw[:, state_size:])
            # print("augmentation_state", augmentation_state)
            next_state = NEXT_scalar.inverse_transform(
                next_state_raw[:, :state_size]
            )  # skl2onnx does not support this. see https://github.com/onnx/sklearn-onnx/issues/765
            # print("next state", next_state)
        else:
            temp_state = torch.Tensor(np.asarray([extrap[-1][1 : state_size + 1]]))
            next_state = (
                ort_sess.run(["output"], {"input": temp_state[0].detach().numpy()})[-1] * dt
                + temp_state.detach().numpy()[-1]
            )

        next_state = np.insert(next_state, 0, validity_time)
        temp_extrap = np.vstack([extrap, next_state])

        # TODO: What if I scaled the ending criteria so that the extrap can be entirly done in the scalared space?
        if use_grdth and (temp_extrap[-1, DOWN_INDEX] > 0 or temp_extrap[-1, GR_INDEX] < 2600e3):
            print("grdth below the ground", temp_extrap[-1, DOWN_INDEX])
            break
        # elif not use_grdth and (temp_extrap[-1, 3] < 0 or np.linalg.norm(temp_extrap[-1, POS_SLICE]) < 250e3):
        elif not use_grdth and (np.linalg.norm(temp_extrap[-1, POS_SLICE]) < 2600e3):
            print("dcu below the ground", temp_extrap[-1, 3])
            break
        extrap = np.vstack([extrap, next_state])

    if extrap.shape[0] < 3:
        raise ValueError(f"Extrap was too short {extrap.shape}")

    return extrap


