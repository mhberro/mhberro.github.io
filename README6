import numpy as np
import pandas as pd
from NEXT_Geodesic_Frame import ecef_to_local_geodesic_vec, local_geodesic_to_ecef_vec

# ---- user inputs ----
in_csv = r"C:/Users/e487666/iRAPTOR Projects/datasets/SBI/2026/2-Working-Data/SBI_boost-glide/HighE_HGV/boost/Albuqurque_lp2_ECEF.csv"
out_geod_csv = r"geodesic_integrated.csv"
out_rt_csv = r"ecef_roundtrip.csv"
out_err_csv = r"ecef_roundtrip_error.csv"
ref_ecef_csv = r"C:/Users/e487666/iRAPTOR Projects/datasets/SBI/2026/2-Working-Data/SBI_boost-glide/HighE_HGV/impact/Albuqurque_lp2_ECEF.csv"
# ---------------------

df = pd.read_csv(in_csv)
ref_df = pd.read_csv(ref_ecef_csv)

required = ["time","x","y","z","vx","vy","vz"]
missing = [c for c in required if c not in df.columns]
if missing:
    raise ValueError(f"Missing columns: {missing}")

ecef = df[required].to_numpy(dtype=float)
time = ecef[:, 0]
pos = ecef[:, 1:4]
vel = ecef[:, 4:7]

ref_ecef_data = ref_df[required].to_numpy(dtype=float)
ref_pos = ref_ecef_data[:, 1:4]

if np.any(np.diff(time) < 0):
    raise ValueError("Time must be monotonic non-decreasing for integrated azimuth reconstruction.")

# Typical reference: impact at last state position
ref_ecef = ref_pos[-1, :]

# ECEF -> geodesic integrated
geod_state, az0 = ecef_to_local_geodesic_vec(pos, vel, ref_ecef)
# geod_state columns: [s, h, v_s, v_alpha, v_h]
geod_with_time = np.hstack([time[:, None], geod_state])

# geodesic integrated -> ECEF
ecef_rt_no_time = local_geodesic_to_ecef_vec(geod_with_time, ref_ecef, az0)
ecef_rt = np.hstack([time[:, None], ecef_rt_no_time])

# Save transformed and reconstructed CSVs
pd.DataFrame(
    geod_with_time,
    columns=["time", "s", "h", "v_s", "v_alpha", "v_h"]
).to_csv(out_geod_csv, index=False)

pd.DataFrame(
    ecef_rt,
    columns=["time","x","y","z","vx","vy","vz"]
).to_csv(out_rt_csv, index=False)

# Error metrics
err = ecef_rt[:, 1:7] - ecef[:, 1:7]
pos_err = err[:, 0:3]
vel_err = err[:, 3:6]

pos_rmse = np.sqrt(np.mean(pos_err**2, axis=0))
vel_rmse = np.sqrt(np.mean(vel_err**2, axis=0))
pos_norm_rmse = np.sqrt(np.mean(np.sum(pos_err**2, axis=1)))
vel_norm_rmse = np.sqrt(np.mean(np.sum(vel_err**2, axis=1)))

print("Azimuth initial (rad):", az0)
print("Position RMSE [m] by axis (x,y,z):", pos_rmse)
print("Velocity RMSE [m/s] by axis (vx,vy,vz):", vel_rmse)
print("Position RMSE norm [m]:", pos_norm_rmse)
print("Velocity RMSE norm [m/s]:", vel_norm_rmse)
print("Max |position error| [m]:", np.max(np.abs(pos_err)))
print("Max |velocity error| [m/s]:", np.max(np.abs(vel_err)))

pd.DataFrame(
    np.hstack([
        time[:, None],
        pos_err,
        vel_err,
        np.linalg.norm(pos_err, axis=1)[:, None],
        np.linalg.norm(vel_err, axis=1)[:, None],
    ]),
    columns=["time","dx","dy","dz","dvx","dvy","dvz","pos_err_norm","vel_err_norm"]
).to_csv(out_err_csv, index=False)

print(f"Wrote: {out_geod_csv}, {out_rt_csv}, {out_err_csv}")
