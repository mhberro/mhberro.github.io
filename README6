class ReduceLROnPlateauConfiguration(SchedulerConfiguration):
    """A learning rate scheduler for training plateaus."""

    def __init__(
        self,
        metric_name: str,
        *,
        mode: ReductionMode = ReductionMode.MIN,  # Default from torch source.
        factor: float = 0.1,  # Default from torch source code.
        patience: int = 10,  # Default from torch source code.
        threshold: float = 1e-4,  # Default from torch source code.
        threshold_mode: ThresholdMode = ThresholdMode.REL,  # From source code.
        cooldown: int = 0,  # Default from torch source code.
        min_lr: float = 0.0,  # Default from torch source code.
        epsilon: float = 1e-8,  # Default from torch source code.
    ) -> None:
        """Initializes a ReduceLROnPlateau scheduler configuration.

        Args:
            metric_name: The name of the metric to monitor for a plateau.
            mode: The metric mode to monitor for changing the LR.
            factor: The factor by which the learning rate will be reduced.
            patience: The number of allowed epochs with no improvement.
                After this number of epochs, the learning rate will be reduced.
            threshold: The threshold for measuring the new optimum.
                This is to only focus on significant changes.
            threshold_mode: The mode to evaluate the threshold.
            cooldown: The number of epochs to wait before resuming.
                This applies to resuming normal operation after lr has been
                reduced.
            min_lr: A lower bound on the learning rate.
            epsilon: The minimal decay applied to lr.
                If the difference between new and old lr is smaller than eps,
                the update is ignored.
        """
        self.metric_name: str = metric_name
        _mode: Feature = Feature(
            name=SchedulerParameter.REDUCTION_MODE.name,
            value=mode,
            ftype=FeatureType.DISCRETE_FEATURE,
            options=list(ReductionMode),
        )

        _factor: Feature = Feature(
            name=SchedulerParameter.FACTOR.name,
            value=factor,
            ftype=FeatureType.CONTINUOUS_FEATURE,
            min_val=0,
            max_val=1.0,
        )

        _patience: Feature = Feature(
            name=SchedulerParameter.PATIENCE.name,
            value=patience,
            ftype=FeatureType.DISCRETE_FEATURE,
            min_val=1,
            max_val=np.inf,
        )

        _threshold: Feature = Feature(
            name=SchedulerParameter.THRESHOLD.name,
            value=threshold,
            ftype=FeatureType.CONTINUOUS_FEATURE,
            min_val=0,
            max_val=1.0,
        )

        _threshold_mode: Feature = Feature(
            name=SchedulerParameter.THRESHOLD_MODE.name,
            value=threshold_mode,
            ftype=FeatureType.DISCRETE_FEATURE,
            options=list(ThresholdMode),
        )

        _cooldown: Feature = Feature(
            name=SchedulerParameter.COOLDOWN.name,
            value=cooldown,
            ftype=FeatureType.DISCRETE_FEATURE,
            min_val=1,
            max_val=np.inf,
        )

        _min_lr: Feature = Feature(
            name=SchedulerParameter.MIN_LR.name,
            value=min_lr,
            ftype=FeatureType.CONTINUOUS_FEATURE,
            min_val=0,
            max_val=1.0,
        )

        _epsilon: Feature = Feature(
            name=SchedulerParameter.EPSILON.name,
            value=epsilon,
            ftype=FeatureType.CONTINUOUS_FEATURE,
            min_val=0,
            max_val=1.0,
        )

        super().__init__(
            features=[
                _mode,
                _factor,
                _patience,
                _threshold,
                _threshold_mode,
                _cooldown,
                _min_lr,
                _epsilon,
            ]
        )

    def create_from_optimizer(
        self, optimizer: torch.optim.Optimizer
    ) -> torch.optim.lr_scheduler.LRScheduler:
        """Creates a learning rate scheduler given a torch optimizer.

        Args:
            optimizer: A torch optimizer.

        Returns:
            A torch learning rate scheduler.
        """
        return torch.optim.lr_scheduler.ReduceLROnPlateau(
            optimizer=optimizer,
            mode=self.get_param(SchedulerParameter.REDUCTION_MODE),
            factor=self.get_param(SchedulerParameter.FACTOR),
            patience=self.get_param(SchedulerParameter.PATIENCE),
            threshold=self.get_param(SchedulerParameter.THRESHOLD),
            threshold_mode=self.get_param(SchedulerParameter.THRESHOLD_MODE),
            cooldown=self.get_param(SchedulerParameter.COOLDOWN),
            min_lr=self.get_param(SchedulerParameter.MIN_LR),
            eps=self.get_param(SchedulerParameter.EPSILON),
        )
