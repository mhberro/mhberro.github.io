        )

    stacked_posvel = np.vstack(traj_targets_train_posvel)
    column_names = ["Down", "Cross", "Up", "dotD", "dotC", "dotU"]  # dcu default
    if args.frame == "grdth":
        column_names = ["GR", "Down", "dotGR", "dotD", "VTheta"]
    elif args.frame == "geodesic":
        if args.geodesic_mode == "integrated":
            column_names = ["s", "h", "v_s", "v_alpha", "v_h"]
        else:  # original
            column_names = ["s", "az", "h", "v_s", "v_alpha", "v_h"]
    plot_column_distributions(
        stacked_posvel,
