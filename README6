if scaler_traj is not None:
        scaler_attrs = ['mean_', 'scale_', 'var_', 'min_', 'data_min_', 'data_max_']
        for attr in scaler_attrs:
            if hasattr(scaler_traj, attr) and getattr(scaler_traj, attr) is not None:
                # Cast the underlying NumPy arrays to 32-bit floating point precision
                setattr(scaler_traj, attr, getattr(scaler_traj, attr).astype(np.float32))
