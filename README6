#!/usr/bin/env python3
"""A/B harness for the field-method experiment (targets val_pos_err).

Runs the SAME training command under different FIELD_METHOD settings and
compares them CORRECTLY -- at matched val_loss / at convergence, never at a
matched epoch number (the runs progress at different rates). Tracks best
val_pos_err and val_vel_err SEPARATELY with the epoch each was achieved.

This does not re-implement training. It drives NEXT_training_mo_cl_ref_loss.py
by overriding the three toggles (FIELD_METHOD / FD_EPS / FD_RELATIVE) via
environment variables, parses the per-epoch metrics each run writes, and
produces the comparison table + winner call.

Wiring required in NEXT_training_mo_cl_ref_loss.py (one-time, minimal):
    import os
    FIELD_METHOD = os.environ.get("NEXT_FIELD_METHOD", "central")
    FD_EPS       = float(os.environ.get("NEXT_FD_EPS", "1e-4"))
    FD_RELATIVE  = os.environ.get("NEXT_FD_RELATIVE", "0") == "1"
and have node.fit / the metrics logger append rows of
    epoch,val_loss,val_pos_err,val_vel_err
to  $NEXT_METRICS_CSV  (one file per run; the harness sets this per arm).

Usage:
    python field_method_ab.py --cmd "python NEXT_training_mo_cl_ref_loss.py <args>" \
        --arms central central64 jvp \
        --outdir ab_runs/field_method

Compare-at-convergence policy:
    * "best": each arm's best val_pos_err over its whole run (default).
    * "matched_val_loss": find the lowest val_loss L* reached by ALL arms, then
      report each arm's val_pos_err at the first epoch it reaches L*. This
      controls for arms that simply trained longer/faster.
"""
from __future__ import annotations

import argparse
import copy
import json
import os
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path


@dataclass
class RunResult:
    arm: str
    csv_path: str
    epochs: list[int] = field(default_factory=list)
    val_loss: list[float] = field(default_factory=list)
    val_pos_err: list[float] = field(default_factory=list)
    val_vel_err: list[float] = field(default_factory=list)

    # -- convergence-aware summaries ------------------------------------
    def best_pos(self) -> tuple[float, int]:
        i = min(range(len(self.val_pos_err)), key=lambda k: self.val_pos_err[k])
        return self.val_pos_err[i], self.epochs[i]

    def best_vel(self) -> tuple[float, int]:
        i = min(range(len(self.val_vel_err)), key=lambda k: self.val_vel_err[k])
        return self.val_vel_err[i], self.epochs[i]

    def best_val_loss(self) -> float:
        return min(self.val_loss)

    def pos_at_val_loss(self, target: float) -> tuple[float, int] | None:
        """val_pos_err at the FIRST epoch this arm's val_loss <= target."""
        for k, vl in enumerate(self.val_loss):
            if vl <= target:
                return self.val_pos_err[k], self.epochs[k]
        return None

    def vel_at_val_loss(self, target: float) -> tuple[float, int] | None:
        for k, vl in enumerate(self.val_loss):
            if vl <= target:
                return self.val_vel_err[k], self.epochs[k]
        return None


ARM_ENV = {
    # arm name -> env overrides for the training toggles
    "central":       {"NEXT_FIELD_METHOD": "central",   "NEXT_FD_EPS": "1e-4", "NEXT_FD_RELATIVE": "0"},
    "central64":     {"NEXT_FIELD_METHOD": "central64", "NEXT_FD_EPS": "1e-4", "NEXT_FD_RELATIVE": "0"},
    "central_rel":   {"NEXT_FIELD_METHOD": "central",   "NEXT_FD_EPS": "1e-2", "NEXT_FD_RELATIVE": "1"},
    "central64_rel": {"NEXT_FIELD_METHOD": "central64", "NEXT_FD_EPS": "1e-2", "NEXT_FD_RELATIVE": "1"},
    "jvp":           {"NEXT_FIELD_METHOD": "jvp",       "NEXT_FD_EPS": "1e-4", "NEXT_FD_RELATIVE": "0"},
}


def run_arm(arm: str, base_cmd: str, outdir: Path) -> RunResult:
    if arm not in ARM_ENV:
        raise SystemExit(f"unknown arm {arm!r}; choices: {sorted(ARM_ENV)}")
    outdir.mkdir(parents=True, exist_ok=True)
    csv_path = outdir / f"{arm}_metrics.csv"
    env = copy.deepcopy(os.environ)
    env.update(ARM_ENV[arm])
    env["NEXT_METRICS_CSV"] = str(csv_path)
    print(f"\n=== ARM {arm} ===\n  env: {ARM_ENV[arm]}\n  metrics -> {csv_path}")
    # Reproducibility: same seed across arms so the ONLY difference is the field.
    env.setdefault("PYTHONHASHSEED", "0")
    proc = subprocess.run(base_cmd, shell=True, env=env)
    if proc.returncode != 0:
        print(f"  WARNING: arm {arm} exited with code {proc.returncode}")
    return parse_metrics(arm, csv_path)


def parse_metrics(arm: str, csv_path: Path) -> RunResult:
    r = RunResult(arm=arm, csv_path=str(csv_path))
    if not csv_path.exists():
        print(f"  ERROR: no metrics file for arm {arm} at {csv_path}")
        return r
    import csv as _csv

    with open(csv_path) as fh:
        reader = _csv.DictReader(fh)
        for row in reader:
            try:
                r.epochs.append(int(float(row["epoch"])))
                r.val_loss.append(float(row["val_loss"]))
                r.val_pos_err.append(float(row["val_pos_err"]))
                r.val_vel_err.append(float(row["val_vel_err"]))
            except (KeyError, ValueError):
                continue
    return r


def compare(results: list[RunResult], policy: str, vel_tol: float) -> None:
    results = [r for r in results if r.epochs]
    if not results:
        raise SystemExit("no arms produced metrics; nothing to compare")

    print("\n" + "=" * 72)
    print("FIELD-METHOD A/B  (win = lower val_pos_err, val_vel_err not materially up)")
    print("=" * 72)

    # baseline is 'central' if present, else the first arm
    base = next((r for r in results if r.arm == "central"), results[0])
    base_pos, base_pos_ep = base.best_pos()
    base_vel, base_vel_ep = base.best_vel()

    if policy == "matched_val_loss":
        target = max(r.best_val_loss() for r in results)  # loss ALL arms reached
        print(f"\nComparison policy: matched val_loss <= {target:.6g} "
              f"(the best loss every arm reached)\n")
        header = f"{'arm':>14} {'pos@L*':>12} {'ep':>5} {'vel@L*':>12} {'ep':>5}"
        print(header); print("-" * len(header))
        for r in results:
            pa = r.pos_at_val_loss(target); va = r.vel_at_val_loss(target)
            if pa is None or va is None:
                print(f"{r.arm:>14} {'n/a':>12} {'-':>5} {'n/a':>12} {'-':>5}")
                continue
            print(f"{r.arm:>14} {pa[0]:>12.4g} {pa[1]:>5} {va[0]:>12.4g} {va[1]:>5}")
    else:
        print("\nComparison policy: each arm's BEST val_pos_err over its full run\n")
        header = (f"{'arm':>14} {'best_pos':>12} {'ep':>5} {'best_vel':>12} {'ep':>5} "
                  f"{'best_vloss':>12}")
        print(header); print("-" * len(header))
        for r in results:
            bp, bpe = r.best_pos(); bv, bve = r.best_vel()
            print(f"{r.arm:>14} {bp:>12.4g} {bpe:>5} {bv:>12.4g} {bve:>5} "
                  f"{r.best_val_loss():>12.4g}")

    # winner call vs baseline ------------------------------------------
    print("\nVerdict vs baseline "
          f"({base.arm}: pos={base_pos:.4g}@{base_pos_ep}, vel={base_vel:.4g}@{base_vel_ep}):")
    for r in results:
        if r is base:
            continue
        bp, _ = r.best_pos(); bv, _ = r.best_vel()
        pos_gain = (base_pos - bp) / base_pos * 100.0
        vel_change = (bv - base_vel) / base_vel * 100.0
        # win: pos improved AND vel not materially worse (within vel_tol %)
        if bp < base_pos and vel_change <= vel_tol * 100.0:
            tag = "WIN"
        elif abs(pos_gain) < 1.0 and abs(vel_change) < 1.0:
            tag = "WASH"
        elif bp < base_pos and vel_change > vel_tol * 100.0:
            tag = "TRADEOFF (pos better, vel worse)"
        else:
            tag = "WORSE"
        print(f"  {r.arm:>14}: pos {pos_gain:+6.2f}%  vel {vel_change:+6.2f}%  -> {tag}")

    print("\nNote: 'jvp' is train-only (not ONNX-traceable). If it wins, ship "
          "'central64' -- it reproduces J*dh to ~1e-9 and IS exportable, so the "
          "deployed field matches. Confirm with a train-vs-ONNX field parity "
          "check on a batch of states before export.")


def main() -> None:
    ap = argparse.ArgumentParser()
    ap.add_argument("--cmd", required=True,
                    help="full training command to run per arm (quoted)")
    ap.add_argument("--arms", nargs="+", default=["central", "central64", "jvp"],
                    choices=sorted(ARM_ENV))
    ap.add_argument("--outdir", default="ab_runs/field_method")
    ap.add_argument("--policy", default="best",
                    choices=["best", "matched_val_loss"])
    ap.add_argument("--vel-tol", type=float, default=0.02,
                    help="max fractional val_vel_err increase still counted a win "
                         "(default 0.02 = 2%%)")
    ap.add_argument("--skip-run", action="store_true",
                    help="don't launch training; just parse existing metrics CSVs")
    args = ap.parse_args()

    outdir = Path(args.outdir)
    results: list[RunResult] = []
    for arm in args.arms:
        if args.skip_run:
            results.append(parse_metrics(arm, outdir / f"{arm}_metrics.csv"))
        else:
            results.append(run_arm(arm, args.cmd, outdir))

    compare(results, args.policy, args.vel_tol)

    summary = {
        r.arm: {
            "best_pos": r.best_pos()[0] if r.epochs else None,
            "best_pos_epoch": r.best_pos()[1] if r.epochs else None,
            "best_vel": r.best_vel()[0] if r.epochs else None,
            "best_vel_epoch": r.best_vel()[1] if r.epochs else None,
            "best_val_loss": r.best_val_loss() if r.epochs else None,
            "csv": r.csv_path,
        }
        for r in results
    }
    (outdir / "summary.json").write_text(json.dumps(summary, indent=2))
    print(f"\nwrote {outdir/'summary.json'}")


if __name__ == "__main__":
    main()
