            )
        ),
    )
    plot_correlation_matrix(
        stacked_posvel,
        column_names=column_names,
        data_path=str(
            Path(
                model_path,
                model_name_target_str,
                model_name_wo_epochs,
            )
        ),
    )

    # plot up the distribution of each feature

    scaler_traj = create_scalar(traj_targets_train_posvel, model_save_path, model_name_wo_epochs)

