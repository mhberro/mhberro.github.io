import torch
import torch.nn as nn

class TrueKinematicGRUODEFunc(nn.Module):
    """
    An optimized, mathematically rigorous Continuous-Time GRU-ODE vector field.
    Fixes the dh_dt = 0 freeze bug, introduces Physics-Informed Second-Order Kinematic
    Injection, and preserves complete ONNX tracing compliance (opset version 18).
    """
    def __init__(self, state_len: int, hidden_dim: int, aug_dim: int = 0):
        super().__init__()
        self.state_len = state_len
        self.hidden_dim = hidden_dim
        self.aug_dim = aug_dim
        
        # Parse coordinate framework layout based on state dimensions
        # state_len = 6: DCU / Geodesic frame (3 position dimensions, 3 velocity dimensions)
        # state_len = 5: Cylindrical Gridith frame (2 position dimensions [GR, Down], 2 velocity dimensions [dotGR, dotDown], 1 heading rate [dotTheta])
        if state_len == 6:
            self.pos_dim = 3
            self.vel_dim = 3
        elif state_len == 5:
            self.pos_dim = 2
            self.vel_dim = 2
        else:
            self.pos_dim = state_len // 2
            self.vel_dim = state_len - self.pos_dim

        # Input dimension for the combined vector field neural layers
        total_input_dim = state_len + hidden_dim + aug_dim
        
        # Parameterize continuous hidden state derivative field transitions (g_theta)
        self.hidden_derivative_net = nn.Sequential(
            nn.Linear(total_input_dim, hidden_dim),
            nn.SiLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.SiLU(),
            nn.Linear(hidden_dim, hidden_dim)
        )
        
        # Parameterize unmodeled aerodynamic maneuvering and acceleration forces
        # Outputs values matching the remaining velocity derivative dimensions
        self.acceleration_net = nn.Sequential(
            nn.Linear(total_input_dim, hidden_dim),
            nn.SiLU(),
            nn.Linear(hidden_dim, state_len - self.pos_dim)
        )
        
        # Counter for solver diagnostics
        self.nfe = 0

    def forward(self, t, state: torch.Tensor) -> torch.Tensor:
        """
        Calculates unified, continuous-time system vector field derivatives.
        Enforces static graph structures with zero dynamic runtime branches for ONNX compliance.
        """
        self.nfe += 1
        
        # Split concatenated dimensions safely
        aug_start = self.state_len + self.hidden_dim
        
        x = state[..., :self.state_len]
        h = state[..., self.state_len:aug_start]
        aug = state[..., aug_start:] if self.aug_dim > 0 else None
        
        # 1. Physics-Informed Second-Order Kinematic Injection
        # Extract velocity values directly from the physical tracking state vector
        # For state_len = 6 (DCU/Geodesic): positions are [0,1,2], velocities are [3,4,5]
        # For state_len = 5 (Gridith): positions are [0,1] (GR, Down), velocities are [2,3] (dotGR, dotDown)
        vel_components = x[..., self.pos_dim : self.pos_dim + self.vel_dim]
        
        # Rigidly assign velocity to serve as the direct derivative of position (dp/dt = v)
        dpos_dt = vel_components
        
        # 2. Neural Field Acceleration and Hidden State Updates
        # Compute active, dynamic derivatives across the continuous sequence space
        dh_dt = self.hidden_derivative_net(state)  # Fixes the hardcoded zero bug
        dvel_dt = self.acceleration_net(state)    # Parameterizes external unmodeled forces
        
        # Combine sub-vectors back into a structurally synchronized physical derivative tensor
        dx_dt = torch.cat([dpos_dt, dvel_dt], dim=-1)
        
        # Handle zero-augmentation context dimensions if present
        if self.aug_dim > 0:
            daug_dt = torch.zeros_like(aug)
            return torch.cat([dx_dt, dh_dt, daug_dt], dim=-1)
        
        return torch.cat([dx_dt, dh_dt], dim=-1)


class GRUODEArchitecture:
    """
    Rectified model architecture wrapper class.
    Exposes correct parameters and initializations to the NODEPredictor wrapper.
    """
    def __init__(self, state_len: int, hidden_dim: int = 128, aug_dim: int = 0):
        self.state_len = state_len
        self.hidden_dim = hidden_dim
        self.aug_dim = aug_dim

    def get_model(self) -> torch.nn.Module:
        """Returns a compiled instance of TrueKinematicGRUODEFunc."""
        return TrueKinematicGRUODEFunc(
            state_len=self.state_len,
            hidden_dim=self.hidden_dim,
            aug_dim=self.aug_dim,
        )

    def get_input_dim(self) -> int:
        return self.state_len

    def get_output_dim(self) -> int:
        return self.state_len

    def get_aug_dim(self) -> int:
        return self.aug_dim

    def get_hidden_dim(self) -> int:
        return self.hidden_dim

