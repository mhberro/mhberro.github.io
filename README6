def _sim_ingress_row_filter(truth_states, args, TIME_INDEX, VEL_SLICE):
    """Build truth_states_sr_cut with an OPTIONAL absolute-time ceiling.

    Returns the filtered array (possibly empty; caller must guard).
    """
    import numpy as np

    time_cutoff = getattr(args, "time_cutoff", None)
    if time_cutoff is None:
        # No absolute cut: keep every moving row. This is correct for
        # pre-segmented glide files whose timestamps start well past any
        # boost-era ceiling.
        rows = tuple(
            x for x in truth_states
            if not np.allclose(x[VEL_SLICE], [0, 0, 0])
        )
    else:
        rows = tuple(
            x for x in truth_states
            if x[TIME_INDEX] < time_cutoff and not np.allclose(x[VEL_SLICE], [0, 0, 0])
        )
    return np.asarray(rows, dtype=np.float64)


