# gru_ode.py
"""Continuous-time GRU-ODE cell for kinematic trajectory forecasting.

This module implements the GRU-ODE dynamics of De Brouwer et al. (NeurIPS 2019,
"GRU-ODE-Bayes: Continuous modeling of sporadically-observed time series"),
adapted to the NEXT trajectory-forecasting pipeline.

Design notes / deviations from the paper
-----------------------------------------
The original GRU-ODE-Bayes targets *sporadically* observed multivariate series,
alternating a GRU-ODE *prediction* flow with a GRU-Bayes *filtering* jump at each
observation. The NEXT problem is different in two important ways:

  1.  The truth trajectories are resampled onto a *dense, regular* time grid
      (``trajectory_dt``) before training, and the task is pure autoregressive
      forecasting from a single initial condition x0 -- there are no sporadic
      in-rollout observations to filter on. The GRU-Bayes jump network is
      therefore unnecessary for the forecasting rollout and is omitted from the
      default model. (A GRUBayesCell is still provided for completeness / future
      use in a filtering encoder, but is not on the ONNX rollout path.)

  2.  The state we integrate is a *physical* kinematic vector (position/velocity
      in DCU or Gridith frame), not an abstract [-1, 1] latent. We keep the
      exact GRU-ODE vector field on a bounded latent ``h`` -- which retains the
      paper's boundedness (h stays in [-1, 1]) and Lipschitz-continuity (K = 2)
      guarantees, giving the continuity prior that the paper shows is decisive in
      the low-sample regime (Table 2) -- and read the physical state out of ``h``
      through a linear observation head. The initial condition is lifted into the
      latent by an encoder head, integrated by the GRU-ODE field, and decoded at
      every step.

The whole object exposes the ``func.forward(t, x)`` signature expected by the
existing ``ODESolver`` / ``TorchdiffeqSolver`` wrappers, so it drops into
``NODEPredictor.batch_loss`` with no changes to the training engine: the solver
integrates the *augmented* state ``[h; readout]`` and ``batch_loss`` slices the
leading ``n_features`` physical channels back out for the loss.

Author: continuous-time DL refactor for NEXT.
"""

from __future__ import annotations

import torch
from torch import nn


# ----------------------------------------------------------------------------
# Full GRU-ODE vector field (Appendix A of the paper)
# ----------------------------------------------------------------------------
class FullGRUODECell(nn.Module):
    r"""The continuous-time GRU vector field on a bounded latent ``h``.

    Implements Eq. (3) / Appendix A:

        r(t) = sigma(W_r x + U_r h + b_r)
        z(t) = sigma(W_z x + U_z h + b_z)
        g(t) = tanh(W_h x + U_h (r . h) + b_h)
        dh/dt = (1 - z) . (g - h)

    With no continuous input ``x`` the field is autonomous (g, z depend only on
    h), which is exactly the NEXT forecasting regime. The ``x`` path is retained
    so control signals / aerodynamic features can be injected later.

    Properties preserved from the paper:
      * Boundedness: if h(0) in [-1, 1] then h(t) in [-1, 1] for all t, because
        dh_j/dt <= 0 at h_j = 1 and >= 0 at h_j = -1 (negative-feedback term).
      * Lipschitz continuity with constant K = 2 (bounded sigmoids/tanh).
    All operations are ONNX-exportable (matmul, sigmoid, tanh, elementwise).
    """

    def __init__(self, hidden_size: int, input_size: int = 0, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.input_size = input_size

        # Recurrent (h -> gate) maps. Packed into a single Linear for the three
        # gates r, z, g to keep the op count low for the ONNX graph.
        self.lin_hh = nn.Linear(hidden_size, 3 * hidden_size, bias=bias)

        # Optional input (x -> gate) maps, only instantiated when there is a
        # continuous input to feed the field.
        if input_size > 0:
            self.lin_xh = nn.Linear(input_size, 3 * hidden_size, bias=False)
        else:
            self.lin_xh = None

    def forward(self, t: torch.Tensor, h: torch.Tensor, x: torch.Tensor | None = None) -> torch.Tensor:
        """Return dh/dt for a bounded latent ``h`` of shape (batch, hidden)."""
        gates_h = self.lin_hh(h)
        if self.lin_xh is not None and x is not None:
            gates_x = self.lin_xh(x)
        else:
            gates_x = None

        # split the r and z pre-activations; g is handled after gating h by r
        rz_h, g_h = gates_h[..., : 2 * self.hidden_size], gates_h[..., 2 * self.hidden_size :]
        if gates_x is not None:
            rz_x, g_x = gates_x[..., : 2 * self.hidden_size], gates_x[..., 2 * self.hidden_size :]
            rz = rz_h + rz_x
        else:
            g_x = None
            rz = rz_h

        r, z = torch.chunk(torch.sigmoid(rz), 2, dim=-1)

        # g uses the *reset-gated* recurrent contribution: U_h (r . h)
        # Re-project (r . h) through the g-slice of lin_hh's weight. To keep this
        # exact and cheap we recompute the g pre-activation from (r * h).
        g_pre = self._g_preactivation(r * h, g_x)
        g = torch.tanh(g_pre)

        return (1.0 - z) * (g - h)

    def _g_preactivation(self, rh: torch.Tensor, g_x: torch.Tensor | None) -> torch.Tensor:
        """Compute the g-gate pre-activation W_h x + U_h (r . h) + b_h."""
        # slice the g portion of the packed recurrent weight/bias
        w_g = self.lin_hh.weight[2 * self.hidden_size :, :]  # (H, H)
        out = torch.nn.functional.linear(rh, w_g)
        if self.lin_hh.bias is not None:
            out = out + self.lin_hh.bias[2 * self.hidden_size :]
        if g_x is not None:
            out = out + g_x
        return out


# ----------------------------------------------------------------------------
# Minimal GRU-ODE vector field (Appendix G) -- fewer params, often as accurate
# ----------------------------------------------------------------------------
class MinimalGRUODECell(nn.Module):
    r"""Minimal GRU-ODE field (Appendix G):

        f(t) = sigma(W_f x + U_f h + b_f)
        dh/dt = (1 - f) . (tanh(W_h x + U_h (h . f) + b_h) - h)

    Same boundedness / Lipschitz properties, ~1/3 fewer recurrent parameters.
    """

    def __init__(self, hidden_size: int, input_size: int = 0, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.input_size = input_size
        self.lin_hf = nn.Linear(hidden_size, hidden_size, bias=bias)
        self.lin_hh = nn.Linear(hidden_size, hidden_size, bias=bias)
        if input_size > 0:
            self.lin_xf = nn.Linear(input_size, hidden_size, bias=False)
            self.lin_xh = nn.Linear(input_size, hidden_size, bias=False)
        else:
            self.lin_xf = None
            self.lin_xh = None

    def forward(self, t: torch.Tensor, h: torch.Tensor, x: torch.Tensor | None = None) -> torch.Tensor:
        f_pre = self.lin_hf(h)
        if self.lin_xf is not None and x is not None:
            f_pre = f_pre + self.lin_xf(x)
        f = torch.sigmoid(f_pre)

        g_pre = self.lin_hh(h * f)
        if self.lin_xh is not None and x is not None:
            g_pre = g_pre + self.lin_xh(x)
        g = torch.tanh(g_pre)

        return (1.0 - f) * (g - h)


# ----------------------------------------------------------------------------
# GRU-Bayes filtering cell (paper Sec. 2.3) -- provided for completeness.
# Not on the autoregressive ONNX rollout path; usable in a filtering encoder.
# ----------------------------------------------------------------------------
class GRUBayesCell(nn.Module):
    """Discrete GRU jump that updates ``h`` from an incoming (masked) observation.

    Implements h(t+) = GRU(h(t-), f_prep(y, m, h)). f_prep concatenates, per
    dimension, the predicted (mu, logvar) from the observation head, the observed
    value y, and the normalized error (y - mu) / sigma, applies a per-dimension
    linear + ReLU, zeros unobserved dimensions via the mask, and feeds the result
    to a standard GRUCell (which keeps h in [-1, 1], matching GRU-ODE's range).
    """

    def __init__(self, hidden_size: int, obs_dim: int, prep_hidden: int = 4, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.obs_dim = obs_dim
        self.prep_hidden = prep_hidden
        # per-dimension prep: input is [mu, sigma, y, (y-mu)/sigma] = 4 features
        self.w_prep = nn.Parameter(0.01 * torch.randn(obs_dim, 4, prep_hidden))
        self.b_prep = nn.Parameter(torch.zeros(obs_dim, prep_hidden))
        self.gru = nn.GRUCell(obs_dim * prep_hidden, hidden_size, bias=bias)

    def forward(
        self,
        h: torch.Tensor,
        y: torch.Tensor,
        mask: torch.Tensor,
        mu: torch.Tensor,
        logvar: torch.Tensor,
    ) -> torch.Tensor:
        sigma = torch.exp(0.5 * logvar)
        error = (y - mu) / (sigma + 1e-6)
        # (batch, obs_dim, 4)
        feats = torch.stack([mu, sigma, y, error], dim=-1)
        # per-dim linear: (batch, obs_dim, prep_hidden)
        prepped = torch.relu(torch.einsum("boi,oih->boh", feats, self.w_prep) + self.b_prep)
        prepped = prepped * mask.unsqueeze(-1)  # zero unobserved dims
        prepped = prepped.reshape(prepped.shape[0], -1)
        return self.gru(prepped, h)


# ----------------------------------------------------------------------------
# Solver-compatible forecasting module
# ----------------------------------------------------------------------------
class GRUODEFunc(nn.Module):
    """GRU-ODE vector field over an *augmented* state ``[h ; y_read]``.

    This is the object handed to ``ODESolver.integrate`` as ``func``. It exposes
    the ``forward(t, state)`` signature the solvers expect and integrates a
    bounded GRU-ODE latent ``h`` together with a physical read-out ``y_read``
    whose derivative is produced by a linear observation head. Concretely the
    integrated state is::

        state = [ y_read (n_features) | h (hidden_size) ]

    and::

        dh/dt      = GRU-ODE field on tanh-clamped h
        dp_i/dt    = v_i               (kinematic identity, hard-wired)
        dv/dt, ... = obs_head(h)       (learned force / rate model)

    where the leading ``n_derivative_pairs`` position channels get their exact
    derivatives from the corresponding velocity channels (not from the network),
    and only the velocities and any extra rate channels are produced by the
    learned observation head. This physics-informed split is the dominant
    accuracy lever: it removes position integration drift and concentrates model
    capacity on the accelerations.

    ``batch_loss`` slices the leading ``n_features`` channels (``y_read``) as the
    trajectory prediction, so the physical output is exactly the first block of
    the solver's return -- no engine changes required.

    The initial condition arrives as the physical x0 of shape
    (batch, n_features) (optionally augmented with zeros by ``aug_dim``; those
    extra channels are ignored here). We lift x0 into h via ``self.encoder`` on
    the *first* field evaluation only, using a one-shot latch keyed off the
    solver's t == 0 call, and seed y_read = x0. To stay purely functional and
    ONNX-friendly, the lift is instead performed in :meth:`build_initial_state`,
    which the wrapper calls before integration; the field itself is stateless.
    """

    ORDER = "y_first"  # physical read-out occupies the leading channels

    def __init__(
        self,
        n_features: int,
        hidden_size: int = 64,
        cell: str = "full",
        couple_state: bool = True,
        n_derivative_pairs: int | None = None,
        couple_indices: tuple[int, ...] | None = None,
    ):
        """GRU-ODE forecasting field with physics-informed kinematic structure.

        Args:
            n_features: physical state width (== model_states).
            hidden_size: GRU-ODE latent width H.
            cell: "full" or "minimal" GRU-ODE cell.
            couple_state: feed physical channels back into the field as x(t).
            n_derivative_pairs: number of leading state channels whose exact time
                derivative is another stored channel (the position block).
                For a kinematic vector laid out as
                    [ p_0 ... p_{k-1} | v_0 ... v_{k-1} | extra_rates... ]
                we have d(p_i)/dt = v_i EXACTLY (a kinematic identity), so the
                network must NOT try to learn it. With n_derivative_pairs = k the
                field hard-wires dp_i/dt = v_i and only the velocities/extra rates
                are produced by the learned dynamics. This is the single most
                important structural prior for trajectory integration: it removes
                position drift and frees all model capacity for the force model
                (the accelerations). If None, no channels are hard-wired
                (falls back to a fully-learned read-out).
            couple_indices: which physical channels to feed back into the field
                as the continuous input x(t). Absolute positions have huge,
                unbounded magnitudes that saturate the bounded field's input
                gates, so by default we couple only the velocity / rate channels
                (indices >= n_derivative_pairs), which are the actual drivers of
                the dynamics and are far better conditioned. If None and
                couple_state is True, this is derived automatically.
        """
        super().__init__()
        self.n_features = n_features
        self.hidden_size = hidden_size
        self.couple_state = couple_state

        # ------------------------------------------------------------------
        # Kinematic structure: which leading channels have a known derivative.
        # ------------------------------------------------------------------
        if n_derivative_pairs is None:
            n_derivative_pairs = 0
        if not (0 <= n_derivative_pairs * 2 <= n_features):
            raise ValueError(
                f"n_derivative_pairs={n_derivative_pairs} incompatible with "
                f"n_features={n_features} (need 2*pairs <= n_features)"
            )
        self.n_derivative_pairs = n_derivative_pairs
        # The learned dynamics only needs to produce the NON-position channels:
        # the velocities of the paired block plus any trailing extra rates.
        self.n_learned = n_features - n_derivative_pairs

        # ------------------------------------------------------------------
        # Coupling feature selection (input x(t) to the field).
        # ------------------------------------------------------------------
        if couple_state:
            if couple_indices is None:
                # default: couple everything EXCEPT absolute positions
                couple_indices = tuple(range(n_derivative_pairs, n_features))
            self.couple_indices = tuple(couple_indices)
            input_size = len(self.couple_indices)
        else:
            self.couple_indices = ()
            input_size = 0

        if cell == "full":
            self.ode_cell = FullGRUODECell(hidden_size, input_size=input_size)
        elif cell == "minimal":
            self.ode_cell = MinimalGRUODECell(hidden_size, input_size=input_size)
        else:
            raise ValueError(f"unknown GRU-ODE cell type: {cell!r}")

        # encoder: physical x0 -> bounded latent h0 (tanh keeps it in [-1, 1])
        self.encoder = nn.Sequential(
            nn.Linear(n_features, hidden_size),
            nn.SiLU(),
            nn.Linear(hidden_size, hidden_size),
            nn.Tanh(),
        )
        # observation head: h -> derivative of the LEARNED channels only
        # (velocities + extra rates). Positions are supplied by the kinematic
        # identity, not by this head.
        self.obs_head = nn.Sequential(
            nn.Linear(hidden_size, hidden_size),
            nn.SiLU(),
            nn.Linear(hidden_size, self.n_learned),
        )
        self.nfe = 0

    def _couple_input(self, y_read: torch.Tensor) -> torch.Tensor | None:
        """Select the physical channels fed back into the field as x(t)."""
        if not self.couple_state:
            return None
        return y_read[..., list(self.couple_indices)]

    def _assemble_dstate(self, y_read: torch.Tensor, dy_learned: torch.Tensor, dh: torch.Tensor) -> torch.Tensor:
        """Build d(state)/dt = [ dp (=velocities) | dy_learned | dh ].

        The first n_derivative_pairs derivatives are taken DIRECTLY from the
        current velocity channels (kinematic identity dp_i/dt = v_i); the
        remaining physical derivatives come from the learned head.
        """
        if self.n_derivative_pairs > 0:
            k = self.n_derivative_pairs
            # velocities that are the exact derivative of the position block
            dp = y_read[..., k : 2 * k]
            dy = torch.cat((dp, dy_learned), dim=-1)
        else:
            dy = dy_learned
        return torch.cat((dy, dh), dim=-1)

    # -- initial-state construction (called by the wrapper, not the solver) ---
    def build_initial_state(self, x0_phys: torch.Tensor) -> torch.Tensor:
        """Lift physical x0 (batch, n_features) to augmented [y_read ; h]."""
        h0 = self.encoder(x0_phys)
        return torch.cat((x0_phys, h0), dim=-1)

    # -- the vector field the solver integrates -------------------------------
    def forward(self, t, state: torch.Tensor) -> torch.Tensor:
        self.nfe += 1
        y_read = state[..., : self.n_features]
        h = state[..., self.n_features : self.n_features + self.hidden_size]

        # clamp h back into [-1, 1] for numerical robustness (paper Sec. 2.2:
        # the negative feedback already enforces this, tanh makes it exact under
        # any solver step) then evaluate the GRU-ODE field.
        h = torch.tanh(h)
        x_in = self._couple_input(y_read)
        dh = self.ode_cell(t, h, x_in)
        dy_learned = self.obs_head(h)

        return self._assemble_dstate(y_read, dy_learned, dh)


class GRUODEPredictorModel(nn.Module):
    """Wraps a :class:`GRUODEFunc` so it is callable both as a field and as a
    standalone ONNX-exportable rollout module.

    * During training the ``NODEPredictor`` calls ``self.model`` through the
      solver, which needs the ``forward(t, state)`` field signature. To satisfy
      that while still lifting the physical x0 into the latent, we register the
      encoder-lift on the augmented ODE dimension: the trainer passes x0 padded
      with ``aug_dim`` zeros; we set ``aug_dim = hidden_size`` so the solver's
      integrated state already carries room for h, and we overwrite that block
      with the encoded h0 at t == 0 via :meth:`forward`.
    """

    def __init__(self, func: GRUODEFunc):
        super().__init__()
        self.func = func
        self.n_features = func.n_features
        self.hidden_size = func.hidden_size

    @property
    def nfe(self) -> int:
        return self.func.nfe

    @nfe.setter
    def nfe(self, v: int) -> None:
        self.func.nfe = v

    def forward(self, t, state: torch.Tensor) -> torch.Tensor:
        """ODE field over the augmented state.

        The trainer augments x0 to ``[x0_phys ; zeros(hidden_size)]``. The latent
        block must be seeded from x0_phys via the encoder on the initial call.

        Seeding is keyed off the integration time ``t == 0`` rather than off an
        all-zero latent block. The old "is the latent all zeros" heuristic
        (1) re-ran the encoder on every solver evaluation, and (2) silently
        misfired for any genuinely zero latent produced mid-rollout. Keying on
        ``t`` is unambiguous, runs the encoder only at the initial time, and
        stays a static graph for ONNX (a scalar comparison broadcast over the
        batch).

        ONNX export contract: the export tracer calls this with ``t=None`` (see
        the training script's example_input), which resolves to the interior
        (non-seeding) field. Consumers of the exported graph must therefore seed
        the latent block themselves via :meth:`GRUODEFunc.build_initial_state`
        before stepping, exactly as the training solver's augmented x0 is seeded
        here at t == 0.
        """
        self.func.nfe += 1
        y_read = state[..., : self.n_features]
        h = state[..., self.n_features : self.n_features + self.hidden_size]

        # is_initial is a 0/1 scalar. torch.Tensor -> compare to 0; None or any
        # non-zero t -> interior step (no seeding).
        if isinstance(t, torch.Tensor):
            is_initial = (t == 0).to(state.dtype)
            h_seeded = self.func.encoder(y_read)
            h = is_initial * h_seeded + (1.0 - is_initial) * h
        elif t == 0:
            h = self.func.encoder(y_read)
        # else: interior step / ONNX trace -> use h as carried in the state

        h = torch.tanh(h)
        x_in = self.func._couple_input(y_read)
        dh = self.func.ode_cell(t, h, x_in)
        dy_learned = self.func.obs_head(h)
        return self.func._assemble_dstate(y_read, dy_learned, dh)
