class ODEfunc(torch.nn.Module):
    def __init__(self, state_vector_len: int, nhidden: int, aug_dim: int = 0, order_shift_slice: slice | None = None):
        super(ODEfunc, self).__init__()
        self.order_shift_slice = order_shift_slice
        self.len_of_order_shift_slice = 0
        if self.order_shift_slice is not None:
            order_indicies = tuple(range(*self.order_shift_slice.indices(state_vector_len)))
            self.len_of_order_shift_slice = len(order_indicies)
        self.act1 = torch.nn.SiLU(inplace=False)
        self.act2 = torch.nn.SiLU(inplace=False)
        self.fc1 = torch.nn.Linear(state_vector_len + aug_dim, nhidden)
        self.fc2 = torch.nn.Linear(nhidden, nhidden)
        self.fc4 = torch.nn.Linear(nhidden, (state_vector_len - self.len_of_order_shift_slice) + aug_dim)
        self.nfe = 0

    def forward(self, t, x: torch.Tensor) -> torch.Tensor:
        if self.order_shift_slice is not None:
            v = torch.narrow(x, dim=-1, start=self.order_shift_slice.start, length=self.len_of_order_shift_slice)
        self.nfe += 1
        out = self.fc1(x)
        out = self.act1(out)
        out = self.fc2(out)
        out = self.act2(out)
        out = self.fc4(out)
        if self.order_shift_slice is not None:
            return torch.cat((v, out), dim=x.ndim - 1)
        else:
            return out


class Normaliser(torch.nn.Module):
    def __init__(self, scaler):
        super().__init__()
        self.mean = torch.nn.Parameter(torch.tensor(scaler.mean_, dtype=torch.float32), requires_grad=False)
        self.scale = torch.nn.Parameter(torch.tensor(scaler.scale_, dtype=torch.float32), requires_grad=False)

    def forward(self, x):
        return (x - self.mean) / self.scale

    def inverse(self, z):
        return z * self.scale + self.mean


class Encoder(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.rnn = torch.nn.GRU(input_size=6, hidden_size=hidden, batch_first=True, num_layers=1)
        self.mu_head = torch.nn.Linear(hidden, latent_dim)
        self.logvar_head = torch.nn.Linear(hidden, latent_dim)

    def forward(self, x):
        _, h_n = self.rnn(x)
        h = h_n.squeeze(0)
        mu = self.mu_head(h)
        logvar = self.logvar_head(h)
        return mu, logvar


class LatentODEFunc(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.net = torch.nn.Sequential(
            torch.nn.Linear(latent_dim, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, latent_dim),
        )

    def forward(self, t, z):
        return self.net(z)


class Decoder(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.net = torch.nn.Sequential(
            torch.nn.Linear(latent_dim, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, 6),
        )

    def forward(self, z):
        return self.net(z)


from torchdiffeq import odeint_adjoint

class LatentNODE(torch.nn.Module):
    def __init__(self, latent_dim=8):
        super().__init__()
        self.encoder = Encoder(latent_dim)
        self.odefunc = LatentODEFunc(latent_dim)
        self.decoder = Decoder(latent_dim)

    def forward(self, obs_window_and_times: tuple[torch.Tensor, torch.Tensor]):
        obs_window, t_eval = obs_window_and_times
        mu, logvar = self.encoder(obs_window)
        std = torch.exp(0.5 * logvar)
        eps = torch.randn_like(std)
        z0 = mu + eps * std

        z_t = odeint_adjoint(self.odefunc, z0, t_eval, atol=1e-5, rtol=1e-5)
        z_t = z_t.permute(1, 0, 2)
        recon = self.decoder(z_t)
        return recon, mu, logvar


def _kl_divergence(mu: torch.Tensor, logvar: torch.Tensor) -> torch.Tensor:
    return 0.5 * torch.mean(torch.sum(1 + logvar - mu.pow(2) - torch.exp(logvar), dim=1))


def _make_obs_target(traj: torch.Tensor, obs_len: int = 10) -> tuple[torch.Tensor, torch.Tensor]:
    assert traj.shape[0] > obs_len, "trajectory shorter than observation window"
    obs_window = traj[:obs_len].unsqueeze(0)
    target = traj.unsqueeze(0)
    return obs_window, target


def train_NEXT(
    model_name,
    traj_targets_train,
    traj_targets_test,
    scaler_traj,
    model_save_path,
    trajectory_dt,
    batch_size,
    use_scalar,
    model_states,
    aug_dim,
    nhidden,
    gpu_index,
    model_type: str = "node",
    frame: str = "dcu",
):
    training_configuration = TrainingConfiguration(
        n_epochs=1,
        optimizer=AdamOptimizer(learning_rate=1e-3),
        batch_size=batch_size,
        num_workers=100,
        verbose=True,
    )
    
    ode_solver = TorchdiffeqSolver(dt=trajectory_dt, method="rk4", adjoint=False, substeps=4)

    if frame == "dcu":
        velocity_indicies = (3, 4, 5)
    elif frame == "grdth":
        velocity_indicies = (2, 3, 4)
    elif frame == "geodesic":
        velocity_indicies = (2, 3, 4) if model_states == 5 else (3, 4, 5)
    else:
        raise ValueError("That frame is not known for what the velocity indicies are")
        
    early_stop_metric_name = "val_loss"
    
    loss_func = WrappedMSELoss(
        height_idx=(2 if (frame == "dcu" or (frame == "geodesic" and model_states == 6)) else 1),
        vel_indices=velocity_indicies,
        scaler=scaler_traj if use_scalar else None,
        N_FEATURES=model_states,
        position_loss_weight=80.0,
        l2_reg=1e-4,
    )

    node = NODEPredictor(
        architecture=FFNNArchitecture(
            layer_channels=[5, 5],
            layer_activation=Activation.SILU,
        ),
        training_configuration=training_configuration,
        solver=ode_solver,
        logging_interval=5,
        loss_func=loss_func,
        early_stopper=EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name),
        checkpoint=ModelCheckpoint(min_epochs=1, directory=model_save_path, model_name=model_name + ".checkpoint"),
        aug_dim=aug_dim,
    )
    if HAVE_GPU:
        node.device = torch.device(f"cuda:{gpu_index}")
        node._initialize_losses(node.criterion)
        node._initialize_model()
        node._initialize_optimizer()

    if model_type == "node":
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "anode":
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=aug_dim,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "sonode":
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=slice(3, 6),
        ).to(node.device)
    elif model_type in ("gruode", "gruode-min"):
        minimal = model_type == "gruode-min"
        latent_dim = max(2 * model_states, nhidden // 2 if nhidden >= 20 else 16)

        if frame == "dcu" or (frame == "geodesic" and model_states == 6):
            pos_idx, vel_idx = [0, 1, 2], [3, 4, 5]
        elif frame == "geodesic" and model_states == 5:
            pos_idx, vel_idx = [0, 1], [2, 4]
        elif frame == "grdth":
            pos_idx, vel_idx = [0, 1], [2, 3]
        else:
            pos_idx, vel_idx = None, None

        so_pos_scale = so_vel_scale = so_vel_mean = None
        if use_scalar and pos_idx is not None and isinstance(scaler_traj, StandardScaler):
            so_pos_scale = scaler_traj.scale_[pos_idx]
            so_vel_scale = scaler_traj.scale_[vel_idx]
            so_vel_mean = scaler_traj.mean_[vel_idx]

        gruode_func = GRUODEFunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            latent_dim=latent_dim,
            minimal=minimal,
            encoder_input_idx=None,
            encoder_dropout=0.1,  # Activated parameter optimization mapping
        ).to(node.device)

        # Connect the stateful caching predictor cell directly to the engine
        node.model = GRUODEPredictorModel(
            func=gruode_func,
            pos_idx=pos_idx,
            vel_idx=vel_idx,
            pos_scale=so_pos_scale,
            vel_scale=so_vel_scale,
            vel_mean=so_vel_mean,
        ).to(node.device)
        
        node.aug_dim = latent_dim
        aug_dim = latent_dim

        # Force structural scale-space loss selection
        loss_func = WrappedMSELoss(
            height_idx=(2 if (frame == "dcu" or (frame == "geodesic" and model_states == 6)) else 1),
            vel_indices=velocity_indicies,
            scaler=scaler_traj if use_scalar else None,
            N_FEATURES=model_states,
            position_loss_weight=80.0,
            l2_reg=1e-4,
        )
        node._initialize_losses(loss_func)

    elif model_type == "latentode":
        latent_dim = nhidden // 2 if nhidden >= 20 else 8
        node.model = LatentNODE(latent_dim=latent_dim).to(node.device)
        recon_criterion = WrappedMSELoss(
            height_idx=1,
            vel_indices=[3, 4, 5],
            scaler=scaler_traj if use_scalar else None,
            N_FEATURES=model_states,
        )

        def latent_ode_loss_fn(recon, target, mu, logvar):
            recon_loss = recon_criterion(recon, target)
            kl = _kl_divergence(mu, logvar)
            return recon_loss + 0.1 * kl

        node.loss_func = lambda pred, true: latent_ode_loss_fn(pred[0], true, pred[1], pred[2])
    else:
        raise ValueError(f"Unsupported model_type: {model_type}")

    # Set parameters hook reference before launching curriculum optimization loops
    if hasattr(node.criterion, "set_model"):
        node.criterion.set_model(node.model)

    if use_scalar:
        scaled_traj_targets_train_posvel = [
            torch.Tensor(scaler_traj.transform(i[:, 0 : model_states + 1])) for i in traj_targets_train
        ]
        scaled_traj_targets_test_posvel = [
            torch.Tensor(scaler_traj.transform(i[:, 0 : model_states + 1])) for i in traj_targets_test
        ]
    else:
        scaled_traj_targets_train_posvel = [torch.Tensor(i[:, 0 : model_states + 1]) for i in traj_targets_train]
        scaled_traj_targets_test_posvel = [torch.Tensor(i[:, 0 : model_states + 1]) for i in traj_targets_test]
    gen_model = False
    try:
        node.load(directory=model_save_path, model_name=model_name)
    except ValueError:
        gen_model = True
        pass

    if gen_model:
        if model_type == "latentode":
            OBS_WINDOW = 10
            train_data = [_make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_train_posvel]
            test_data = [_make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_test_posvel]
            fraction_of_data = [
                (obs[: max(math.ceil(obs.shape[0] * data_fraction), 5)], tgt[: max(math.ceil(tgt.shape[0] * data_fraction), 5)])
                for (obs, tgt) in train_data
            ]
            fraction_of_data_val = [
                (obs[: max(math.ceil(obs.shape[0] * data_fraction), 5)], tgt[: max(math.ceil(tgt.shape[0] * data_fraction), 5)])
                for (obs, tgt) in test_data
            ]

        length_strategies = [
            (0.1, 5000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (0.3, 5000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (0.5, 3000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (0.7, 2000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-3),
            (1.0, 1500, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-5),
            (1.0, 5000, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-7),
        ]

        for len_strat in length_strategies:
            print("running length strategy", len_strat)
            data_fraction, epochs, early_stopper, learning_rate = len_strat
            node.training_configuration = TrainingConfiguration(
                n_epochs=epochs,
                optimizer=AdamOptimizer(learning_rate=learning_rate),
                batch_size=batch_size,
                num_workers=2,
                verbose=True,
            )

            node.optimizer_config = node.training_configuration.optimizer
            node.n_epochs = node.training_configuration.get_param(TrainingParam.N_EPOCHS)
            node.training_metrics = {}
            node._initialize_optimizer()
            node.early_stopper = early_stopper

            min_states = 5
            if model_type == "latentode":
                pass
            else:
                fraction_of_data = [
                    x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :]
                    for x in scaled_traj_targets_train_posvel
                ]
                fraction_of_data_val = [
                    x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :]
                    for x in scaled_traj_targets_test_posvel
                ]

            metrics = node.fit(
                x=fraction_of_data,
                validation_data=fraction_of_data_val,
                enable_checkpoints=True if data_fraction == 1.0 else False,
            )
        p = Path(model_save_path, model_name + ".checkpoint.pt")
        p.rename(Path(p.parent, p.name.replace(".checkpoint", "")))

    node.load(directory=model_save_path, model_name=model_name)
    node.model.train(False)
    node.model.eval()

    example_input = torch.cat((scaled_traj_targets_train_posvel[0][0], torch.zeros(aug_dim))).to(node.device)
    model_onx = torch.onnx.export(
        node.model,
        example_input,
        os.path.join(model_save_path, model_name + ".onnx"),
        export_params=True,
        opset_version=18,
        external_data=False,
        input_names=["input"],
        output_names=["output"],
    )

    with open(os.path.join(model_save_path, model_name + "_plain.onnx"), "w") as f:
        f.write(onnx.printer.to_text(model_onx.model_proto))

    if isinstance(scaler_traj, MinMaxScaler):
        with open(os.path.join(model_save_path, f"{model_name}_scalar_params_and_test_inputs.txt"), "w", encoding="utf-8") as f:
            for m, s, dmin, dmax in zip(scaler_traj.min_, scaler_traj.scale_, scaler_traj.data_min_, scaler_traj.data_max_):
                f.write(f"InputScaleFactorsMinMaxScaler\n{{\n\tMin: {m}\n\tScale: {s}\n\tDataMin: {dmin}\n\tDataMax: {dmax}\n}}\n")
    elif isinstance(scaler_traj, StandardScaler):
        with open(os.path.join(model_save_path, f"{model_name}_scalar_params_and_test_inputs.txt"), "w", encoding="utf-8") as f:
            for s, m, v in zip(scaler_traj.scale_, scaler_traj.mean_, scaler_traj.var_):
                f.write(f"InputScaleFactorsStandardScaler\n{{\n\tScale: {s}\n\tMean: {m}\n\tVariance: {v}\n}}\n")
    return node, model_name


def prep_trajectory(x):
    ecef_data, traj_number, max_sr, trajectory_dt, args = x
    ecef_data = ecef_data[:, 0:7]
    print("prepping traj", traj_number)
    ref_ecef = deepcopy(ecef_data[-1, POS_SLICE])

    while np.any(np.isclose(ecef_data[0, VEL_SLICE], 0)):
        ecef_data = ecef_data[1:]

    sr_ecef_data = np.asarray(
        tuple(x for x in ecef_data if np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) < max_sr),
        dtype=np.float64,
    )

    if sr_ecef_data.shape[-1] < 5:
        print(f"{traj_number} does not have enough time stamps for this slant range")
        return None, None
    time_diff = np.diff(sr_ecef_data[:, TIME_INDEX])
    unique_time_diff = np.unique(np.round(time_diff, decimals=2))
    if np.any(time_diff < 0):
        raise ValueError(f"warning: {traj_number} has time that goes backwards.")

    new_times = np.arange(sr_ecef_data[0, 0], sr_ecef_data[-1, 0] + trajectory_dt, trajectory_dt)

    try:
        resampled_sr_ecef_data = np.hstack(
            [np.atleast_2d(new_times).T]
            + [make_interp_spline(sr_ecef_data[:, 0], sr_ecef_data[:, 1:], bc_type="not-a-knot")(new_times, extrapolate=True)]
        )
    except Exception as e:
        print(f"warning: {traj_number} had the error with interpolation")
        raise e

    if args.frame == "grdth":
        next_frame_data, initial_point_heading = ecef_to_next_grdth(resampled_sr_ecef_data, ref_ecef)
    elif args.frame == "geodesic":
        next_frame_data = ecef_to_local_geodesic_vec(resampled_sr_ecef_data[:, POS_SLICE], resampled_sr_ecef_data[:, VEL_SLICE], np.zeros_like(resampled_sr_ecef_data[:, VEL_SLICE]), ref_ecef)
        next_frame_data = np.hstack([resampled_sr_ecef_data[:, TIME_INDEX][..., np.newaxis], next_frame_data[:, :6]])
    elif args.frame == "dcu":
        next_frame_data, initial_point_heading, flip_c = ecef_to_next_dcu(resampled_sr_ecef_data, ref_ecef)
    else:
        raise NotImplementedError("That frame is not supported yet")

    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[0]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[1]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[2]]

    return next_frame_data, traj_number


def load_data_dir(path: str, trajectory_dt: float, args, do_prep: bool = True):
    boost_ecef = []
    glide_ecef = []
    dest_ecef = []
    target_path = Path(path)
    for phase in ["boost", "glide", "impact"]:
        phase_path = target_path / phase
        traj_files = [Path(phase_path, x) for x in sorted(os.listdir(phase_path))]
        if len(traj_files) == 0:
            raise ValueError("bad target path", path)
        traj_targets = [load_single_truth(x, debug=False, low_memory=not HAVE_HIGH_MEMORY, memory_map=HAVE_HIGH_MEMORY, min_state_vector_size=7) for x in traj_files]
        if phase == "boost":
            boost_ecef = traj_targets
        elif phase == "glide":
            glide_ecef = traj_targets
        elif phase == "impact":
            dest_ecef = traj_targets
    if not do_prep:
        return list(zip(list(zip(boost_ecef, glide_ecef, dest_ecef)), [x.name for x in traj_files]))

    cpu_count = psutil.cpu_count(logical=False)
    if cpu_count is None:
        cpu_count = mp.cpu_count()
    print(f"there are {cpu_count} cpus being used for trajectory prep")
    with mp.Pool(processes=cpu_count) as pool:
        tmp_data = pool.map(prep_trajectory, traj_targets)

    tmp_data = [x for x in tmp_data if x[0] is not None]
    print("post-prep. how many made it though prep", len(traj_targets))
    return tmp_data


def create_scalar(traj_targets_train_posvel, model_save_path, model_name_wo_epochs):
    stacked_posvel = torch.Tensor(np.vstack(traj_targets_train_posvel))
    scaler_traj = StandardScaler().fit(stacked_posvel)
    pickle_scalar_name = os.path.join(model_save_path, f"{model_name_wo_epochs}_scalar.pickle")
    with open(pickle_scalar_name, "wb") as o:
        pickle.dump(scaler_traj, o)
    return scaler_traj


def plot_column_distributions(data, bins=30, cmap="tab10", column_names=None, data_path=""):
    if data.ndim != 2:
        raise ValueError("`data` must be a 2-D array.")
    n_cols = data.shape[1]
    max_per_row = 5
    n_rows = int(np.ceil(n_cols / max_per_row))
    n_cols_plot = min(n_cols, max_per_row)
    fig, axes = plt.subplots(n_rows, n_cols_plot, figsize=(4 * n_cols_plot, 3 * n_rows), constrained_layout=True)
    if n_rows == 1:
        axes = np.expand_dims(axes, axis=0)
    colors = plt.get_cmap(cmap).colors
    for idx in range(data.shape[1]):
        row = idx // max_per_row
        col = idx % max_per_row
        ax = axes[row, col]
        ax.hist(data[:, idx], bins=bins, density=True, color=colors[idx % len(colors)], alpha=0.75, edgecolor="black")
        if column_names is None:
            ax.set_title(f"Column {idx}")
        else:
            ax.set_title(column_names[idx])
    total_plots = n_rows * n_cols_plot
    for empty_idx in range(data.shape[1], total_plots):
        row = empty_idx // max_per_row
        col = empty_idx % max_per_row
        fig.delaxes(axes[row, col])
    plt.suptitle("Column-wise Distributions", fontsize=16, y=1.02)
    plt.savefig(data_path + "_feature_distribution.png")


def plot_correlation_matrix(data, method="pearson", cmap="coolwarm", column_names=None, data_path=""):
    if data.ndim != 2:
        raise ValueError("`data` must be a 2-D array.")
    if method == "pearson":
        corr = np.corrcoef(data, rowvar=False)
    elif method == "spearman":
        from scipy.stats import spearmanr
        corr, _ = spearmanr(data, axis=0)
    plt.figure(figsize=(0.6 * corr.shape[0] + 2, 0.6 * corr.shape[0] + 2))
    sns.heatmap(corr, annot=True, fmt=".2f", cmap=cmap, vmin=-1, vmax=1, square=True, cbar_kws={"shrink": 0.75}, linewidths=0.5)
    labels = column_names if column_names is not None else [f"Col {i}" for i in range(corr.shape[0])]
    plt.title(f"{method.title()} Correlation Matrix", fontsize=14, pad=12)
    plt.xticks(ticks=np.arange(corr.shape[0]) + 0.5, labels=labels, rotation=0)
    plt.yticks(ticks=np.arange(corr.shape[0]) + 0.5, labels=labels, rotation=0)
    plt.tight_layout()
    plt.savefig(data_path + "_correlation_matrix.png")


def sbi_trajectory_prep(ecef_data_traj: tuple, phase_to_transform: str, trajectory_dt: float, args):
    timeseries_to_transform = ecef_data_traj[0] if phase_to_transform == "boost" else ecef_data_traj[1]
    if timeseries_to_transform.shape[0] < 10:
        return None
    new_times = np.arange(timeseries_to_transform[0, TIME_INDEX], timeseries_to_transform[-1, TIME_INDEX] + trajectory_dt, trajectory_dt)
    resampled_timeseries = np.hstack([np.atleast_2d(new_times).T] + [make_interp_spline(timeseries_to_transform[:, TIME_INDEX], timeseries_to_transform[:, 1:], bc_type="not-a-knot")(new_times, extrapolate=True)])
    ref_ecef = ecef_data_traj[2][-1, POS_SLICE]
    if args.ref_ecef == "boost":
        ref_ecef = ecef_data_traj[0][-1, POS_SLICE]
    elif args.ref_ecef == "glide":
        ref_ecef = ecef_data_traj[1][-1, POS_SLICE]

    if args.frame == "dcu":
        timeseries_in_next_frame, initial_point_heading, flip_c = ecef_to_next_dcu(resampled_timeseries, ref_ecef)
    elif args.frame == "grdth":
        timeseries_in_next_frame, initial_point_heading = ecef_to_next_grdth(resampled_timeseries, ref_ecef)
    elif args.frame == "geodesic":
        if getattr(args, "geodesic_mode", "original") == "original":
            timeseries_in_next_frame = ecef_to_local_geodesic_vec(resampled_timeseries[:, POS_SLICE], resampled_timeseries[:, VEL_SLICE], np.zeros_like(resampled_timeseries[:, VEL_SLICE]), ref_ecef)
            timeseries_in_next_frame = np.hstack([resampled_timeseries[:, TIME_INDEX][..., np.newaxis], timeseries_in_next_frame[:, :6]])
        else:
            timeseries_state, initial_azimuth = ecef_to_local_geodesic_vec_frame_trick(resampled_timeseries[:, POS_SLICE], resampled_timeseries[:, VEL_SLICE], ref_ecef)
            timeseries_in_next_frame = np.hstack([resampled_timeseries[:, TIME_INDEX][..., np.newaxis], timeseries_state])
    return timeseries_in_next_frame


def main():
    parser = argparse.ArgumentParser(description="Training script for creating NEXT models", formatter_class=argparse.ArgumentDefaultsHelpFormatter)
    parser.add_argument("--tgt-data-paths", default=[], type=str, nargs="+")
    parser.add_argument("--validation-data-paths", default=[], type=str, nargs="+")
    parser.add_argument("--sr", default=100000, type=int)
    parser.add_argument("-o", default="model_outputs", type=str)
    parser.add_argument("--use-scalar", default=False, action="store_true")
    parser.add_argument("--frame", default="dcu", choices=["dcu", "grdth", "geodesic"])
    parser.add_argument("--geodesic-mode", default="original", choices=["original", "integrated"])
    parser.add_argument("--sbi-phase", default="boost", choices=["boost", "glide"])
    parser.add_argument("--nhidden", default=200, type=int)
    parser.add_argument("--aug", default=0, type=int, dest="aug_dim")
    parser.add_argument("--gpuidx", default=0, type=int, dest="gpu_index")
    parser.add_argument("--model-type", default="node", choices=["node", "anode", "sonode", "latentode", "gruode", "gruode-min"])
    parser.add_argument("--dt", default=0.1, type=float)
    parser.add_argument("--ref-ecef", default="impact", choices=["boost", "glide", "impact"])
    
    args = parser.parse_args()

    model_states = 6
    if args.frame == "grdth":
        model_states = 5
    elif args.frame == "geodesic" and args.geodesic_mode == "integrated":
        model_states = 5

    trajectory_dt = args.dt
    seed = 47
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

    target_strs = [Path(x).name for x in args.tgt_data_paths]
    model_name_target_str = "+".join(target_strs)
    model_path = args.o
    model_save_path = os.path.join(model_path, model_name_target_str)

    batch_size = 16
    frame_tag = args.frame
    if args.frame == "geodesic":
        frame_tag = f"geodesic-{args.geodesic_mode}"
    model_name_wo_epochs = f"NEXT_{model_name_target_str}_{frame_tag}_{args.sbi_phase}_{int(args.sr / 1000)}sr_{trajectory_dt}sec_{args.nhidden}hid_{args.aug_dim}aug_{batch_size}"
    if args.use_scalar:
        model_name_wo_epochs = model_name_wo_epochs + "_scalarOn"
    model_name = f"{model_name_wo_epochs}"

    traj_targets_train = []
    traj_targets_test = []
    if len(args.validation_data_paths) == 0:
        for tgt_data_path in args.tgt_data_paths:
            traj_targets = load_data_dir(tgt_data_path, trajectory_dt, args, do_prep=False)
            traj_targets_train_one_tgt, traj_targets_test_one_tgt = train_test_split(traj_targets, test_size=0.2, random_state=26525)
            traj_targets_train.extend(traj_targets_train_one_tgt)
            traj_targets_test.extend(traj_targets_test_one_tgt)
    else:
        for tgt_data_path in args.tgt_data_paths:
            traj_targets_train.extend(load_data_dir(tgt_data_path, trajectory_dt, args))
        for tgt_data_path in args.validation_data_paths:
            traj_targets_test.extend(load_data_dir(tgt_data_path, trajectory_dt, args))

    traj_targets_train, traj_targets_train_traj_numbers = zip(*traj_targets_train)
    traj_targets_test, traj_targets_test_traj_numbers = zip(*traj_targets_test)
    split_dict = {"train": traj_targets_train_traj_numbers, "test": traj_targets_test_traj_numbers}
    os.makedirs(os.path.join(model_path, model_name_target_str), exist_ok=True)
    with open(os.path.join(model_path, model_name_target_str, f"{model_name_wo_epochs}_train_test_split.json"), "w", encoding="utf-8") as f:
        json.dump(split_dict, f)

    phase_to_model = args.sbi_phase
    traj_targets_train = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_train]
    traj_targets_test = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_test]
    traj_targets_train = list(filter(lambda x: x is not None, traj_targets_train))
    traj_targets_test = list(filter(lambda x: x is not None, traj_targets_test))

    time_series_point_count = [x.shape[0] for x in traj_targets_train + traj_targets_test]
    if any(x < 10 for x in time_series_point_count):
        raise ValueError("Some data has less than 10 points.")

    traj_targets_train_posvel = [torch.Tensor(x[:, 1 : model_states + 1]) for x in traj_targets_train]
    traj_targets_test_posvel = [torch.Tensor(x[:, 1 : model_states + 1]) for x in traj_targets_test]
    if any([torch.isnan(x).any() for x in traj_targets_train_posvel]) or any([torch.isnan(x).any() for x in traj_targets_test_posvel]):
        raise ValueError("There are NaNs in coordinate conversion arrays.")

    stacked_posvel = np.vstack(traj_targets_train_posvel)
    column_names = ["Down", "Cross", "Up", "dotD", "dotC", "dotU"] if args.frame == "dcu" else (["GR", "Down", "dotGR", "dotD", "VTheta"] if args.frame == "grdth" else (["s", "h", "v_s", "v_alpha", "v_h"] if args.geodesic_mode == "integrated" else ["s", "az", "h", "v_s", "v_alpha", "v_h"]))
    plot_column_distributions(stacked_posvel, column_names=column_names, data_path=str(Path(model_path, model_name_target_str, model_name_wo_epochs)))
    plot_correlation_matrix(stacked_posvel, column_names=column_names, data_path=str(Path(model_path, model_name_target_str, model_name_wo_epochs)))

    scaler_traj = create_scalar(traj_targets_train_posvel, model_save_path, model_name_wo_epochs)
    node, model_name = train_NEXT(
        model_name, traj_targets_train_posvel, traj_targets_test_posvel, scaler_traj,
        model_save_path, trajectory_dt, batch_size, args.use_scalar, model_states,
        args.aug_dim, args.nhidden, args.gpu_index, args.model_type, args.frame
    )


if __name__ == "__main__":
    main()
