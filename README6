import torch

class GRUODEFunc(torch.nn.Module):
    """
    Refactored Continuous-Time ODE right-hand side function using a GRU cell.
    Integrates continuous hidden state evolution and Scale-Invariant Kinematic Injection.
    """

    def __init__(self, state_len: int, hidden_dim: int, aug_dim: int = 0, 
                 order_shift_slice: slice | None = None, normalizer: torch.nn.Module | None = None):
        super().__init__()
        self.state_len = state_len
        self.hidden_dim = hidden_dim
        self.aug_dim = aug_dim
        self.order_shift_slice = order_shift_slice
        self.normalizer = normalizer

        self.len_of_order_shift_slice = 0
        if self.order_shift_slice is not None:
            order_indices = tuple(range(*self.order_shift_slice.indices(state_len)))
            self.len_of_order_shift_slice = len(order_indices)

        input_dim = state_len + aug_dim
        self.gru = torch.nn.GRUCell(input_dim, hidden_dim)

        # Output layer maps hidden states strictly to higher-order derivatives (acceleration)
        output_dim = state_len - self.len_of_order_shift_slice
        self.to_dx = torch.nn.Linear(hidden_dim, output_dim)
        self.nfe = 0

    def forward(self, t, state):
        self.nfe += 1
        aug_start = self.state_len + self.hidden_dim

        x = state[..., :self.state_len]
        h = state[..., self.state_len:aug_start]
        aug = state[..., aug_start:] if self.aug_dim > 0 else None

        gru_input = x if aug is None else torch.cat([x, aug], dim=-1)
        h_next = self.gru(gru_input, h)

        # Continuous hidden state derivative matching latent state-space behaviors
        dh_dt = h_next - h
        raw_dx = self.to_dx(h_next)

        if self.order_shift_slice is not None:
            # Extract normalized velocity elements from the state vector
            v_norm = torch.narrow(x, dim=-1, start=self.order_shift_slice.start, length=self.len_of_order_shift_slice)
            
            if self.normalizer is not None:
                # Retrieve scale factors dynamically from the wrapped StandardScaler parameters
                # dx_norm/dt = v_physical / sigma_position
                slice_start = self.order_shift_slice.start
                slice_len = self.len_of_order_shift_slice
                
                scale_p = self.normalizer.scale[:slice_start]
                mean_v = self.normalizer.mean[slice_start:slice_start + slice_len]
                scale_v = self.normalizer.scale[slice_start:slice_start + slice_len]
                
                v_phys = (v_norm * scale_v) + mean_v
                v_injection = v_phys / scale_p
                dx_dt = torch.cat([v_injection, raw_dx], dim=-1)
            else:
                dx_dt = torch.cat([v_norm, raw_dx], dim=-1)
        else:
            dx_dt = raw_dx

        if self.aug_dim > 0:
            daug_dt = torch.zeros_like(aug)
            return torch.cat([dx_dt, dh_dt, daug_dt], dim=-1)
        else:
            return torch.cat([dx_dt, dh_dt], dim=-1)


class GRUODEArchitecture:
    """
    Architecture wrapper class enabling NODEPredictor interfacing with GRU-ODE structures.
    Passes scaling references into the continuous function evaluation network.
    """

    def __init__(self, state_len: int, hidden_dim: int = 128, aug_dim: int = 0, 
                 order_shift_slice: slice | None = None, normalizer: torch.nn.Module | None = None):
        self.state_len = state_len
        self.hidden_dim = hidden_dim
        self.aug_dim = aug_dim
        self.order_shift_slice = order_shift_slice
        self.normalizer = normalizer

    def get_model(self) -> torch.nn.Module:
        return GRUODEFunc(
            state_len=self.state_len,
            hidden_dim=self.hidden_dim,
            aug_dim=self.aug_dim,
            order_shift_slice=self.order_shift_slice,
            normalizer=self.normalizer
        )

    def get_input_dim(self) -> int:
        return self.state_len

    def get_output_dim(self) -> int:
        return self.state_len

    def get_aug_dim(self) -> int:
        return self.aug_dim

    def get_hidden_dim(self) -> int:
        return self.hidden_dim

