"""Euler Ordinary Differential Equation Solver for NODE implementation."""

from __future__ import annotations

from typing import Callable

import torch
from prediction.mlearn.neural_ode.ode_solver import ODESolver

try:
    import torchdiffeq as tde

except ModuleNotFoundError:
    tde = None


class TorchdiffeqSolver(ODESolver):
    """ODE Solver that wraps torchdiffeq"""

    def __init__(self, dt=1, *, adjoint=False, method="dopri5", substeps: int = 1):
        super().__init__(dt, adjoint=False)  # torchdiffeq provides an adjoint method
        self.method = method
        # substeps: number of internal integration steps taken PER data interval.
        # For fixed-step methods (rk4/euler), torchdiffeq steps between the times
        # we hand odeint, so by default the integration step equals the data
        # spacing dt. On chaotic, maneuver-heavy trajectories that coarse step is
        # where truncation error compounds. substeps>1 integrates on a grid that
        # is `substeps` times finer (dt/substeps), then returns only the points
        # aligned to the original dt -- improving accuracy with NO change to the
        # output shape or the (steps-based) caller contract. substeps=1 exactly
        # reproduces the original behaviour.
        if substeps < 1:
            raise ValueError(f"substeps must be >= 1, got {substeps}")
        self.substeps = int(substeps)
        if tde is None:
            raise ImportError("Prediction Core is not able to use torchdiffeq. Please install torchdiffeq")
        self.odeint = tde.odeint
        if adjoint:
            self.odeint = tde.odeint_adjoint

    def integrate(
        self,
        func: torch.nn.Module,
        x0: torch.Tensor,
        steps: int = 1,
        extra_feat: torch.Tensor | None = None,
    ) -> torch.Tensor:
        """Solves an ODE by integrating it from the initial conditions.

        Euler's Method uses the ODE evaluated at a given point and the
        approximation that with a small step size, the function is almost
        linear to solve the ODE. The update step can be written as follows:

        x_i+1 = x_i + dt*f(x_i)

        where x_i is the given state, x_i+1 is the next state, dt is the step
        size, and f(x_i) is the ODE evaluated at the given state.

        Args:
            func: Function to be integrated.
                This should be a Callable with a single torch tensor as an
                input. It can represent a physical system or in general be
                anything.
            x0: A tensor containing the initial conditions.
                This is expected to be of shape (batch_size, n_features).
            steps: The number of steps to integrate forward.
            extra_feat: Optional extra features to include.
                It is concatenated to the initial conditions and each subsequent
                step. It can contain "scenario specific" information. It is of
                shape (batch_size, n_extra_features).

        Returns:
            The solution to the ODE as a torch tensor.
                The shape will be (batch_size, steps + 1, n_features).
        """
        if extra_feat is not None:
            raise Warning("Prediction Core torchdiffeq wrapper does not implement extra_feat")
        # subtract epsilon from the end values because torch has inconsistent arange behavior (see torch docs)
        epsilon = 1e-10
        if self.substeps == 1:
            # original behaviour: integrate directly on the data grid
            times = torch.arange(0, self.dt * steps + self.dt - epsilon, self.dt, dtype=torch.float64).to(x0.device)
            x = self.odeint(func, x0, times, method=self.method)
            x = torch.permute(x, (1, 0, 2))  # swap axis to match PCM order
            return x

        # sub-stepped integration: build a grid `substeps` times finer so the
        # solver takes smaller (more accurate) internal steps, then return ONLY
        # the points aligned to the original dt grid so the output shape and the
        # caller contract are unchanged: (batch, steps + 1, n_features).
        fine_dt = self.dt / self.substeps
        n_fine = steps * self.substeps  # number of fine intervals
        times = torch.arange(
            0, fine_dt * n_fine + fine_dt - epsilon, fine_dt, dtype=torch.float64
        ).to(x0.device)
        x = self.odeint(func, x0, times, method=self.method)
        # x: (len(times), batch, n_features). Keep every substeps-th sample,
        # i.e. indices 0, substeps, 2*substeps, ... which land exactly on the
        # original dt grid and number steps + 1.
        x = x[:: self.substeps]
        x = torch.permute(x, (1, 0, 2))  # swap axis to match PCM order
        return x
