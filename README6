    # single threaded, but one at a time
    # tmp_data = []
    # for x in traj_targets[7:]:
    #     tmp_data.append(prep_trajectory(x))
    #     exit(0)

    tmp_data = [x for x in tmp_data if x[0] is not None]

    # check if all of the trajectories are much shorter than the asked for bucket
    # if not use_grdth:
