def calc_sim_metric(output, trajs, truth_trajs, truth_filename):
    ingress_metric = []
    for next_traj, truth_traj in zip(trajs, truth_trajs):
        ingress_metric.append(calc_sim_metric_for_one_pair(truth_traj, next_traj))
    return np.mean(ingress_metric)


def calc_sim_metric_for_one_pair(truth_traj, test_traj):
    # TODO: remove this when we get DTW
    # check if the truth needs to be resampled
    t = truth_traj
    if len(truth_traj) != len(test_traj):
        # use scipy to adjust the truth data
        reduction_factor = np.gcd(len(test_traj), len(truth_traj))
        t = resample_poly(
            truth_traj,
            len(test_traj) / reduction_factor,
            len(truth_traj) / reduction_factor,
            padtype="line",
        )
    return mean_absolute_error(t[:, POS_SLICE], test_traj[:, POS_SLICE])


def save_sim_result(output, trajs, truth_filename):
    # this was written to support the file format that originated from THADD Pitch Black. POET uses it as well.
    print(f"Saving {len(trajs)} extrapolations to disk")
    dfs = [None] * len(trajs)
    for i, traj in enumerate(trajs):
        # create a df from the numpy array where the columns are time, pos, vel
        df = pd.DataFrame(
            traj,
            columns=(
                "time",
                "x_pos_ecef",
                "y_pos_ecef",
                "z_pos_ecef",
                "x_vel_ecef",
                "y_vel_ecef",
                "z_vel_ecef",
                "x_acc_ecef",
                "y_acc_ecef",
                "z_acc_ecef",
            ),
        )

        # these columns change per traj
        # curr_time, pred_num, validity_time
        df["curr_time"] = df["time"][0]
        df["pred_num"] = i + 1
        df["validity_time"] = df["time"][0]
        dfs[i] = df

    # combine the dfs into one larger df
    big_df = pd.concat(dfs)

    # now add the static columns
    big_df["system_track_number"] = 1701
    big_df["threat_id"] = 47
    big_df["true_object_id"] = 31
    big_df["hyp_id"] = 1
    big_df["asset_id"] = 0
    big_df["threat_genre"] = "HGV"
    big_df["eng_status"] = "ELIGIBLE"
    big_df["traj_genre"] = "MRV"
    big_df["traj_genre_score"] = 0
    big_df["reach_assess"] = 0
    big_df["extrap_in_SR"] = "Y"

    # write to file
    s = f"NEXT_extraps_{truth_filename}"
    big_df.to_csv(os.path.join(output, f"extrap-dt_{extrapolation_dt}", s), index=False)


