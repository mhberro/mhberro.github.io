class ODEfunc(torch.nn.Module):
    def __init__(self, state_vector_len: int, nhidden: int, aug_dim: int = 0, order_shift_slice: slice | None = None):
        super(ODEfunc, self).__init__()
        # aug_dim: is the number of zeros that have been added on to the initial conditions
        # order_shift_slice: is slice of states that will be shifted left in the output vector. This works for both
        #   balanced order (e.g. 3 position and 3 velocity) and non-balanced order (e.g. 2 position and 3 velocity).
        #   For non-balanced order, only the velocity states that relate to the position states should be sliced. This
        #   does mean that the arrangement of the states in the vector does matter. (e.g. the arrangement for a 2-3
        #   state must be px,py,vx,vy,vz)
        self.order_shift_slice = order_shift_slice
        self.len_of_order_shift_slice = 0
        if self.order_shift_slice is not None:
            order_indicies = tuple(range(*self.order_shift_slice.indices(state_vector_len)))
            self.len_of_order_shift_slice = len(order_indicies)
        # self.act = torch.nn.ELU(inplace=False)
        # self.act = torch.nn.ReLU(inplace=False)  # not a smooth function. this lead to slow epochs
        self.act1 = torch.nn.SiLU(inplace=False)
        self.act2 = torch.nn.SiLU(inplace=False)
        # self.act3 = torch.nn.SiLU(inplace=False)
        # self.act = torch.nn.Tanh()
        self.fc1 = torch.nn.Linear(state_vector_len + aug_dim, nhidden)
        self.fc2 = torch.nn.Linear(nhidden, nhidden)
        # self.fc3 = torch.nn.Linear(nhidden, nhidden)
        self.fc4 = torch.nn.Linear(nhidden, (state_vector_len - self.len_of_order_shift_slice) + aug_dim)
        self.nfe = 0

    # def forward(self, x: torch.Tensor) -> torch.Tensor:  # this is the signature needed by PCM
    def forward(self, t, x: torch.Tensor) -> torch.Tensor:  # this is the signature needed by torchdiffeq
        if self.order_shift_slice is not None:
            # Is narrow the best option here? I'm trying to do slicing on the last dimension and have it work in ONNX
            v = torch.narrow(x, dim=-1, start=self.order_shift_slice.start, length=self.len_of_order_shift_slice)
        self.nfe += 1
        out = self.fc1(x)  # TODO: swap out this manual MLP with torchvision.ops.MLP
        out = self.act1(out)
        out = self.fc2(out)
        out = self.act2(out)
        # out = self.fc3(out)  # TODO: why so many layers?
        # out = self.act(out)
        out = self.fc4(out)
        if self.order_shift_slice is not None:
            return torch.cat((v, out), dim=x.ndim - 1)
            # return torch.cat((v, out), dim=x.ndim - 1)  # TODO: subtract a small MLP here for dissipation on the acceleration term
        else:
            return out


# =====================================================================
#  GRU-ODE  (De Brouwer et al., NeurIPS 2019 — GRU-ODE-Bayes)
# ---------------------------------------------------------------------
#  Continuous-time GRU vector field for the latent state h(t):
#
#       dh/dt = (1 - z(t)) ⊙ (g(t) - h(t))            (paper Eq. 3 / App. A)
#
#  with the continuous-time gates
#       r(t) = σ(W_r x + U_r h + b_r)
#       z(t) = σ(W_z x + U_z h + b_z)
#       g(t) = tanh(W_h x + U_h (r ⊙ h) + b_h)
#
#  Key properties exploited here for chaotic kinematic forecasting:
#    * Boundedness:   h(0) ∈ [-1,1]  ⇒  h(t) ∈ [-1,1] ∀t  (negative
#      feedback term -(1-z)⊙h points inward at the boundary). This bounds
#      long-horizon rollouts and collapses S-curve / phugoid divergence.
#    * Lipschitz K=2: globally smooth vector field ⇒ adaptive solvers
#      (DOPRI) stay stable and can take large steps.
#    * Continuity prior on h(t): a smooth latent flow that regularises the
#      forecaster, especially valuable in the low-sample regime.
#
#  Design note for THIS pipeline: the truth data is resampled onto a uniform
#  grid and is fully observed (no per-feature mask), so the Bayesian filtering
#  half of the paper (GRU-Bayes + KL post-jump loss) has nothing to filter at
#  train time. We therefore use the GRU-ODE *cell* as a bounded latent vector
#  field and expose the GRU-Bayes jump as an OPT-IN path (GRUODEBayesPredictor)
#  for when genuinely sporadic/masked observations are available. The autonomous
#  forecaster below (no continuous input x(t)) is the default — g and z then
#  depend on h(t) only, exactly the autonomous case described in paper §2.1.
# =====================================================================
class FullGRUODECell(torch.nn.Module):
    """The GRU-ODE vector field dh/dt = (1 - z) ⊙ (g - h).

    Operates on a *latent* state h ∈ R^H. If a continuous control/observation
    signal x(t) ∈ R^D is supplied it is injected into all three gates; if not,
    the cell is autonomous (the default for forecasting).

    The forward signature is (t, h) to match torchdiffeq and the existing
    TorchdiffeqSolver / ONNX export contract used by ODEfunc.
    """

    def __init__(self, hidden_size: int, input_size: int = 0, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.input_size = input_size
        # --- OPTIMIZED weight layout -------------------------------------
        # The r and z gates depend on h directly; g depends on the RESET-GATED
        # hidden state (r ⊙ h). Computing them in one packed 3H×H matmul forces
        # the wasted product U_h·h to be computed and then subtracted out. We
        # instead split into:
        #   lin_hrz : (2H, H)  -> U_r, U_z      applied to h
        #   lin_hg  : ( H, H)  -> U_h           applied to (r ⊙ h)
        # This is two matmuls instead of three, mathematically identical to the
        # packed-and-correct form (verified to machine precision), and removes
        # the per-step subtraction. Fewer/larger fused GEMMs also map better to
        # GPU tensor cores.
        self.lin_hrz = torch.nn.Linear(hidden_size, 2 * hidden_size, bias=False)
        self.lin_hg = torch.nn.Linear(hidden_size, hidden_size, bias=False)
        if input_size > 0:
            # Input weights for all three gates: W_r, W_z (for r,z) and W_h (g).
            self.lin_xrz = torch.nn.Linear(input_size, 2 * hidden_size, bias=bias)
            self.lin_xg = torch.nn.Linear(input_size, hidden_size, bias=bias)
        else:
            # Learnable gate biases so the autonomous field is not pinned to the
            # origin. Registered as parameters (broadcast over batch).
            if bias:
                self.bias_rz = torch.nn.Parameter(torch.zeros(2 * hidden_size))
                self.bias_g = torch.nn.Parameter(torch.zeros(hidden_size))
            else:
                self.register_parameter("bias_rz", None)
                self.register_parameter("bias_g", None)

    def forward(self, t, h: torch.Tensor, x: torch.Tensor | None = None) -> torch.Tensor:
        """Return dh/dt with the same trailing-dim layout as h.

        h : (..., H)   latent state (any batch/sequence leading dims)
        x : (..., D)   optional continuous input aligned on the last dim

        No host-syncing side effects (no nfe counter) so the field is safe for
        CUDA-graph capture and torch.compile.
        """
        pre_rz = self.lin_hrz(h)
        if self.input_size > 0:
            pre_rz = pre_rz + self.lin_xrz(x)
        elif self.bias_rz is not None:
            pre_rz = pre_rz + self.bias_rz
        r, z = torch.sigmoid(pre_rz).chunk(2, dim=-1)

        pre_g = self.lin_hg(r * h)
        if self.input_size > 0:
            pre_g = pre_g + self.lin_xg(x)
        elif self.bias_g is not None:
            pre_g = pre_g + self.bias_g
        g = torch.tanh(pre_g)

        return (1.0 - z) * (g - h)


class MinimalGRUODECell(torch.nn.Module):
    """Minimal GRU-ODE (paper App. G):

        dh/dt = (1 - f) ⊙ (σ(W_h x + U_h (h ⊙ f) + b_h) - h)

    Fewer parameters than the full cell; retains boundedness and the K=2
    Lipschitz property. Useful when latent H is large or data is scarce.
    """

    def __init__(self, hidden_size: int, input_size: int = 0, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.input_size = input_size
        self.lin_hf = torch.nn.Linear(hidden_size, hidden_size, bias=False)  # U_f
        self.lin_hh = torch.nn.Linear(hidden_size, hidden_size, bias=False)  # U_h
        if input_size > 0:
            self.lin_xf = torch.nn.Linear(input_size, hidden_size, bias=bias)
            self.lin_xh = torch.nn.Linear(input_size, hidden_size, bias=bias)
        else:
            self.bias_f = torch.nn.Parameter(torch.zeros(hidden_size)) if bias else None
            self.bias_h = torch.nn.Parameter(torch.zeros(hidden_size)) if bias else None

    def forward(self, t, h: torch.Tensor, x: torch.Tensor | None = None) -> torch.Tensor:
        pre_f = self.lin_hf(h)
        if self.input_size > 0:
            pre_f = pre_f + self.lin_xf(x)
        elif self.bias_f is not None:
            pre_f = pre_f + self.bias_f
        f = torch.sigmoid(pre_f)

        pre_h = self.lin_hh(f * h)
        if self.input_size > 0:
            pre_h = pre_h + self.lin_xh(x)
        elif self.bias_h is not None:
            pre_h = pre_h + self.bias_h
        g = torch.tanh(pre_h)

        dh = (1.0 - f) * (g - h)
        return dh


class GRUODEFunc(torch.nn.Module):
    """Drop-in replacement for ``ODEfunc`` that integrates a GRU-ODE field in a
    BOUNDED LATENT SPACE and decodes back to the physical kinematic state.

    Pipeline per integration call (single physical state, autonomous):

        x_phys (..., D)
           │  encoder (Linear→SiLU→Linear→tanh)        lift to latent
           ▼
        h (..., H) ∈ (-1, 1)                            boundedness precondition
           │  ∫ FullGRUODECell  dt   (handled by the external solver)
           ▼
        h(t) (..., H) ∈ (-1, 1)                         stays bounded ∀t
           │  decoder (Linear→SiLU→Linear)             project to physical
           ▼
        x_phys(t) (..., D)

    To keep a SINGLE state vector flowing through the existing solver / ONNX
    export (which integrate a vector field of fixed dimension), we expose the
    *augmented* state  s = [x_phys, h]  ∈ R^{D+H}  and define its derivative:

        d/dt [x_phys] = decoder_jacobian-free readout:  ẋ_phys = J·ḣ  ≈  Dec(h+εḣ) trick
        d/dt [h]      = FullGRUODECell(h)

    In practice, decoding every step is cheap and exact, so we instead carry h
    as the integrated state and the physical readout is produced by the decoder
    AFTER integration (see GRUODELatentModel). For ONNX/solver parity we still
    provide a fixed-dim ``forward(t, s)`` that advances the latent block and
    holds the physical block via its decoded velocity, supporting the
    second-order (order_shift_slice) kinematic prior.

    For the common case we recommend using ``GRUODELatentModel`` end-to-end,
    which the trainer wires up automatically.
    """

    def __init__(
        self,
        state_vector_len: int,
        nhidden: int,
        latent_dim: int | None = None,
        minimal: bool = False,
        encoder_hidden: int | None = None,
    ):
        super().__init__()
        self.state_vector_len = state_vector_len
        self.latent_dim = latent_dim if latent_dim is not None else max(2 * state_vector_len, nhidden)
        enc_h = encoder_hidden if encoder_hidden is not None else nhidden

        # Encoder: physical → bounded latent. Final tanh guarantees h ∈ (-1,1),
        # satisfying the GRU-ODE boundedness precondition.
        self.encoder = torch.nn.Sequential(
            torch.nn.Linear(state_vector_len, enc_h),
            torch.nn.SiLU(),
            torch.nn.Linear(enc_h, self.latent_dim),
            torch.nn.Tanh(),
        )
        # The continuous-time GRU vector field (autonomous: input_size=0).
        cell_cls = MinimalGRUODECell if minimal else FullGRUODECell
        self.cell = cell_cls(hidden_size=self.latent_dim, input_size=0, bias=True)
        # Decoder: bounded latent → physical state.
        self.decoder = torch.nn.Sequential(
            torch.nn.Linear(self.latent_dim, enc_h),
            torch.nn.SiLU(),
            torch.nn.Linear(enc_h, state_vector_len),
        )

    def forward(self, t, h: torch.Tensor) -> torch.Tensor:
        """Vector field on the LATENT state h (this is what the solver integrates).

        Accepts h of shape (..., latent_dim) and returns dh/dt of the same shape.
        Boundedness is structural, so no clamping is required.
        """
        return self.cell(t, h)

    # --- convenience maps used by the latent wrapper / ONNX model ---
    def encode(self, x_phys: torch.Tensor) -> torch.Tensor:
        return self.encoder(x_phys)

    def decode(self, h: torch.Tensor) -> torch.Tensor:
        return self.decoder(h)


# Forward-mode JVP: prefer torch.func (single forward pass) over
# torch.autograd.functional.jvp (double-backward, ~3x cost and an extra graph).
try:  # torch >= 2.0
    from torch.func import jvp as _func_jvp

    def _decoder_jvp(decode_fn, h, dh):
        # (output, J·dh) in one forward-mode pass — no backward graph built.
        return _func_jvp(decode_fn, (h,), (dh,))
except Exception:  # pragma: no cover - older torch fallback
    def _decoder_jvp(decode_fn, h, dh):
        return torch.autograd.functional.jvp(decode_fn, h, v=dh, create_graph=True, strict=False)


class GRUODELatentModel(torch.nn.Module):
    """GRU-ODE as a physical-space vector field, drop-in for ODEfunc, with an
    optional structural second-order constraint dpos/dt = vel.

    New args:
        pos_idx, vel_idx : paired index lists. xdot[pos_idx[i]] is forced to
                           x[vel_idx[i]]. If either is None, the constraint is
                           OFF and the model behaves exactly as before.
    """

    def __init__(
        self,
        func,                 # GRUODEFunc
        solver=None,
        aug_dim: int = 0,
        pos_idx: list[int] | None = None,
        vel_idx: list[int] | None = None,
        pos_scale=None,       # StandardScaler scale_ (sigma) for the pos block
        vel_scale=None,       # StandardScaler scale_ (sigma) for the vel block
        vel_mean=None,        # StandardScaler mean_ (mu) for the vel block
    ):
        super().__init__()
        self.func = func
        self.aug_dim = aug_dim
        # second-order coupling (None => disabled, original behaviour)
        self.second_order = pos_idx is not None and vel_idx is not None
        if self.second_order:
            assert len(pos_idx) == len(vel_idx), "pos_idx and vel_idx must pair up"
            self.register_buffer("pos_idx", torch.tensor(list(pos_idx), dtype=torch.long))
            self.register_buffer("vel_idx", torch.tensor(list(vel_idx), dtype=torch.long))
            # CRITICAL: the model works in SCALED units, but the kinematic
            # identity d/dt(pos)=vel holds in PHYSICAL units. With a
            # StandardScaler (x_s=(x-mu)/sigma), the correct scaled-space
            # position derivative is
            #     xdot_s[pos] = (sigma_vel/sigma_pos)*vel_s + (mu_vel/sigma_pos)
            # NOT vel_s. We precompute the per-axis ratio and offset. If no
            # scaler stats are supplied we assume physical units (ratio=1,
            # offset=0), recovering the naive constraint.
            if pos_scale is not None and vel_scale is not None:
                ratio = torch.as_tensor(vel_scale, dtype=torch.float32) / torch.as_tensor(
                    pos_scale, dtype=torch.float32
                )
                offset = (
                    torch.as_tensor(vel_mean, dtype=torch.float32)
                    / torch.as_tensor(pos_scale, dtype=torch.float32)
                    if vel_mean is not None
                    else torch.zeros_like(ratio)
                )
                self.register_buffer("so_ratio", ratio)
                self.register_buffer("so_offset", offset)
                self.scaled_space = True
            else:
                self.so_ratio = None
                self.so_offset = None
                self.scaled_space = False
        else:
            self.pos_idx = None
            self.vel_idx = None

    def _field(self, t, x_phys: torch.Tensor) -> torch.Tensor:
        h = self.func.encode(x_phys)
        dh = self.func.cell(t, h)
        _, xdot = _decoder_jvp(self.func.decode, h, dh)  # noqa: F821 (defined in your script)
        if self.second_order:
            # Force d/dt(pos) = vel, expressed correctly in the model's units.
            # In scaled space the relationship is NOT identity; it is scaled by
            # sigma_vel/sigma_pos with a mu_vel/sigma_pos offset (see __init__).
            vel_now = x_phys.index_select(-1, self.vel_idx)
            if getattr(self, "scaled_space", False):
                vel_now = vel_now * self.so_ratio + self.so_offset
            xdot = xdot.index_copy(-1, self.pos_idx, vel_now)
        return xdot

    def forward(self, t, x: torch.Tensor) -> torch.Tensor:
        if self.aug_dim > 0 and x.shape[-1] > self.func.state_vector_len:
            x_core = x.narrow(-1, 0, self.func.state_vector_len)
            xdot_core = self._field(t, x_core)
            pad = torch.zeros(
                *xdot_core.shape[:-1], self.aug_dim, dtype=xdot_core.dtype, device=xdot_core.device
            )
            return torch.cat((xdot_core, pad), dim=-1)
        return self._field(t, x)



class GRUBayes(torch.nn.Module):
    """OPT-IN Bayesian jump update (paper §2.3, Eq. 4 + App. D fprep).

    Only used when genuinely sporadic / masked observations are present. Given
    the pre-jump latent h(t-), an observation y[k] and its mask m[k], it
    produces a discrete update h(t+) = GRU(h(t-), fprep(y, m, h)). Because
    GRU-ODE keeps h ∈ [-1,1], a standard GRUCell is range-compatible.

    The trainer leaves this dormant for the current uniformly-resampled,
    fully-observed pipeline; it is provided so the architecture is complete and
    activates without code changes once masked inputs are wired in.
    """

    def __init__(self, latent_dim: int, obs_dim: int, prep_hidden: int):
        super().__init__()
        self.latent_dim = latent_dim
        self.obs_dim = obs_dim
        # fprep: per-dimension [θ (mean,logvar), y, (y-μ)/σ] -> prep_hidden, ReLU,
        # zeroed where unobserved. Implemented as a grouped linear over dims.
        self.obs_to_theta = torch.nn.Linear(latent_dim, 2 * obs_dim)  # fobs: μ, logσ²
        self.prep = torch.nn.Linear(4 * obs_dim, prep_hidden * obs_dim)
        self.gru = torch.nn.GRUCell(prep_hidden * obs_dim, latent_dim)

    def fobs(self, h: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor]:
        theta = self.obs_to_theta(h)
        mu, logvar = theta.chunk(2, dim=-1)
        return mu, logvar

    def forward(self, h_minus: torch.Tensor, y: torch.Tensor, m: torch.Tensor) -> torch.Tensor:
        mu, logvar = self.fobs(h_minus)
        sigma = torch.exp(0.5 * logvar)
        norm_err = (y - mu) / (sigma + 1e-6)
        # Per-dim feature vector q_d = [μ, logσ², y, norm_err], masked.
        q = torch.cat([mu, logvar, y, norm_err], dim=-1)
        q = torch.relu(self.prep(q))
        # Zero out contributions where there was no observation.
        m_rep = m.repeat_interleave(self.prep.out_features // self.obs_dim, dim=-1)
        q = q * m_rep
        h_plus = self.gru(q, h_minus)
        # Re-bound to the GRU-ODE operating region (defensive; GRUCell ≈ in-range).
        return torch.tanh(h_plus)


# wrap the sklearn StandardScalar
class Normaliser(torch.nn.Module):
    def __init__(self, scaler):
        super().__init__()
        self.mean = torch.nn.Parameter(torch.tensor(scaler.mean_, dtype=torch.float32), requires_grad=False)
        self.scale = torch.nn.Parameter(torch.tensor(scaler.scale_, dtype=torch.float32), requires_grad=False)

    def forward(self, x):  # phys → norm
        return (x - self.mean) / self.scale

    def inverse(self, z):  # norm → phys
        return z * self.scale + self.mean


# -------------------------------------------------
# 2️⃣  Encoder – maps a short observation window to μ, logσ
# -------------------------------------------------
class Encoder(torch.nn.Module):
    """
    Input: (B, K, 6)  – K initial time steps per trajectory
    Output: μ, logσ each of shape (B, latent_dim)
    """

    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        # TODO: replace 6 with state size
        self.rnn = torch.nn.GRU(input_size=6, hidden_size=hidden, batch_first=True, num_layers=1)
        self.mu_head = torch.nn.Linear(hidden, latent_dim)
        self.logvar_head = torch.nn.Linear(hidden, latent_dim)

    def forward(self, x):
        # x already normalised
        _, h_n = self.rnn(x)  # h_n: (1, B, hidden)
        h = h_n.squeeze(0)  # (B, hidden)
        mu = self.mu_head(h)
        logvar = self.logvar_head(h)
        return mu, logvar


# -------------------------------------------------
# 3️⃣  Latent ODE dynamics (continuous flow)
# -------------------------------------------------
class LatentODEFunc(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.net = torch.nn.Sequential(
            torch.nn.Linear(latent_dim, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, latent_dim),
        )

    def forward(self, t, z):
        return self.net(z)


# -------------------------------------------------
# 4️⃣  Decoder – maps latent state back to (p, v)
# -------------------------------------------------
class Decoder(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.net = torch.nn.Sequential(
            torch.nn.Linear(latent_dim, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, 6),  # TODO: replace 6 with state size
        )  # output 6-D physical state (still normalised)

    def forward(self, z):
        return self.net(z)


# -------------------------------------------------
# 5️⃣  Full model wrapper (for a single trajectory)
# -------------------------------------------------
from torchdiffeq import odeint_adjoint


class LatentNODE(torch.nn.Module):
    def __init__(self, latent_dim=8):
        super().__init__()
        self.encoder = Encoder(latent_dim)
        self.odefunc = LatentODEFunc(latent_dim)
        self.decoder = Decoder(latent_dim)

    def forward(self, obs_window_and_times: tuple[torch.Tensor, torch.Tensor]):
        """
        obs_window : (B, K, 6)  – normalised observations used by encoder
        t_eval     : (T,)       – times at which we want a reconstruction
        Returns:
            recon   : (B, T, 6) – decoded physical state (still normalised)
            mu, logvar : (B, latent_dim)  – encoder statistics (for KL)
        """
        obs_window, t_eval = obs_window_and_times
        mu, logvar = self.encoder(obs_window)

        # Reparameterisation trick (sample z₀)
        std = torch.exp(0.5 * logvar)
        eps = torch.randn_like(std)
        z0 = mu + eps * std  # (B, latent_dim)

        # Integrate the latent ODE
        # odeint expects (T, B, latent_dim); we transpose after
        z_t = odeint_adjoint(self.odefunc, z0, t_eval, atol=1e-5, rtol=1e-5)  # (T, B, latent_dim)
        z_t = z_t.permute(1, 0, 2)  # (B, T, latent_dim)

        # Decode every latent snapshot
        recon = self.decoder(z_t)  # (B, T, 6)
        return recon, mu, logvar


def _kl_divergence(mu: torch.Tensor, logvar: torch.Tensor) -> torch.Tensor:
    """Standard normal-prior KL term used by VAEs / latent ODEs."""
    # 0.5 * Σ (1 + logσ² – μ² – σ²)
    return 0.5 * torch.mean(torch.sum(1 + logvar - mu.pow(2) - torch.exp(logvar), dim=1))


def _make_obs_target(
    traj: torch.Tensor,
    obs_len: int = 10,
) -> tuple[torch.Tensor, torch.Tensor]:
    """
    Returns a short observation window (first *obs_len* points) that will be
    fed to the encoder and the full trajectory (starting at the same first
    time-step) that will be used as the reconstruction target.
    """
    assert traj.shape[0] > obs_len, "trajectory shorter than observation window"
    obs_window = traj[:obs_len].unsqueeze(0)  # (B=1, K=obs_len, D)
    target = traj.unsqueeze(0)  # (B=1, T, D)
    return obs_window, target


def train_NEXT(
    model_name,
    traj_targets_train,
    traj_targets_test,
    scaler_traj,
    model_save_path,
    trajectory_dt,
    batch_size,
    use_scalar,
    model_states,
    aug_dim,
    nhidden,
    gpu_index,
    model_type: str = "node",
    frame: str = "dcu",
):
    # define initial training configuration
    training_configuration = TrainingConfiguration(
        n_epochs=1,
        optimizer=AdamOptimizer(learning_rate=1e-3),
        # optimizer=ReduceLROnPlateauConfiguration("loss").create_from_optimizer(AdamOptimizer(learning_rate=1e-3)),
        batch_size=batch_size,
        num_workers=100,  # is this the parallel control? cpu_count()//2?
        verbose=True,
    )
    # ode_solver = EulerSolver(dt=trajectory_dt)
    # ode_solver = RK4Solver(dt=trajectory_dt)
    # Fixed-step RK4 with adjoint=False stores the forward graph for exact, fast
    # gradients — appropriate here because the GRU-ODE field is K=2 Lipschitz, so
    # a fixed step is numerically stable. Tradeoffs for GRU-ODE specifically:
    #   * method="dopri5": adaptive step — fewer evals on smooth stretches, more
    #     near sharp dynamics; better stability at the cost of variable runtime.
    #   * adjoint=True: O(1) memory in the number of steps (recompute on the
    #     backward pass) — switch this on if long horizons OOM the GPU; it trades
    #     memory for ~2x compute and is the setting the paper uses for big latents.
    ode_solver = TorchdiffeqSolver(dt=trajectory_dt, method="rk4", adjoint=False, substeps=4)

    if frame in ("dcu", "geodesic"):
        velocity_indicies = (3, 4, 5)
    elif frame in ("grdth",):
        velocity_indicies = (2, 3, 4)
    else:
        raise ValueError("That frame is not known for what the velocity indicies are")
    # Define custom loss function.
    early_stop_metric_name = "val_loss"
    # loss_func = EnergyMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     energy_fn=mechanical_energy,
    #     energy_weight=1,
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    # )

    # loss_func = WrappedMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    # )

    # loss_func = PhysicsSplitMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     dt=trajectory_dt,
    #     pos_weight=1.0,
    #     vel_weight=2.0,
    #     physics_weight=0,
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    # )

    loss_func = PhysicsSplitMSELoss(
        height_idx=1,
        vel_indices=velocity_indicies,
        dt=trajectory_dt,
        pos_weight=1.0,
        vel_weight=3.0,        # glide: velocity is the laggard AND now feeds position
        physics_weight=0.0,    # second-order model makes the soft residual redundant
        scaler=scaler_traj if use_scalar else None,
        N_FEATURES=model_states,
    )

    # this does have influence, but it is not a hard limit on the given expected values
    # loss_func = SecondOrderSplitMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     vel_weight=1.0,  # TODO: try this set to zero so that only position is used for loss
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    #     pos_expect=1e9,
    #     vel_expect=1e9,
    # )

    # more influential, but not a hard limit
    # loss_func = WeightedHuberLoss(
    #     delta_pos=1e500,
    #     delta_vel=1e500,
    #     # height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     # vel_weight=1.0,
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    #     weight_pos=1.0,
    #     weight_vel=1.0,
    # )
    # early_stop_metric_name = "val_loss_unweighted"

    # Define the Neural ODE model
    node = NODEPredictor(
        architecture=FFNNArchitecture(
            layer_channels=[5, 5],  # this doesn't do anything when using ODEfunc
            # layer_activation=Activation.RELU,
            # layer_activation=Activation.TANH,
            layer_activation=Activation.SILU,
        ),
        training_configuration=training_configuration,
        solver=ode_solver,
        logging_interval=5,
        loss_func=loss_func,
        early_stopper=EarlyStopper(10, 0.5, metric_name=early_stop_metric_name),
        checkpoint=ModelCheckpoint(min_epochs=1, directory=model_save_path, model_name=model_name + ".checkpoint"),
        aug_dim=aug_dim,
    )
    if HAVE_GPU:
        node.device = torch.device(f"cuda:{gpu_index}")
        node._initialize_losses(node.criterion)
        node._initialize_model()
        node._initialize_optimizer()

    # --------------------------------------------------------------------
    #  Build the requested model
    # --------------------------------------------------------------------
    if model_type == "node":
        # plain NODE (no augmentation, no order-shift)
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "anode":
        # Augmented NODE – aug_dim comes from the CLI flag
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=aug_dim,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "sonode":
        # Second-order NODE – shift the velocity slice left
        # (the slice that selects the velocity components; adjust if you
        # change the state ordering)
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=slice(3, 6),
        ).to(node.device)
    elif model_type in ("gruode", "gruode-min"):
        # ------------------------------------------------------------
        #  GRU-ODE forecaster (De Brouwer et al., 2019).
        #  Bounded latent vector field; encode → ∫GRU-ODE → decode.
        #  'gruode'     -> full GRU-ODE cell
        #  'gruode-min' -> minimal GRU-ODE cell (fewer params)
        # ------------------------------------------------------------
        minimal = model_type == "gruode-min"
        # Latent dimension: default to a comfortable lift above the physical
        # state. nhidden controls the encoder/decoder MLP width.
        latent_dim = max(2 * model_states, nhidden // 2 if nhidden >= 20 else 16)
        gruode_func = GRUODEFunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            latent_dim=latent_dim,
            minimal=minimal,
        ).to(node.device)
        if frame in ("dcu", "geodesic"):
            pos_idx, vel_idx = [0, 1, 2], [3, 4, 5]
        elif frame == "grdth":
            pos_idx, vel_idx = [0, 1], [2, 3]      # idx 4 (VTheta) left to the network
        else:
            pos_idx, vel_idx = None, None          # constraint off

        # Scaler stats for the scaled-space second-order correction. The model
        # operates in StandardScaler-scaled units, so d/dt(pos)=vel must be
        # expressed as xdot_s[pos] = (sigma_vel/sigma_pos)*vel_s + mu_vel/sigma_pos.
        # Without these, the constraint is dimensionally wrong (see _field).
        so_pos_scale = so_vel_scale = so_vel_mean = None
        if use_scalar and pos_idx is not None and isinstance(scaler_traj, StandardScaler):
            so_pos_scale = scaler_traj.scale_[pos_idx]
            so_vel_scale = scaler_traj.scale_[vel_idx]
            so_vel_mean = scaler_traj.mean_[vel_idx]

        node.model = GRUODELatentModel(
            func=gruode_func, solver=ode_solver, aug_dim=aug_dim,
            pos_idx=pos_idx, vel_idx=vel_idx,
            pos_scale=so_pos_scale, vel_scale=so_vel_scale, vel_mean=so_vel_mean,
        ).to(node.device)
        # Optional JIT compilation of the field for extra GPU throughput.
        # Opt-in via NEXT_COMPILE=1 because torch.compile can interact with the
        # solver's autograd path (especially adjoint) and the forward-mode JVP;
        # we use mode="reduce-overhead" (CUDA graphs) and fall back silently if
        # the backend can't trace the graph on this torch/driver combo.
        if HAVE_GPU and os.environ.get("NEXT_COMPILE", "0") == "1":
            try:
                node.model = torch.compile(node.model, mode="reduce-overhead", fullgraph=False)
                print("torch.compile enabled for GRU-ODE field (reduce-overhead)")
            except Exception as e:
                print(f"torch.compile unavailable, running eager: {e}")
        # The GRU-ODE forecaster outputs a physical-state trajectory directly,
        # so the existing physical-space loss (WrappedMSELoss, already assigned
        # to loss_func above) applies unchanged. The structural boundedness of
        # the latent state supplies the trajectory-stabilisation prior that
        # otherwise required an explicit boundary penalty.
        #
        # Optional: couple a light physical boundary / energy penalty by
        # swapping loss_func for EnergyMSELoss above — the GRU-ODE recon is a
        # drop-in target for any of the existing loss wrappers.
    elif model_type == "latentode":
        # ------------------------------------------------------------
        #  Latent-ODE model – a completely different object
        # ------------------------------------------------------------
        # Encoder/Decoder expect a *state size* of 6 (or whatever you use).
        # They are already defined above (Encoder, Decoder, LatentODEFunc,
        # LatentNODE).  We just instantiate the wrapper.
        latent_dim = nhidden // 2 if nhidden >= 20 else 8  # a sensible default
        node.model = LatentNODE(latent_dim=latent_dim).to(node.device)

        # For latent ODE we need a **different loss** that adds the KL term.
        # Keep the same MSE wrapper you already use for the physical states.
        recon_criterion = WrappedMSELoss(
            height_idx=1,
            vel_indices=[3, 4, 5],
            scaler=scaler_traj if use_scalar else None,
            N_FEATURES=model_states,
        )

        def latent_ode_loss_fn(recon, target, mu, logvar):
            """Reconstruction (MSE) + KL."""
            recon_loss = recon_criterion(recon, target)
            kl = _kl_divergence(mu, logvar)
            # You may weight the KL term; 0.1 works well for many problems.
            return recon_loss + 0.1 * kl

        # Replace the NODEPredictor's loss with our custom wrapper.
        # NOTE: NODEPredictor expects a callable that takes (pred, true).
        # We therefore bind the extra arguments via a lambda.
        node.loss_func = lambda pred, true: latent_ode_loss_fn(pred[0], true, pred[1], pred[2])
    else:
        raise ValueError(f"Unsupported model_type: {model_type}")

    # Train the model if it does not exist
    if use_scalar:
        scaled_traj_targets_train_posvel = [
            torch.Tensor(scaler_traj.transform(i[:, 0 : model_states + 1])) for i in traj_targets_train
        ]
        scaled_traj_targets_test_posvel = [
            torch.Tensor(scaler_traj.transform(i[:, 0 : model_states + 1])) for i in traj_targets_test
        ]
    else:
        scaled_traj_targets_train_posvel = [torch.Tensor(i[:, 0 : model_states + 1]) for i in traj_targets_train]
        scaled_traj_targets_test_posvel = [torch.Tensor(i[:, 0 : model_states + 1]) for i in traj_targets_test]
    gen_model = False
    try:
        # Try loading the specific requested model
        node.load(directory=model_save_path, model_name=model_name)
    except ValueError:
        gen_model = True
        pass

    if gen_model:
        # did not find a model to load. creating a new one

        # Model file not found. Train and create it
        # node._log_metrics = new_log_metrics.__get__(node)
        # try:
        #     node.model.compile()  # this resulted in slower epochs on cpu
        #     print("successfully compile the nn")
        # except Exception as e:
        #     print("failed to compile the nn due to", e)

        if model_type == "latentode":
            # Choose a short window (e.g. 10 time-steps).  You can expose this
            # as another CLI argument if you wish.
            OBS_WINDOW = 10

            train_data = [
                _make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_train_posvel
            ]  # list of (obs_window, target)
            test_data = [_make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_test_posvel]
            # reshape for NODEPredictor: it expects a list of tensors.
            # We will pack the tuple into a single tensor where the first two
            # dimensions are (B, K/ T) and let the model unpack them.
            # The simplest approach is to keep them as tuples and let the
            # training loop handle them.
            # → In the `node.fit` call below replace `fraction_of_data` /
            #   `fraction_of_data_val` with these lists.

        # length strategies is a trick from NODE literature to initialize the model on shorter time frames
        length_strategies = [
            (0.1, 5000, EarlyStopper(20, 5e-6, metric_name=early_stop_metric_name), 1e-4),
            (0.3, 5000, EarlyStopper(20, 5e-6, metric_name=early_stop_metric_name), 1e-4),
            (0.5, 3000, EarlyStopper(20, 5e-5, metric_name=early_stop_metric_name), 1e-4),
            (0.7, 2000, EarlyStopper(20, 5e-4, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(50, 5e-4, metric_name=early_stop_metric_name), 1e-3),
            # TODO: get rid of this one when the ReduceOnPlateau lr scheduler is working
            (1.0, 1500, EarlyStopper(50, 5e-4, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(50, 5e-4, metric_name=early_stop_metric_name), 1e-5),
            (1.0, 5000, EarlyStopper(50, 5e-3, metric_name=early_stop_metric_name), 1e-7),
        ]

        for len_strat in length_strategies:
            print("running length strategy", len_strat)
            data_fraction, epochs, early_stopper, learning_rate = len_strat
            # update the training configuration for the new length strategy
            node.training_configuration = TrainingConfiguration(
                n_epochs=epochs,
                optimizer=AdamOptimizer(learning_rate=learning_rate),
                # optimizer=ReduceLROnPlateauConfiguration("loss").create_from_optimizer(
                #     torch.optim.Adam(node.parameters(), learning_rate)
                # ),
                # optimizer=torch.optim.lr_scheduler.ReduceLROnPlateau(
                #     torch.optim.Adam(node.parameters(), learning_rate)
                # ),
                batch_size=batch_size,
                num_workers=2,  # is this the parallel control? cpu_count()//2?
                verbose=True,
            )

            # manually re-initialize some of the neural_ode object things. copied from NODEPredictor.__init__
            # Parse parameters from the training configuration.
            node.optimizer_config = node.training_configuration.optimizer
            node.n_epochs = node.training_configuration.get_param(TrainingParam.N_EPOCHS)

            # Set the iteration parameter for required optimizers.
            node.training_metrics = {}

            # Setup the model for training and inference.
            node._initialize_optimizer()

            # reset the early stop check
            node.early_stopper = early_stopper
            # node.early_stopper = None

            min_states = 5
            if math.ceil(scaled_traj_targets_train_posvel[0].shape[0] * data_fraction) < min_states:
                print("length strategy results in too few states. overriding to maintain stability")
            if model_type == "latentode":
                # each element is a tuple (obs_window, target)
                fraction_of_data = [
                    (
                        obs[: max(math.ceil(obs.shape[0] * data_fraction), min_states)],  # obs_window
                        tgt[: max(math.ceil(tgt.shape[0] * data_fraction), min_states)],
                    )  # target
                    for (obs, tgt) in train_data
                ]
                fraction_of_data_val = [
                    (
                        obs[: max(math.ceil(obs.shape[0] * data_fraction), min_states)],
                        tgt[: max(math.ceil(tgt.shape[0] * data_fraction), min_states)],
                    )
                    for (obs, tgt) in test_data
                ]
            else:
                # existing behaviour (plain NODE/ANODE/SONODE)
                fraction_of_data = [
                    x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :]
                    for x in scaled_traj_targets_train_posvel
                ]
                fraction_of_data_val = [
                    x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :]
                    for x in scaled_traj_targets_test_posvel
                ]

            # torch.autograd.set_detect_anomaly(True)  # the magic command to look into the guts of torch
            metrics = node.fit(
                x=fraction_of_data,
                validation_data=fraction_of_data_val,
                # validation_data=fraction_of_data,
                enable_checkpoints=True if data_fraction == 1.0 else False,
            )
        p = Path(model_save_path, model_name + ".checkpoint.pt")
        p.rename(Path(p.parent, p.name.replace(".checkpoint", "")))

    # load the saved checkpoint model
    node.load(directory=model_save_path, model_name=model_name)

    # disable training mode on the model
    node.model.train(False)
    node.model.eval()

    # TODO: move this conversion to a separate script
    # export the model to ONNX binary (protobuf) format
    #
    # For GRU-ODE we export through GRUODEFieldForONNX, which exposes the induced
    # physical-space field ẋ = f(x) WITHOUT any autograd JVP (it uses a central
    # finite difference through the decoder). This is required because the
    # torch.export-based ONNX exporter cannot trace autograd.functional.jvp /
    # torch.func.jvp (it fails with "unbacked symbol" AssertionErrors). The
    # adapter takes a single tensor and returns the physical derivative, the
    # same contract the sim and other NODE exports use.
    #
    # Unwrap torch.compile (if enabled) to get the raw module before export.
    raw_model = getattr(node.model, "_orig_mod", node.model)
    if isinstance(raw_model, GRUODELatentModel):
        # Pull the second-order config (and its scaled-space correction stats)
        # off the constructed model so this works regardless of whether the
        # model was just built or loaded from disk, and regardless of the local
        # pos_idx/vel_idx scope.
        if getattr(raw_model, "second_order", False):
            _pos_idx = raw_model.pos_idx.tolist()
            _vel_idx = raw_model.vel_idx.tolist()
            _pos_scale = raw_model.so_ratio is not None and getattr(raw_model, "scaled_space", False)
            if getattr(raw_model, "scaled_space", False):
                # reconstruct the per-block sigma/mu the adapter needs from the
                # ratio/offset buffers is lossy; instead re-derive from scaler.
                _ps = scaler_traj.scale_[_pos_idx] if isinstance(scaler_traj, StandardScaler) else None
                _vs = scaler_traj.scale_[_vel_idx] if isinstance(scaler_traj, StandardScaler) else None
                _vm = scaler_traj.mean_[_vel_idx] if isinstance(scaler_traj, StandardScaler) else None
            else:
                _ps = _vs = _vm = None
        else:
            _pos_idx = _vel_idx = None
            _ps = _vs = _vm = None
        export_model = GRUODEFieldForONNX(
            raw_model.func, state_vector_len=model_states, aug_dim=aug_dim,
            pos_idx=_pos_idx, vel_idx=_vel_idx,
            pos_scale=_ps, vel_scale=_vs, vel_mean=_vm,
        ).to(node.device).eval()
        example_input = torch.cat(
            (scaled_traj_targets_train_posvel[0][0], torch.zeros(aug_dim))
        ).to(node.device)
    elif isinstance(ode_solver, TorchdiffeqSolver):
        export_model = node.model
        example_input = (
            None,
            torch.cat((scaled_traj_targets_train_posvel[0][0], torch.zeros(aug_dim))).to(node.device),
        )
    else:
        export_model = node.model
        example_input = torch.cat((scaled_traj_targets_train_posvel[0][0], torch.zeros(aug_dim))).to(node.device)
    model_onx = torch.onnx.export(
        export_model,
        example_input,
        os.path.join(model_save_path, model_name + ".onnx"),
        export_params=True,
        opset_version=18,  # 18 is the max we can go do right now. 17 is max w/o dynamo. https://onnxruntime.ai/docs/reference/compatibility.html#onnx-opset-support
        external_data=False,
        input_names=["input"],
        output_names=["output"],
        # dynamo=False,
    )

    # export the model to ONNX plain text format
    with open(
        os.path.join(model_save_path, model_name + "_plain.onnx"),
        "w",
    ) as f:
        f.write(onnx.printer.to_text(model_onx.model_proto))  # This is plain text

    # export the scalar to ONNX format
    # NOTE: slk2onnx does not support the inverse transform call that NEXT needs
    # onx = to_onnx(
    #     scaler_traj,
    #     traj_targets_train[0].numpy(),
    #     target_opset=18,
    # )
    # print(type(onx))
    # with open(
    #     os.path.join(model_save_path, model_name + "_scalar.onnx"),
    #     "wb",
    # ) as f:
    #     f.write(onx.SerializeToString())  # This is a protobuf format
    # with open(
    #     os.path.join(model_save_path, model_name + "_scalar_plain.onnx"),
    #     "w",
    # ) as f:
    #     f.write(onnx.printer.to_text(onx))  # This is plain text

    # save a protobuf text file of the scalar
    if isinstance(scaler_traj, MinMaxScaler):
        min_input = scaler_traj.min_
        scale_input = scaler_traj.scale_
        data_min_input = scaler_traj.data_min_
        data_max_input = scaler_traj.data_max_

        with open(
            os.path.join(
                model_save_path,
                f"{model_name}_scalar_params_and_test_inputs.txt",
            ),
            "w",
            encoding="utf-8",
        ) as f:
            for m, s, dmin, dmax in zip(min_input, scale_input, data_min_input, data_max_input):
                f.write(f"""InputScaleFactorsMinMaxScaler
{{
\tMin: {m}
\tScale: {s}
\tDataMin: {dmin}
\tDataMax: {dmax}
}}""")
    elif isinstance(scaler_traj, StandardScaler):
        scale_input = scaler_traj.scale_
        mean_input = scaler_traj.mean_
        var_input = scaler_traj.var_

        with open(
            os.path.join(
                model_save_path,
                f"{model_name}_scalar_params_and_test_inputs.txt",
            ),
            "w",
            encoding="utf-8",
        ) as f:
            for s, m, v in zip(scale_input, mean_input, var_input):
                f.write(f"""InputScaleFactorsStandardScaler
{{
\tScale: {s}
\tMean: {m}
\tVariance: {v}
}}""")
    return node, model_name


def prep_trajectory(x):
    # load_single_truth(x, debug=False), x.name, args.sr, path
    ecef_data, traj_number, max_sr, trajectory_dt, args = x
    # keep time, pos, vel. don't need the rest of the columns
    ecef_data = ecef_data[:, 0:7]
    print("prepping traj", traj_number)
    ref_ecef = deepcopy(ecef_data[-1, POS_SLICE])

    # remove launch point based on near zero speed state
    # while np.all(np.isclose(np.linalg.norm(ecef_data[0, VEL_SLICE]), 0)):
    while np.any(np.isclose(ecef_data[0, VEL_SLICE], 0)):
        ecef_data = ecef_data[1:]

   
    sr_ecef_data = np.asarray(
        tuple(x for x in ecef_data if np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) < max_sr),
        # tuple(x for x in ecef_data if 2500e3 < np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) < max_sr),
        dtype=np.float64,
    )
    # TODO: add a min slant range to avoid the origin discontinuity
    # sr_ecef_data = np.asarray(
    #     tuple(x for x in ecef_data if np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) > 1000),
    #     dtype=np.float64,
    # )

    # nice idea, but it wasn't the source of the problem
    # filter the points by only those above the horizon. Work from impact backwards.
    # def while_gen_backward_up(data):
    #     for x in reversed(data):
    #         if ecef_to_ned(x[POS_SLICE], ref_ecef)[2] <= 0:
    #             yield x
    #         else:
    #             break

    # sr_ecef_data = np.asarray(tuple(reversed(tuple(while_gen_backward_up(sr_ecef_data)))))

    # TODO: move this to a trajectory time check helper function file
    # check the time rate of the data
    # diff the time column, run unique, print that if there is more than 1 unique
    if sr_ecef_data.shape[-1] < 5:
        print(f"{traj_number} does not have enough time stamps for this slant range")
        return None, None
    time_diff = np.diff(sr_ecef_data[:, TIME_INDEX])
    unique_time_diff = np.unique(np.round(time_diff, decimals=2))
    if np.any(time_diff < 0):
        raise ValueError(
            f"warning: {traj_number} has time that goes backwards. Time diffs are {unique_time_diff}, excluding from data pool"
        )

    # TODO: this resampling needs to move into a function so it can reused
    # TODO: this needs to flip around so that the range is relative to the impact time (and flip sign again after)
    new_times = np.arange(sr_ecef_data[0, 0], sr_ecef_data[-1, 0] + trajectory_dt, trajectory_dt)

    try:
        resampled_sr_ecef_data = np.hstack(
            [np.atleast_2d(new_times).T]
            + [
                make_interp_spline(
                    sr_ecef_data[:, 0],
                    sr_ecef_data[:, 1:],
                    bc_type="not-a-knot",
                )(new_times, extrapolate=True)
            ]
        )
        # for when resampling of the truth data is not desired
        # resampled_sr_ecef_data = sr_ecef_data
    except Exception as e:
        print(f"warning: {traj_number} had the error with interpolation")
        raise e

    if args.frame == "grdth":
        # convert ecef truth to the training frame
        next_frame_data, initial_point_heading = ecef_to_next_grdth(resampled_sr_ecef_data, ref_ecef)

        # check the inverse transform
        check_ecef = next_grdth_to_ecef(next_frame_data, ref_ecef, initial_point_heading)
    elif args.frame == "geodesic":
        # convert to geodesic frame relative to the impact point
        next_frame_data = ecef_to_local_geodesic_vec(
            resampled_sr_ecef_data[:, POS_SLICE],
            resampled_sr_ecef_data[:, VEL_SLICE],
            np.zeros_like(
                resampled_sr_ecef_data[:, VEL_SLICE]
            ),  # TODO: better handling of acceleration being in the transform functions
            ref_ecef,
        )
        # Prepend time and only include pos and vel
        next_frame_data = np.hstack([resampled_sr_ecef_data[:, TIME_INDEX][..., np.newaxis], next_frame_data[:, :6]])
        
    elif args.frame == "dcu":
        # convert ecef truth to the training frame
        next_frame_data, initial_point_heading, flip_c = ecef_to_next_dcu(resampled_sr_ecef_data, ref_ecef)

        # check the inverse transform
        check_ecef = next_dcu_to_ecef(next_frame_data, ref_ecef, initial_point_heading, flip_c)
    else:
        raise NotImplementedError("That frame is not supported yet")
    # closeness_check
    # pos_err = mean_squared_error(resampled_sr_ecef_data[POS_SLICE], check_ecef[POS_SLICE])
    # vel_err = mean_squared_error(resampled_sr_ecef_data[VEL_SLICE], check_ecef[VEL_SLICE])
    # print(f"MSE round-trip position: {pos_err:.3e}")
    # print(f"MSE round-trip velocity: {vel_err:.3e}")

    # add column for traj number
    # next_frame_data = np.c_[next_frame_data, [traj_number] * next_frame_data.shape[0]]

    # add columns for ECEF reference point (12, 13, 14)
    # TODO: stop doing this to save some RAM and use a metadata attribute
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[0]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[1]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[2]]

    # if traj_number in ("traj.data.19.csv", "traj.data.11.csv"):
    #     print(next_frame_data)
    # np.savetxt(
    #     "grdth_" + traj_number,
    #     next_frame_data,
    #     delimiter=",",
    #     # header=",".join(header_row),
    #     comments="",
    #     fmt="%.8f",
    # )

    return next_frame_data, traj_number


