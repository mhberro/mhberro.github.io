class GRUODEFunc(torch.nn.Module):
    """
    ODE right‑hand side implemented with a GRU cell and Second-Order Kinematic Injection.

    The ODE state is a concatenation of:
        [physical_state (len = state_len),
         hidden_state   (len = hidden_dim),
         aug_state      (len = aug_dim, optional)]

    Enforces dx/dt = v natively via kinematic constraints, meaning the neural network 
    only has to learn unmodeled forces/accelerations.
    """

    def __init__(self, state_len: int, hidden_dim: int, aug_dim: int = 0, order_shift_slice: slice | None = None):
        super().__init__()
        self.state_len = state_len
        self.hidden_dim = hidden_dim
        self.aug_dim = aug_dim
        self.order_shift_slice = order_shift_slice
        
        # Calculate how many dimensions represent known velocity states
        self.len_of_order_shift_slice = 0
        if self.order_shift_slice is not None:
            order_indices = tuple(range(*self.order_shift_slice.indices(state_len)))
            self.len_of_order_shift_slice = len(order_indices)

        # The GRU cell receives the entire physical state (+ optional augmentation vector)
        input_dim = state_len + aug_dim
        self.gru = torch.nn.GRUCell(input_dim, hidden_dim)

        # SHRINKAGE: Map hidden state ONLY to the unconstrained physical derivatives 
        # (e.g., 3 acceleration dimensions instead of all 6 state dimensions) + aug_dim
        neural_output_dim = state_len - self.len_of_order_shift_slice
        self.to_dx = torch.nn.Linear(hidden_dim, neural_output_dim + aug_dim)

        # Diagnostic step counter
        self.nfe = 0

    def forward(self, t, state):
        """
        Parameters
        ----------
        t : torch scalar (ignored – required by torchdiffeq)
        state : tensor of shape (..., state_len + hidden_dim + aug_dim)
        """
        self.nfe += 1

        # 1. Split the concatenated tracking state
        aug_start = self.state_len + self.hidden_dim
        x   = state[..., :self.state_len]                                 # Physical kinematic states
        h   = state[..., self.state_len:aug_start]                        # GRU hidden memory state
        aug = state[..., aug_start:] if self.aug_dim > 0 else None        # Hidden augmentation space

        # 2. Evolve hidden states continuously
        gru_input = x if aug is None else torch.cat([x, aug], dim=-1)
        
        # Reshape wrapper handles multi-dimensional batch configurations during validation matching
        h_shape = h.shape
        h_next = self.gru(gru_input.view(-1, gru_input.shape[-1]), h.view(-1, h.shape[-1]))
        h_next = h_next.view(h_shape)
        
        # Continuous-time hidden state update rule
        dh_dt = h_next - h 

        # 3. Evaluate physical system updates with Kinematic Injection
        neural_out = self.to_dx(h_next)
        
        if self.order_shift_slice is not None:
            # Extract incoming tracker velocity vectors directly from input telemetry (bypasses neural estimation)
            v_telemetry = torch.narrow(x, dim=-1, start=self.order_shift_slice.start, length=self.len_of_order_shift_slice)
            
            # Extract predicted accelerations from the network output
            acc_neural = neural_out[..., :self.state_len - self.len_of_order_shift_slice]
            
            # Concatenate: [v_telemetry, acc_neural] -> Perfect [vx, vy, vz, ax, ay, az] mapping
            dx_dt = torch.cat((v_telemetry, acc_neural), dim=-1)
        else:
            dx_dt = neural_out[..., :self.state_len]

        # 4. Construct final joint derivative state vector
        if self.aug_dim > 0:
            daug_dt = neural_out[..., -self.aug_dim:]
            dstate = torch.cat([dx_dt, dh_dt, daug_dt], dim=-1)
        else:
            dstate = torch.cat([dx_dt, dh_dt], dim=-1)

        return dstate

