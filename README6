class TrueKinematicGRUODEFunc(torch.nn.Module):
    """
    Optimized, Continuous-Time Recurrent Trajectory Vector Field.
    Fixes the dh_dt = 0 freeze bug, introduces Physics-Informed Second-Order Kinematic
    Injection adjusted for normalized scale grids, and eliminates Torch Dynamo 
    recompilation loops using persistent tensor metrics tracking buffers.
    """
    def __init__(self, state_len: int, hidden_dim: int, aug_dim: int = 0, scaler=None):
        super().__init__()
        self.state_len = state_len
        self.hidden_dim = hidden_dim
        self.aug_dim = aug_dim
        
        # Isolate kinematic mapping coordinates based on active state definitions
        if state_len == 6:
            self.pos_indices = [0, 1, 2] # DCU / Geodesic Positions
            self.vel_indices = [3, 4, 5] # DCU / Geodesic Velocities
        elif state_len == 5:
            self.pos_indices = [0, 1]    # Gridith Framework Positions (GR, Down)
            self.vel_indices = [2, 3]    # Gridith Framework Velocities (dotGR, dotDown)
        else:
            pos_dim = state_len // 2
            self.pos_indices = list(range(pos_dim))
            self.vel_indices = list(range(pos_dim, 2 * pos_dim))

        scale_p = torch.ones(len(self.pos_indices), dtype=torch.float32)
        scale_v = torch.ones(len(self.pos_indices), dtype=torch.float32)
        shift_v = torch.zeros(len(self.pos_indices), dtype=torch.float32)
        self.is_minmax = False

        if scaler is not None:
            if isinstance(scaler, StandardScaler):
                scale_p = torch.tensor(scaler.scale_[self.pos_indices], dtype=torch.float32)
                scale_v = torch.tensor(scaler.scale_[self.vel_indices], dtype=torch.float32)
                shift_v = torch.tensor(scaler.mean_[self.vel_indices], dtype=torch.float32)
                self.is_minmax = False
            elif isinstance(scaler, MinMaxScaler):
                scale_p = torch.tensor(scaler.scale_[self.pos_indices], dtype=torch.float32)
                scale_v = torch.tensor(scaler.scale_[self.vel_indices], dtype=torch.float32)
                shift_v = torch.tensor(scaler.min_[self.vel_indices], dtype=torch.float32)
                self.is_minmax = True

        # Register scaling constants and diagnostic monitors as persistent parameters
        self.register_buffer('scale_p', scale_p)
        self.register_buffer('scale_v', scale_v)
        self.register_buffer('shift_v', shift_v)
        self.register_buffer('nfe_buffer', torch.tensor(0, dtype=torch.int64))

        total_input_dim = state_len + hidden_dim + aug_dim
        
        self.hidden_derivative_net = torch.nn.Sequential(
            torch.nn.Linear(total_input_dim, hidden_dim),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden_dim, hidden_dim),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden_dim, hidden_dim)
        )
        
        self.acceleration_net = torch.nn.Sequential(
            torch.nn.Linear(total_input_dim, hidden_dim),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden_dim, state_len - len(self.pos_indices))
        )

    @property
    def nfe(self):
        return self.nfe_buffer.item()

    @nfe.setter
    def nfe(self, val):
        self.nfe_buffer.fill_(val)

    def forward(self, t, state):
        self.nfe_buffer.add_(1)
        aug_start = self.state_len + self.hidden_dim

        x = state[..., :self.state_len]
        h = state[..., self.state_len:aug_start]
        aug = state[..., aug_start:] if self.aug_dim > 0 else None

        vel_components = x[..., self.vel_indices]
        
        # Enforce exact, scaler-adjusted Newtonian transitions to align position/velocity loss metrics
        if self.is_minmax:
            dpos_dt = (self.scale_p / self.scale_v) * (vel_components - self.shift_v)
        else:
            dpos_dt = (self.scale_v / self.scale_p) * vel_components + (self.shift_v / self.scale_p)

        dh_dt = self.hidden_derivative_net(state)
        dvel_dt = self.acceleration_net(state)
        
        dx_dt = torch.cat([dpos_dt, dvel_dt], dim=-1)

        if self.aug_dim > 0:
            daug_dt = torch.zeros_like(aug)
            return torch.cat([dx_dt, dh_dt, daug_dt], dim=-1)
        
        return torch.cat([dx_dt, dh_dt], dim=-1)

    
class GRUODEArchitecture:
    """
    Wrapper class mapping the continuous recurrent sequence tracker variables
    directly into NODEPredictor initialization channels.
    """
    def __init__(self, state_len: int, hidden_dim: int = 128, aug_dim: int = 0, scaler=None):
        self.state_len  = state_len
        self.hidden_dim = hidden_dim
        self.aug_dim    = aug_dim
        self.scaler     = scaler

    def get_model(self) -> torch.nn.Module:
        return TrueKinematicGRUODEFunc(
            state_len=self.state_len,
            hidden_dim=self.hidden_dim,
            aug_dim=self.aug_dim,
            scaler=self.scaler
        )

    def get_input_dim(self) -> int: return self.state_len
    def get_output_dim(self) -> int: return self.state_len
    def get_aug_dim(self) -> int: return self.aug_dim
    def get_hidden_dim(self) -> int: return self.hidden_dim


class ODEfunc(torch.nn.Module):
    def __init__(self, state_vector_len: int, nhidden: int, aug_dim: int = 0, order_shift_slice: slice | None = None):
        super(ODEfunc, self).__init__()
        self.order_shift_slice = order_shift_slice
        self.len_of_order_shift_slice = 0
        if self.order_shift_slice is not None:
            order_indicies = tuple(range(*self.order_shift_slice.indices(state_vector_len)))
            self.len_of_order_shift_slice = len(order_indicies)
        self.act1 = torch.nn.SiLU(inplace=False)
        self.act2 = torch.nn.SiLU(inplace=False)
        self.fc1 = torch.nn.Linear(state_vector_len + aug_dim, nhidden)
        self.fc2 = torch.nn.Linear(nhidden, nhidden)
        self.fc4 = torch.nn.Linear(nhidden, (state_vector_len - self.len_of_order_shift_slice) + aug_dim)
        self.nfe = 0

    def forward(self, t, x: torch.Tensor) -> torch.Tensor:
        if self.order_shift_slice is not None:
            v = torch.narrow(x, dim=-1, start=self.order_shift_slice.start, length=self.len_of_order_shift_slice)
        self.nfe += 1
        out = self.fc1(x)
        out = self.act1(out)
        out = self.fc2(out)
        out = self.act2(out)
        out = self.fc4(out)
        if self.order_shift_slice is not None:
            return torch.cat((v, out), dim=x.ndim - 1)
        else:
            return out


class Normaliser(torch.nn.Module):
    def __init__(self, scaler):
        super().__init__()
        self.mean = torch.nn.Parameter(torch.tensor(scaler.mean_, dtype=torch.float32), requires_grad=False)
        self.scale = torch.nn.Parameter(torch.tensor(scaler.scale_, dtype=torch.float32), requires_grad=False)

    def forward(self, x): return (x - self.mean) / self.scale
    def inverse(self, z): return z * self.scale + self.mean


class Encoder(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.rnn = torch.nn.GRU(input_size=6, hidden_size=hidden, batch_first=True, num_layers=1)
        self.mu_head = torch.nn.Linear(hidden, latent_dim)
        self.logvar_head = torch.nn.Linear(hidden, latent_dim)

    def forward(self, x):
        _, h_n = self.rnn(x)
        h = h_n.squeeze(0)
        mu = self.mu_head(h)
        logvar = self.logvar_head(h)
        return mu, logvar


class LatentODEFunc(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.net = torch.nn.Sequential(
            torch.nn.Linear(latent_dim, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, latent_dim),
        )

    def forward(self, t, z): return self.net(z)


class Decoder(torch.nn.Module):
    def __init__(self, latent_dim=8, hidden=128):
        super().__init__()
        self.net = torch.nn.Sequential(
            torch.nn.Linear(latent_dim, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, hidden),
            torch.nn.SiLU(),
            torch.nn.Linear(hidden, 6),
        )

    def forward(self, z): return self.net(z)


from torchdiffeq import odeint_adjoint

class LatentNODE(torch.nn.Module):
    def __init__(self, latent_dim=8):
        super().__init__()
        self.encoder = Encoder(latent_dim)
        self.odefunc = LatentODEFunc(latent_dim)
        self.decoder = Decoder(latent_dim)

    def forward(self, obs_window_and_times: tuple[torch.Tensor, torch.Tensor]):
        obs_window, t_eval = obs_window_and_times
        mu, logvar = self.encoder(obs_window)
        std = torch.exp(0.5 * logvar)
        eps = torch.randn_like(std)
        z0 = mu + eps * std
        z_t = odeint_adjoint(self.odefunc, z0, t_eval, atol=1e-5, rtol=1e-5)
        z_t = z_t.permute(1, 0, 2)
        recon = self.decoder(z_t)
        return recon, mu, logvar


def _kl_divergence(mu: torch.Tensor, logvar: torch.Tensor) -> torch.Tensor:
    return 0.5 * torch.mean(torch.sum(1 + logvar - mu.pow(2) - torch.exp(logvar), dim=1))


def _make_obs_target(traj: torch.Tensor, obs_len: int = 10) -> tuple[torch.Tensor, torch.Tensor]:
    assert traj.shape[0] > obs_len, "trajectory shorter than observation window"
    obs_window = traj[:obs_len].unsqueeze(0)
    target = traj.unsqueeze(0)
    return obs_window, target


def train_NEXT(
    model_name,
    traj_targets_train,
    traj_targets_test,
    scaler_traj,
    model_save_path,
    trajectory_dt,
    batch_size,
    use_scalar,
    model_states,
    aug_dim,
    nhidden,
    gpu_index,
    model_type: str = "node",
    frame: str = "dcu",
):
    # --------------------------------------------------------------------
    # MPS Optimization Matrix: Sanitize float64 Scaler Metrics to float32
    # --------------------------------------------------------------------
    if scaler_traj is not None:
        scaler_attrs = ['mean_', 'scale_', 'var_', 'min_', 'data_min_', 'data_max_']
        for attr in scaler_attrs:
            if hasattr(scaler_traj, attr) and getattr(scaler_traj, attr) is not None:
                setattr(scaler_traj, attr, getattr(scaler_traj, attr).astype(np.float32))

    training_configuration = TrainingConfiguration(
        n_epochs=1,
        optimizer=AdamOptimizer(learning_rate=1e-3),
        batch_size=batch_size,
        num_workers=100,
        verbose=True,
    )
    ode_solver = TorchdiffeqSolver(dt=trajectory_dt, method="rk4", adjoint=False)

    if frame in ("dcu", "geodesic"):
        velocity_indicies = (3, 4, 5)
    elif frame in ("grdth",):
        velocity_indicies = (2, 3, 4)
    else:
        raise ValueError("That frame is not known for what the velocity indicies are")
        
    early_stop_metric_name = "val_loss"
    loss_func = WrappedMSELoss(
        height_idx=1,
        vel_indices=velocity_indicies,
        scaler=scaler_traj if use_scalar else None,
        N_FEATURES=model_states,
    )

    # Calculate expanded solver metrics tracking footprint for hidden sequences
    total_solver_aug = aug_dim + nhidden if model_type == "gruode" else aug_dim

    node = NODEPredictor(
        architecture=GRUODEArchitecture(
            state_len=model_states,
            hidden_dim=nhidden,
            aug_dim=aug_dim,
            scaler=scaler_traj if use_scalar else None
        ),
        training_configuration=training_configuration,
        solver=ode_solver,
        logging_interval=5,
        loss_func=loss_func,
        early_stopper=EarlyStopper(10, 0.5, metric_name=early_stop_metric_name),
        checkpoint=ModelCheckpoint(min_epochs=1, directory=model_save_path, model_name=model_name + ".checkpoint"),
        aug_dim=total_solver_aug,
    )

    # Establish localized target run-time platform configurations
    if DEVICE_TYPE == "cuda":
        node.device = torch.device(f"cuda:{gpu_index}")
    elif DEVICE_TYPE == "mps":
        node.device = torch.device("mps")
    else:
        node.device = torch.device("cpu")

    node._initialize_losses(node.criterion)
    node._initialize_model()
    node._initialize_optimizer()

    # --------------------------------------------------------------------
    #  Build the requested model
    # --------------------------------------------------------------------
    if model_type == "gruode":
        print("Activating Continuous-Time Physics-Informed GRU-ODE Tracking Module.")
        node.model = node.architecture.get_model().to(node.device)
    elif model_type == "node":
        node.model = ODEfunc(state_vector_len=model_states, nhidden=nhidden, aug_dim=0, order_shift_slice=None).to(node.device)
    elif model_type == "anode":
        node.model = ODEfunc(state_vector_len=model_states, nhidden=nhidden, aug_dim=aug_dim, order_shift_slice=None).to(node.device)
    elif model_type == "sonode":
        node.model = ODEfunc(state_vector_len=model_states, nhidden=nhidden, aug_dim=0, order_shift_slice=slice(3, 6)).to(node.device)
    elif model_type == "latentode":
        latent_dim = nhidden // 2 if nhidden >= 20 else 8
        node.model = LatentNODE(latent_dim=latent_dim).to(node.device)
        recon_criterion = WrappedMSELoss(height_idx=1, vel_indices=[3, 4, 5], scaler=scaler_traj if use_scalar else None, N_FEATURES=model_states)

        def latent_ode_loss_fn(recon, target, mu, logvar):
            recon_loss = recon_criterion(recon, target)
            kl = _kl_divergence(mu, logvar)
            return recon_loss + 0.1 * kl

        node.loss_func = lambda pred, true: latent_ode_loss_fn(pred[0], true, pred[1], pred[2])
    else:
        raise ValueError(f"Unsupported model_type: {model_type}")

    # Trace compiled execution graphs exclusively on enterprise CUDA clusters
    if DEVICE_TYPE == "cuda":
        try:
            node.model = torch.compile(node.model)
            print("Successfully JIT-compiled the trajectory vector field execution graph.")
        except Exception as e:
            print(f"Skipping graph compilation: {e}")

    if use_scalar:
        scaled_traj_targets_train_posvel = [torch.tensor(scaler_traj.transform(i[:, 0 : model_states + 1]), dtype=torch.float32).to(node.device) for i in traj_targets_train]
        scaled_traj_targets_test_posvel = [torch.tensor(scaler_traj.transform(i[:, 0 : model_states + 1]), dtype=torch.float32).to(node.device) for i in traj_targets_test]
    else:
        scaled_traj_targets_train_posvel = [torch.tensor(i[:, 0 : model_states + 1], dtype=torch.float32).to(node.device) for i in traj_targets_train]
        scaled_traj_targets_test_posvel = [torch.tensor(i[:, 0 : model_states + 1], dtype=torch.float32).to(node.device) for i in traj_targets_test]
        
    gen_model = False
    try:
        node.load(directory=model_save_path, model_name=model_name)
    except ValueError:
        gen_model = True
        pass

    if gen_model:
        if model_type == "latentode":
            OBS_WINDOW = 10
            train_data = [_make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_train_posvel]
            test_data = [_make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_test_posvel]

        length_strategies = [
            (0.1, 5000, EarlyStopper(20, 5e-6, metric_name=early_stop_metric_name), 1e-4),
            (0.3, 5000, EarlyStopper(20, 5e-6, metric_name=early_stop_metric_name), 1e-4),
            (0.5, 3000, EarlyStopper(20, 5e-5, metric_name=early_stop_metric_name), 1e-4),
            (0.7, 2000, EarlyStopper(20, 5e-4, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(50, 5e-4, metric_name=early_stop_metric_name), 1e-3),
            (1.0, 1500, EarlyStopper(50, 5e-4, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(50, 5e-4, metric_name=early_stop_metric_name), 1e-5),
            (1.0, 5000, EarlyStopper(50, 5e-3, metric_name=early_stop_metric_name), 1e-7),
        ]

        for len_strat in length_strategies:
            print("running length strategy", len_strat)
            data_fraction, epochs, early_stopper, learning_rate = len_strat
            node.training_configuration = TrainingConfiguration(
                n_epochs=epochs,
                optimizer=AdamOptimizer(learning_rate=learning_rate),
                batch_size=batch_size,
                num_workers=2,
                verbose=True,
            )

            node.optimizer_config = node.training_configuration.optimizer
            node.n_epochs = node.training_configuration.get_param(TrainingParam.N_EPOCHS)
            node.training_metrics = {}
            node._initialize_optimizer()
            node.early_stopper = early_stopper

            min_states = 5
            if math.ceil(scaled_traj_targets_train_posvel[0].shape[0] * data_fraction) < min_states:
                print("length strategy results in too few states. overriding to maintain stability")
            if model_type == "latentode":
                fraction_of_data = [(obs[: max(math.ceil(obs.shape[0] * data_fraction), min_states)], tgt[: max(math.ceil(tgt.shape[0] * data_fraction), min_states)]) for (obs, tgt) in train_data]
                fraction_of_data_val = [(obs[: max(math.ceil(obs.shape[0] * data_fraction), min_states)], tgt[: max(math.ceil(tgt.shape[0] * data_fraction), min_states)]) for (obs, tgt) in test_data]
            else:
                fraction_of_data = [x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :] for x in scaled_traj_targets_train_posvel]
                fraction_of_data_val = [x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :] for x in scaled_traj_targets_test_posvel]

            metrics = node.fit(x=fraction_of_data, validation_data=fraction_of_data_val, enable_checkpoints=True if data_fraction == 1.0 else False)
            
        p = Path(model_save_path, model_name + ".checkpoint.pt")
        p.rename(Path(p.parent, p.name.replace(".checkpoint", "")))

    node.load(directory=model_save_path, model_name=model_name)
    node.model.train(False)
    node.model.eval()

    example_input = torch.cat((scaled_traj_targets_train_posvel[0][0], torch.zeros(node.aug_dim, device=node.device))).to(node.device)
    if isinstance(ode_solver, TorchdiffeqSolver):
        example_input = (None, example_input)
        
    model_onx = torch.onnx.export(
        node.model,
        example_input,
        os.path.join(model_save_path, model_name + ".onnx"),
        export_params=True,
        opset_version=18,
        external_data=False,
        input_names=["input"],
        output_names=["output"],
    )

    with open(os.path.join(model_save_path, model_name + "_plain.onnx"), "w") as f:
        f.write(onnx.printer.to_text(model_onx.model_proto))

    if isinstance(scaler_traj, MinMaxScaler):
        min_input = scaler_traj.min_
        scale_input = scaler_traj.scale_
        data_min_input = scaler_traj.data_min_
        data_max_input = scaler_traj.data_max_

        with open(os.path.join(model_save_path, f"{model_name}_scalar_params_and_test_inputs.txt"), "w", encoding="utf-8") as f:
            for m, s, dmin, dmax in zip(min_input, scale_input, data_min_input, data_max_input):
                f.write(f"InputScaleFactorsMinMaxScaler\n{{\n\tMin: {m}\n\tScale: {s}\n\tDataMin: {dmin}\n\tDataMax: {dmax}\n}}\n")
    elif isinstance(scaler_traj, StandardScaler):
        scale_input = scaler_traj.scale_
        mean_input = scaler_traj.mean_
        var_input = scaler_traj.var_

        with open(os.path.join(model_save_path, f"{model_name}_scalar_params_and_test_inputs.txt"), "w", encoding="utf-8") as f:
            for s, m, v in zip(scale_input, mean_input, var_input):
                f.write(f"InputScaleFactorsStandardScaler\n{{\n\tScale: {s}\n\tMean: {m}\n\tVariance: {v}\n}}\n")
    return node, model_name


def prep_trajectory(x):
    ecef_data, traj_number, max_sr, trajectory_dt, args = x
    ecef_data = ecef_data[:, 0:7]
    print("prepping traj", traj_number)
    ref_ecef = deepcopy(ecef_data[-1, POS_SLICE])

    while np.any(np.isclose(ecef_data[0, VEL_SLICE], 0)):
        ecef_data = ecef_data[1:]

    end_of_launch_index = 62
    sbi_target_name = "LowE_555063a9_HGV"

    sr_ecef_data = np.asarray(
        tuple(x for x in ecef_data if np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) < max_sr),
        dtype=np.float64,
    )

    if sr_ecef_data.shape[-1] < 5:
        print(f"{traj_number} does not have enough time stamps for this slant range")
        return None, None
    time_diff = np.diff(sr_ecef_data[:, TIME_INDEX])
    unique_time_diff = np.unique(np.round(time_diff, decimals=2))
    if np.any(time_diff < 0):
        raise ValueError(f"warning: {traj_number} has time that goes backwards.")

    new_times = np.arange(sr_ecef_data[0, 0], sr_ecef_data[-1, 0] + trajectory_dt, trajectory_dt)

    try:
        resampled_sr_ecef_data = np.hstack(
            [np.atleast_2d(new_times).T]
            + [make_interp_spline(sr_ecef_data[:, 0], sr_ecef_data[:, 1:], bc_type="not-a-knot")(new_times, extrapolate=True)]
        )
    except Exception as e:
        print(f"warning: {traj_number} had the error with interpolation")
        raise e

    if args.frame == "grdth":
        next_frame_data, initial_point_heading = ecef_to_next_grdth(resampled_sr_ecef_data, ref_ecef)
    elif args.frame == "geodesic":
        next_frame_data = ecef_to_local_geodesic_vec(resampled_sr_ecef_data[:, POS_SLICE], resampled_sr_ecef_data[:, VEL_SLICE], np.zeros_like(resampled_sr_ecef_data[:, VEL_SLICE]), ref_ecef)
        next_frame_data = np.hstack([resampled_sr_ecef_data[:, TIME_INDEX][..., np.newaxis], next_frame_data[:, :6]])
    elif args.frame == "dcu":
        next_frame_data, initial_point_heading, flip_c = ecef_to_next_dcu(resampled_sr_ecef_data, ref_ecef)
    else:
        raise NotImplementedError("That frame is not supported yet")

    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[0]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[1]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[2]]

    return next_frame_data, traj_number


def load_data_dir(path: str, trajectory_dt: float, args, do_prep: bool = True):
    boost_ecef = []
    glide_ecef = []
    impact_ecef = []
    target_path = Path(path)
    for phase in ["boost", "glide", "impact"]:
        phase_path = target_path / phase
        traj_files = [Path(phase_path, x) for x in sorted(os.listdir(phase_path))]

        if len(traj_files) == 0:
            raise ValueError("bad target path", path)

        traj_targets = [
            load_single_truth(x, debug=False, low_memory=not HAVE_HIGH_MEMORY, memory_map=HAVE_HIGH_MEMORY, min_state_vector_size=7)
            for x in traj_files
        ]
        if phase == "boost": boost_ecef = traj_targets
        elif phase == "glide": glide_ecef = traj_targets
        elif phase == "impact": impact_ecef = traj_targets

    if not do_prep:
        return list(zip(list(zip(boost_ecef, glide_ecef, impact_ecef)), [x.name for x in traj_files]))

    cpu_count = psutil.cpu_count(logical=False)
    if cpu_count is None:
        cpu_count = mp.cpu_count()
    print(f"there are {cpu_count} cpus being used for trajectory prep")
    with mp.Pool(processes=cpu_count) as pool:
        tmp_data = pool.map(prep_trajectory, traj_targets)

    tmp_data = [x for x in tmp_data if x[0] is not None]
    return tmp_data


def create_scalar(traj_targets_train_posvel, model_save_path, model_name_wo_epochs):
    stacked_posvel = np.vstack([x.cpu().numpy() for x in traj_targets_train_posvel])
    scaler_traj = StandardScaler().fit(stacked_posvel)
    pickle_scalar_name = os.path.join(model_save_path, f"{model_name_wo_epochs}_scalar.pickle")
    with open(pickle_scalar_name, "wb") as o:
        pickle.dump(scaler_traj, o)
    return scaler_traj


def plot_column_distributions(data, bins=30, cmap="tab10", column_names=None, data_path=""):
    if data.ndim != 2: raise ValueError("`data` must be a 2-D array.")
    n_cols = data.shape[1]
    max_per_row = 5
    n_rows = int(np.ceil(n_cols / max_per_row))
    n_cols_plot = min(n_cols, max_per_row)
    fig, axes = plt.subplots(n_rows, n_cols_plot, figsize=(4 * n_cols_plot, 3 * n_rows), constrained_layout=True)
    if n_rows == 1: axes = np.expand_dims(axes, axis=0)
    colors = plt.get_cmap(cmap).colors
    for idx in range(data.shape[1]):
        row = idx // max_per_row
        col = idx % max_per_row
        ax = axes[row, col]
        ax.hist(data[:, idx], bins=bins, density=True, color=colors[idx % len(colors)], alpha=0.75, edgecolor="black")
        if column_names is None: ax.set_title(f"Column {idx}")
        else: ax.set_title(column_names[idx])
    total_plots = n_rows * n_cols_plot
    for empty_idx in range(data.shape[1], total_plots):
        row = empty_idx // max_per_row
        col = empty_idx % max_per_row
        fig.delaxes(axes[row, col])
    plt.savefig(data_path + "_feature_distribution.png")


def plot_correlation_matrix(data, method="pearson", cmap="coolwarm", column_names=None, data_path=""):
    if corr := np.corrcoef(data, rowvar=False) if method == "pearson" else scipy.stats.spearmanr(data, axis=0)[0]:
        plt.figure(figsize=(0.6 * corr.shape[0] + 2, 0.6 * corr.shape[0] + 2))
        sns.heatmap(corr, annot=True, fmt=".2f", cmap=cmap, vmin=-1, vmax=1, square=True, cbar_kws={"shrink": 0.75}, linewidths=0.5)
        labels = column_names if column_names is not None else [f"Col {i}" for i in range(corr.shape[0])]
        plt.xticks(ticks=np.arange(corr.shape[0]) + 0.5, labels=labels, rotation=0)
        plt.yticks(ticks=np.arange(corr.shape[0]) + 0.5, labels=labels, rotation=0)
        plt.tight_layout()
        plt.savefig(data_path + "_correlation_matrix.png")


def sbi_trajectory_prep(ecef_data_traj: tuple, phase_to_transform: str, trajectory_dt: float, args):
    timeseries_to_transform = ecef_data_traj[0] if phase_to_transform == "boost" else ecef_data_traj[1]
    if timeseries_to_transform.shape[0] < 10: return None
    new_times = np.arange(timeseries_to_transform[0, TIME_INDEX], timeseries_to_transform[-1, TIME_INDEX] + trajectory_dt, trajectory_dt)
    resampled_timeseries = np.hstack([np.atleast_2d(new_times).T] + [make_interp_spline(timeseries_to_transform[:, TIME_INDEX], timeseries_to_transform[:, 1:], bc_type="not-a-knot")(new_times, extrapolate=True)])
    ref_ecef = ecef_data_traj[2][-1, POS_SLICE]

    if args.frame == "dcu":
        timeseries_in_next_frame, initial_point_heading, flip_c = ecef_to_next_dcu(resampled_timeseries, ref_ecef)
    elif args.frame == "grdth":
        timeseries_in_next_frame, initial_point_heading = ecef_to_next_grdth(resampled_timeseries, ref_ecef)
    elif args.frame == "geodesic":
        timeseries_in_next_frame = ecef_to_local_geodesic_vec(resampled_timeseries[:, POS_SLICE], resampled_timeseries[:, VEL_SLICE], np.zeros_like(resampled_timeseries[:, VEL_SLICE]), ref_ecef)
        timeseries_in_next_frame = np.hstack([resampled_timeseries[:, TIME_INDEX][..., np.newaxis], timeseries_in_next_frame[:, :6]])
    else:
        raise NotImplementedError("Frame not implemented.")
    return timeseries_in_next_frame


def main():
    parser = argparse.ArgumentParser(description="Training script for creating NEXT models", formatter_class=argparse.ArgumentDefaultsHelpFormatter)
    parser.add_argument("--tgt-data-paths", default=[], type=str, nargs="+", help="Directories where training data can be found.")
    parser.add_argument("--validation-data-paths", default=[], type=str, nargs="+", help="Directories where validation data can be found.")
    parser.add_argument("--sr", default=100000, type=int, help="Maximum slant range threshold.")
    parser.add_argument("-o", default="model_outputs", type=str, help="Directory output path.")
    parser.add_argument("--use-scalar", default=False, action="store_true", help="Enable tracking normalizer scaling grids.")
    parser.add_argument("--frame", default="dcu", choices=["dcu", "grdth", "geodesic"], help="Select targeted spatial grid mapping coordinate systems.")
    parser.add_argument("--sbi-phase", default="boost", choices=["boost", "glide"], help="Target mission segment window profile choice.")
    parser.add_argument("--nhidden", default=200, type=int, help="Continuous dynamic sequence channel network parameters layer tracking dimension size.")
    parser.add_argument("--aug", default=0, type=int, help="Augmentation parameters width footprint context size.", dest="aug_dim")
    parser.add_argument("--gpuidx", default=0, type=int, help="Targeted deployment index cluster tracking layer location.", dest="gpu_index")
    parser.add_argument("--model-type", default="node", choices=["node", "anode", "sonode", "latentode", "gruode"], help="Select sequence layer architecture modules framework configuration.")
    parser.add_argument("--dt", default=0.1, type=float, help="Delta integration interval.")

    args = parser.parse_args()

    model_states = 6
    if args.frame in ("grdth",): model_states = 5

    trajectory_dt = args.dt
    seed = 47
    np.random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available(): torch.cuda.manual_seed_all(seed)

    target_strs = [Path(x).name for x in args.tgt_data_paths]
    model_name_target_str = "+".join(target_strs)
    model_path = args.o
    model_save_path = os.path.join(model_path, model_name_target_str)

    batch_size = 1024 if HAVE_HIGH_MEMORY else 512

    model_name_wo_epochs = f"NEXT_{model_name_target_str}_{args.frame}_{args.sbi_phase}_{int(args.sr / 1000)}sr_{trajectory_dt}sec_{args.nhidden}hid_{args.aug_dim}aug_{batch_size}"
    if args.use_scalar: model_name_wo_epochs = model_name_wo_epochs + "_scalarOn"
    model_name = f"{model_name_wo_epochs}"

    traj_targets_train = []
    traj_targets_test = []
    
    if len(args.validation_data_paths) == 0:
        for tgt_data_path in args.tgt_data_paths:
            traj_targets = load_data_dir(tgt_data_path, trajectory_dt, args, do_prep=False)
            traj_targets_train_one_tgt, traj_targets_test_one_tgt = train_test_split(traj_targets, test_size=0.2, random_state=26525)
            traj_targets_train.extend(traj_targets_train_one_tgt)
            traj_targets_test.extend(traj_targets_test_one_tgt)
    else:
        for tgt_data_path in args.tgt_data_paths: traj_targets_train.extend(load_data_dir(tgt_data_path, trajectory_dt, args))
        for tgt_data_path in args.validation_data_paths: traj_targets_test.extend(load_data_dir(tgt_data_path, trajectory_dt, args))

    traj_targets_train, traj_targets_train_traj_numbers = zip(*traj_targets_train)
    traj_targets_test, traj_targets_test_traj_numbers = zip(*traj_targets_test)
    
    split_dict = {"train": list(traj_targets_train_traj_numbers), "test": list(traj_targets_test_traj_numbers)}
    os.makedirs(os.path.join(model_path, model_name_target_str), exist_ok=True)
    with open(os.path.join(model_path, model_name_target_str, f"{model_name_wo_epochs}_train_test_split.json"), "w", encoding="utf-8") as f:
        json.dump(split_dict, f)

    phase_to_model = args.sbi_phase
    traj_targets_train = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_train]
    traj_targets_test = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_test]

    traj_targets_train = list(filter(lambda x: x is not None, traj_targets_train))
    traj_targets_test = list(filter(lambda x: x is not None, traj_targets_test))

    time_series_point_count = [x.shape[0] for x in traj_targets_train + traj_targets_test]
    if any(x < 10 for x in time_series_point_count): raise ValueError("Some tracking inputs have less than 10 tracking coordinates segments points.")

    # Instantiate safe, non-pinned CPU tensors first to prevent device-mismatch errors
    traj_targets_train_posvel = [torch.tensor(x[:, 1 : model_states + 1], dtype=torch.float32) for x in traj_targets_train]
    traj_targets_test_posvel = [torch.tensor(x[:, 1 : model_states + 1], dtype=torch.float32) for x in traj_targets_test]

    if any([torch.isnan(x).any() for x in traj_targets_train_posvel]) or any([torch.isnan(x).any() for x in traj_targets_test_posvel]):
        raise ValueError("NaN values detected inside targeted data matrix sequences arrays.")

    stacked_posvel = np.vstack([x.numpy() for x in traj_targets_train_posvel])
    column_names = ["GR", "Down", "dotGR", "dotD", "VTheta"] if args.frame == "grdth" else ["Down", "Cross", "Up", "dotD", "dotC", "dotU"]
    
    plot_column_distributions(stacked_posvel, column_names=column_names, data_path=str(Path(model_path, model_name_target_str, model_name_wo_epochs)))
    plot_correlation_matrix(stacked_posvel, column_names=column_names, data_path=str(Path(model_path, model_name_target_str, model_name_wo_epochs)))

    scaler_traj = create_scalar(traj_targets_train_posvel, model_save_path, model_name_wo_epochs)

    train_NEXT(
        model_name, traj_targets_train_posvel, traj_targets_test_posvel, scaler_traj, model_save_path,
        trajectory_dt, batch_size, args.use_scalar, model_states, args.aug_dim, args.nhidden,
        args.gpu_index, args.model_type, args.frame
    )


if __name__ == "__main__":
    main()
