def load_phase_guide_point(path_to_truth, truth):
    """Guide/reference point for the frame transforms.

    Training sets ref_ecef from the IMPACT phase file (ecef_data_traj[2][-1]),
    not from the end of the glide segment. The sim must use the same origin or
    the geodesic frame (s, h) and the encoder's h0 seed are computed around a
    shifted reference. Phase library layout: <target>/<phase>/<file> with a
    sibling <target>/impact/<file>. Falls back to the truth's last row if no
    impact file exists (e.g. full-trajectory files, where they coincide).
    """
    import os
    from copy import deepcopy

    from load_truth import load_single_truth
    from trajectory_helpers import POS_SLICE

    phase_dir = os.path.dirname(path_to_truth)
    target_dir = os.path.dirname(phase_dir)
    impact_path = os.path.join(target_dir, "impact", os.path.basename(path_to_truth))
    if os.path.exists(impact_path):
        try:
            impact_truth = load_single_truth(impact_path)
            return deepcopy(impact_truth[-1, POS_SLICE])
        except Exception:
            pass
    return deepcopy(truth[-1, POS_SLICE])


