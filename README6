# torchdiffeq_solver.py
"""Euler Ordinary Differential Equation Solver for NODE implementation."""

from __future__ import annotations

from typing import Callable

import torch
from prediction.mlearn.neural_ode.ode_solver import ODESolver

try:
    import torchdiffeq as tde

except ModuleNotFoundError:
    tde = None


class TorchdiffeqSolver(ODESolver):
    """ODE Solver that wraps torchdiffeq"""

    def __init__(self, dt=1, *, adjoint=False, method="dopri5", atol=1e-8, rtol=1e-6):
        super().__init__(dt, adjoint=False)
        self.method = method
        self.atol = atol
        self.rtol = rtol
        if tde is None:
            raise ImportError("Prediction Core is not able to use torchdiffeq. Please install torchdiffeq")
        self.odeint = tde.odeint
        if adjoint:
            self.odeint = tde.odeint_adjoint

    def integrate(
        self,
        func: torch.nn.Module,
        x0: torch.Tensor,
        steps: int = 1,
        extra_feat: torch.Tensor | None = None,
    ) -> torch.Tensor:
        """Solves an ODE by integrating it from the initial conditions."""
        if extra_feat is not None:
            raise Warning("Prediction Core torchdiffeq wrapper does not implement extra_feat")
        
        epsilon = 1e-10
        times = torch.arange(0, self.dt * steps + self.dt - epsilon, self.dt, dtype=torch.float64).to(x0.device)
        
        # Bugfix: explicitly forwarding error bounds down into the integration backend
        x = self.odeint(
            func,
            x0,
            times,
            method=self.method,
            atol=self.atol,
            rtol=self.rtol,
        )
        x = torch.permute(x, (1, 0, 2))  # swap axis to match PCM order

        return x

