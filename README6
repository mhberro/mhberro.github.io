def main():
    parser = argparse.ArgumentParser(description="")
    parser.add_argument(
        "truths",
        nargs="+",
        type=str,
        help="list of files to run the sim with. all output will end up in a single directory",
    )
    parser.add_argument("-o", dest="output", required=True, default=None, help="dir to place results")
    parser.add_argument("-m", dest="model", required=True, default=None, help="onnx file")
    parser.add_argument(
        "-s",
        dest="scalar",
        required=True,
        default=None,
        help="this is currently only the pickled scalar.",
    )
    parser.add_argument(
        "--sr-min",
        type=int,
        default=10000,
        help="run the sim until the target gets near this slant range",
    )
    parser.add_argument(
        "--sr-max",
        type=int,
        default=150000,
        help="start the sim no further than this slant range",
    )

    args = parser.parse_args()

    # check that the sr min and max values are reasonable
    if args.sr_min >= args.sr_max:
        raise ValueError("sr min must be less than sr max")

    # check if the model file exists
    if not os.path.exists(args.model):
        raise ValueError(f"There is no model at {args.model}")

    model_path = os.path.dirname(args.model)
    # split the file extension off of the model name
    model_name = ".".join(os.path.basename(args.model).split(".")[:-1])
    # scalar_path = args.scalar

    # check if there is a train_test split file next to the model
    # split the number of epochs off of the model name
    # model_name_wo_epoch = "_".join(model_name.split("_")[:-1])
    # model_name_wo_bucket = re.sub(r"_\d{1,3}sr_", "_", model_name)
    train_test_split_file = os.path.join(model_path, model_name + "_train_test_split.json")
    train_test_trajs = None
    if os.path.exists(train_test_split_file):
        with open(train_test_split_file) as f:
            train_test_trajs = json.load(f)

    # run sim
    sim_many_truths(args, model_name, train_test_trajs)


