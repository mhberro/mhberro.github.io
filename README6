    # TODO: make an object to hold the data and the metadata
    # Encode the geodesic sub-mode in the model name so original/integrated
    # runs don't collide on disk.
    frame_tag = args.frame
    if args.frame == "geodesic":
        frame_tag = f"geodesic-{args.geodesic_mode}"
    model_name_wo_epochs = f"NEXT_{model_name_target_str}_{frame_tag}_{args.sbi_phase}_{int(args.sr / 1000)}sr_{trajectory_dt}sec_{args.nhidden}hid_{args.aug_dim}aug_{batch_size}"
    if args.use_scalar:
        model_name_wo_epochs = model_name_wo_epochs + "_scalarOn"

    # TODO: Move the epoch name string to somewhere else after the callbacks thing
    model_name = f"{model_name_wo_epochs}"

    # load data
    traj_targets_train = []
    traj_targets_test = []
    # traj_targets = []
    if len(args.validation_data_paths) == 0:
        for tgt_data_path in args.tgt_data_paths:
            traj_targets = load_data_dir(
                tgt_data_path, trajectory_dt, args, do_prep=False
            )  # NOTE: do_prep is false for SBI support
            # this is where the test/train split has been for a while. Move it to in the train_NEXT function?
            (
                traj_targets_train_one_tgt,
                traj_targets_test_one_tgt,
            ) = train_test_split(traj_targets, test_size=0.2, random_state=26525)
            traj_targets_train.extend(traj_targets_train_one_tgt)
            traj_targets_test.extend(traj_targets_test_one_tgt)
    else:
        # the split has already been done
        print("split already done")
        for tgt_data_path in args.tgt_data_paths:
            traj_targets_train.extend(load_data_dir(tgt_data_path, trajectory_dt, args))
        for tgt_data_path in args.validation_data_paths:
            traj_targets_test.extend(load_data_dir(tgt_data_path, trajectory_dt, args))

    print(
        f"There are {len(traj_targets_train)} training trajs and {len(traj_targets_test)} validation trajs. There will be {(len(traj_targets_train) // batch_size) + 1} batch(es) for training and {(len(traj_targets_test) // batch_size) + 1} for validation"
    )

    # split the trajectory data from the metadata
    traj_targets_train, traj_targets_train_traj_numbers = zip(*traj_targets_train)
    traj_targets_test, traj_targets_test_traj_numbers = zip(*traj_targets_test)
    # create a list of all of the trajectories loaded with a notation of which side of the split they were on
    split_dict = {
        "train": traj_targets_train_traj_numbers,
        "test": traj_targets_test_traj_numbers,
    }
    os.makedirs(os.path.join(model_path, model_name_target_str), exist_ok=True)
    with open(
        os.path.join(
            model_path,
            model_name_target_str,
            f"{model_name_wo_epochs}_train_test_split.json",
        ),
        "w",
        encoding="utf-8",
    ) as f:
        json.dump(split_dict, f)

    # NOTE: For SBI, at this point in the script the traj_targets_train and traj_targets_test variables are a size 3 tuple. The tuple is boost_ecef, glide_ecef, and impact_ecef.
    # print(traj_targets_train[0])
    phase_to_model = args.sbi_phase
    traj_targets_train = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_train]
    traj_targets_test = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_test]

    traj_targets_train = list(filter(lambda x: x is not None, traj_targets_train))
    traj_targets_test = list(filter(lambda x: x is not None, traj_targets_test))

    # check that each traj has at least 10 points of data. 10 points seems like enough to get a decent model. Doing an FFT might be good.
    time_series_point_count = [x.shape[0] for x in traj_targets_train + traj_targets_test]
    if any(x < 10 for x in time_series_point_count):
        raise ValueError(
            "Some of the training or test data has less than 10 time series points. Consider changing the trajectory_dt or extending to a further slant range",
            time_series_point_count,
        )

    # validate that the derivative of position is close to velocity
    # if args.use_grdth:
    #     # [Time, GroundRange, GroundRangeDot, ThetaDot, Down, DownDot]
    #     # print(np.gradient(traj_targets_train[0][:-3, 1], traj_targets_train[0][:-3, 0]), traj_targets_train[0][:-3, 2])
    #     # print(np.gradient(traj_targets_train[0][:-3, 1], traj_targets_train[0][:-3, 0]) - traj_targets_train[0][:-3, 2])
    #     if not all(
    #         [np.isclose(np.gradient(x[:-3, 1], x[:-3, 0]), x[:-3, 2], atol=5).all() for x in traj_targets_train]
    #     ):
    #         raise ValueError("Numerical derivative of ground range is not close to the ground range rate values")
    #     # print(np.gradient(traj_targets_train[0][:, 4], traj_targets_train[0][:, 0]), traj_targets_train[0][:, 5])
    #     # print(np.gradient(traj_targets_train[0][:, 4], traj_targets_train[0][:, 0]) - traj_targets_train[0][:, 5])
    #     if not all(
    #         [np.isclose(np.gradient(x[:-3, 4], x[:-3, 0]), x[:-3, 5], atol=5).all() for x in traj_targets_train]
    #     ):
    #         raise ValueError("Numerical derivative of down is not close to the down rate values")
    # TODO: try validating that the integral of the velocity is close to the position

    # delete time plus (zero index), the extra state variables/metadata (everything from the last state to the end), convert to float64 data, and covert to tensor
    traj_targets_train_posvel = [torch.Tensor(x[:, 1 : model_states + 1]) for x in traj_targets_train]
    traj_targets_test_posvel = [torch.Tensor(x[:, 1 : model_states + 1]) for x in traj_targets_test]
    # print(
    #     "initial points",
    #     [x[0, :] for x in traj_targets_train_posvel],
    #     [x[0, :] for x in traj_targets_test_posvel],
    # )

    # check if any of the data turned into a NaN in the transforms
    if any([torch.isnan(x).any() for x in traj_targets_train_posvel]) or any(
        [torch.isnan(x).any() for x in traj_targets_test_posvel]
    ):
