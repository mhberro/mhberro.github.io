# --------------------------------------------------------------------
    #  Build the requested model
    # --------------------------------------------------------------------
    if model_type == "gruode":
        # Retain the continuous recurrent state architecture instance
        # Pull model directly from the configured wrapper block
        print("Activating Continuous-Time Physics-Informed GRU-ODE Tracking Module.")
        node.model = node.architecture.get_model().to(node.device)
        
    elif model_type == "node":
        # plain NODE (no augmentation, no order-shift)
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "anode":
        # Augmented NODE – aug_dim comes from the CLI flag
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=aug_dim,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "sonode":
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=slice(3, 6),
        ).to(node.device)
    elif model_type == "latentode":
        latent_dim = nhidden // 2 if nhidden >= 20 else 8
        node.model = LatentNODE(latent_dim=latent_dim).to(node.device)
        recon_criterion = WrappedMSELoss(
            height_idx=1,
            vel_indices=velocity_indicies,
            scaler=scaler_traj if use_scalar else None,
            N_FEATURES=model_states,
        )

        def latent_ode_loss_fn(recon, target, mu, logvar):
            recon_loss = recon_criterion(recon, target)
            kl = _kl_divergence(mu, logvar)
            return recon_loss + 0.1 * kl

        node.loss_func = lambda pred, true: latent_ode_loss_fn(pred[0], true, pred[1], pred[2])
    else:
        raise ValueError(f"Unsupported model_type: {model_type}")

    # Invoke PyTorch 2.0 graph compilation for accelerated hardware tracking execution
    if HAVE_GPU:
        try:
            node.model = torch.compile(node.model)
            print("Successfully JIT-compiled the trajectory vector field execution graph.")
        except Exception as e:
            print(f"Skipping graph compilation due to environment constraints: {e}")

