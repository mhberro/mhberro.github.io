    #         )
    #         exit()

    print("post-prep. how many made it though prep", len(tmp_data))
    return tmp_data


def create_scalar(traj_targets_train_posvel, model_save_path, model_name_wo_epochs):
    # scale the trajectories
    def find_traj_targets_minmax(
        traj_targets: list[torch.Tensor],
    ) -> np.ndarray:
        """Finds the main and max values in the list of the trajectories."""
        traj_targets_min = torch.min(
            torch.Tensor([torch.min(i, dim=0).values.tolist() for i in traj_targets]),
            dim=0,
        ).values.tolist()
        traj_targets_max = torch.max(
            torch.Tensor([torch.max(i, dim=0).values.tolist() for i in traj_targets]),
            dim=0,
        ).values.tolist()
        return np.array([traj_targets_min, traj_targets_max])

    # traj_targets_minmax = find_traj_targets_minmax(traj_targets_train_posvel)
    # scaler_traj = MinMaxScaler(feature_range=(-1, 1))
    # scaler_traj.fit(traj_targets_minmax)
    stacked_posvel = torch.Tensor(np.vstack(traj_targets_train_posvel))
    scaler_traj = StandardScaler().fit(stacked_posvel)

    # pickle the scaler
    pickle_scalar_name = os.path.join(model_save_path, f"{model_name_wo_epochs}_scalar.pickle")
    with open(pickle_scalar_name, "wb") as o:
        pickle.dump(scaler_traj, o)
    return scaler_traj


def plot_column_distributions(data, bins=30, cmap="tab10", column_names=None, data_path=""):
    """
    Plot the distribution of each column of a 2-D array in its own subplot.

    Parameters
    ----------
    data : np.ndarray
        2-D array of shape (n_samples, n_columns).
    bins : int or sequence, optional
        Number of histogram bins (default 30).  Pass a sequence to specify
        custom bin edges for all columns.
    cmap : str, optional
        Matplotlib colormap name used to assign a distinct color to each subplot.
    """
    if data.ndim != 2:
        raise ValueError("`data` must be a 2-D array (samples x columns).")

    n_cols = data.shape[1]

    # Choose a layout that keeps subplots readable.
    # Up to 5 columns → a single row, otherwise wrap to multiple rows.
    max_per_row = 5
    n_rows = int(np.ceil(n_cols / max_per_row))
    n_cols_plot = min(n_cols, max_per_row)

    # Create subplots
    fig, axes = plt.subplots(n_rows, n_cols_plot, figsize=(4 * n_cols_plot, 3 * n_rows), constrained_layout=True)

    # If there is only one row, `axes` is 1-D; make it 2-D for consistent indexing.
    if n_rows == 1:
        axes = np.expand_dims(axes, axis=0)

    colors = plt.get_cmap(cmap).colors

    for idx in range(data.shape[1]):
        row = idx // max_per_row
        col = idx % max_per_row
        ax = axes[row, col]

        # Plot histogram - `density=True` gives a probability density (area = 1)
        ax.hist(data[:, idx], bins=bins, density=True, color=colors[idx % len(colors)], alpha=0.75, edgecolor="black")

        if column_names is None:
            ax.set_title(f"Column {idx}")
        else:
            ax.set_title(column_names[idx])
        ax.set_xlabel("Value")
        ax.set_ylabel("Density")
        # Each axis gets its own y-scale automatically

    # Hide any unused sub-axes (when columns < rows*max_per_row)
    total_plots = n_rows * n_cols_plot
    for empty_idx in range(data.shape[1], total_plots):
        row = empty_idx // max_per_row
        col = empty_idx % max_per_row
        fig.delaxes(axes[row, col])

    plt.suptitle("Column-wise Distributions", fontsize=16, y=1.02)
    # plt.show()
    plt.savefig(data_path + "_feature_distribution.png")


def plot_correlation_matrix(data, method="pearson", cmap="coolwarm", column_names=None, data_path=""):
    """
    Visualise the correlation matrix of the columns.

    Parameters
    ----------
    data : np.ndarray
        2-D array (samples x columns).
    method : str, optional
        Correlation method passed to ``np.corrcoef`` - ``'pearson'`` (default)
        or ``'spearman'`` (requires scipy.stats.spearmanr).
    cmap : str, optional
        Colormap for the heat-map.
    """
    if data.ndim != 2:
        raise ValueError("`data` must be a 2-D array (samples x columns).")

    # ------------------------------------------------------------------
    # Compute correlation matrix
    # ------------------------------------------------------------------
    if method == "pearson":
        corr = np.corrcoef(data, rowvar=False)  # shape (n_cols, n_cols)
    elif method == "spearman":
        from scipy.stats import spearmanr

        corr, _ = spearmanr(data, axis=0)
    else:
        raise ValueError("Unsupported method; choose 'pearson' or 'spearman'.")

    # ------------------------------------------------------------------
    # Plot heat-map
    # ------------------------------------------------------------------
    plt.figure(figsize=(0.6 * corr.shape[0] + 2, 0.6 * corr.shape[0] + 2))
    sns.heatmap(
        corr, annot=True, fmt=".2f", cmap=cmap, vmin=-1, vmax=1, square=True, cbar_kws={"shrink": 0.75}, linewidths=0.5
    )
    labels = [f"Col {i}" for i in range(corr.shape[0])]
    if column_names is not None:
        labels = column_names
    plt.title(f"{method.title()} Correlation Matrix", fontsize=14, pad=12)
    plt.xticks(ticks=np.arange(corr.shape[0]) + 0.5, labels=labels, rotation=0)
    plt.yticks(ticks=np.arange(corr.shape[0]) + 0.5, labels=labels, rotation=0)
    plt.tight_layout()
    # plt.show()
    plt.savefig(data_path + "_correlation_matrix.png")


def sbi_trajectory_prep(ecef_data_traj: tuple, phase_to_transform: str, trajectory_dt: float, args):
    # input is a tuple of three 2d arrays with columns time, x, y, z, vx, vy, vz
    # phase_to_transform selects with phase to transform
    # the impact point is also availble if needed for the transform
    # if there are mulptiple timestamps, resample the data to align to a common time grid
    timeseries_to_transform = ecef_data_traj[0] if phase_to_transform == "boost" else ecef_data_traj[1]
    if timeseries_to_transform.shape[0] < 10:
        print(
            "the shape of the timeseries to be transformed seems small. skipping this one",
            timeseries_to_transform.shape,
            timeseries_to_transform[-1],
        )
        return None
    new_times = np.arange(
        timeseries_to_transform[0, TIME_INDEX], timeseries_to_transform[-1, TIME_INDEX] + trajectory_dt, trajectory_dt
    )
    resampled_timeseries = np.hstack(
        [np.atleast_2d(new_times).T]
        + [
            make_interp_spline(
                timeseries_to_transform[:, TIME_INDEX],
                timeseries_to_transform[:, 1:],
                bc_type="not-a-knot",
            )(new_times, extrapolate=True)
        ]
    )

    ref_ecef = ecef_data_traj[2][-1, POS_SLICE]
    # Changing the reference frame to be at the end of the desired phase rather than impact
    if args.ref_ecef == "boost":
        ref_ecef = ecef_data_traj[0][-1, POS_SLICE]
    elif args.ref_ecef == "glide":
        ref_ecef = ecef_data_traj[1][-1, POS_SLICE]

    # now apply a transform
    if args.frame == "dcu":
        # convert ecef truth to the training frame
        timeseries_in_next_frame, initial_point_heading, flip_c = ecef_to_next_dcu(resampled_timeseries, ref_ecef)

        # check the inverse transform
        check_ecef = next_dcu_to_ecef(timeseries_in_next_frame, ref_ecef, initial_point_heading, flip_c)
    elif args.frame == "grdth":
        # convert ecef truth to the training frame
        timeseries_in_next_frame, initial_point_heading = ecef_to_next_grdth(resampled_timeseries, ref_ecef)

        # check the inverse transform
        check_ecef = next_grdth_to_ecef(timeseries_in_next_frame, ref_ecef, initial_point_heading)
    elif args.frame == "geodesic":
        # Two geodesic sub-modes (Jackson's frame trick):
        #   original   -> 6-state [s, az, h, v_s, v_alpha, v_h] (azimuth kept)
        #   integrated -> 5-state [s, h, v_s, v_alpha, v_h] (azimuth dropped;
        #                 reconstructed from v_alpha on the inverse transform)
        if args.geodesic_mode == "original":
            timeseries_in_next_frame = ecef_to_local_geodesic_vec(
                resampled_timeseries[:, POS_SLICE],
                resampled_timeseries[:, VEL_SLICE],
                np.zeros_like(
                    resampled_timeseries[:, VEL_SLICE]
                ),  # TODO: better handling of acceleration being in the transform functions
                ref_ecef,  # grab the impact point as the reference ecef point
            )
            # Prepend time and only include pos and vel (only needed for the geodesic transform. the DCU and GRDTH functions handle time internally)
            timeseries_in_next_frame = np.hstack(
                [resampled_timeseries[:, TIME_INDEX][..., np.newaxis], timeseries_in_next_frame[:, :6]]
            )
        else:  # integrated (frame trick): 5-state, tracks azimuth rate
            timeseries_state, initial_azimuth = ecef_to_local_geodesic_vec_frame_trick(
                resampled_timeseries[:, POS_SLICE],
                resampled_timeseries[:, VEL_SLICE],
                ref_ecef,
            )
            timeseries_in_next_frame = np.hstack(
                [resampled_timeseries[:, TIME_INDEX][..., np.newaxis], timeseries_state]
            )
        # TODO: add check_ecef
    else:
        raise NotImplementedError("haven't gotten to adding this frame transform code for SBI")

    # output is a 2d array with the same columns
    return timeseries_in_next_frame


def main():
    parser = argparse.ArgumentParser(
        description="Training script for creating NEXT models",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument(
        "--tgt-data-paths",
        default=[],
        type=str,
        nargs="+",
        help="A list of directories where training data can be found. Data will be test/train split if validation data is not provided. It is suggested thet the final directory in the path be named for the target. Ex: datasets/train/PrSM",
    )
    parser.add_argument(
        "--validation-data-paths",
        default=[],
        type=str,
        nargs="+",
        help="A list of directories where validation data can be found. Helpful for when the test/train split has already been done. Ex: datasets/test/PrSM",
    )
    # parser.add_argument("--max-epoch", default=50, type=int)
    parser.add_argument(
        "--sr",
        default=100000,
        type=int,
        help="The maximum slant range to trim data at. All data less than this value will be used. [meters]",
    )
    parser.add_argument(
        "-o",
        default="model_outputs",
        type=str,
        help="Directory to place pickles, JSON, checkpoints, ModelProto, and ONNX files related to the model",
    )
    parser.add_argument(
        "--use-scalar",
        default=False,
        action="store_true",
        help="Enable training with a scalar",
    )
    parser.add_argument(
        "--frame",
        default="dcu",
        choices=["dcu", "grdth", "geodesic"],
        help="Select which frame to put the data in for training the model",
    )
    parser.add_argument(
        "--sbi-phase",
        default="boost",
        choices=["boost", "glide"],
        help="Select which SBI phase to train a model for",
    )
    parser.add_argument(
        "--nhidden",
        default=200,
        type=int,
        help="The size of the hidden layers of the MLP/FFNN",
    )
    parser.add_argument(
        "--aug",
        default=0,
        type=int,
        help="The size of the zeros augmented to the initial states",
        dest="aug_dim",
    )
    parser.add_argument(
        "--gpuidx",
        default=0,
        type=int,
        help="The index of the gpu to use",
        dest="gpu_index",
    )
    parser.add_argument(
        "--model-type",
        default="node",
        choices=["node", "anode", "sonode", "latentode", "gruode", "gruode-min"],
        help=(
            "Which ODE architecture to train: regular NODE, Augmented NODE, "
            "Second-Order NODE, Latent-ODE, GRU-ODE (full cell) or GRU-ODE "
            "with the minimal cell (gruode-min)."
        ),
    )
    parser.add_argument(
        "--dt",
        default=0.1,
        type=float,
        help="The delta time to use for resampling the truth trajectory to align the time grid",
    )
    parser.add_argument(
        "--ref-ecef",
        default="impact",
        choices=["boost", "glide", "impact"],
        help="The reference point for the frame transformations",
    )
    parser.add_argument(
        "--geodesic-mode",
        default="original",
        choices=["original", "integrated"],
        help=(
            "Geodesic frame mode: 'original' keeps absolute azimuth in the "
            "state (6-state); 'integrated' drops azimuth and reconstructs it "
            "from the azimuth rate v_alpha (5-state frame trick). Only used "
            "when --frame geodesic."
        ),
    )

    args = parser.parse_args()

    # State-vector width per frame:
    #   dcu                    -> 6  [D, C, U, dotD, dotC, dotU]
    #   grdth                  -> 5  [GR, Down, dotGR, dotD, VTheta]
    #   geodesic (original)    -> 6  [s, az, h, v_s, v_alpha, v_h]
    #   geodesic (integrated)  -> 5  [s, h, v_s, v_alpha, v_h]  (frame trick)
    model_states = 6  # this is 6 for ImpAntiHeadDCU and 5 for GRDTH
    if args.frame == "grdth":
        model_states = 5
    elif args.frame == "geodesic" and args.geodesic_mode == "integrated":
        # The integration trick drops the absolute-azimuth state (Jackson's
        # frame trick) -- resolves the old TODO about a 5-state geodesic frame.
        model_states = 5

    trajectory_dt = args.dt  # [s]

    seed = 47
    # random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

