def train_NEXT(
    model_name,
    traj_targets_train,
    traj_targets_test,
    scaler_traj,
    model_save_path,
    trajectory_dt,
    batch_size,
    use_scalar,
    model_states,
    aug_dim,
    nhidden,
    gpu_index,
    model_type: str = "node",
    frame: str = "dcu",
):
    training_configuration = TrainingConfiguration(
        n_epochs=1,
        optimizer=AdamOptimizer(learning_rate=1e-3),
        batch_size=batch_size,
        num_workers=100,
        verbose=True,
    )
    
    GRUODE_SOLVER_METHOD = "dopri5"
    if model_type in ("gruode", "gruode-min"):
        ode_method = GRUODE_SOLVER_METHOD
    else:
        ode_method = "rk4"
        
    # Tightened local tolerances to prevent truncation propagation over 10,000km rollouts
    ode_solver = TorchdiffeqSolver(
        dt=trajectory_dt, 
        method=ode_method, 
        adjoint=False, 
        atol=1e-9, 
        rtol=1e-7
    )

    if frame == "dcu":
        velocity_indicies = (3, 4, 5)
    elif frame == "grdth":
        velocity_indicies = (2, 3, 4)
    elif frame == "geodesic":
        velocity_indicies = (2, 3, 4) if model_states == 5 else (3, 4, 5)
    else:
        raise ValueError("That frame is not known for what the velocity indicies are")
        
    early_stop_metric_name = "val_loss"
    
    # Leverages the new non-diluting velocity loss balance parameter
    loss_func = WrappedMSELoss(
        height_idx=1,
        vel_indices=velocity_indicies,
        scaler=scaler_traj if use_scalar else None,
        N_FEATURES=model_states,
        position_loss_weight=80.0,
        velocity_loss_weight=10.0,
        l2_reg=1e-4,
        temporal_weighting=True,
    )

    node = NODEPredictor(
        architecture=FFNNArchitecture(
            layer_channels=[5, 5],
            layer_activation=Activation.SILU,
        ),
        training_configuration=training_configuration,
        solver=ode_solver,
        logging_interval=5,
        loss_func=loss_func,
        early_stopper=EarlyStopper(10, 0.5, metric_name=early_stop_metric_name),
        checkpoint=ModelCheckpoint(min_epochs=1, directory=model_save_path, model_name=model_name + ".checkpoint"),
        aug_dim=aug_dim,
    )
    
