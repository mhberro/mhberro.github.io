def resample_traj_data(traj_data, dt):
    # TODO: this resampling needs to move into a function so it can reused
    # TODO: this needs to flip around so that the range is relative to the impact time (and flip sign again after)
    new_times = np.arange(traj_data[0, 0], traj_data[-1, 0] + dt, dt)

    try:
        resampled_data = np.hstack(
            [np.atleast_2d(new_times).T]
            + [
                make_interp_spline(
                    traj_data[:, 0],
                    traj_data[:, 1:],
                    bc_type="not-a-knot",
                )(new_times, extrapolate=True)
            ]
        )
    except Exception as e:
        print("Hit an the error with interpolation")
        raise e
    return resampled_data


def check_time_series(traj_data):
    # diff the time column, run unique, print that if there is more than 1 unique
    time_diff = np.diff(traj_data[:, TIME_INDEX])
    unique_time_diff = np.unique(np.round(time_diff, decimals=2))
    if np.any(time_diff < 0):
        raise ValueError(f"Found has time that goes backwards. Time diffs are {unique_time_diff}")
    return unique_time_diff.squeeze()
