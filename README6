class SecondOrderSplitMSELoss(torch.nn.Module):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        vel_weight: float | None = 1.0,
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
        pos_expect: float = "inf",
        vel_expect: float = "inf",
    ) -> None:
        """Initializes SecondOrderSplitMSELoss."""
        super().__init__()
        self.height_idx = height_idx
        self.vel_indices = vel_indices
        self.vel_weight = vel_weight
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        self.pos_expect = pos_expect
        self.vel_expect = vel_expect

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)

        # Compute metrics.
        # with torch.no_grad():
        if self.scaler is not None:
            pred_unscaled = torch.from_numpy(
                self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                    -1, n_timesteps, self.N_FEATURES
                )
            )
            target_unscaled = torch.from_numpy(
                self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                    -1, n_timesteps, self.N_FEATURES
                )
            )
        else:
            pred_unscaled = pred.detach()
            target_unscaled = target.detach()

        pos_pred_unscaled = pred_unscaled[..., : self.vel_indices[0]]
        pos_target_unscaled = target_unscaled[..., : self.vel_indices[0]]
        vel_pred_unscaled = pred_unscaled[..., self.vel_indices]
        vel_target_unscaled = target_unscaled[..., self.vel_indices]

        avg_pos_diff = torch.nn.L1Loss().forward(pos_pred_unscaled, pos_target_unscaled)
        avg_vel_diff = torch.nn.L1Loss().forward(vel_pred_unscaled, vel_target_unscaled)

        pos_pred = pred[..., : self.vel_indices[0]]
        pos_target = target[..., : self.vel_indices[0]]
        vel_pred = pred[..., self.vel_indices]
        vel_target = target[..., self.vel_indices]

        # calculate vel weight based on how far above the expectation each error is
        # piecewise above expect ratio
        pos_ratio = torch.max(torch.Tensor([1.0]), avg_pos_diff / self.pos_expect) ** 2
        vel_ratio = torch.max(torch.Tensor([1.0]), avg_vel_diff / self.vel_expect) ** 2

        pos_loss = torch.nn.MSELoss().forward(pos_pred, pos_target) * pos_ratio
        vel_loss = torch.nn.MSELoss().forward(vel_pred, vel_target) * vel_ratio
        total_loss = pos_loss + vel_loss

        return {
            "loss": total_loss,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
            # "energy_loss": loss_energy,
        }


class PhysicsSplitMSELoss(torch.nn.Module):
    """Position/velocity-weighted MSE with an optional physics-residual coupling.

    Combines the two requested GRU-ODE improvements in one loss, each behind a
    weight that defaults to recovering plain summed MSE:

      total = w_pos * MSE(pos) + w_vel * MSE(vel) + w_phys * MSE(d/dt pos - vel)

    1. Velocity weighting (w_vel): the laggard in the training logs was velocity
       (val_vel_err ~58 while position kept improving). w_vel lets you up- or
       down-weight the velocity MSE relative to position. (The old
       SecondOrderSplitMSELoss declared a vel_weight but never applied it; here
       it is actually used.)

    2. Physics residual (w_phys): the geodesic `gruode` path sets no
       order_shift_slice, so predicted position and velocity are untied — the
       model can output a position trajectory inconsistent with its own
       velocity, which compounds into long-horizon drift. This term penalises
       the violation of the kinematic identity d/dt(position) = velocity,
       directly coupling the two and damping that drift.

    CRITICAL — scaling: the loss sees the StandardScaler-scaled state, in which
    dx = v*dt does NOT hold (position and velocity have different scale factors).
    The residual is therefore computed in PHYSICAL units by multiplying each
    block by its scaler scale_ factor before finite-differencing. The forward
    difference uses dt (seconds) between consecutive timesteps. With w_phys=0
    this term and its unscaling are skipped entirely.

    Returns the {"loss", "pos_err", "vel_err"} dict the early stopper expects
    (early_stop_metric_name="val_loss"). pos_err/vel_err remain physical-unit
    L1 metrics, identical in meaning to the other losses, so curves stay
    comparable across runs.
    """

    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        dt: float,
        pos_weight: float = 1.0,
        vel_weight: float = 1.0,
        physics_weight: float = 0.0,
        late_weight: float = 0.0,
        late_power: float = 1.0,
        vel_bias_weight: float = 0.0,
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
    ) -> None:
        super().__init__()
        self.height_idx = height_idx
        self.vel_indices = list(vel_indices)
        self.dt = float(dt)
        self.pos_weight = pos_weight
        self.vel_weight = vel_weight
        self.physics_weight = physics_weight
        # Velocity DC-bias penalty (aero review item C). Position drift on an
        # axis is ~ sigma_p * T * dt * mean_t(v_residual): a small CONSTANT
        # velocity offset integrates into large end-of-trajectory position
        # error while being nearly invisible to MSE (which penalizes variance).
        # This term penalizes the time-mean signed velocity residual squared --
        # exactly the DC offset -- and leaves zero-mean maneuver noise alone.
        # Computed on scaled velocities so it's O(1) alongside the other terms.
        # Start vel_bias_weight ~= pos_weight; 0.0 disables it.
        self.vel_bias_weight = vel_bias_weight
        # Late-weighted position term (reviewer R2). Ordinary per-timestep MSE
        # penalizes variance but is BLIND to accumulated drift: a small constant
        # velocity bias (~0.05%) integrates into a large end-of-trajectory
        # position error while contributing almost nothing to pointwise MSE.
        # Weighting the position error by a ramp that grows toward the
        # trajectory end makes that drift expensive (its cost scales with
        # horizon), so the optimizer finally "sees" and suppresses the bias.
        #   late_weight : strength of the extra late-weighted position term (0=off)
        #   late_power  : ramp steepness; weight_k = (k/(T-1))**late_power.
        #                 1.0 = linear ramp, 2.0 = quadratic (emphasize the very end).
        self.late_weight = late_weight
        self.late_power = late_power
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        # Position block is everything before the first velocity index. For the
        # balanced 6-state geodesic/DCU layout (vel_indices=[3,4,5]) this gives
        # position indices [0,1,2], so pos component i pairs with vel component i.
        self.n_pos = self.vel_indices[0]
        # Pre-extract per-block physical scale factors (std dev for StandardScaler)
        # so the physics residual can be evaluated in physical units. Registered
        # as buffers so they ride along to the correct device.
        if scaler is not None and physics_weight > 0.0:
            scale = torch.as_tensor(getattr(scaler, "scale_"), dtype=torch.float32)
            self.register_buffer("pos_scale", scale[: self.n_pos].clone())
            self.register_buffer("vel_scale", scale[self.vel_indices].clone())
        else:
            self.pos_scale = None
            self.vel_scale = None

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)

        # --- physical-unit L1 metrics (no grad), matching the other losses ---
        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(
                        pred.detach().cpu().numpy().reshape(-1, self.N_FEATURES)
                    ).reshape(-1, n_timesteps, self.N_FEATURES)
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(
                        target.detach().cpu().numpy().reshape(-1, self.N_FEATURES)
                    ).reshape(-1, n_timesteps, self.N_FEATURES)
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred_u = pred_unscaled[..., : self.n_pos]
            pos_target_u = target_unscaled[..., : self.n_pos]
            vel_pred_u = pred_unscaled[..., self.vel_indices]
            vel_target_u = target_unscaled[..., self.vel_indices]
            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred_u, pos_target_u)
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred_u, vel_target_u)

        # --- differentiable position / velocity MSE (scaled space) ---
        pos_pred = pred[..., : self.n_pos]
        pos_target = target[..., : self.n_pos]
        vel_pred = pred[..., self.vel_indices]
        vel_target = target[..., self.vel_indices]

        pos_loss = torch.nn.functional.mse_loss(pos_pred, pos_target)
        vel_loss = torch.nn.functional.mse_loss(vel_pred, vel_target)
        total_loss = self.pos_weight * pos_loss + self.vel_weight * vel_loss

        # --- optional physics-residual coupling: d/dt(pos) ?= vel ---
        if self.physics_weight > 0.0 and n_timesteps >= 2:
            # Convert the predicted blocks to physical units. With a scaler we
            # multiply by the per-component std; without one we assume the data
            # is already physical (scale = 1).
            if self.pos_scale is not None:
                pos_phys = pos_pred * self.pos_scale.to(pos_pred.device)
                vel_phys = vel_pred * self.vel_scale.to(vel_pred.device)
            else:
                pos_phys = pos_pred
                vel_phys = vel_pred
            # forward finite difference along time: (x[t+1]-x[t])/dt vs v[t]
            dpos_dt = (pos_phys[:, 1:, :] - pos_phys[:, :-1, :]) / self.dt
            vel_mid = vel_phys[:, :-1, :]
            # normalise the residual back by pos_scale so its magnitude is
            # comparable to the scaled MSE terms (keeps physics_weight ~O(1)).
            if self.pos_scale is not None:
                resid = (dpos_dt - vel_mid) / self.pos_scale.to(pos_pred.device)
            else:
                resid = dpos_dt - vel_mid
            physics_loss = torch.mean(resid**2)
            total_loss = total_loss + self.physics_weight * physics_loss

        # --- late-weighted position term (reviewer R2): penalize accumulated
        #     drift by weighting per-timestep position error toward the end of
        #     the trajectory. A constant velocity bias produces position error
        #     that grows with k, so a ramp weight makes it expensive where a
        #     flat MSE does not. Computed in scaled space (same as pos_loss) so
        #     late_weight stays O(1) relative to the other terms.
        if self.late_weight > 0.0 and n_timesteps >= 2:
            # per-timestep squared position error, averaged over batch & axes
            se = (pos_pred - pos_target) ** 2               # (B, T, n_pos)
            per_t = se.mean(dim=(0, 2))                      # (T,)
            # ramp weight in [0,1], growing toward the trajectory end
            k = torch.arange(n_timesteps, device=pos_pred.device, dtype=pos_pred.dtype)
            w = (k / (n_timesteps - 1)) ** self.late_power   # (T,)
            # normalize so the ramp has unit mean -> late_weight is comparable
            # in scale to pos_weight regardless of trajectory length / power
            w = w / (w.mean() + 1e-8)
            late_loss = torch.mean(w * per_t)
            total_loss = total_loss + self.late_weight * late_loss

        # --- velocity DC-bias penalty (aero review item C): penalize the
        #     time-mean signed velocity residual per axis, i.e. the constant
        #     offset that integrates into position drift. mean over time gives
        #     the DC component; squaring + averaging over batch/axes gives a
        #     scalar. Zero-mean maneuver noise averages out and is not penalized.
        if self.vel_bias_weight > 0.0 and n_timesteps >= 2:
            r = vel_pred - vel_target                        # (B, T, n_vel), scaled
            bias = r.mean(dim=1)                             # (B, n_vel): DC offset
            bias_loss = torch.mean(bias**2)
            total_loss = total_loss + self.vel_bias_weight * bias_loss

        return {
            "loss": total_loss,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
        }


class EnergyMSELoss(MSELoss):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        energy_fn: Callable[[Tensor, int, list[int]], Tensor],
        energy_weight: float | None = 1.0,
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
    ) -> None:
        """Initializes EnergyMSELoss."""
        super().__init__()
        self.height_idx = height_idx
        self.vel_indices = vel_indices
        self.energy_fn = energy_fn
        self.energy_weight = energy_weight
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)
        loss_data = super().forward(pred, target)
        energy_pred = self.energy_fn(pred, self.height_idx, self.vel_indices)
        energy_target = self.energy_fn(target, self.height_idx, self.vel_indices)
        loss_energy = super().forward(energy_pred, energy_target) * self.energy_weight

        total_loss = loss_data + loss_energy

        # Compute metrics.
        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred, pos_target)
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred, vel_target)

        return {
            "loss": total_loss,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
            "energy_loss": loss_energy,
        }


class ReverseLinearWeightingLoss(torch.nn.modules.loss._Loss):  # noqa: SLF001
    """Reverse Linear Weighting Loss function.

    The Reverse Linear Weighting Loss function calculates a linearly weighted
    Mean Absolute Error (MAE) where the last points in the time series data are
    weighted more than the first points. The weights are calculated linearly,
    monotonically increasing in weight.

    This loss function helps the NODE model learn the end of the time series
    target data better by increasing the importance of these points through the
    weighting scheme.

    Example:
        If pred = [100 200 300 400 500] and target = [105 205 305 405 505]:

        absolute error = [5 5 5 5 5]
        reverse_linear_weights = [0 0.1 0.2 0.3 0.4] * 100
        weighted absolute errors = [0 50 100 150 200]
        mean weighted absolute error = 100
    """

    def __init__(self) -> None:
        """Initializes ReverseLinearWeightingLoss."""
        super().__init__()

    def forward(
        self,
        pred: torch.Tensor,
        target: torch.Tensor,
    ) -> torch.Tensor:
        """Calculates the reverse linear weighting loss.

        Args:
            pred: The prediction from the model.
            target: The target data the model should predict.

        Returns:
            A tensor containing the reverse linear weighting loss.
        """
        batch_size, time_steps, n_features = pred.shape

        # Calculate reverse linear weights.
        # Create a tensor of shape (batch_size, time_steps) row counts up from 0
        # to time_steps-1.
        reverse_linear_weights: torch.Tensor = torch.arange(time_steps).repeat(batch_size, 1)

        # Normalize accross the rows.
        reverse_linear_weights = reverse_linear_weights / reverse_linear_weights.sum(dim=1, keepdim=True) * 100.0

        # Duplicate in the feature dimension. Final result is tensor of shape
        # (batch_size, time_steps, n_features) to match pred and target shapes.
        reverse_linear_weights = torch.stack([reverse_linear_weights for _ in range(n_features)], dim=-1)

        # Calculate Weighted Mean Absolute Error according to the weight tensor.
        return {"loss": torch.mean(torch.abs(pred - target) * reverse_linear_weights)}


class SoftDTWLossWrapper(SoftDTWLossPyTorch):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
        gamma=1,
        normalize=False,
        dist_func=None,
    ):
        super().__init__(gamma, normalize, dist_func)
        self.height_idx = height_idx
        self.vel_indices = vel_indices
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)
        loss_data = super().forward(pred, target)

        # Compute metrics.
        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred, pos_target)
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred, vel_target)

        return {
            "loss": loss_data,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
            # "energy_loss": loss_energy,
        }


class WeightedHuberLoss(torch.nn.Module):
    """
    δp, δv are the *normalised* thresholds (already divided by the
    corresponding std-dev).  wp, wv are optional scalar weights.
    """

    def __init__(
        self,
        delta_pos,
        delta_vel,
        vel_indices: list[int],
        weight_pos=1.0,
        weight_vel=1.0,
        scaler=None,
        N_FEATURES: int = 6,
    ):
        super().__init__()
        self.delta_pos = delta_pos
        self.delta_vel = delta_vel
        self.delta_pos_unsacled = delta_pos
        self.delta_vel_unsacled = delta_vel
        self.vel_indices = vel_indices
        self.wp = weight_pos
        self.wv = weight_vel
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        if scaler is not None:
            # self.compute_normalised_deltas(scaler, delta_pos, delta_vel)
            sigma = scaler.scale_
            # simple average, or keep per‑axis
            self.delta_pos = delta_pos / sigma[: self.vel_indices[0]].mean()
            self.delta_vel = delta_vel / sigma[self.vel_indices[0] :].mean()

    # def compute_normalised_deltas(
    #     self,
    #     scaler,
    #     delta_pos_phys,  # metres
    #     delta_vel_phys,
    # ):  # metres / sec
    #     # scaler.scale_ is an array of length 6: [σ_px, σ_py, σ_pz, σ_vx, σ_vy, σ_vz]

    #     # return delta_pos_norm, delta_vel_norm

    # def huber(self, r, delta):
    #     """Element-wise Huber for a tensor of residuals."""
    #     abs_r = torch.abs(r)
    #     quadratic = 0.5 * r**2
    #     linear = delta * (abs_r - 0.5 * delta)
    #     return torch.where(abs_r <= delta, quadratic, linear)

    def forward(self, pred, target):
        """
        pred_norm / target_norm : (T,6) tensors in normalised space
        Returns a scalar loss (mean over all time steps and components)
        """
        n_timesteps = pred.size(1)

        pos_pred_scaled = pred[..., : self.vel_indices[0]]
        pos_target_scaled = target[..., : self.vel_indices[0]]
        vel_pred_scaled = pred[..., self.vel_indices]
        vel_target_scaled = target[..., self.vel_indices]

        # Compute metrics.
        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred, pos_target)  # TODO: What about RMSE?
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred, vel_target)

            # TODO: What about RMSE?
            avg_pos_diff_scaled = torch.nn.L1Loss().forward(pos_pred_scaled, pos_target_scaled)
            avg_vel_diff_scaled = torch.nn.L1Loss().forward(vel_pred_scaled, vel_target_scaled)

        loss_pos = torch.nn.HuberLoss(delta=self.delta_pos).forward(pos_pred_scaled, pos_target_scaled) * self.wp
        loss_vel = torch.nn.HuberLoss(delta=self.delta_vel).forward(vel_pred_scaled, vel_target_scaled) * self.wv

        # sum over dimensions, then mean over time steps
        # total_loss = (self.wp * loss_pos.sum(dim=1) + self.wv * loss_vel.sum(dim=1)).mean()
        total_loss = (loss_pos * self.wp) + (loss_vel * self.wv)
        total_loss_unweighted = loss_pos + loss_vel
        return {
            "loss": total_loss,
