class TorchdiffeqSolver(ODESolver):
    # ... Keep existing __init__ implementation untouched ...
    pass

    def integrate(
        self,
        func: torch.nn.Module,
        x0: torch.Tensor,
        steps: int = 1,
        extra_feat: torch.Tensor | None = None,
    ) -> torch.Tensor:
        if extra_feat is not None:
            raise Warning("Prediction Core torchdiffeq wrapper does not implement extra_feat")
            
        epsilon = 1e-10
        
        if self.substeps == 1:
            # FIXED: Instantiated directly on target hardware device with matching model data type
            times = torch.arange(
                0, self.dt * steps + self.dt - epsilon, self.dt, 
                dtype=x0.dtype, device=x0.device
            )
            x = self.odeint(func, x0, times, method=self.method)
            return torch.permute(x, (1, 0, 2))

        fine_dt = self.dt / self.substeps
        n_fine = steps * self.substeps
        
        # FIXED: Instantiated directly on target hardware device with matching model data type
        times = torch.arange(
            0, fine_dt * n_fine + fine_dt - epsilon, fine_dt, 
            dtype=x0.dtype, device=x0.device
        )
        x = self.odeint(func, x0, times, method=self.method)
        x = x[:: self.substeps]
        return torch.permute(x, (1, 0, 2))

