# -*- coding: utf-8 -*-
r"""
GRU-ODE compatibility patch for simple_sim.py
=============================================

Replace the existing `_field_eval`, `_integrate_one_step`, and
`NEXT_extrapolation` functions in simple_sim.py with the versions below, and
add the small `_gruode_latent_dim` / `_load_encoder_session` helpers.

WHY THE ORIGINAL SIM FAILS ON GRU-ODE
-------------------------------------
The trained GRU-ODE field integrates the FULL state = [y, h], where:
  * y is the physical state (state_size dims),
  * h is a latent vector (latent_dim dims) seeded ONCE at t0 by an encoder
    (h0 = encode(y0)) and then evolved continuously by the coupled cell
    dh/dt = cell(h, y).

The original `_field_eval` rebuilt the model input every step as
[y, zeros(aug)] -- it threw h away and re-injected zeros. That means the
coupled cell (the mechanism that cut error ~60% in training) never actually
ran at inference: the model was evaluated in a regime it never saw. On top of
that, the input width is state_size + latent_dim (here 5 + 100 = 105), NOT
state_size + <single-digit aug token>. The `_(\d)aug_` filename token cannot
even represent latent_dim=100, so the old width logic was wrong for this model.

WHAT THIS PATCH DOES
--------------------
  1. Derives the true latent width from the `_{nhidden}hid_` filename token
     using the SAME formula as NEXT_training
     (latent_dim = max(2*state_size, nhidden//2 if nhidden>=20 else 16)).
  2. Loads the companion `<model>_encoder.onnx` and calls it once to build h0
     from the (scaled) initial physical state.
  3. Carries the full [y, h] vector through the RK4 sub-stepping, exactly
     mirroring training's batch_loss rollout, and reads back only the physical
     partition for the trajectory.

The non-GRU-ODE (LatentNODE / ANODE) path is preserved unchanged: it still
zero-fills augmentation, because those models really were trained to integrate
from h0 = 0.
"""

import os
import re

import numpy as np
import onnxruntime


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def _gruode_latent_dim(model_basename: str, state_size: int) -> int:
    """Recover the GRU-ODE latent width from the model filename.

    Must match NEXT_training exactly:
        latent_dim = max(2 * state_size, nhidden // 2 if nhidden >= 20 else 16)
    The filename carries `_{nhidden}hid_`.
    """
    m = re.findall(r"_(\d+)hid_", model_basename)
    if not m:
        raise ValueError(
            f"Could not find `_<nhidden>hid_` token in model name '{model_basename}'. "
            "GRU-ODE latent width cannot be recovered."
        )
    nhidden = int(m[-1])
    return max(2 * state_size, nhidden // 2 if nhidden >= 20 else 16)


_encoder_sess_stash = {}


def _load_encoder_session(model_path: str):
    """Load (and cache) the companion `<model>_encoder.onnx` next to the field graph."""
    enc_path = re.sub(r"\.onnx$", "_encoder.onnx", model_path)
    if enc_path in _encoder_sess_stash:
        return _encoder_sess_stash[enc_path]
    if not os.path.exists(enc_path):
        raise FileNotFoundError(
            f"GRU-ODE requires an encoder graph to seed the latent state, but "
            f"'{enc_path}' was not found. Re-export the model with the updated "
            "NEXT_training (it writes `<model>_encoder.onnx` alongside the field graph)."
        )
    sess = onnxruntime.InferenceSession(enc_path)
    _encoder_sess_stash[enc_path] = sess
    return sess


# ---------------------------------------------------------------------------
# Field evaluation
# ---------------------------------------------------------------------------
def _field_eval(ort_sess, state_full_scaled, state_size):
    """Evaluate the ODE field on the FULL state vector.

    state_full_scaled is [y, h] for GRU-ODE (width state_size + latent_dim) or
    [y, zeros(aug)] for ANODE-style models. The field returns a derivative of
    the same width; the caller decides which components to integrate.
    """
    out = ort_sess.run(["output"], {"input": state_full_scaled.astype(np.float32)})[-1].reshape(-1)
    return out


# ---------------------------------------------------------------------------
# One output-dt integration step (RK4 sub-stepped), carrying the full state
# ---------------------------------------------------------------------------
def _integrate_one_step(
    ort_sess,
    x_full_scaled,
    out_dt: float,
    sub_dt: float,
    integrator: str,
    state_size: int,
):
    """Advance the FULL state [y, h] by one output dt.

    Unlike the original, this integrates every component of the field output
    (both physical y and latent h), so the latent evolves continuously and the
    coupled cell sees a consistent h at each evaluation -- exactly as in
    training. For ANODE-style models the "latent" partition is the augmentation
    the model was trained to carry (or zeros of width aug), which is likewise
    integrated rather than reset.
    """
    n_sub = max(1, int(round(out_dt / sub_dt)))
    h_step = out_dt / n_sub

    x = np.asarray(x_full_scaled, dtype=np.float64).reshape(-1).copy()

    def f(state_full):
        return _field_eval(ort_sess, state_full, state_size)

    for _ in range(n_sub):
        if integrator == "euler":
            x = x + h_step * f(x)
        else:  # rk4
            k1 = f(x)
            k2 = f(x + 0.5 * h_step * k1)
            k3 = f(x + 0.5 * h_step * k2)
            k4 = f(x + h_step * k3)
            x = x + (h_step / 6.0) * (k1 + 2.0 * k2 + 2.0 * k3 + k4)
    return x  # full [y, h]


# ---------------------------------------------------------------------------
# Extrapolation
# ---------------------------------------------------------------------------
def NEXT_extrapolation(
    initial_state_next_frame,
    dt: float,
    n_steps: int,
    ref_angle,
    use_grdth: bool,
    args,
    ort_sess: onnxruntime.InferenceSession,
    use_geodesic: bool = False,
):
    import pickle
    from copy import deepcopy

    from trajectory_helpers import (
        TIME_INDEX,
        POS_SLICE,
        GR_INDEX,
        DOWN_INDEX,
    )

    def _infer_training_dt(model_basename: str, default: float = 0.1) -> float:
        m = re.findall(r"_([0-9]*\.?[0-9]+)sec_", model_basename)
        if m:
            try:
                return float(m[-1])
            except ValueError:
                pass
        return default

    use_scalar = "_scalarOn" in os.path.basename(args.model)
    if use_scalar:
        with open(args.scalar, "rb") as scalar_pickle:
            NEXT_scalar = pickle.load(scalar_pickle)

    state_size = 6
    if use_grdth:
        state_size = 5

    model_basename = os.path.basename(args.model)

    is_gruode = (
        getattr(args, "gruode", False)
        or ("_gruode_" in model_basename)
        or ("_gruode-min_" in model_basename)
    )

    if is_gruode:
        integrator = "rk4"
        sub_dt = _infer_training_dt(model_basename, default=0.1)
        # GRU-ODE carries a latent h of width latent_dim (NOT the single-digit
        # aug token). Recover it from the filename and seed h0 via the encoder.
        latent_dim = _gruode_latent_dim(model_basename, state_size)
        aug_width = latent_dim
        enc_sess = _load_encoder_session(args.model)
        print(
            f"GRU-ODE detected: RK4 sub-step ~{sub_dt}s over output dt {dt}s; "
            f"latent_dim={latent_dim}; seeding h0 from encoder graph"
        )
    else:
        integrator = "euler"
        sub_dt = dt
        # Legacy ANODE/LatentNODE: width comes from the aug token, seeded to zero.
        aug_width = int(re.findall(r"_(\d)aug_", args.model)[-1])
        enc_sess = None

    extrap = np.array([np.hstack([initial_state_next_frame])])
    validity_time = deepcopy(initial_state_next_frame[0])

    # ------------------------------------------------------------------
    # Seed the augmented/latent partition ONCE from the initial condition.
    # For GRU-ODE this is h0 = encode(y0_scaled); for ANODE it is zeros.
    # ------------------------------------------------------------------
    y0_phys = np.asarray(extrap[-1][1 : state_size + 1], dtype=np.float64)
    if use_scalar:
        y0_seed = NEXT_scalar.transform(np.asarray([y0_phys]))[0]
    else:
        y0_seed = y0_phys

    if is_gruode:
        # The encoder graph was exported with a 1-D example input, so its input
        # rank is fixed to 1. Feed a flat (state_size,) vector, NOT (1, state_size).
        h_current = enc_sess.run(
            ["h0"], {"y0": y0_seed.astype(np.float32).reshape(-1)}
        )[-1].reshape(-1)
        if h_current.shape[0] != latent_dim:
            raise ValueError(
                f"Encoder produced h0 of width {h_current.shape[0]} but filename "
                f"implies latent_dim={latent_dim}. Filename/model mismatch."
            )
    else:
        h_current = np.zeros(aug_width, dtype=np.float64)

    temp_iter = 0
    while temp_iter < n_steps and float(validity_time) < 122.0:
        temp_iter += 1
        validity_time += dt

        cur_phys = np.asarray(extrap[-1][1 : state_size + 1], dtype=np.float64)

        if use_scalar:
            cur_scaled = NEXT_scalar.transform(np.asarray([cur_phys]))[0]
        else:
            cur_scaled = cur_phys

        # Assemble the FULL state the field was trained on: [y_scaled, h].
        x_full = np.concatenate([cur_scaled, h_current])

        next_full = _integrate_one_step(
            ort_sess,
            x_full,
            out_dt=dt,
            sub_dt=sub_dt,
            integrator=integrator,
            state_size=state_size,
        )

        next_scaled = next_full[:state_size]
        # CARRY the evolved latent forward -- this is the whole point.
        h_current = next_full[state_size : state_size + aug_width]

        if use_scalar:
            next_state = NEXT_scalar.inverse_transform(next_scaled.reshape(1, -1))
            if os.environ.get("NEXT_DEBUG") and temp_iter == 1:
                start_phys = np.asarray(extrap[0][1 : state_size + 1], dtype=np.float64)
                print(
                    f"[debug] step1 geodesic frame: start={start_phys} "
                    f"-> next={next_state.reshape(-1)}  "
                    f"delta/sec={next_state.reshape(-1) - start_phys}",
                    flush=True,
                )
        else:
            next_state = next_scaled.reshape(1, -1)

        next_state = np.insert(next_state, 0, validity_time)
        temp_extrap = np.vstack([extrap, next_state])

        if use_grdth and (temp_extrap[-1, DOWN_INDEX] > 0 or temp_extrap[-1, GR_INDEX] < 2600e3):
            print("grdth below the ground", temp_extrap[-1, DOWN_INDEX])
            break
        elif use_geodesic:
            if not np.all(np.isfinite(temp_extrap[-1, POS_SLICE])) or \
               np.linalg.norm(temp_extrap[-1, POS_SLICE]) > 1e8:
                print("geodesic trajectory diverged", temp_extrap[-1, POS_SLICE])
                break
        elif not use_grdth and (np.linalg.norm(temp_extrap[-1, POS_SLICE]) < 2600e3):
            print("dcu below the ground", temp_extrap[-1, 3])
            break

        extrap = np.vstack([extrap, next_state])

    if extrap.shape[0] < 3:
        raise ValueError(f"Extrap was too short {extrap.shape}")

    return extrap
