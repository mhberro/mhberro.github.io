class GRUODEPredictorModel(nn.Module):
    def __init__(
        self,
        func: GRUODEFunc,
        pos_idx: list[int] | None = None,
        vel_idx: list[int] | None = None,
        pos_scale=None,
        vel_scale=None,
        vel_mean=None,
    ):
        """Production wrapper implementing a stateless continuous integration field."""
        super().__init__()
        self.func = func
        self.n_features = func.state_vector_len
        self.hidden_size = func.latent_dim
        self.second_order = pos_idx is not None and vel_idx is not None
        
        if self.second_order:
            self.register_buffer("pos_idx", torch.tensor(list(pos_idx), dtype=torch.long))
            self.register_buffer("vel_idx", torch.tensor(list(vel_idx), dtype=torch.long))
            if pos_scale is not None and vel_scale is not None:
                ratio = torch.as_tensor(vel_scale, dtype=torch.float32) / torch.as_tensor(
                    pos_scale, dtype=torch.float32
                )
                offset = (
                    torch.as_tensor(vel_mean, dtype=torch.float32)
                    / torch.as_tensor(pos_scale, dtype=torch.float32)
                    if vel_mean is not None
                    else torch.zeros_like(ratio)
                )
                self.register_buffer("so_ratio", ratio)
                self.register_buffer("so_offset", offset)
                self.scaled_space = True
            else:
                self.scaled_space = False

    def forward(self, t, state: torch.Tensor) -> torch.Tensor:
        self.func.nfe += 1
        
        # Unpack the absolute physical and latent partitions directly from the solver state
        y_read = state[..., : self.n_features]
        h = state[..., self.n_features : self.n_features + self.hidden_size]

        # Enforce analytical bounding constraints cleanly on every evaluation step
        h = torch.tanh(h)
        dh = self.func.cell(t, h)
        xdot = self.func.decode(h)

        if self.second_order:
            vel_now = y_read.index_select(-1, self.vel_idx)
            if getattr(self, "scaled_space", False):
                vel_now = vel_now * self.so_ratio + self.so_offset
            pos_deriv = vel_now
            xdot = xdot.index_copy(-1, self.pos_idx, pos_deriv)

        return torch.cat((xdot, dh), dim=-1)

