def plot_color_trajs(truth, extraps, ax51, ax52):
    # plot the truth
    color = "lime"
    linestyle = "--"
    lw = 1
    label = "Truth"
    zorder = 8
    ax51.plot(
        truth[:, 1] / 1e3,
        truth[:, 3] / 1e3,
        label=label,
        color=color,
        lw=lw,
        zorder=zorder,
        linestyle=linestyle,
    )
    ax52.plot(
        truth[:, 1] / 1e3,
        truth[:, 2] / 1e3,
        label=label,
        color=color,
        lw=lw,
        zorder=zorder,
        linestyle=linestyle,
    )

    tall = []
    dall = []
    call = []
    uall = []
    for i in range(len(extraps)):
        ex = extraps[i]
        t, d, c, u, *_ = ex.T
        tall.append(t)
        dall.append(d / 1e3)
        call.append(c / 1e3)
        uall.append(u / 1e3)

    init_times = tuple(x[0][0] for x in extraps)
    plot = multiline(dall, uall, init_times, ax=ax51, cmap="plasma", lw=0.5, label="NEXT")
    multiline(dall, call, init_times, ax=ax52, cmap="plasma", lw=0.5)

    cbar = ax51.get_figure().colorbar(plot, ax=[ax51, ax52])
    cbar.set_label(label="Trajectory Initial Point Validity Time")

    ax51.set_xlabel("Down [km]")
    ax51.set_ylabel("Up [km]")
    ax52.set_ylabel("Cross [km]")


