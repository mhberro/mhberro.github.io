def batch_loss(
        self,
        x: torch.Tensor,
        extra_feat: torch.Tensor | None = None,
    ) -> dict[str, torch.Tensor]:
        """Calculates the loss of the batch using stateless latent seeding."""
        batch_size, time_steps, n_features = x.shape
        x0_phys = x[:, 0, :]

        if self.aug_dim == 0:
            x0 = x0_phys
        else:
            # Check if the underlying model is a GRU-ODE network exposing an encode mechanism
            if hasattr(self.model, "func") and hasattr(self.model.func, "encode"):
                h0 = self.model.func.encode(x0_phys)
            else:
                # Fallback path for standard zero-augmented ANODE structures
                h0 = torch.zeros((batch_size, self.aug_dim), device=self.device)
            
            x0 = torch.cat((x0_phys, h0), dim=-1)

        if self.solver.adjoint:
            x_pred = AdjointMethod.apply(
                self.solver,
                self.model,
                x0,
                time_steps - 1,
                extra_feat,
                *tuple(self.model.parameters()),
            )[:, :, : n_features]
        else:
            x_pred = self.solver.integrate(
                func=self.model,
                x0=x0,
                steps=time_steps - 1,
                extra_feat=extra_feat,
            )[:, :, : n_features]

        x_pred = torch.nan_to_num(x_pred, nan=0.0)
        x = torch.nan_to_num(x, nan=0.0)

        return self.criterion(x_pred, x)

