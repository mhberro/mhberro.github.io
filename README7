#!/usr/bin/env python
# -*- coding: utf-8 -*-
r"""
export_gruode_onnx.py
=====================
Re-export a *already-trained* GRU-ODE checkpoint to ONNX WITHOUT retraining.

It reconstructs the exact model architecture your training run built,
loads the weights from the existing `.pt` checkpoint, and writes:

    <model>.onnx           - the ODE field graph, input=[y,h] -> output=[xdot,dh]
    <model>_encoder.onnx   - the encoder graph, input=y0 -> output=h0

The second graph is what the patched simple_sim needs to seed the latent state.
Nothing about the trained weights changes; this only produces graphs.

------------------------------------------------------------------------------
IMPORTANT: architecture must match the training run EXACTLY or weight-loading
fails. The values below are hard-coded to YOUR run:

    --frame geodesic --geodesic-mode integrated  -> model_states = 5
    --nhidden 200                                -> latent_dim   = max(10,100)=100
    5-state geodesic (non-DCU)                   -> enc_in_idx = [1,2,3,4]
                                                    pos_idx=[0,1], vel_idx=[2,4]
    --use-scalar                                 -> second-order scales from scaler

If you re-run this for a DIFFERENT model, re-check MODEL_STATES / NHIDDEN /
FRAME / the index blocks against NEXT_training.train_NEXT.
------------------------------------------------------------------------------

USAGE
    python export_gruode_onnx.py \
        --checkpoint model_outputs/SBI/GRUODE_mo_cl_heun_HighE7/GEODESIC/glide/HighE_HGV/NEXT_HighE_HGV_geodesic-integrated_glide_100000sr_1.0sec_200hid_0aug_16_scalarOn.pt \
        --scaler    <path to the pickled scaler used in training> \
        --training-module NEXT_training_mo_cl_ref_loss_new_agent_grdth_heun

`--scaler` is required only if you want the second-order (scaled-space) buffers
populated exactly as in training. If omitted, the model still exports and runs,
but the second-order velocity->position coupling uses the unscaled ratio path
(scaled_space=False); prefer passing the scaler so the export matches training
bit-for-bit.
"""

import argparse
import importlib
import os
import pickle
import re
import sys

import numpy as np
import torch


def _derive_from_name(checkpoint_path):
    """Sanity-parse the checkpoint filename and return (model_name, model_dir)."""
    model_dir = os.path.dirname(checkpoint_path)
    base = os.path.basename(checkpoint_path)
    # strip trailing .pt / .checkpoint.pt
    model_name = re.sub(r"\.checkpoint\.pt$", "", base)
    model_name = re.sub(r"\.pt$", "", model_name)
    return model_name, model_dir


def main():
    ap = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--checkpoint", required=True, help="Path to the trained .pt checkpoint")
    ap.add_argument("--scaler", default=None, help="Path to the pickled scaler used in training (recommended)")
    ap.add_argument(
        "--training-module",
        default="NEXT_training",
        help="Importable module name of your training script (without .py). "
        "Default: NEXT_training. For your run use "
        "NEXT_training_mo_cl_ref_loss_new_agent_grdth_heun",
    )
    ap.add_argument("--opset", type=int, default=18)
    # Architecture knobs, defaulted to YOUR run; override only for other models.
    ap.add_argument("--model-states", type=int, default=5)
    ap.add_argument("--nhidden", type=int, default=200)
    ap.add_argument("--frame", default="geodesic")
    args = ap.parse_args()

    if not os.path.exists(args.checkpoint):
        sys.exit(f"[fatal] checkpoint not found: {args.checkpoint}")

    model_name, model_dir = _derive_from_name(args.checkpoint)
    print(f"[info] model_name = {model_name}")
    print(f"[info] model_dir  = {model_dir}")

    # ---- import the training module so we reuse its EXACT classes ----------
    try:
        mod = importlib.import_module(args.training_module)
    except Exception as e:
        sys.exit(
            f"[fatal] could not import training module '{args.training_module}': {e}\n"
            "Run this script from the same directory as your training script, or "
            "pass --training-module with the correct importable name."
        )

    # Pull the classes/functions we need from YOUR module's namespace.
    try:
        GRUODEFunc = mod.GRUODEFunc
        GRUODEPredictorModel = mod.GRUODEPredictorModel
        NODEPredictor = mod.NODEPredictor
        FFNNArchitecture = mod.FFNNArchitecture
        Activation = mod.Activation
        TrainingConfiguration = mod.TrainingConfiguration
        AdamOptimizer = mod.AdamOptimizer
        TorchdiffeqSolver = mod.TorchdiffeqSolver
        WrappedMSELoss = mod.WrappedMSELoss
        EarlyStopper = mod.EarlyStopper
        ModelCheckpoint = mod.ModelCheckpoint
    except AttributeError as e:
        sys.exit(
            f"[fatal] training module is missing an expected symbol: {e}\n"
            "Your script may import these from submodules. If so, edit the "
            "imports at the top of THIS section to match where they live "
            "(e.g. `from gru_ode import GRUODEFunc`)."
        )

    frame = args.frame

    # ---- load the checkpoint tensors and UNWRAP nested dicts ---------------
    # Your .pt stores the state_dict one level down under a 'model' key, so a
    # naive load_state_dict sees only {'model': ...} and matches nothing. Unwrap
    # to the flat {param_name: tensor} dict.
    raw = torch.load(args.checkpoint, map_location="cpu")
    sd = raw
    for _ in range(4):  # peel a few possible nesting layers
        if isinstance(sd, dict) and len(sd) == 1 and isinstance(next(iter(sd.values())), dict):
            sd = next(iter(sd.values()))
            continue
        for k in ("model_state_dict", "state_dict", "model"):
            if isinstance(sd, dict) and k in sd and isinstance(sd[k], dict):
                sd = sd[k]
                break
        else:
            break
    if not isinstance(sd, dict) or not any("." in k for k in sd):
        sys.exit(f"[fatal] could not locate a flat state_dict inside {args.checkpoint}")
    print(f"[info] unwrapped state_dict with {len(sd)} tensors")

    # ---- DERIVE architecture from the checkpoint tensors (no guessing) -----
    # encoder.0.weight has shape (enc_hidden, enc_in); enc_in tells us exactly
    # how many inputs the encoder was built with.
    def _shape(name):
        t = sd.get(name)
        return tuple(t.shape) if t is not None else None

    enc0 = _shape("func.encoder.0.weight")
    if enc0 is None:
        sys.exit("[fatal] checkpoint has no func.encoder.0.weight; not a GRU-ODE model?")
    enc_hidden, enc_in = enc0
    # latent width = encoder's final output = decoder input = cell hidden size
    latent_from_dec = _shape("func.decoder.0.weight")   # (enc_hidden, latent_dim)
    latent_dim = latent_from_dec[1] if latent_from_dec else _shape("func.encoder.3.weight")[0]
    # physical state width = decoder final output
    dec_last = None
    for k in sd:
        if re.match(r"func\.decoder\.\d+\.weight$", k):
            dec_last = k
    model_states = _shape(dec_last)[0]

    # encoder_input_idx is stored as a buffer; recover it verbatim.
    if "func.encoder_input_idx" in sd:
        enc_in_idx = sd["func.encoder_input_idx"].tolist()
    else:
        enc_in_idx = list(range(model_states)) if enc_in == model_states else None

    # pos_idx / vel_idx / second-order buffers, if the checkpoint has them.
    pos_idx = sd["pos_idx"].tolist() if "pos_idx" in sd else None
    vel_idx = sd["vel_idx"].tolist() if "vel_idx" in sd else None

    minimal = "func.cell.lin_hf.weight" in sd  # MinimalGRUODECell has lin_hf/lin_hh

    print(f"[info] derived from checkpoint: model_states={model_states}, "
          f"latent_dim={latent_dim}, enc_in={enc_in}, "
          f"enc_in_idx={enc_in_idx}, pos_idx={pos_idx}, vel_idx={vel_idx}, "
          f"minimal={minimal}")
    print(f"[info] field width = {model_states + latent_dim}")
    nhidden = enc_hidden  # for building the encoder/decoder hidden layers

    # ---- optional scaler for second-order (scaled-space) buffers -----------
    scaler_traj = None
    if args.scaler:
        if not os.path.exists(args.scaler):
            sys.exit(f"[fatal] --scaler given but not found: {args.scaler}")
        with open(args.scaler, "rb") as f:
            scaler_traj = pickle.load(f)
        print(f"[info] loaded scaler: {args.scaler}")

    so_pos_scale = so_vel_scale = so_vel_mean = None
    if scaler_traj is not None and pos_idx is not None:
        so_pos_scale = scaler_traj.scale_[pos_idx]
        so_vel_scale = scaler_traj.scale_[vel_idx]
        so_vel_mean = scaler_traj.mean_[vel_idx]

    # ---- build the field + predictor exactly as train_NEXT does ------------
    gruode_func = GRUODEFunc(
        state_vector_len=model_states,
        nhidden=nhidden,
        latent_dim=latent_dim,
        minimal=minimal,
        encoder_input_idx=enc_in_idx,
        encoder_dropout=0.1,
        cell_input_size=model_states,
    )
    model = GRUODEPredictorModel(
        func=gruode_func,
        pos_idx=pos_idx,
        vel_idx=vel_idx,
        pos_scale=so_pos_scale,
        vel_scale=so_vel_scale,
        vel_mean=so_vel_mean,
    )

    # ---- wrap in the NODEPredictor so node.load() matches training ---------
    training_configuration = TrainingConfiguration(
        n_epochs=1,
        optimizer=AdamOptimizer(learning_rate=1e-3),
        batch_size=16,
        num_workers=1,
        verbose=False,
    )
    ode_solver = TorchdiffeqSolver(dt=1.0, method="rk4", adjoint=False, substeps=4)
    loss_func = WrappedMSELoss(
        height_idx=1,
        vel_indices=(2, 3, 4),
        scaler=scaler_traj,
        N_FEATURES=model_states,
        position_loss_weight=80.0,
        l2_reg=1e-4,
    )
    node = NODEPredictor(
        architecture=FFNNArchitecture(layer_channels=[5, 5], layer_activation=Activation.SILU),
        training_configuration=training_configuration,
        solver=ode_solver,
        logging_interval=5,
        loss_func=loss_func,
        early_stopper=EarlyStopper(60, 1e-2, metric_name="val_loss"),
        checkpoint=ModelCheckpoint(min_epochs=1, directory=model_dir, model_name=model_name + ".checkpoint"),
        aug_dim=latent_dim,
    )
    node.device = torch.device("cpu")
    node.model = model.to(node.device)
    node.aug_dim = latent_dim

    # ---- load the trained weights from the already-unwrapped sd ------------
    # We built the architecture FROM this checkpoint's tensor shapes, so the
    # load must be exact. strict=True: if anything is missing/unexpected/
    # mismatched we ABORT rather than silently export random weights (which is
    # what happened before). A clean load is the guarantee the ONNX is real.
    missing, unexpected = node.model.load_state_dict(sd, strict=False)
    # Filter out non-persistent buffers that legitimately may differ; but any
    # weight/bias miss is fatal.
    hard_missing = [k for k in missing if k.endswith((".weight", ".bias")) or k in ("so_ratio", "so_offset")]
    hard_unexpected = [k for k in unexpected if k.endswith((".weight", ".bias"))]
    if hard_missing or hard_unexpected:
        sys.exit(
            "[fatal] state_dict did not load cleanly — refusing to export random "
            f"weights.\n  missing: {hard_missing}\n  unexpected: {hard_unexpected}\n"
            "The reconstructed architecture does not match the checkpoint. "
            "Check model_states/latent_dim/enc_in_idx above against training."
        )
    if missing or unexpected:
        # Non-fatal (buffers registered at build time, index tensors, etc.)
        print(f"[info] load: {len(missing)} non-critical missing, "
              f"{len(unexpected)} non-critical unexpected (buffers/indices)")
    print("[ok] trained weights loaded cleanly")

    node.model.train(False)
    node.model.eval()

    # ---- export the field graph via the t-binding adapter ------------------
    class _AutonomousFieldExport(torch.nn.Module):
        def __init__(self, m):
            super().__init__()
            self.m = m

        def forward(self, state):
            t0 = torch.zeros((), dtype=state.dtype, device=state.device)
            return self.m(t0, state)

    field_out = os.path.join(model_dir, model_name + ".onnx")
    example_state = torch.zeros(model_states + latent_dim, dtype=torch.float32)
    torch.onnx.export(
        _AutonomousFieldExport(node.model).eval(),
        example_state,
        field_out,
        export_params=True,
        opset_version=args.opset,
        external_data=False,
        input_names=["input"],
        output_names=["output"],
    )
    print(f"[ok] wrote field graph:   {field_out}")

    # ---- export the encoder graph ------------------------------------------
    class _EncoderExport(torch.nn.Module):
        def __init__(self, func):
            super().__init__()
            self.func = func

        def forward(self, y0):
            return self.func.encode(y0)

    enc_out = os.path.join(model_dir, model_name + "_encoder.onnx")
    example_y0 = torch.zeros(model_states, dtype=torch.float32)
    torch.onnx.export(
        _EncoderExport(node.model.func).eval(),
        example_y0,
        enc_out,
        export_params=True,
        opset_version=args.opset,
        external_data=False,
        input_names=["y0"],
        output_names=["h0"],
    )
    print(f"[ok] wrote encoder graph: {enc_out}")

    # ---- quick self-check: run both graphs once ----------------------------
    try:
        import onnxruntime as ort

        enc = ort.InferenceSession(enc_out)
        fld = ort.InferenceSession(field_out)
        # Both graphs were traced with 1-D example inputs, so feed 1-D here —
        # this is exactly how the sim must call them.
        y0 = np.zeros((model_states,), dtype=np.float32)
        h0 = enc.run(["h0"], {"y0": y0})[-1].reshape(-1)
        assert h0.shape[0] == latent_dim, (h0.shape, latent_dim)
        state = np.concatenate([y0, h0]).astype(np.float32)
        out = fld.run(["output"], {"input": state})[-1].reshape(-1)
        assert out.shape[0] == model_states + latent_dim, (out.shape, model_states + latent_dim)
        print(
            f"[ok] self-check passed: encoder h0 width={h0.shape[0]}, "
            f"field output width={out.shape[0]}"
        )
    except ImportError:
        print("[info] onnxruntime not installed here; skipping self-check.")
    except Exception as e:
        print(f"[warn] self-check raised: {e}")

    print("[done] re-export complete. Point simple_sim at the .onnx above; "
          "it will find the _encoder.onnx automatically.")


if __name__ == "__main__":
    main()
