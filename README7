"""
SECOND-ORDER GRU-ODE: changes to apply to your NEXT_training GRU-ODE script.

This enforces the kinematic identity  d/dt(position) = velocity  STRUCTURALLY
at the decoder output of GRUODELatentModel, the latent-model analog of the
`order_shift_slice` trick that ODEfunc/sonode use in physical space.

Mechanism
---------
GRUODELatentModel produces the physical derivative xdot = J_dec(h) . hdot.
Instead of trusting the decoder JVP for the position-block derivatives, we
OVERWRITE them with the velocity components of the CURRENT physical state x:

        xdot[pos_idx[i]]  :=  x[vel_idx[i]]        (exact: dpos/dt = vel)
        xdot[vel_idx[i]]  :=  J_dec(h).hdot[...]   (network-learned acceleration)
        xdot[aux_idx]     :=  J_dec(h).hdot[...]   (unchanged; e.g. GRDTH VTheta)

So the network only has to learn accelerations (and any uncoupled aux-state
rates); position/velocity consistency is built in and cannot drift. This makes
the PhysicsSplitMSELoss physics_weight redundant — set it to 0.0 when using a
second-order model (keep vel_weight).

The (pos_idx, vel_idx) pairing is passed explicitly so it is correct for BOTH
the balanced geodesic/DCU layout and the unbalanced GRDTH layout:

    geodesic / dcu : pos_idx=[0,1,2], vel_idx=[3,4,5]   (aux: none)
    grdth          : pos_idx=[0,1],   vel_idx=[2,3]      (aux: [4] = VTheta)

The override is a pure gather/scatter of tensor slices — fully ONNX-traceable,
no autograd tricks — so the export adapter applies the same rule.
"""

import torch


# =====================================================================
# 1) REPLACE GRUODELatentModel.__init__ and add the second-order plumbing.
#    (Full replacement of the class __init__ and forward/_field shown below.)
# =====================================================================
class GRUODELatentModel(torch.nn.Module):
    """GRU-ODE as a physical-space vector field, drop-in for ODEfunc, with an
    optional structural second-order constraint dpos/dt = vel.

    New args:
        pos_idx, vel_idx : paired index lists. xdot[pos_idx[i]] is forced to
                           x[vel_idx[i]]. If either is None, the constraint is
                           OFF and the model behaves exactly as before.
    """

    def __init__(
        self,
        func,                 # GRUODEFunc
        solver=None,
        aug_dim: int = 0,
        pos_idx: list[int] | None = None,
        vel_idx: list[int] | None = None,
    ):
        super().__init__()
        self.func = func
        self.aug_dim = aug_dim
        # second-order coupling (None => disabled, original behaviour)
        self.second_order = pos_idx is not None and vel_idx is not None
        if self.second_order:
            assert len(pos_idx) == len(vel_idx), "pos_idx and vel_idx must pair up"
            self.register_buffer("pos_idx", torch.tensor(list(pos_idx), dtype=torch.long))
            self.register_buffer("vel_idx", torch.tensor(list(vel_idx), dtype=torch.long))
        else:
            self.pos_idx = None
            self.vel_idx = None

    def _field(self, t, x_phys: torch.Tensor) -> torch.Tensor:
        h = self.func.encode(x_phys)
        dh = self.func.cell(t, h)
        _, xdot = _decoder_jvp(self.func.decode, h, dh)  # noqa: F821 (defined in your script)
        if self.second_order:
            # Force dpos/dt = vel(current state). index_copy on the last dim,
            # out-of-place so autograd stays clean and ONNX traces it.
            vel_now = x_phys.index_select(-1, self.vel_idx)
            xdot = xdot.index_copy(-1, self.pos_idx, vel_now)
        return xdot

    def forward(self, t, x: torch.Tensor) -> torch.Tensor:
        if self.aug_dim > 0 and x.shape[-1] > self.func.state_vector_len:
            x_core = x.narrow(-1, 0, self.func.state_vector_len)
            xdot_core = self._field(t, x_core)
            pad = torch.zeros(
                *xdot_core.shape[:-1], self.aug_dim, dtype=xdot_core.dtype, device=xdot_core.device
            )
            return torch.cat((xdot_core, pad), dim=-1)
        return self._field(t, x)


# =====================================================================
# 2) REPLACE GRUODEFieldForONNX.forward to apply the SAME constraint, so the
#    exported field matches the trained field exactly.
# =====================================================================
class GRUODEFieldForONNX(torch.nn.Module):
    def __init__(
        self,
        func,                 # GRUODEFunc
        state_vector_len: int,
        aug_dim: int = 0,
        eps: float = 1e-4,
        pos_idx: list[int] | None = None,
        vel_idx: list[int] | None = None,
    ):
        super().__init__()
        self.func = func
        self.state_vector_len = state_vector_len
        self.aug_dim = aug_dim
        self.eps = eps
        self.second_order = pos_idx is not None and vel_idx is not None
        if self.second_order:
            self.register_buffer("pos_idx", torch.tensor(list(pos_idx), dtype=torch.long))
            self.register_buffer("vel_idx", torch.tensor(list(vel_idx), dtype=torch.long))

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        if self.aug_dim > 0 and x.shape[-1] > self.state_vector_len:
            x_phys = x.narrow(-1, 0, self.state_vector_len)
        else:
            x_phys = x
        h = self.func.encode(x_phys)
        dh = self.func.cell(0.0, h)
        x_plus = self.func.decode(h + self.eps * dh)
        x_minus = self.func.decode(h - self.eps * dh)
        xdot = (x_plus - x_minus) / (2.0 * self.eps)
        if self.second_order:
            vel_now = x_phys.index_select(-1, self.vel_idx)
            xdot = xdot.index_copy(-1, self.pos_idx, vel_now)
        return xdot
