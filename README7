# gru_ode.py
"""Continuous-time GRU-ODE cell for kinematic trajectory forecasting."""

from __future__ import annotations

import torch
from torch import nn


class FullGRUODECell(nn.Module):
    def __init__(self, hidden_size: int, input_size: int = 0, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.input_size = input_size
        self.lin_hrz = nn.Linear(hidden_size, 2 * hidden_size, bias=False)
        self.lin_hg = nn.Linear(hidden_size, hidden_size, bias=False)
        if input_size > 0:
            self.lin_xrz = nn.Linear(input_size, 2 * hidden_size, bias=bias)
            self.lin_xg = nn.Linear(input_size, hidden_size, bias=bias)
        else:
            if bias:
                self.bias_rz = nn.Parameter(torch.zeros(2 * hidden_size))
                self.bias_g = nn.Parameter(torch.zeros(hidden_size))
            else:
                self.register_parameter("bias_rz", None)
                self.register_parameter("bias_g", None)

    def forward(self, t, h: torch.Tensor, x: torch.Tensor | None = None) -> torch.Tensor:
        pre_rz = self.lin_hrz(h)
        if self.input_size > 0:
            pre_rz = pre_rz + self.lin_xrz(x)
        elif self.bias_rz is not None:
            pre_rz = pre_rz + self.bias_rz
        r, z = torch.sigmoid(pre_rz).chunk(2, dim=-1)

        pre_g = self.lin_hg(r * h)
        if self.input_size > 0:
            pre_g = pre_g + self.lin_xg(x)
        elif self.bias_g is not None:
            pre_g = pre_g + self.bias_g
        g = torch.tanh(pre_g)

        return (1.0 - z) * (g - h)


class MinimalGRUODECell(nn.Module):
    def __init__(self, hidden_size: int, input_size: int = 0, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.input_size = input_size
        self.lin_hf = nn.Linear(hidden_size, hidden_size, bias=False)
        self.lin_hh = nn.Linear(hidden_size, hidden_size, bias=False)
        if input_size > 0:
            self.lin_xf = nn.Linear(input_size, hidden_size, bias=bias)
            self.lin_xh = nn.Linear(input_size, hidden_size, bias=bias)
        else:
            self.bias_f = torch.nn.Parameter(torch.zeros(hidden_size)) if bias else None
            self.bias_h = torch.nn.Parameter(torch.zeros(hidden_size)) if bias else None

    def forward(self, t, h: torch.Tensor, x: torch.Tensor | None = None) -> torch.Tensor:
        pre_f = self.lin_hf(h)
        if self.input_size > 0:
            pre_f = pre_f + self.lin_xf(x)
        elif self.bias_f is not None:
            pre_f = pre_f + self.bias_f
        f = torch.sigmoid(pre_f)

        pre_h = self.lin_hh(f * h)
        if self.input_size > 0:
            pre_h = pre_h + self.lin_xh(x)
        elif self.bias_h is not None:
            pre_h = pre_h + self.bias_h
        g = torch.tanh(pre_h)

        return (1.0 - f) * (g - h)


class GRUBayesCell(nn.Module):
    def __init__(self, hidden_size: int, obs_dim: int, prep_hidden: int = 4, bias: bool = True):
        super().__init__()
        self.hidden_size = hidden_size
        self.obs_dim = obs_dim
        self.prep_hidden = prep_hidden
        self.w_prep = nn.Parameter(0.01 * torch.randn(obs_dim, 4, prep_hidden))
        self.b_prep = nn.Parameter(torch.zeros(obs_dim, prep_hidden))
        self.gru = nn.GRUCell(obs_dim * prep_hidden, hidden_size, bias=bias)

    def forward(
        self,
        h: torch.Tensor,
        y: torch.Tensor,
        mask: torch.Tensor,
        mu: torch.Tensor,
        logvar: torch.Tensor,
    ) -> torch.Tensor:
        sigma = torch.exp(0.5 * logvar)
        error = (y - mu) / (sigma + 1e-6)
        feats = torch.stack([mu, sigma, y, error], dim=-1)
        prepped = torch.relu(torch.einsum("boi,oih->boh", feats, self.w_prep) + self.b_prep)
        prepped = prepped * mask.unsqueeze(-1)
        prepped = prepped.reshape(prepped.shape[0], -1)
        return self.gru(prepped, h)


class GRUODEFunc(nn.Module):
    ORDER = "y_first"

    def __init__(
        self,
        state_vector_len: int,
        nhidden: int,
        latent_dim: int | None = None,
        minimal: bool = False,
        encoder_hidden: int | None = None,
        encoder_input_idx: list[int] | None = None,
        encoder_dropout: float = 0.1,
    ):
        super().__init__()
        self.state_vector_len = state_vector_len
        self.latent_dim = latent_dim if latent_dim is not None else max(2 * state_vector_len, nhidden)
        enc_h = encoder_hidden if encoder_hidden is not None else nhidden

        if encoder_input_idx is None:
            encoder_input_idx = list(range(state_vector_len))
        self.register_buffer("encoder_input_idx", torch.tensor(list(encoder_input_idx), dtype=torch.long))
        enc_in = len(encoder_input_idx)

        # Expose active dropout on the initial mapping layer to satisfy Fix C
        if encoder_dropout > 0.0:
            self.encoder = nn.Sequential(
                nn.Linear(enc_in, enc_h),
                nn.SiLU(),
                nn.Dropout(p=encoder_dropout),
                nn.Linear(enc_h, self.latent_dim),
                nn.Tanh(),
            )
        else:
            self.encoder = nn.Sequential(
                nn.Linear(enc_in, enc_h),
                nn.SiLU(),
                nn.Linear(enc_h, self.latent_dim),
                nn.Tanh(),
            )
        self.encoder_dropout = float(encoder_dropout)

        cell_cls = MinimalGRUODECell if minimal else FullGRUODECell
        self.cell = cell_cls(hidden_size=self.latent_dim, input_size=0, bias=True)
        
        self.decoder = nn.Sequential(
            nn.Linear(self.latent_dim, enc_h),
            nn.SiLU(),
            nn.Linear(enc_h, state_vector_len),
        )
        self.nfe = 0

    def forward(self, t, h: torch.Tensor) -> torch.Tensor:
        return self.cell(t, h)

    def encode(self, x_phys: torch.Tensor) -> torch.Tensor:
        x_sel = x_phys.index_select(-1, self.encoder_input_idx)
        return self.encoder(x_sel)

    def decode(self, h: torch.Tensor) -> torch.Tensor:
        return self.decoder(h)


class GRUODEPredictorModel(nn.Module):
    def __init__(
        self,
        func: GRUODEFunc,
        pos_idx: list[int] | None = None,
        vel_idx: list[int] | None = None,
        pos_scale=None,
        vel_scale=None,
        vel_mean=None,
        physics=None,
    ):
        """Production wrapper implementing a stateless continuous integration field.

        `physics` is an optional ScaledPhysicsField implementing the fused model
            xdot = f_physics(y) + f_residual(y, h)
        It consumes the SCALED physical state and returns a SCALED derivative,
        so it drops straight into the existing scaled-space pipeline. When None
        (the default) behaviour is bit-identical to the pure-neural model.
        """
        super().__init__()
        self.func = func
        self.physics = physics
        self.use_physics = physics is not None
        self.n_features = func.state_vector_len
        self.hidden_size = func.latent_dim
        self.second_order = pos_idx is not None and vel_idx is not None
        
        if self.second_order:
            self.register_buffer("pos_idx", torch.tensor(list(pos_idx), dtype=torch.long))
            self.register_buffer("vel_idx", torch.tensor(list(vel_idx), dtype=torch.long))
            if pos_scale is not None and vel_scale is not None:
                ratio = torch.as_tensor(vel_scale, dtype=torch.float32) / torch.as_tensor(
                    pos_scale, dtype=torch.float32
                )
                offset = (
                    torch.as_tensor(vel_mean, dtype=torch.float32)
                    / torch.as_tensor(pos_scale, dtype=torch.float32)
                    if vel_mean is not None
                    else torch.zeros_like(ratio)
                )
                self.register_buffer("so_ratio", ratio)
                self.register_buffer("so_offset", offset)
                self.scaled_space = True
            else:
                self.scaled_space = False

    def forward(self, t, state: torch.Tensor) -> torch.Tensor:
        self.func.nfe += 1
        
        # Unpack the absolute physical and latent partitions directly from the solver state
        y_read = state[..., : self.n_features]
        h = state[..., self.n_features : self.n_features + self.hidden_size]

        # Enforce analytical bounding constraints cleanly on every evaluation step
        h = torch.tanh(h)
        dh = self.func.cell(t, h)
        xdot = self.func.decode(h)

        # ---- fused physics term -------------------------------------------
        # xdot = f_physics(y) + f_residual(y, h). The neural decoder output is
        # now the RESIDUAL: what physics cannot express (principally maneuvers).
        #
        # Added BEFORE the second-order index_copy so the exact position-row
        # identities still win: PhysicsField writes zeros to rows s and h, and
        # index_copy overwrites them regardless, so there is no double-count.
        #
        # Stateless: no module-state mutation here, so autograd/adjoint hold.
        if self.use_physics:
            xdot = xdot + self.physics(y_read)

        if self.second_order:
            vel_now = y_read.index_select(-1, self.vel_idx)
            if getattr(self, "scaled_space", False):
                vel_now = vel_now * self.so_ratio + self.so_offset
            pos_deriv = vel_now
            xdot = xdot.index_copy(-1, self.pos_idx, pos_deriv)

        return torch.cat((xdot, dh), dim=-1)
