#verify_mdn_numpy
"""Torch-free verification of the MDN model's numerical core (integration,
bounding, scaling), mirroring mdn_trajectory_model.py exactly in numpy."""
import numpy as np

rng = np.random.default_rng(0)

# config mirrors a 6-state [x,y,z,vx,vy,vz] drone frame
D, A, K, T, H, B = 6, 3, 5, 20, 8, 4
pos_idx = np.array([0, 1, 2]); vel_idx = np.array([3, 4, 5])
dt = 0.1
sig_p = np.array([50.0, 50.0, 30.0])     # StandardScaler sigmas (m)
sig_v = np.array([12.0, 12.0, 8.0])      # (m/s)
mu_v = np.array([1.0, -0.5, 0.0])        # velocity means
a_max_phys = np.array([40.0, 40.0, 40.0])
a_max_scaled = a_max_phys / sig_v

# ---- 1) acceleration bounding: |a_phys| <= a_max_phys always ----
raw = rng.normal(size=(B, K, T, A)) * 5.0   # large pre-activations
accel_scaled = a_max_scaled.reshape(1, 1, 1, A) * np.tanh(raw)
accel_phys = accel_scaled * sig_v.reshape(1, 1, 1, A)
assert np.all(np.abs(accel_phys) <= a_max_phys.reshape(1, 1, 1, A) + 1e-9)
print(f"[1] bounded accel: max |a_phys| = {np.abs(accel_phys).max():.2f} "
      f"<= a_max = {a_max_phys.max():.0f} m/s^2  OK")

# ---- 2) integration correctness: recover a known constant-accel path ----
# Physical ground truth: constant physical acceleration, integrate analytically.
a_const_phys = np.array([3.0, -2.0, 1.0])                 # m/s^2
p0_phys = np.array([100.0, 200.0, 50.0])
v0_phys = np.array([10.0, -5.0, 2.0])
# scaled ICs (StandardScaler: scaled = (phys - mean)/sigma; use pos mean 0 for simplicity)
mu_p = np.zeros(A)
x_last = np.zeros(D)
x_last[pos_idx] = (p0_phys - mu_p) / sig_p
x_last[vel_idx] = (v0_phys - mu_v) / sig_v

# feed constant scaled accel = a_const_phys/sig_v to the SAME loop as the model
a_s_const = (a_const_phys / sig_v).reshape(1, 1, 1, A) * np.ones((B, K, T, A))
p = np.broadcast_to((x_last[pos_idx]).reshape(1, 1, A), (B, K, A)).copy()
v = np.broadcast_to((x_last[vel_idx]).reshape(1, 1, A), (B, K, A)).copy()
pos_steps, vel_steps = [], []
for t in range(T):
    v = v + a_s_const[:, :, t, :] * dt
    v_phys = v * sig_v.reshape(1, 1, A) + mu_v.reshape(1, 1, A)
    p = p + (v_phys / sig_p.reshape(1, 1, A)) * dt
    pos_steps.append(p.copy()); vel_steps.append(v.copy())
pos = np.stack(pos_steps, axis=2)  # (B,K,T,A) scaled
vel = np.stack(vel_steps, axis=2)

# analytic physical reference (semi-implicit Euler, matching the loop's v-then-p)
pos_ref = np.zeros((T, A)); vel_ref = np.zeros((T, A))
pp, vv = p0_phys.copy(), v0_phys.copy()
for t in range(T):
    vv = vv + a_const_phys * dt
    pp = pp + vv * dt
    vel_ref[t] = vv; pos_ref[t] = pp
# convert model output back to physical and compare
pos_model_phys = pos[0, 0] * sig_p + mu_p
vel_model_phys = vel[0, 0] * sig_v + mu_v
assert np.allclose(pos_model_phys, pos_ref, atol=1e-9), np.abs(pos_model_phys - pos_ref).max()
assert np.allclose(vel_model_phys, vel_ref, atol=1e-9)
print(f"[2] kinematic integration matches analytic constant-accel path to "
      f"{np.abs(pos_model_phys - pos_ref).max():.2e} m  OK")

# ---- 3) mixture-mean shape + convex-combination property ----
log_pi = rng.normal(size=(B, K))
log_pi = log_pi - np.log(np.exp(log_pi).sum(axis=1, keepdims=True))  # log-softmax
pi = np.exp(log_pi)
assert np.allclose(pi.sum(axis=1), 1.0)
traj = rng.normal(size=(B, K, T, D))
mean = (pi.reshape(B, K, 1, 1) * traj).sum(axis=1)  # (B,T,D)
assert mean.shape == (B, T, D)
# mean must lie within the per-element convex hull of the modes
lo, hi = traj.min(axis=1), traj.max(axis=1)
assert np.all(mean >= lo - 1e-9) and np.all(mean <= hi + 1e-9)
print(f"[3] mixture-mean shape {mean.shape}, lies in convex hull of modes  OK")

# ---- 4) mixture NLL sanity: closer/tighter mode -> lower NLL ----
def mixture_nll(mode_pos, tgt_pos, log_pi, log_sig):
    B, K, T, A = mode_pos.shape
    sig = np.exp(log_sig).reshape(B, K, 1, A)
    diff = mode_pos - tgt_pos[:, None]
    lp = -0.5 * (diff / sig) ** 2 - np.log(sig) - 0.5 * np.log(2 * np.pi)
    lp_mode = lp.sum(axis=(2, 3))
    from scipy.special import logsumexp
    return -logsumexp(log_pi + lp_mode, axis=1).mean()

tgt = rng.normal(size=(B, T, A))
mode_good = np.broadcast_to(tgt[:, None], (B, K, T, A)).copy()  # one mode = target
mode_bad = mode_good + 2.0
ls = np.zeros((B, K, A))  # sigma=1
nll_good = mixture_nll(mode_good, tgt, log_pi, ls)
nll_bad = mixture_nll(mode_bad, tgt, log_pi, ls)
assert nll_good < nll_bad
print(f"[4] mixture NLL rewards matching mode: good={nll_good:.2f} < bad={nll_bad:.2f}  OK")

print("\nALL MDN CHECKS PASSED")
