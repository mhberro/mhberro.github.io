def main():
    parser = argparse.ArgumentParser(
        description="Training script for creating NEXT models",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument(
        "--tgt-data-paths",
        default=[],
        type=str,
        nargs="+",
        help="A list of directories where training data can be found. Data will be test/train split if validation data is not provided. It is suggested that the final directory in the path be named for the target. Ex: datasets/train/PrSM",
    )
    parser.add_argument(
        "--validation-data-paths",
        default=[],
        type=str,
        nargs="+",
        help="A list of directories where validation data can be found. Helpful for when the test/train split has already been done. Ex: datasets/test/PrSM",
    )
    parser.add_argument(
        "--sr",
        default=100000,
        type=int,
        help="The maximum slant range to trim data at. All data less than this value will be used. [meters]",
    )
    parser.add_argument(
        "-o",
        default="model_outputs",
        type=str,
        help="Directory to place pickles, JSON, checkpoints, ModelProto, and ONNX files related to the model",
    )
    parser.add_argument(
        "--use-scalar",
        default=False,
        action="store_true",
        help="Enable training with a scalar",
    )
    parser.add_argument(
        "--frame",
        default="dcu",
        choices=["dcu", "grdth", "geodesic"],
        help="Select which frame to put the data in for training the model",
    )
    parser.add_argument(
        "--sbi-phase",
        default="boost",
        choices=["boost", "glide"],
        help="Select which SBI phase to train a model for",
    )
    parser.add_argument(
        "--nhidden",
        default=200,
        type=int,
        help="The size of the hidden layers of the MLP/FFNN",
    )
    parser.add_argument(
        "--aug",
        default=0,
        type=int,
        help="The size of the zeros augmented to the initial states",
        dest="aug_dim",
    )
    parser.add_argument(
        "--gpuidx",
        default=0,
        type=int,
        help="The index of the gpu to use",
        dest="gpu_index",
    )
    # UPDATED: Added "gruodebayes" to choices and appended to documentation
    parser.add_argument(
        "--model-type",
        default="node",
        choices=["node", "anode", "sonode", "latentode", "gruodebayes"],
        help="Which ODE architecture to train: regular NODE, Augmented NODE, Second-Order NODE, Latent-ODE, or GRU-ODE-Bayes.",
    )
    parser.add_argument(
        "--dt",
        default=0.1,
        type=float,
        help="The delta time to use for resampling the truth trajectory to align the time grid",
    )

    args = parser.parse_args()

    model_states = 6  # this is 6 for ImpAntiHeadDCU and 5 for GRDTH
    if args.frame in ("grdth",):  
        model_states = 5

    trajectory_dt = args.dt  # [s]

    seed = 47
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

    target_strs = [Path(x).name for x in args.tgt_data_paths]
    model_name_target_str = "+".join(target_strs)
    model_path = args.o
    model_save_path = os.path.join(model_path, model_name_target_str)

    batch_size = 512  # increase the number when more RAM is available
    if HAVE_HIGH_MEMORY:
        batch_size = 1024

    # UPDATED: Added {args.model_type} into the string pattern to prevent execution run collisions
    model_name_wo_epochs = f"NEXT_{model_name_target_str}_{args.model_type}_{args.frame}_{args.sbi_phase}_{int(args.sr / 1000)}sr_{trajectory_dt}sec_{args.nhidden}hid_{args.aug_dim}aug_{batch_size}"
    if args.use_scalar:
        model_name_wo_epochs = model_name_wo_epochs + "_scalarOn"

    model_name = f"{model_name_wo_epochs}"

    # load data
    traj_targets_train = []
    traj_targets_test = []
    
    if len(args.validation_data_paths) == 0:
        for tgt_data_path in args.tgt_data_paths:
            traj_targets = load_data_dir(tgt_data_path, trajectory_dt, args, do_prep=False)
            traj_targets_train_one_tgt, traj_targets_test_one_tgt = train_test_split(
                traj_targets, test_size=0.2, random_state=26525
            )
            traj_targets_train.extend(traj_targets_train_one_tgt)
            traj_targets_test.extend(traj_targets_test_one_tgt)
    else:
        print("split already done")
        for tgt_data_path in args.tgt_data_paths:
            traj_targets_train.extend(load_data_dir(tgt_data_path, trajectory_dt, args))
        for tgt_data_path in args.validation_data_paths:
            traj_targets_test.extend(load_data_dir(tgt_data_path, trajectory_dt, args))

    print(
        f"There are {len(traj_targets_train)} training trajs and {len(traj_targets_test)} validation trajs. "
        f"There will be {(len(traj_targets_train) // batch_size) + 1} batch(es) for training and "
        f"{(len(traj_targets_test) // batch_size) + 1} for validation"
    )

    # split the trajectory data from the metadata
    traj_targets_train, traj_targets_train_traj_numbers = zip(*traj_targets_train)
    traj_targets_test, traj_targets_test_traj_numbers = zip(*traj_targets_test)
    
    split_dict = {
        "train": traj_targets_train_traj_numbers,
        "test": traj_targets_test_traj_numbers,
    }
    os.makedirs(os.path.join(model_path, model_name_target_str), exist_ok=True)
    with open(
        os.path.join(model_path, model_name_target_str, f"{model_name_wo_epochs}_train_test_split.json"),
        "w",
        encoding="utf-8",
    ) as f:
        json.dump(split_dict, f)

    phase_to_model = args.sbi_phase
    traj_targets_train = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_train]
    traj_targets_test = [sbi_trajectory_prep(x, phase_to_model, trajectory_dt, args) for x in traj_targets_test]

    traj_targets_train = list(filter(lambda x: x is not None, traj_targets_train))
    traj_targets_test = list(filter(lambda x: x is not None, traj_targets_test))

    time_series_point_count = [x.shape[0] for x in traj_targets_train + traj_targets_test]
    if any(x < 10 for x in time_series_point_count):
        raise ValueError(
            "Some of the training or test data has less than 10 time series points. Consider changing the trajectory_dt or extending to a further slant range",
            time_series_point_count,
        )

    traj_targets_train_posvel = [torch.Tensor(x[:, 1 : model_states + 1]) for x in traj_targets_train]
    traj_targets_test_posvel = [torch.Tensor(x[:, 1 : model_states + 1]) for x in traj_targets_test]

    if any([torch.isnan(x).any() for x in traj_targets_train_posvel]) or any(
        [torch.isnan(x).any() for x in traj_targets_test_posvel]
    ):
        print("traj_targets_train_posvel", traj_targets_train)
        print("traj_targets_test_posvel", traj_targets_test)
        raise ValueError(
            "There are NaN(s) in the training or validation data. See the data dump above for where the NaN(s) are."
        )

    stacked_posvel = np.vstack(traj_targets_train_posvel)
    column_names = ["Down", "Cross", "Up", "dotD", "dotC", "dotU"]
    if args.frame == "grdth":
        column_names = ["GR", "Down", "dotGR", "dotD", "VTheta"]
        
    plot_column_distributions(
        stacked_posvel,
        column_names=column_names,
        data_path=str(Path(model_path, model_name_target_str, model_name_wo_epochs)),
    )
    plot_correlation_matrix(
        stacked_posvel,
        column_names=column_names,
        data_path=str(Path(model_path, model_name_target_str, model_name_wo_epochs)),
    )

    scaler_traj = create_scalar(traj_targets_train_posvel, model_save_path, model_name_wo_epochs)

    # This call now cleanly passes args.model_type = "gruodebayes" down into the refactored training loop
    (node, model_name) = train_NEXT(
        model_name=model_name,
        traj_targets_train=traj_targets_train_posvel,
        traj_targets_test=traj_targets_test_posvel,
        scaler_traj=scaler_traj,
        model_save_path=model_save_path,
        trajectory_dt=trajectory_dt,
        batch_size=batch_size,
        use_scalar=args.use_scalar,
        model_states=model_states,
        aug_dim=args.aug_dim,
        nhidden=args.nhidden,
        gpu_index=args.gpu_index,
        model_type=args.model_type,
        frame=args.frame,
    )
