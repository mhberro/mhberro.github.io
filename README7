    # Use node.aug_dim to ensure example inputs match the expanded state register
    if isinstance(ode_solver, TorchdiffeqSolver):
        example_input = (
            None,
            torch.cat((scaled_traj_targets_train_posvel[0][0], torch.zeros(node.aug_dim))).to(node.device),
        )
    else:
        example_input = torch.cat((scaled_traj_targets_train_posvel[0][0], torch.zeros(node.aug_dim))).to(node.device)
        
    model_onx = torch.onnx.export(
        node.model,
        example_input,
        os.path.join(model_save_path, model_name + ".onnx"),
