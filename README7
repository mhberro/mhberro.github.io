from copy import deepcopy

import numpy as np
import numba


# copying coordinate transforms from IBCS Tools
FLATTENING = 1.0 / 298.2572235630
SEMI_MAJOR_AXIS = 6378137.0
SEMI_MINOR_AXIS = SEMI_MAJOR_AXIS * (1 - FLATTENING)
AXIS_RATIO = SEMI_MINOR_AXIS / SEMI_MAJOR_AXIS
ECCENTRICITY_SQUARED = FLATTENING * (2.0 - FLATTENING)


def state_vector_dim_check(a):
    if a.ndim > 2:
        raise ValueError("Array must be 1D or 2D")
    if a.shape[0] == 3:
        return a
    elif a.shape[1] == 3:
        return a.T
    else:
        raise ValueError("Array must have at least 1 dimension with length of 3")


def state_vector_validity_checks(a):
    a = np.atleast_2d(np.asarray(a, dtype=np.float64))
    a = state_vector_dim_check(a)
    return a.squeeze()


@numba.jit
def _R_ecef_to_ned(ref_point):
    lat, lon, _, _ = _ecef_to_lla(ref_point)
    S_lat = np.sin(lat)
    C_lat = np.cos(lat)
    S_lon = np.sin(lon)
    C_lon = np.cos(lon)
    r = np.asarray(
        (
            (-S_lat * C_lon, -S_lat * S_lon, C_lat),
            (-S_lon, C_lon, 0),
            (-C_lat * C_lon, -C_lat * S_lon, -S_lat),
        ),
        dtype=np.float64,
    )
    return r


def ecef_to_lla(ecef_position, deg=False):
    ecef_pos = state_vector_validity_checks(ecef_position)
    return _ecef_to_lla(ecef_pos, deg)


@numba.jit
def _ecef_to_lla(ecef_position, deg=False):
    ecef_position = ecef_position.astype(np.float64)
    if np.all(np.abs(ecef_position) < 1e-5) or np.any(np.invert(np.isfinite(ecef_position))):
        return np.nan, 0, np.nan, 0
    epsilon = np.finfo(ecef_position.dtype).eps
    max_iter = 1000

    x = ecef_position[0]
    y = ecef_position[1]
    z = ecef_position[2]

    # From Stevens and Lewis Aircraft Control and Simulation
    lon = np.arctan2(y, x)
    h = 0
    N = SEMI_MAJOR_AXIS
    h0 = 0
    i = 0

    # TODO: would this be faster with scipy?
    finished = False
    while not finished:
        i += 1
        phi = np.arctan(((z) / np.linalg.norm(ecef_position[:2])) / (1 - (ECCENTRICITY_SQUARED * N) / (N + h)))
        N = SEMI_MAJOR_AXIS / np.sqrt(1 - ECCENTRICITY_SQUARED * np.sin(phi) ** 2)
        hplusN = np.linalg.norm(ecef_position[:2]) / np.cos(phi)
        h = hplusN - N

        if abs(h - h0) < epsilon or i > max_iter:
            finished = True
        h0 = h
    lat = phi
    alt = h

    # lat_check = np.abs(np.rad2deg((lat % np.pi) - (np.pi / 2)))
    # if np.any(lat_check > 88):
    #     print(
    #         "warning: ecef to lla being done at a latitude of greater than 85 degrees. use caution with the result.",
    #         lat_check,
    #         "degrees",
    #     )

    if deg:
        lat = np.rad2deg(lat)
        lon = np.rad2deg(lon)
    return lat, lon, alt, i


def ecef_to_ned(ecef_pos, ref_pos):
    ecef_pos = state_vector_validity_checks(ecef_pos)
    ref_pos = state_vector_validity_checks(ref_pos)
    diff = ecef_pos - ref_pos
    r = _R_ecef_to_ned(ref_pos)
    return np.matmul(r, diff.T)


def ecef_to_ned_velocity(ecef_vel, ref_pos):
    ecef_vel = state_vector_validity_checks(ecef_vel)
    ref_pos = state_vector_validity_checks(ref_pos)
    r = _R_ecef_to_ned(ref_pos)
    return np.matmul(r, ecef_vel)


def ned_to_ecef(ned_position, ref_position):
    state_vector_validity_checks(ned_position)
    state_vector_validity_checks(ref_position)
    return _ned_to_ecef(ned_position, ref_position)


def ned_to_ecef_velocity(ned_position, ref_position):
    state_vector_validity_checks(ned_position)
    state_vector_validity_checks(ref_position)
    return _ned_to_ecef_velocity(ned_position, ref_position)


@numba.jit
def _ned_to_ecef(ned_position, ref_position):
    ned_mat = np.asarray(ned_position, dtype=np.float64).T
    ref_position = np.asarray(ref_position, dtype=np.float64)
    r = _R_ecef_to_ned(ref_position)
    return ned_mat @ r + ref_position


@numba.jit
def _ned_to_ecef_velocity(ned_position, ref_position):
    ned_mat = np.asarray(ned_position, dtype=np.float64).T
    ref_position = np.asarray(ref_position, dtype=np.float64)
    r = _R_ecef_to_ned(ref_position)
    return ned_mat @ r


def frd_to_dcu(frd_position):
    frd_position = state_vector_validity_checks(frd_position)
    return _frd_to_dcu(frd_position)


@numba.jit
def _frd_to_dcu(frd_position):
    frd_pos = np.asarray(frd_position, dtype=np.float64)
    r = np.asarray(((1, 0, 0), (0, -1, 0), (0, 0, -1)), dtype=np.float64)
    # return np.matmul(r, frd_pos)
    return r @ frd_pos


def dcu_to_ned(dcu_position, ref_angle):
    dcu_position = state_vector_validity_checks(dcu_position)
    return _dcu_to_ned(dcu_position, ref_angle)


@numba.jit
def _dcu_to_ned(dcu_position, ref_angle):
    dcu_pos = np.asarray(dcu_position, dtype=np.float64).T
    r = T_ned_to_dcu(ref_angle).T
    # return np.matmul(r, dcu_pos)
    return r @ dcu_pos


@numba.jit
def T_ned_to_dcu(ref_angle):
    return np.asarray(
        (
            (np.cos(ref_angle), np.sin(ref_angle), 0),
            (np.sin(ref_angle), -np.cos(ref_angle), 0),
            (0, 0, -1),
        )
    )


def ned_to_dcu(ned_position, ref_angle):
    ned_position = state_vector_validity_checks(ned_position)
    return _ned_to_dcu(ned_position, ref_angle)


@numba.jit
def _ned_to_dcu(ned_position, ref_angle):
    r = T_ned_to_dcu(ref_angle)
    return r @ ned_position.T
