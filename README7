def next_grdth_to_ecef(grdth_data, ref_ecef, ref_heading):
    """Convert from grdth frame to ECEF.

    grdth_data: array of size (n_states,5),
    ref_ecef: the impact point in ecef,
    ref_heading: target initial point heading from impact
    """
    # [Time, GroundRange, GroundRangeDot, ThetaDot, Down, DownDot]
    # get theta from thetadot
    # TODO: What about cumulative_simpson? only in scipy>=1.12.0
    theta = (
        scipy.integrate.cumulative_trapezoid(
            np.divide(grdth_data[:, THETA_DOT_INDEX], grdth_data[:, GR_INDEX]),
            grdth_data[:, TIME_INDEX],
            initial=0,
        )
        + ref_heading
    )

    theta = scipy.integrate.cumulative_simpson(
        np.divide(grdth_data[:, THETA_DOT_INDEX], grdth_data[:, GR_INDEX]),  # omega = V_theta / rho
        x=grdth_data[:, TIME_INDEX],
        initial=ref_heading,
    )

    # now from grdth to NED
    ned_data = np.empty((grdth_data.shape[0], 7))
    # take care of time, down, and downdot in single lines
    ned_data[:, TIME_INDEX] = grdth_data[:, TIME_INDEX]
    ned_data[:, 3] = grdth_data[:, DOWN_INDEX]
    ned_data[:, 6] = grdth_data[:, DOWN_DOT_INDEX]
    # now the math from cylindrical to cartesian
    # position
    C_theta = np.cos(theta)
    S_theta = np.sin(theta)
    ned_data[:, 1] = grdth_data[:, GR_INDEX] * C_theta
    ned_data[:, 2] = grdth_data[:, GR_INDEX] * S_theta
    # gr_dot_ortho = grdth_data[:, GR_INDEX] * grdth_data[:, THETA_DOT_INDEX]  # radius * omega
    gr_dot_ortho = grdth_data[:, THETA_DOT_INDEX]  # V_theta
    for i in range(grdth_data.shape[0]):
        # velocity
        # TODO: this needs to be a rotation about R3. use an einsum when taking away the for loop
        ned_data[i, 4:6] = np.matmul(
            np.array(((C_theta[i], -S_theta[i]), (S_theta[i], C_theta[i]))),
            np.array((grdth_data[i, GR_DOT_INDEX], gr_dot_ortho[i])),
        )
        # gr_dot = grdth_data[i, 2]
        # vel_north = (
        #     C_theta[i] * gr_dot - S_theta[i] * gr_dot_ortho[i]
        #     # + (  # ignore this correction term. there are better ways to do this
        #     #     grdth_data[i, 0]
        #     #     * (
        #     #         np.gradient(grdth_data[:, 2], grdth_data[:, 0])[i]
        #     #         - (2 * grdth_data[i, 3] * gr_dot * S_theta[i])
        #     #         - (
        #     #             np.gradient(grdth_data[:, 3], grdth_data[:, 0])[i]
        #     #             * grdth_data[i, 1]
        #     #             * S_theta[i]
        #     #         )
        #     #         - ((grdth_data[i, 3] ** 2) * grdth_data[i, 1] * C_theta[i])
        #     #     )
        #     # )
        # )
        # vel_east = S_theta[i] * gr_dot + C_theta[i] * gr_dot_ortho[i]
        # ned_data[i, 4] = vel_north
        # ned_data[i, 5] = vel_east

    # NED to ECEF
    ecef_data = np.empty_like(ned_data)
    ecef_data[:, TIME_INDEX] = ned_data[:, TIME_INDEX]  # time
    for i in range(ecef_data.shape[0]):
        ecef_data[i, POS_SLICE] = ned_to_ecef(ned_data[i, POS_SLICE], ref_ecef)
        ecef_data[i, VEL_SLICE] = ned_to_ecef_velocity(ned_data[i, VEL_SLICE], ref_ecef)
    return ecef_data


def ecef_to_next_grdth(ecef_data, ref_ecef):
    # ecef_data: expected to be [time, pos x3, vel x3]
    # get the input point as the ECEF reference point
    # careful with the pointers
    ref_point = deepcopy(ref_ecef)
    ecef_data = np.atleast_2d(ecef_data)

    # convert all of the ECEF data to local NED relative to the reference point
    ned_data = deepcopy(ecef_data)
    ned_data[:, TIME_INDEX] = ecef_data[:, TIME_INDEX]
    for i in range(ecef_data.shape[0]):
        ned_data[i, POS_SLICE] = ecef_to_ned(ecef_data[i, POS_SLICE], ref_point)
        ned_data[i, VEL_SLICE] = ecef_to_ned_velocity(ecef_data[i, VEL_SLICE], ref_point)
        # ned_data[:, acc_slice] = ecef_to_ned_velocity(
        #     ecef_data[i, acc_slice], ref_point
        # )
    # print("please be ned", ned_data)

    # TODO: throw away the velocity data and do a numpy gradient to recreate it.

    # convert traj from NED to GRDTH
    gr = np.linalg.norm(ned_data[:, 1:3], axis=1)
    # print("gr", gr)
    # 2d orthogonal vector. same thing as <N,E,0> cross <0,0,1>, but with fewer operations?
    gr_orthogonal = np.array([-ned_data[:, 2], ned_data[:, 1]]).T
    grdth_data = np.empty((ned_data.shape[0], 6))  # time plus GRDTH has 5 channels
    # fill in the table for GRDTH frame
    # [Time, GroundRange, GroundRangeDot, ThetaDot, Down, DownDot]
    grdth_data[:, TIME_INDEX] = ned_data[:, 0]  # time
    grdth_data[:, GR_INDEX] = gr  # ground range
    gr_speed = np.linalg.norm(ned_data[:, 4:6], axis=1)
    # global theta_pre
    theta_initial = np.arctan2(ned_data[0, 2], ned_data[0, 1])
    # the einsums are doing the dot product of each row pair of vectors from each array
    # C_theta = np.cos(theta_pre)
    # S_theta = np.sin(theta_pre)
    # for i in range(ned_data.shape[0]):
    #     if gr[i] != 0:
    #         grdth_data[i, 2] = np.dot(ned_data[i, 4:6], ned_data[i, 1:3]) / gr[i]
    #         grdth_data[i, 3] = np.dot(ned_data[i, 4:6], gr_orthogonal[i]) / (gr[i] ** 2)
    #     else:
    #         grdth_data[i, 2] = gr_speed[i]
    #         grdth_data[i, 3] = 0

    grdth_data[:, GR_DOT_INDEX] = np.divide(
        np.einsum("ij,ij->i", ned_data[:, 4:6], ned_data[:, 1:3]),
        gr,
        out=np.ones_like(gr) * gr_speed,  # force the data to come to the center
        # where=gr != 0,
        where=gr >= np.finfo(gr.dtype).eps,
    ).squeeze()  # ground range dot
    grdth_data[:, THETA_DOT_INDEX] = np.divide(
        np.einsum("ij,ij->i", ned_data[:, 4:6], gr_orthogonal),
        # gr**2,  # squared b/c V_orth = r*omega
        gr,  # squared b/c V_orth = r*omega
        # out=np.full_like(gr, np.finfo(gr.dtype).eps),
        out=np.zeros_like(gr),  # no radial movement when close in
        # where=gr != 0,
        where=gr >= np.finfo(gr.dtype).eps,
    ).squeeze()  # theta dot
    grdth_data[:, DOWN_INDEX] = ned_data[:, 3]  # Down
    grdth_data[:, DOWN_DOT_INDEX] = ned_data[:, 6]  # Downdot
    # print("please be grdth", grdth_data.squeeze())
    return grdth_data.squeeze(), theta_initial


def ecef_to_next_dcu(ecef_data, ref_ecef):
    # get the input point as the ECEF reference point
    # careful with the pointers
    ref_point = deepcopy(ref_ecef)
    # print("ecef to next grdth ref ecef", ref_point)
    ecef_data = np.atleast_2d(ecef_data)

    # convert all of the ECEF data to local NED relative to the reference point
    ned_data = deepcopy(ecef_data)
    ned_data[:, TIME_INDEX] = ecef_data[:, TIME_INDEX]
    for i in range(ecef_data.shape[0]):
        ned_data[i, POS_SLICE] = ecef_to_ned(ecef_data[i, POS_SLICE], ref_point)
        ned_data[i, VEL_SLICE] = ecef_to_ned_velocity(ecef_data[i, VEL_SLICE], ref_point)
        # ned_data[:, acc_slice] = ecef_to_ned_velocity(
        #     ecef_data[i, acc_slice], ref_point
        # )

    # threat anti-heading
    # ref_heading = (np.arctan2(ned_data[0, 5], ned_data[0, 4])) % (2 * np.pi)
    # threat position heading
    ref_heading = (np.arctan2(ned_data[0, 2], ned_data[0, 1])) % (2 * np.pi)

    # NED to DCU
    dcu_data = np.empty_like(ned_data)
    dcu_data[:, TIME_INDEX] = ned_data[:, TIME_INDEX]
    for i in range(ned_data.shape[0]):
        dcu_data[i, POS_SLICE] = ned_to_dcu(ned_data[i, POS_SLICE], ref_heading)
        dcu_data[i, VEL_SLICE] = ned_to_dcu(ned_data[i, VEL_SLICE], ref_heading)

    # check for flip_c
    do_flip_c = dcu_data[0, 2] < 0
    if do_flip_c:
        dcu_data = flip_c(dcu_data)

    return dcu_data.squeeze(), ref_heading, do_flip_c


def flip_c(dcu_state):
    # change the sign of the cross range position and velocity
    dcu_state[..., 2::3] = -dcu_state[..., 2::3]
    return dcu_state


def next_dcu_to_ecef(dcu_data, ref_ecef, ref_heading, do_flip_c):
    if do_flip_c:
        dcu_data = flip_c(dcu_data)

    # DCU to NED
    ned_data = np.empty_like(dcu_data)
    ned_data[:, TIME_INDEX] = dcu_data[:, TIME_INDEX]
    for i in range(dcu_data.shape[0]):
        ned_data[i, POS_SLICE] = dcu_to_ned(dcu_data[i, POS_SLICE], ref_heading)
        ned_data[i, VEL_SLICE] = dcu_to_ned(dcu_data[i, VEL_SLICE], ref_heading)

    # NED to ECEF
    ecef_data = np.empty_like(ned_data)
    ecef_data[:, TIME_INDEX] = ned_data[:, TIME_INDEX]
    for i in range(ned_data.shape[0]):
        ecef_data[i, POS_SLICE] = ned_to_ecef(ned_data[i, POS_SLICE], ref_ecef)
        ecef_data[i, VEL_SLICE] = ned_to_ecef_velocity(ned_data[i, VEL_SLICE], ref_ecef)
    return ecef_data.squeeze()


# ----------------------------------------------------------------------
# Global ellipsoid (WGS-84)
# ----------------------------------------------------------------------
WGS84 = Geodesic.WGS84
a = WGS84.a  # semi-major axis (m)
f = WGS84.f  # flattening
b = a * (1 - f)  # semi-minor axis (m)


# ----------------------------------------------------------------------
# Simple helpers
# ----------------------------------------------------------------------
def deg2rad(x):
    return np.deg2rad(x)


def rad2deg(x):
    return np.rad2deg(x)


# ----------------------------------------------------------------------
# 0. Geodetic ↔ ECEF (scalar - called inside vectorised loops)
# ----------------------------------------------------------------------
def ecef_to_geodetic(x, y, z):
    """Scalar conversion using GeographicLib's exact algorithm."""
    # lat, lon, h = Geodesic.WGS84._LatLonFromXYZ(x, y, z)
    # return lat, lon, h
    # TODO: Vermeille has a better method that Karney suggested updates to and then Vermeille updated in 2011. Update to using that rather than this Bowrank-like iterative method.
    from coordinate_transform_functions import _ecef_to_lla

    lat, lon, h, _ = _ecef_to_lla(np.hstack([x, y, z]), deg=True)

    return lat, lon, h


def geodetic_to_ecef(lat, lon, h):
    """Scalar conversion (deg, deg, m) → (x, y, z) in metres."""
    lat_rad = deg2rad(lat)
    lon_rad = deg2rad(lon)

    sin_phi = np.sin(lat_rad)
    cos_phi = np.cos(lat_rad)
    sin_lam = np.sin(lon_rad)
    cos_lam = np.cos(lon_rad)

    N = a / np.sqrt(1 - (2 * f - f**2) * sin_phi**2)
    x = (N + h) * cos_phi * cos_lam
    y = (N + h) * cos_phi * sin_lam
    z = ((1 - f) ** 2 * N + h) * sin_phi
    return x, y, z


# ----------------------------------------------------------------------
# 1. ENU rotation matrix (scalar - reused for a whole batch)
# ----------------------------------------------------------------------
def enu_rotation_matrix(lat0_rad, lon0_rad):
    """Scalar rotation matrix from ECEF → ENU at (lat0,lon0) [radians]."""
    sin_phi = np.sin(lat0_rad)
    cos_phi = np.cos(lat0_rad)
    sin_lam = np.sin(lon0_rad)
    cos_lam = np.cos(lon0_rad)

    R = np.array(
        [
            [-sin_lam, cos_lam, 0.0],
            [-sin_phi * cos_lam, -sin_phi * sin_lam, cos_phi],
            [cos_phi * cos_lam, cos_phi * sin_lam, sin_phi],
        ]
    )
    return R


# ----------------------------------------------------------------------
# 2. Vectorised ENU conversion
# ----------------------------------------------------------------------
def _apply_rotation(R, vec):
    """
    Apply the same (3×3) rotation matrix `R` to an (N,3) array `vec`.
    """
    # Using @ works with both (3,3) @ (3,) and (3,3) @ (N,3).T
    return (R @ vec.T).T


def ecef_to_enu_vec(p_ecef, impact_ecef, lat0_deg, lon0_deg):
    """
    Convert an (N,3) array of ECEF positions to ENU centred at the impact point.
    Returns an (N,3) array.
    """
    lat0 = deg2rad(lat0_deg)
    lon0 = deg2rad(lon0_deg)
    R = enu_rotation_matrix(lat0, lon0)

    delta = np.asarray(p_ecef) - np.asarray(impact_ecef)  # (N,3)
    return _apply_rotation(R, delta)


def ecef_vel_acc_to_enu_vec(v_ecef, a_ecef, lat0_deg, lon0_deg):
    """
    Convert (N,3) velocity and (N,3) acceleration arrays to ENU.
    Returns two (N,3) arrays: (v_enu, a_enu).
    """
    lat0 = deg2rad(lat0_deg)
    lon0 = deg2rad(lon0_deg)
    R = enu_rotation_matrix(lat0, lon0)

    v_enu = _apply_rotation(R, v_ecef)
    a_enu = _apply_rotation(R, a_ecef)
    return v_enu, a_enu


def enu_to_ecef_vec(p_enu, impact_ecef, lat0_deg, lon0_deg):
    """
    Inverse ENU → ECEF for an (N,3) array.
    """
    lat0 = deg2rad(lat0_deg)
    lon0 = deg2rad(lon0_deg)
    R = enu_rotation_matrix(lat0, lon0)
    # Inverse rotation = transpose because R is orthogonal
    return impact_ecef + _apply_rotation(R.T, p_enu)


# ----------------------------------------------------------------------
# 3. Geodesic helpers (scalar)
# ----------------------------------------------------------------------
def inverse_geodesic(lat0, lon0, lat, lon):
    """
    Scalar inverse geodesic. Returns distance (m), forward azimuth (deg),
    reverse azimuth (deg), reduced length m12 (m), geodesic scale M12 (-).
    """
    mask = Geodesic.DISTANCE | Geodesic.AZIMUTH | Geodesic.REDUCEDLENGTH | Geodesic.GEODESICSCALE
    inv = WGS84.Inverse(lat0, lon0, lat, lon, outmask=mask)
    return inv["s12"], inv["azi1"], inv["azi2"], inv["m12"], inv["M12"]


def forward_geodesic(lat0, lon0, s, azi):
    """
    Scalar forward geodesic. Returns destination lat, lon, reverse azimuth,
    reduced length, geodesic scale.
    """
    mask = Geodesic.LATITUDE | Geodesic.LONGITUDE | Geodesic.AZIMUTH | Geodesic.REDUCEDLENGTH | Geodesic.GEODESICSCALE
    dirc = WGS84.Direct(lat0, lon0, azi, s, outmask=mask)
    return dirc["lat2"], dirc["lon2"], dirc["azi2"], dirc["m12"], dirc["M12"]


# ----------------------------------------------------------------------
# 4. Vectorised geodesic-based state conversion
# ----------------------------------------------------------------------
def ecef_to_local_geodesic_vec(p_ecef, v_ecef, a_ecef, impact_ecef):
    """
    Vectorised conversion of whole trajectories.

    Parameters
    ----------
    p_ecef : (N,3) array of positions (m)
    v_ecef : (N,3) array of velocities (m/s)
    a_ecef : (N,3) array of accelerations (m/s²)
    impact_ecef : (3,) array - impact point in ECEF
    lat0_deg, lon0_deg : impact latitude/longitude (deg)
    h0 : impact height above ellipsoid (m) - usually 0

    Returns
    -------
    A dictionary where each entry is an (N,) NumPy array:
        s   - geodesic distance from impact (m)
        h   - relative height (m)   (trajectory h - h0)
        az  - forward azimuth from impact (rad)
        v_s - along-track speed (m/s)
        v_α - azimuth rate (rad/s)
        v_h - vertical speed (m/s)
        a_s - along-track accel (m/s²)
        a_α - azimuth accel (rad/s²)
        a_h - vertical accel (m/s²)
    """
    N = p_ecef.shape[0]

    lat0_deg, lon0_deg, h0 = ecef_to_geodetic(*impact_ecef)

    # ------------------------------------------------------------------
    # 1) Convert positions to lat/lon/h (scalar loop - cheap)
    # ------------------------------------------------------------------
    lat = np.empty(N)
    lon = np.empty(N)
    h = np.empty(N)

    for i in range(N):
        lat[i], lon[i], h[i] = ecef_to_geodetic(*p_ecef[i])

    # ------------------------------------------------------------------
    # 2) Inverse geodesic for each point (scalar loop - still fast)
    # ------------------------------------------------------------------
    s = np.empty(N)
    az_deg = np.empty(N)  # forward azimuth (deg)
    m12 = np.empty(N)
    M12 = np.empty(N)

    for i in range(N):
        s[i], az_deg[i], _, m12[i], M12[i] = inverse_geodesic(lat0_deg, lon0_deg, lat[i], lon[i])

    # ------------------------------------------------------------------
    # 3) Build ENU rotation matrix once (same for whole trajectory)
    # ------------------------------------------------------------------
    R = enu_rotation_matrix(deg2rad(lat0_deg), deg2rad(lon0_deg))

    # ------------------------------------------------------------------
    # 4) Rotate velocities & accelerations to ENU (vectorised)
    # ------------------------------------------------------------------
    v_enu = _apply_rotation(R, v_ecef)  # (N,3)
    a_enu = _apply_rotation(R, a_ecef)  # (N,3)

    # Split ENU components for readability
    v_east, v_north, v_up = v_enu[:, 0], v_enu[:, 1], v_enu[:, 2]
    a_east, a_north, a_up = a_enu[:, 0], a_enu[:, 1], a_enu[:, 2]

    # ------------------------------------------------------------------
    # 5) Build unit vectors that follow each geodesic direction
    # ------------------------------------------------------------------
    az_rad = deg2rad(az_deg)  # (N,)

    # Tangent (east-north) unit vector along the geodesic
    t_hat = np.column_stack((np.sin(az_rad), np.cos(az_rad), np.zeros(N)))  # (N,3)

    # Lateral unit vector (perpendicular to t_hat in the ENU plane)
    l_hat = np.column_stack((np.cos(az_rad), -np.sin(az_rad), np.zeros(N)))  # (N,3)

    # Up unit vector - same for all rows
    up_hat = np.array([0.0, 0.0, 1.0])

    # ------------------------------------------------------------------
    # 6) Velocity decomposition
    # ------------------------------------------------------------------
    v_s = np.einsum("ij,ij->i", t_hat, v_enu)  # dot product (N,)
    v_l = np.einsum("ij,ij->i", l_hat, v_enu)  # lateral component
    v_h = v_up  # vertical

    # Azimuth rate (rad/s), guarding against division by zero
    v_alpha = np.where(s > 0.0, (M12 / s) * v_l, 0.0)

    # ------------------------------------------------------------------
    # 7) Acceleration decomposition
    # ------------------------------------------------------------------
    a_s = np.einsum("ij,ij->i", t_hat, a_enu)
    a_l = np.einsum("ij,ij->i", l_hat, a_enu)
    a_h = a_up

    a_alpha = np.where(s > 0.0, (M12 / s) * a_l - (v_s * v_alpha) / s, 0.0)

    # ------------------------------------------------------------------
    # 8) Assemble results
    # ------------------------------------------------------------------
    out = pd.DataFrame(
        {
            "s": s,
            "az": az_rad,
            "h": h - h0,
            "v_s": v_s,
            "v_α": v_alpha,
            "v_h": v_h,
            "a_s": a_s,
            "a_α": a_alpha,
            "a_h": a_h,
        }
    ).values
    return out


# ----------------------------------------------------------------------
# 5. Vectorised inverse conversion (local → ECEF)
# ----------------------------------------------------------------------
def local_geodesic_to_ecef_vec(state, impact_ecef):
    """
    Convert a batch of geodesic-based states (as returned by
    `ecef_to_local_geodesic_vec`) back to ECEF positions, velocities and
    accelerations.

    Parameters
    ----------
    state : dict of (N,) arrays
        ["s", "az(rad)", "h", "v_s", "v_α", "v_h", "a_s", "a_α", "a_h"]
          0    1     2    3      4      5      6      7      8
    impact_ecef : (3,) array
    lat0_deg, lon0_deg : impact latitude/longitude (deg)
    h0 : impact height (m) - usually 0

    Returns
    -------
    p_ecef, v_ecef, a_ecef : each an (N,3) array
    """
    N = state.shape[0]

    lat0_deg, lon0_deg, h0 = ecef_to_geodetic(*impact_ecef)

    # ------------------------------------------------------------------
    # 1) Destination lat/lon for each sample (scalar loop)
    # ------------------------------------------------------------------
    lat = np.empty(N)
    lon = np.empty(N)

    for i in range(N):
        lat[i], lon[i], _, _, _ = forward_geodesic(lat0_deg, lon0_deg, state[i, 0], rad2deg(state[i, 1]))

    # ------------------------------------------------------------------
    # 2) Build ENU rotation matrix (same for whole batch)
    # ------------------------------------------------------------------
    R = enu_rotation_matrix(deg2rad(lat0_deg), deg2rad(lon0_deg))

    # ------------------------------------------------------------------
    # 3) Assemble ENU velocity / acceleration from geodesic components
    # ------------------------------------------------------------------
    az_rad = state[:, 1]
    s = state[:, 0]
    # Need the differential scale M12 for each point - get it with another
    # scalar inverse geodesic call.
    M12 = np.empty(N)
    for i in range(N):
        _, _, _, _, M12[i] = inverse_geodesic(lat0_deg, lon0_deg, lat[i], lon[i])

    # Unit vectors per sample (same definitions as in the forward routine)
    t_hat = np.column_stack((np.sin(az_rad), np.cos(az_rad), np.zeros(N)))  # (N,3)
    l_hat = np.column_stack((np.cos(az_rad), -np.sin(az_rad), np.zeros(N)))  # (N,3)
    up_hat = np.array([0.0, 0.0, 1.0])

    # ENU velocity
    v_enu = (
        (state[:, 3][:, None] * t_hat) + ((state[:, 4] * s / M12)[:, None] * l_hat) + (state[:, 5][:, None] * up_hat)
    )

    # ENU acceleration
    a_enu = (
        (state[:, 6][:, None] * t_hat) + ((state[:, 7] * s / M12)[:, None] * l_hat) + (state[:, 8][:, None] * up_hat)
    )

    # ------------------------------------------------------------------
    # 4) Transform ENU → ECEF (vectorised) and add impact offset
    # ------------------------------------------------------------------
    p_ecef = np.empty((N, 3))
    for i in range(N):
        p_ecef[i] = geodetic_to_ecef(lat[i], lon[i], h0 + state[i, 2])

    v_ecef = _apply_rotation(R.T, v_enu)
    a_ecef = _apply_rotation(R.T, a_enu)

    # Add impact offset to positions (the geodetic conversion already gives
    # absolute coordinates, so no extra offset is needed)
    # (If you had stored the impact point in ECEF already you could also do:)
    # p_ecef += impact_ecef   # <-- not required here

    return np.hstack([p_ecef, v_ecef, a_ecef])


def _local_heading_from_guide(origin_ecef, guide_ecef=None, fallback_vel_ecef=None):
    if guide_ecef is not None:
        lat0, lon0, _ = ecef_to_geodetic(*origin_ecef)
        lat_guide, lon_guide, _ = ecef_to_geodetic(*guide_ecef)
        dist, azi, _, _, _ = inverse_geodesic(lat0, lon0, lat_guide, lon_guide)
        if dist > 0:
            return deg2rad(azi)

    if fallback_vel_ecef is None:
        return 0.0
    vel_ned = ecef_to_ned_velocity(fallback_vel_ecef, origin_ecef)
    return np.arctan2(vel_ned[1], vel_ned[0])


def ecef_to_local_ned_hvuh(ecef_data, guide_ecef=None):
    ecef_data = np.atleast_2d(ecef_data)
    origin = ecef_data[0, POS_SLICE]
    lat0, lon0, _ = ecef_to_geodetic(*origin)
    heading0 = _local_heading_from_guide(origin, guide_ecef, ecef_data[0, VEL_SLICE])

    lned = np.empty((ecef_data.shape[0], 7))  # time, forward, right, altitude, v_forward, v_right, v_up
    lned[:, TIME_INDEX] = ecef_data[:, TIME_INDEX]

    for i, state in enumerate(ecef_data):
        lat, lon, hae = ecef_to_geodetic(*state[POS_SLICE])
        dist, azi, _, _, _ = inverse_geodesic(lat0, lon0, lat, lon)
        vel_ned = ecef_to_ned_velocity(state[VEL_SLICE], origin)
        north = dist * np.cos(deg2rad(azi))
        east = dist * np.sin(deg2rad(azi))

        lned[i, 1] = north * np.cos(heading0) + east * np.sin(heading0)
        lned[i, 2] = -north * np.sin(heading0) + east * np.cos(heading0)
        lned[i, 3] = hae
        lned[i, 4] = vel_ned[0] * np.cos(heading0) + vel_ned[1] * np.sin(heading0)
        lned[i, 5] = -vel_ned[0] * np.sin(heading0) + vel_ned[1] * np.cos(heading0)
        lned[i, 6] = -vel_ned[2]

    return lned


def local_ned_hvuh_to_ecef(lned_data, initial_state_ecef, guide_ecef=None):
    lned_data = np.atleast_2d(lned_data)
    initial_state_ecef = np.asarray(initial_state_ecef)
    origin = initial_state_ecef[POS_SLICE]
    lat0, lon0, _ = ecef_to_geodetic(*origin)
    heading0 = _local_heading_from_guide(origin, guide_ecef, initial_state_ecef[VEL_SLICE])

    ecef_data = np.empty((lned_data.shape[0], 7))
    ecef_data[:, TIME_INDEX] = lned_data[:, TIME_INDEX]

    for i, state in enumerate(lned_data):
        north = state[1] * np.cos(heading0) - state[2] * np.sin(heading0)
        east = state[1] * np.sin(heading0) + state[2] * np.cos(heading0)
        dist = np.hypot(north, east)
        azi = rad2deg(np.arctan2(east, north))
        lat, lon, _, _, _ = forward_geodesic(lat0, lon0, dist, azi)
        vel_ned = np.array(
            [
                state[4] * np.cos(heading0) - state[5] * np.sin(heading0),
                state[4] * np.sin(heading0) + state[5] * np.cos(heading0),
                -state[6],
            ]
        )

        ecef_data[i, POS_SLICE] = geodetic_to_ecef(lat, lon, state[3])
        ecef_data[i, VEL_SLICE] = ned_to_ecef_velocity(vel_ned, origin)

    return ecef_data


