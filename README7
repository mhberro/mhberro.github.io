    )
    parser.add_argument(
        "--dt",
        default=0.1,
        type=float,
        help="The delta time to use for resampling the truth trajectory to align the time grid",
    )
    parser.add_argument(
        "--ref-ecef",
        default="impact",
        choices=["boost", "glide", "impact"],
        help="The reference point for the frame transformations",
    )
    
    args = parser.parse_args()

    model_states = 6  # this is 6 for ImpAntiHeadDCU and 5 for GRDTH
    if args.frame == "grdth":
        model_states = 5
    elif args.frame == "geodesic" and args.geodesic_mode == "integrated":
        # The "frame trick": integrated geodesic drops absolute azimuth and
        # tracks azimuth rate -> 5-state [s, h, v_s, v_alpha, v_h]. (This
        # resolves the long-standing "geodesic should also be 5" TODO.)
        model_states = 5

    trajectory_dt = args.dt  # [s]

    seed = 47
    # random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

    target_strs = [Path(x).name for x in args.tgt_data_paths]
