class ODEfunc(torch.nn.Module):
    def __init__(self, state_vector_len: int, nhidden: int, aug_dim: int = 0, order_shift_slice: slice | None = None):
        super(ODEfunc, self).__init__()
        # aug_dim: is the number of zeros that have been added on to the initial conditions
        # order_shift_slice: is slice of states that will be shifted left in the output vector. This works for both
        #   balanced order (e.g. 3 position and 3 velocity) and non-balanced order (e.g. 2 position and 3 velocity).
        #   For non-balanced order, only the velocity states that relate to the position states should be sliced. This
        #   does mean that the arrangement of the states in the vector does matter. (e.g. the arrangement for a 2-3
        #   state must be px,py,vx,vy,vz)
        self.order_shift_slice = order_shift_slice
        self.len_of_order_shift_slice = 0
        if self.order_shift_slice is not None:
            order_indicies = tuple(range(*self.order_shift_slice.indices(state_vector_len)))
            self.len_of_order_shift_slice = len(order_indicies)
        # self.act = torch.nn.ELU(inplace=False)
        # self.act = torch.nn.ReLU(inplace=False)  # not a smooth function. this lead to slow epochs
        self.act1 = torch.nn.SiLU(inplace=False)
        self.act2 = torch.nn.SiLU(inplace=False)
        # self.act3 = torch.nn.SiLU(inplace=False)
        # self.act = torch.nn.Tanh()
        self.fc1 = torch.nn.Linear(state_vector_len + aug_dim, nhidden)
        self.fc2 = torch.nn.Linear(nhidden, nhidden)
        # self.fc3 = torch.nn.Linear(nhidden, nhidden)
        self.fc4 = torch.nn.Linear(nhidden, (state_vector_len - self.len_of_order_shift_slice) + aug_dim)
        self.nfe = 0

    # def forward(self, x: torch.Tensor) -> torch.Tensor:  # this is the signature needed by PCM
    def forward(self, t, x: torch.Tensor) -> torch.Tensor:  # this is the signature needed by torchdiffeq
        if self.order_shift_slice is not None:
            # Is narrow the best option here? I'm trying to do slicing on the last dimension and have it work in ONNX
            v = torch.narrow(x, dim=-1, start=self.order_shift_slice.start, length=self.len_of_order_shift_slice)
        self.nfe += 1
        out = self.fc1(x)  # TODO: swap out this manual MLP with torchvision.ops.MLP
        out = self.act1(out)
        out = self.fc2(out)
        out = self.act2(out)
        # out = self.fc3(out)  # TODO: why so many layers?
        # out = self.act(out)
        out = self.fc4(out)
        if self.order_shift_slice is not None:
            return torch.cat((v, out), dim=x.ndim - 1)
            # return torch.cat((v, out), dim=x.ndim - 1)  # TODO: subtract a small MLP here for dissipation on the acceleration term
        else:
            return out


# =====================================================================
#  GRU-ODE  (De Brouwer et al., NeurIPS 2019 — GRU-ODE-Bayes)
# ---------------------------------------------------------------------
#  Continuous-time GRU vector field for the latent state h(t):
#
#       dh/dt = (1 - z(t)) ⊙ (g(t) - h(t))            (paper Eq. 3 / App. A)
#
#  with the continuous-time gates
#       r(t) = σ(W_r x + U_r h + b_r)
#       z(t) = σ(W_z x + U_z h + b_z)
#       g(t) = tanh(W_h x + U_h (r ⊙ h) + b_h)
#
#  Key properties exploited here for chaotic kinematic forecasting:
#    * Boundedness:   h(0) ∈ [-1,1]  ⇒  h(t) ∈ [-1,1] ∀t  (negative
#      feedback term -(1-z)⊙h points inward at the boundary). This bounds
#      long-horizon rollouts and collapses S-curve / phugoid divergence.
#    * Lipschitz K=2: globally smooth vector field ⇒ adaptive solvers
#      (DOPRI) stay stable and can take large steps.
#    * Continuity prior on h(t): a smooth latent flow that regularises the
#      forecaster, especially valuable in the low-sample regime.
#
#  Design note for THIS pipeline: the truth data is resampled onto a uniform
#  grid and is fully observed (no per-feature mask), so the Bayesian filtering
#  half of the paper (GRU-Bayes + KL post-jump loss) has nothing to filter at
#  train time. We therefore use the GRU-ODE *cell* as a bounded latent vector
#  field and expose the GRU-Bayes jump as an OPT-IN path (GRUODEBayesPredictor)
#  for when genuinely sporadic/masked observations are available. The autonomous
#  forecaster below (no continuous input x(t)) is the default — g and z then
#  depend on h(t) only, exactly the autonomous case described in paper §2.1.
# =====================================================================


def train_NEXT(
    model_name,
    traj_targets_train,
    traj_targets_test,
    scaler_traj,
    model_save_path,
    trajectory_dt,
    batch_size,
    use_scalar,
    model_states,
    aug_dim,
    nhidden,
    gpu_index,
    model_type: str = "node",
    frame: str = "dcu",
):
    # define initial training configuration
    training_configuration = TrainingConfiguration(
        n_epochs=1,
        optimizer=AdamOptimizer(learning_rate=1e-3),
        # optimizer=ReduceLROnPlateauConfiguration("loss").create_from_optimizer(AdamOptimizer(learning_rate=1e-3)),
        batch_size=batch_size,
        num_workers=100,  # is this the parallel control? cpu_count()//2?
        verbose=True,
    )
    # ode_solver = EulerSolver(dt=trajectory_dt)
    # ode_solver = RK4Solver(dt=trajectory_dt)
    # Fixed-step RK4 with adjoint=False stores the forward graph for exact, fast
    # gradients — appropriate here because the GRU-ODE field is K=2 Lipschitz, so
    # a fixed step is numerically stable. Tradeoffs for GRU-ODE specifically:
    #   * method="dopri5": adaptive step — fewer evals on smooth stretches, more
    #     near sharp dynamics; better stability at the cost of variable runtime.
    #   * adjoint=True: O(1) memory in the number of steps (recompute on the
    #     backward pass) — switch this on if long horizons OOM the GPU; it trades
    #     memory for ~2x compute and is the setting the paper uses for big latents.
    ode_solver = TorchdiffeqSolver(dt=trajectory_dt, method="rk4", adjoint=False, substeps=4)

    if frame == "dcu":
        velocity_indicies = (3, 4, 5)
    elif frame == "grdth":
        velocity_indicies = (2, 3, 4)
    elif frame == "geodesic":
        # 6-state ("original") geodesic pairs like DCU; 5-state ("integrated"
        # frame trick) [s,h,v_s,v_alpha,v_h] has GRDTH-like unbalanced layout:
        # positions s,h at 0,1; "velocities" v_s,v_alpha,v_h at 2,3,4.
        velocity_indicies = (2, 3, 4) if model_states == 5 else (3, 4, 5)
    else:
        raise ValueError("That frame is not known for what the velocity indicies are")
    # Define custom loss function.
    early_stop_metric_name = "val_loss"
    # loss_func = EnergyMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     energy_fn=mechanical_energy,
    #     energy_weight=1,
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    # )

    # loss_func = WrappedMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    # )

    # loss_func = PhysicsSplitMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     dt=trajectory_dt,
    #     pos_weight=1.0,
    #     vel_weight=2.0,
    #     physics_weight=0,
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    # )

    loss_func = WrappedMSELoss(
        height_idx=(2 if (frame == "dcu" or (frame == "geodesic" and model_states == 6)) else 1),
        vel_indices=velocity_indicies,
        scaler=scaler_traj if use_scalar else None,
        N_FEATURES=model_states,
        position_loss_weight=80.0,
        l2_reg=1e-4,
    )

    # this does have influence, but it is not a hard limit on the given expected values
    # loss_func = SecondOrderSplitMSELoss(
    #     height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     vel_weight=1.0,  # TODO: try this set to zero so that only position is used for loss
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    #     pos_expect=1e9,
    #     vel_expect=1e9,
    # )

    # more influential, but not a hard limit
    # loss_func = WeightedHuberLoss(
    #     delta_pos=1e500,
    #     delta_vel=1e500,
    #     # height_idx=1,  # This changes for GRDTH frame
    #     vel_indices=velocity_indicies,  # This changes for GRDTH frame
    #     # vel_weight=1.0,
    #     scaler=scaler_traj if use_scalar else None,
    #     N_FEATURES=model_states,
    #     weight_pos=1.0,
    #     weight_vel=1.0,
    # )
    # early_stop_metric_name = "val_loss_unweighted"

    # Define the Neural ODE model
    node = NODEPredictor(
        architecture=FFNNArchitecture(
            layer_channels=[5, 5],  # this doesn't do anything when using ODEfunc
            # layer_activation=Activation.RELU,
            # layer_activation=Activation.TANH,
            layer_activation=Activation.SILU,
        ),
        training_configuration=training_configuration,
        solver=ode_solver,
        logging_interval=5,
        loss_func=loss_func,
        early_stopper=EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name),
        checkpoint=ModelCheckpoint(min_epochs=1, directory=model_save_path, model_name=model_name + ".checkpoint"),
        aug_dim=aug_dim,
    )
    if HAVE_GPU:
        node.device = torch.device(f"cuda:{gpu_index}")
        node._initialize_losses(node.criterion)
        node._initialize_model()
        node._initialize_optimizer()

    # --------------------------------------------------------------------
    #  Build the requested model
    # --------------------------------------------------------------------
    if model_type == "node":
        # plain NODE (no augmentation, no order-shift)
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "anode":
        # Augmented NODE – aug_dim comes from the CLI flag
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=aug_dim,
            order_shift_slice=None,
        ).to(node.device)
    elif model_type == "sonode":
        # Second-order NODE – shift the velocity slice left
        # (the slice that selects the velocity components; adjust if you
        # change the state ordering)
        node.model = ODEfunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            aug_dim=0,
            order_shift_slice=slice(3, 6),
        ).to(node.device)
    elif model_type in ("gruode", "gruode-min"):
        # ------------------------------------------------------------
        #  GRU-ODE forecaster (De Brouwer et al., 2019).
        #  Bounded latent vector field; encode → ∫GRU-ODE → decode.
        #  'gruode'     -> full GRU-ODE cell
        #  'gruode-min' -> minimal GRU-ODE cell (fewer params)
        # ------------------------------------------------------------
        minimal = model_type == "gruode-min"
        # Latent dimension: default to a comfortable lift above the physical
        # state. nhidden controls the encoder/decoder MLP width.
        latent_dim = max(2 * model_states, nhidden // 2 if nhidden >= 20 else 16)

        # --- Encoder-input selection (position-invariance experiment) --------
        # Choose which state components feed the dynamics encoder. Absolute
        # horizontal position is translation-variant and dynamically irrelevant;
        # dropping it should improve generalization (and thus val position via
        # the integrated velocity) without a pos/vel tradeoff.
        #   "keep_alt"  : drop horizontal position, KEEP altitude + velocity
        #   "vel_only"  : velocity only (SME proposal)
        #   "all"       : original behaviour (full state)
        ENCODER_INPUT_MODE = "all"   # "keep_alt"/"vel_only" tested WORSE than "all"

        if frame == "dcu" or (frame == "geodesic" and model_states == 6):
            # state = [Down, Cross, Up(alt), dotD, dotC, dotU]
            if ENCODER_INPUT_MODE == "keep_alt":
                enc_in_idx = [2, 3, 4, 5]        # Up + all velocities
            elif ENCODER_INPUT_MODE == "vel_only":
                enc_in_idx = [3, 4, 5]           # velocities only
            else:
                enc_in_idx = None                # all 6
        elif frame == "geodesic" and model_states == 5:
            # integrated [s, h(alt), v_s, v_alpha, v_h]: keep_alt drops range s.
            if ENCODER_INPUT_MODE == "keep_alt":
                enc_in_idx = [1, 2, 3, 4]        # drop s (range); keep h + rates
            elif ENCODER_INPUT_MODE == "vel_only":
                enc_in_idx = [2, 3, 4]           # rates only
            else:
                enc_in_idx = None
        elif frame == "grdth":
            # state = [GR, Down, dotGR, dotD, VTheta]; Down is altitude-like.
            if ENCODER_INPUT_MODE == "keep_alt":
                enc_in_idx = [1, 2, 3, 4]        # drop GR (horizontal range)
            elif ENCODER_INPUT_MODE == "vel_only":
                enc_in_idx = [2, 3, 4]           # rates only
            else:
                enc_in_idx = None
        else:
            enc_in_idx = None

        gruode_func = GRUODEFunc(
            state_vector_len=model_states,
            nhidden=nhidden,
            latent_dim=latent_dim,
            minimal=minimal,
            encoder_input_idx=enc_in_idx,
            encoder_dropout=0.1,
        ).to(node.device)
        if frame == "dcu" or (frame == "geodesic" and model_states == 6):
            pos_idx, vel_idx = [0, 1, 2], [3, 4, 5]
        elif frame == "geodesic" and model_states == 5:
            pos_idx, vel_idx = [0, 1], [2, 4]
        elif frame == "grdth":
            pos_idx, vel_idx = [0, 1], [2, 3]
        else:
            pos_idx, vel_idx = None, None

        # Scaler stats for the scaled-space second-order correction. The model
        # operates in StandardScaler-scaled units, so d/dt(pos)=vel must be
        # expressed as xdot_s[pos] = (sigma_vel/sigma_pos)*vel_s + mu_vel/sigma_pos.
        # Without these, the constraint is dimensionally wrong (see _field).
        so_pos_scale = so_vel_scale = so_vel_mean = None
        if use_scalar and pos_idx is not None and isinstance(scaler_traj, StandardScaler):
            so_pos_scale = scaler_traj.scale_[pos_idx]
            so_vel_scale = scaler_traj.scale_[vel_idx]
            so_vel_mean = scaler_traj.mean_[vel_idx]

        node.model = GRUODEPredictorModel(
            func=gruode_func,
            pos_idx=pos_idx,
            vel_idx=vel_idx,
            pos_scale=so_pos_scale,
            vel_scale=so_vel_scale,
            vel_mean=so_vel_mean,
        ).to(node.device)
        
        node.aug_dim = latent_dim
        aug_dim = latent_dim

        # Force structural scale-space loss selection
        loss_func = WrappedMSELoss(
            height_idx=(2 if (frame == "dcu" or (frame == "geodesic" and model_states == 6)) else 1),
            vel_indices=velocity_indicies,
            scaler=scaler_traj if use_scalar else None,
            N_FEATURES=model_states,
            position_loss_weight=80.0,
            l2_reg=1e-4,
        )
        node._initialize_losses(loss_func)
    elif model_type == "latentode":
        # ------------------------------------------------------------
        #  Latent-ODE model – a completely different object
        # ------------------------------------------------------------
        # Encoder/Decoder expect a *state size* of 6 (or whatever you use).
        # They are already defined above (Encoder, Decoder, LatentODEFunc,
        # LatentNODE).  We just instantiate the wrapper.
        latent_dim = nhidden // 2 if nhidden >= 20 else 8  # a sensible default
        node.model = LatentNODE(latent_dim=latent_dim).to(node.device)

        # For latent ODE we need a **different loss** that adds the KL term.
        # Keep the same MSE wrapper you already use for the physical states.
        recon_criterion = WrappedMSELoss(
            height_idx=1,
            vel_indices=[3, 4, 5],
            scaler=scaler_traj if use_scalar else None,
            N_FEATURES=model_states,
        )

        def latent_ode_loss_fn(recon, target, mu, logvar):
            """Reconstruction (MSE) + KL."""
            recon_loss = recon_criterion(recon, target)
            kl = _kl_divergence(mu, logvar)
            # You may weight the KL term; 0.1 works well for many problems.
            return recon_loss + 0.1 * kl

        # Replace the NODEPredictor's loss with our custom wrapper.
        # NOTE: NODEPredictor expects a callable that takes (pred, true).
        # We therefore bind the extra arguments via a lambda.
        node.loss_func = lambda pred, true: latent_ode_loss_fn(pred[0], true, pred[1], pred[2])
    else:
        raise ValueError(f"Unsupported model_type: {model_type}")

    # Set parameter reference hooks before launching training strategies
    if hasattr(node.criterion, "set_model"):
        node.criterion.set_model(node.model)

    # Train the model if it does not exist
    if use_scalar:
        scaled_traj_targets_train_posvel = [
            torch.Tensor(scaler_traj.transform(i[:, 0 : model_states + 1])) for i in traj_targets_train
        ]
        scaled_traj_targets_test_posvel = [
            torch.Tensor(scaler_traj.transform(i[:, 0 : model_states + 1])) for i in traj_targets_test
        ]
    else:
        scaled_traj_targets_train_posvel = [torch.Tensor(i[:, 0 : model_states + 1]) for i in traj_targets_train]
        scaled_traj_targets_test_posvel = [torch.Tensor(i[:, 0 : model_states + 1]) for i in traj_targets_test]
    gen_model = False
    try:
        # Try loading the specific requested model
        node.load(directory=model_save_path, model_name=model_name)
    except ValueError:
        gen_model = True
        pass

    if gen_model:
        # did not find a model to load. creating a new one

        # Model file not found. Train and create it
        # node._log_metrics = new_log_metrics.__get__(node)
        # try:
        #     node.model.compile()  # this resulted in slower epochs on cpu
        #     print("successfully compile the nn")
        # except Exception as e:
        #     print("failed to compile the nn due to", e)

        if model_type == "latentode":
            # Choose a short window (e.g. 10 time-steps).  You can expose this
            # as another CLI argument if you wish.
            OBS_WINDOW = 10

            train_data = [
                _make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_train_posvel
            ]  # list of (obs_window, target)
            test_data = [_make_obs_target(traj, obs_len=OBS_WINDOW) for traj in scaled_traj_targets_test_posvel]
            # reshape for NODEPredictor: it expects a list of tensors.
            # We will pack the tuple into a single tensor where the first two
            # dimensions are (B, K/ T) and let the model unpack them.
            # The simplest approach is to keep them as tuples and let the
            # training loop handle them.
            # → In the `node.fit` call below replace `fraction_of_data` /
            #   `fraction_of_data_val` with these lists.

        # length strategies is a trick from NODE literature to initialize the model on shorter time frames
        #
        # Early-stopper tuning for the mini-batched (noisy) regime:
        #   * min_delta must sit ABOVE the val_loss noise floor. With ~2-6
        #     batches/epoch the val_loss bounces ~+/-0.02-0.05; the old
        #     min_delta=5e-6 treated a 0.000005 non-improvement as a strike, so
        #     runs early-stopped on pure noise (the after-run died at ~57 epochs
        #     while still improving). 1e-2 lets normal bounces pass.
        #   * patience must be LARGE enough to (a) ride out noisy non-improving
        #     epochs and (b) exceed the ReduceLROnPlateau patience so the LR gets
        #     to drop and help BEFORE the stopper fires. The scheduler (applied
        #     on the 1.0 stages) uses patience = early_stop_patience // 2, so an
        #     early-stop patience of 60 gives the scheduler (~30) a full cycle
        #     plus recovery room before stopping.
        length_strategies = [
            (0.1, 5000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (0.3, 5000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (0.5, 3000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (0.7, 2000, EarlyStopper(60, 1e-2, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-3),
            # TODO: get rid of this one when the ReduceOnPlateau lr scheduler is working
            (1.0, 1500, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-4),
            (1.0, 1500, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-5),
            (1.0, 5000, EarlyStopper(80, 5e-3, metric_name=early_stop_metric_name), 1e-7),
        ]

        for len_strat in length_strategies:
            print("running length strategy", len_strat)
            data_fraction, epochs, early_stopper, learning_rate = len_strat
            # update the training configuration for the new length strategy
            node.training_configuration = TrainingConfiguration(
                n_epochs=epochs,
                optimizer=AdamOptimizer(learning_rate=learning_rate),
                # optimizer=ReduceLROnPlateauConfiguration("loss").create_from_optimizer(
                #     torch.optim.Adam(node.parameters(), learning_rate)
                # ),
                # optimizer=torch.optim.lr_scheduler.ReduceLROnPlateau(
                #     torch.optim.Adam(node.parameters(), learning_rate)
                # ),
                batch_size=batch_size,
                num_workers=2,  # is this the parallel control? cpu_count()//2?
                verbose=True,
            )

            # manually re-initialize some of the neural_ode object things. copied from NODEPredictor.__init__
            # Parse parameters from the training configuration.
            node.optimizer_config = node.training_configuration.optimizer
            node.n_epochs = node.training_configuration.get_param(TrainingParam.N_EPOCHS)

            # Set the iteration parameter for required optimizers.
            node.training_metrics = {}

            # Setup the model for training and inference.
            node._initialize_optimizer()

            # reset the early stop check
            node.early_stopper = early_stopper
            # node.early_stopper = None

            min_states = 5
            if math.ceil(scaled_traj_targets_train_posvel[0].shape[0] * data_fraction) < min_states:
                print("length strategy results in too few states. overriding to maintain stability")
            if model_type == "latentode":
                # each element is a tuple (obs_window, target)
                fraction_of_data = [
                    (
                        obs[: max(math.ceil(obs.shape[0] * data_fraction), min_states)],  # obs_window
                        tgt[: max(math.ceil(tgt.shape[0] * data_fraction), min_states)],
                    )  # target
                    for (obs, tgt) in train_data
                ]
                fraction_of_data_val = [
                    (
                        obs[: max(math.ceil(obs.shape[0] * data_fraction), min_states)],
                        tgt[: max(math.ceil(tgt.shape[0] * data_fraction), min_states)],
                    )
                    for (obs, tgt) in test_data
                ]
            else:
                # existing behaviour (plain NODE/ANODE/SONODE)
                fraction_of_data = [
                    x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :]
                    for x in scaled_traj_targets_train_posvel
                ]
                fraction_of_data_val = [
                    x[: max(math.ceil(x.shape[0] * data_fraction), min_states), :]
                    for x in scaled_traj_targets_test_posvel
                ]

            # torch.autograd.set_detect_anomaly(True)  # the magic command to look into the guts of torch
            metrics = node.fit(
                x=fraction_of_data,
                validation_data=fraction_of_data_val,
                # validation_data=fraction_of_data,
                enable_checkpoints=True if data_fraction == 1.0 else False,
            )
        p = Path(model_save_path, model_name + ".checkpoint.pt")
        p.rename(Path(p.parent, p.name.replace(".checkpoint", "")))

    # load the saved checkpoint model
    node.load(directory=model_save_path, model_name=model_name)

    # disable training mode on the model
    node.model.train(False)
    node.model.eval()

    # TODO: replace this with individual adapter model setup if required for GRUODEPredictorModel export
    example_input = torch.cat((scaled_traj_targets_train_posvel[0][0], torch.zeros(aug_dim))).to(node.device)
    model_onx = torch.onnx.export(
        node.model,
        example_input,
        os.path.join(model_save_path, model_name + ".onnx"),
        export_params=True,
        opset_version=18,  # 18 is the max we can go do right now. 17 is max w/o dynamo. https://onnxruntime.ai/docs/reference/compatibility.html#onnx-opset-support
        external_data=False,
        input_names=["input"],
        output_names=["output"],
    )

    # export the model to ONNX plain text format
    with open(
        os.path.join(model_save_path, model_name + "_plain.onnx"),
        "w",
    ) as f:
        f.write(onnx.printer.to_text(model_onx.model_proto))  # This is plain text

    # save a protobuf text file of the scalar
    if isinstance(scaler_traj, MinMaxScaler):
        min_input = scaler_traj.min_
        scale_input = scaler_traj.scale_
        data_min_input = scaler_traj.data_min_
        data_max_input = scaler_traj.data_max_

        with open(
            os.path.join(
                model_save_path,
                f"{model_name}_scalar_params_and_test_inputs.txt",
            ),
            "w",
            encoding="utf-8",
        ) as f:
            for m, s, dmin, dmax in zip(min_input, scale_input, data_min_input, data_max_input):
                f.write(f"""InputScaleFactorsMinMaxScaler
{{
\tMin: {m}
\tScale: {s}
\tDataMin: {dmin}
\tDataMax: {dmax}
}}""")
    elif isinstance(scaler_traj, StandardScaler):
        scale_input = scaler_traj.scale_
        mean_input = scaler_traj.mean_
        var_input = scaler_traj.var_

        with open(
            os.path.join(
                model_save_path,
                f"{model_name}_scalar_params_and_test_inputs.txt",
            ),
            "w",
            encoding="utf-8",
        ) as f:
            for s, m, v in zip(scale_input, mean_input, var_input):
                f.write(f"""InputScaleFactorsStandardScaler
{{
\tScale: {s}
\tMean: {m}
\tVariance: {v}
}}""")
    return node, model_name


def prep_trajectory(x):
    # load_single_truth(x, debug=False), x.name, args.sr, path
    ecef_data, traj_number, max_sr, trajectory_dt, args = x
    # keep time, pos, vel. don't need the rest of the columns
    ecef_data = ecef_data[:, 0:7]
    print("prepping traj", traj_number)
    ref_ecef = deepcopy(ecef_data[-1, POS_SLICE])

    # remove launch point based on near zero speed state
    # while np.all(np.isclose(np.linalg.norm(ecef_data[0, VEL_SLICE]), 0)):
    while np.any(np.isclose(ecef_data[0, VEL_SLICE], 0)):
        ecef_data = ecef_data[1:]

   
    sr_ecef_data = np.asarray(
        tuple(x for x in ecef_data if np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) < max_sr),
        # tuple(x for x in ecef_data if 2500e3 < np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) < max_sr),
        dtype=np.float64,
    )
    # TODO: add a min slant range to avoid the origin discontinuity
    # sr_ecef_data = np.asarray(
    #     tuple(x for x in ecef_data if np.linalg.norm(x[POS_SLICE] - ecef_data[-1, POS_SLICE]) > 1000),
    #     dtype=np.float64,
    # )

    # nice idea, but it wasn't the source of the problem
    # filter the points by only those above the horizon. Work from impact backwards.
    # def while_gen_backward_up(data):
    #     for x in reversed(data):
    #         if ecef_to_ned(x[POS_SLICE], ref_ecef)[2] <= 0:
    #             yield x
    #         else:
    #             break

    # sr_ecef_data = np.asarray(tuple(reversed(tuple(while_gen_backward_up(sr_ecef_data)))))

    # TODO: move this to a trajectory time check helper function file
    # check the time rate of the data
    # diff the time column, run unique, print that if there is more than 1 unique
    if sr_ecef_data.shape[-1] < 5:
        print(f"{traj_number} does not have enough time stamps for this slant range")
        return None, None
    time_diff = np.diff(sr_ecef_data[:, TIME_INDEX])
    unique_time_diff = np.unique(np.round(time_diff, decimals=2))
    if np.any(time_diff < 0):
        raise ValueError(
            f"warning: {traj_number} has time that goes backwards. Time diffs are {unique_time_diff}, excluding from data pool"
        )

    # TODO: this resampling needs to move into a function so it can reused
    # TODO: this needs to flip around so that the range is relative to the impact time (and flip sign again after)
    new_times = np.arange(sr_ecef_data[0, 0], sr_ecef_data[-1, 0] + trajectory_dt, trajectory_dt)

    try:
        resampled_sr_ecef_data = np.hstack(
            [np.atleast_2d(new_times).T]
            + [
                make_interp_spline(
                    sr_ecef_data[:, 0],
                    sr_ecef_data[:, 1:],
                    bc_type="not-a-knot",
                )(new_times, extrapolate=True)
            ]
        )
        # for when resampling of the truth data is not desired
        # resampled_sr_ecef_data = sr_ecef_data
    except Exception as e:
        print(f"warning: {traj_number} had the error with interpolation")
        raise e

    if args.frame == "grdth":
        # convert ecef truth to the training frame
        next_frame_data, initial_point_heading = ecef_to_next_grdth(resampled_sr_ecef_data, ref_ecef)

        # check the inverse transform
        check_ecef = next_grdth_to_ecef(next_frame_data, ref_ecef, initial_point_heading)
    elif args.frame == "geodesic":
        # convert to geodesic frame relative to the impact point
        next_frame_data = ecef_to_local_geodesic_vec(
            resampled_sr_ecef_data[:, POS_SLICE],
            resampled_sr_ecef_data[:, VEL_SLICE],
            np.zeros_like(
                resampled_sr_ecef_data[:, VEL_SLICE]
            ),  # TODO: better handling of acceleration being in the transform functions
            ref_ecef,
        )
        # Prepend time and only include pos and vel
        next_frame_data = np.hstack([resampled_sr_ecef_data[:, TIME_INDEX][..., np.newaxis], next_frame_data[:, :6]])
        
    elif args.frame == "dcu":
        # convert ecef truth to the training frame
        next_frame_data, initial_point_heading, flip_c = ecef_to_next_dcu(resampled_sr_ecef_data, ref_ecef)

        # check the inverse transform
        check_ecef = next_dcu_to_ecef(next_frame_data, ref_ecef, initial_point_heading, flip_c)
    else:
        raise NotImplementedError("That frame is not supported yet")
    # closeness_check
    # pos_err = mean_squared_error(resampled_sr_ecef_data[POS_SLICE], check_ecef[POS_SLICE])
    # vel_err = mean_squared_error(resampled_sr_ecef_data[VEL_SLICE], check_ecef[VEL_SLICE])
    # print(f"MSE round-trip position: {pos_err:.3e}")
    # print(f"MSE round-trip velocity: {vel_err:.3e}")

    # add column for traj number
    # next_frame_data = np.c_[next_frame_data, [traj_number] * next_frame_data.shape[0]]

    # add columns for ECEF reference point (12, 13, 14)
    # TODO: stop doing this to save some RAM and use a metadata attribute
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[0]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[1]]
    next_frame_data = np.c_[next_frame_data, np.ones(next_frame_data.shape[0]) * ref_ecef[2]]

    # if traj_number in ("traj.data.19.csv", "traj.data.11.csv"):
    #     print(next_frame_data)
    # np.savetxt(
    #     "grdth_" + traj_number,
    #     next_frame_data,
    #     delimiter=",",
    #     # header=",".join(header_row),
    #     comments="",
    #     fmt="%.8f",
    # )

    return next_frame_data, traj_number


