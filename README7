class SecondOrderSplitMSELoss(torch.nn.Module):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        vel_weight: float | None = 1.0,
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
        pos_expect: float = "inf",
        vel_expect: float = "inf",
    ) -> None:
        """Initializes SecondOrderSplitMSELoss."""
        super().__init__()
        self.height_idx = height_idx
        self.vel_indices = vel_indices
        self.vel_weight = vel_weight
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        self.pos_expect = pos_expect
        self.vel_expect = vel_expect

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)

        if self.scaler is not None:
            pred_unscaled = torch.from_numpy(
                self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                    -1, n_timesteps, self.N_FEATURES
                )
            )
            target_unscaled = torch.from_numpy(
                self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                    -1, n_timesteps, self.N_FEATURES
                )
            )
        else:
            pred_unscaled = pred.detach()
            target_unscaled = target.detach()

        pos_pred_unscaled = pred_unscaled[..., : self.vel_indices[0]]
        pos_target_unscaled = target_unscaled[..., : self.vel_indices[0]]
        vel_pred_unscaled = pred_unscaled[..., self.vel_indices]
        vel_target_unscaled = target_unscaled[..., self.vel_indices]

        avg_pos_diff = torch.nn.L1Loss().forward(pos_pred_unscaled, pos_target_unscaled)
        avg_vel_diff = torch.nn.L1Loss().forward(vel_pred_unscaled, vel_target_unscaled)

        pos_pred = pred[..., : self.vel_indices[0]]
        pos_target = target[..., : self.vel_indices[0]]
        vel_pred = pred[..., self.vel_indices]
        vel_target = target[..., self.vel_indices]

        pos_ratio = torch.max(torch.Tensor([1.0]), avg_pos_diff / self.pos_expect) ** 2
        vel_ratio = torch.max(torch.Tensor([1.0]), avg_vel_diff / self.vel_expect) ** 2

        pos_loss = torch.nn.MSELoss().forward(pos_pred, pos_target) * pos_ratio
        vel_loss = torch.nn.MSELoss().forward(vel_pred, vel_target) * vel_ratio
        total_loss = pos_loss + vel_loss

        return {
            "loss": total_loss,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
        }


class EnergyMSELoss(MSELoss):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        energy_fn: Callable[[Tensor, int, list[int]], Tensor],
        energy_weight: float | None = 1.0,
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
    ) -> None:
        """Initializes EnergyMSELoss."""
        super().__init__()
        self.height_idx = height_idx
        self.vel_indices = vel_indices
        self.energy_fn = energy_fn
        self.energy_weight = energy_weight
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)
        loss_data = super().forward(pred, target)
        energy_pred = self.energy_fn(pred, self.height_idx, self.vel_indices)
        energy_target = self.energy_fn(target, self.height_idx, self.vel_indices)
        loss_energy = super().forward(energy_pred, energy_target) * self.energy_weight

        total_loss = loss_data + loss_energy

        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred, pos_target)
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred, vel_target)

        return {
            "loss": total_loss,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
            "energy_loss": loss_energy,
        }


class ReverseLinearWeightingLoss(torch.nn.modules.loss._Loss):  # noqa: SLF001
    def __init__(self) -> None:
        """Initializes ReverseLinearWeightingLoss."""
        super().__init__()

    def forward(
        self,
        pred: torch.Tensor,
        target: torch.Tensor,
    ) -> torch.Tensor:
        batch_size, time_steps, n_features = pred.shape

        reverse_linear_weights: torch.Tensor = torch.arange(time_steps).repeat(batch_size, 1)
        reverse_linear_weights = reverse_linear_weights / reverse_linear_weights.sum(dim=1, keepdim=True) * 100.0
        reverse_linear_weights = torch.stack([reverse_linear_weights for _ in range(n_features)], dim=-1)

        return {"loss": torch.mean(torch.abs(pred - target) * reverse_linear_weights)}


