    #         raise ValueError("Numerical derivative of ground range is not close to the ground range rate values")
    #     # print(np.gradient(traj_targets_train[0][:, 4], traj_targets_train[0][:, 0]), traj_targets_train[0][:, 5])
    #     # print(np.gradient(traj_targets_train[0][:, 4], traj_targets_train[0][:, 0]) - traj_targets_train[0][:, 5])
    #     if not all(
    #         [np.isclose(np.gradient(x[:-3, 4], x[:-3, 0]), x[:-3, 5], atol=5).all() for x in traj_targets_train]
    #     ):
    #         raise ValueError("Numerical derivative of down is not close to the down rate values")
    # TODO: try validating that the integral of the velocity is close to the position

