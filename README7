"""
Physics-constrained Recurrent State-Space Model (RSSM) with a discrete
mode-latent for high-dimensional chaotic kinematic trajectory forecasting.

This module implements the architecture concluded as optimal in the
"AI Model Design" trade study:

  1. Physics-informed parameterization
       The network emits ACCELERATION on the position-bearing states. The
       kinematic state is advanced by a fixed-rate semi-implicit (symplectic)
       Euler integrator: v <- v + a*dt ; p <- p + v*dt. Position and velocity
       are never predicted independently, which bounds long-horizon drift by
       construction (the doc's "constrain the output manifold" decision).

  2. Discrete mode-latent (SLDS-style, modernized)
       A Gumbel-Softmax categorical z_t gates K mode-specific dynamics heads,
       so the model represents distinct regimes (cruise / juke / spiral /
       stall-turn / terrain-mask) instead of averaging across them.

  3. RSSM backbone (Dreamer/PlaNet-style)
       Deterministic GRU recurrence h_t plus a stochastic latent s_t with a
       prior (open-loop) and posterior (observation-conditioned) split.

  4. Multi-step rollout
       forward() produces a full open-loop / scheduled-sampling rollout so the
       training loss can be computed on the deployment condition directly.

  5. Ensemble / distributional output
       The stochastic latent supports multi-sample rollouts; an ensemble
       wrapper (RSSMEnsemble) provides a predictive cone for the chaser.

Tensor conventions
------------------
  B  : batch (number of trajectories)
  T  : sequence length (time steps, regular-rate, spacing dt)
  D  : physical state size (6 for DCU, 5 for GRDTH)
All public tensors are (B, T, D) in the SAME normalised physical state space
that the rest of training.py already uses. dt is a scalar (seconds).
"""

from __future__ import annotations

import torch
import torch.nn as nn
import torch.nn.functional as F


# ----------------------------------------------------------------------
# State layout helper
# ----------------------------------------------------------------------
class StateLayout:
    """
    Describes how the D-dimensional physical state maps to position /
    velocity components, so the integrator works for both the balanced
    6-state DCU layout (Down,Cross,Up, dotD,dotC,dotU) and the unbalanced
    5-state GRDTH layout (GR, Down, dotGR, dotD, VTheta).

    pos_indices[i] is advanced by vel_indices[i] * dt.
    vel_indices[i] is advanced by the network's acceleration output i * dt.
    aux_indices are states with no position/velocity coupling (e.g. VTheta /
    heading-rate in GRDTH); the network predicts their derivative directly.
    """

    def __init__(self, pos_indices, vel_indices, aux_indices=None):
        assert len(pos_indices) == len(vel_indices), (
            "pos_indices and vel_indices must pair up (p advanced by its v)"
        )
        self.pos_indices = list(pos_indices)
        self.vel_indices = list(vel_indices)
        self.aux_indices = list(aux_indices) if aux_indices is not None else []
        # number of scalar derivatives the network must emit:
        #   one acceleration per (pos,vel) pair + one rate per aux state
        self.n_accel = len(self.vel_indices)
        self.n_aux = len(self.aux_indices)
        self.n_deriv = self.n_accel + self.n_aux

    @property
    def state_dim(self):
        return len(self.pos_indices) + len(self.vel_indices) + len(self.aux_indices)

    @staticmethod
    def for_frame(frame: str) -> "StateLayout":
        if frame in ("dcu", "geodesic"):
            # Down,Cross,Up, dotD,dotC,dotU
            return StateLayout(pos_indices=[0, 1, 2], vel_indices=[3, 4, 5])
        elif frame == "grdth":
            # GR, Down, dotGR, dotD, VTheta(heading-rate, no paired position)
            return StateLayout(pos_indices=[0, 1], vel_indices=[2, 3], aux_indices=[4])
        raise ValueError(f"Unknown frame for state layout: {frame}")


# ----------------------------------------------------------------------
# Physics integrator
# ----------------------------------------------------------------------
class SymplecticIntegrator(nn.Module):
    """
    Fixed-rate semi-implicit (symplectic) Euler advance of one kinematic step.

    Given current state x_t (B, D) and network-emitted derivatives
    deriv (B, n_deriv) = [accel on vel states ; rate on aux states], returns
    x_{t+1} (B, D). Position/velocity consistency (dx = v*dt, dv = a*dt) is
    enforced structurally, not learned.

    Semi-implicit ordering (update velocity first, then position with the NEW
    velocity) is used because it bounds energy growth on oscillatory /
    phugoid-like dynamics far better than explicit Euler.
    """

    def __init__(self, layout: StateLayout, dt: float):
        super().__init__()
        self.layout = layout
        self.register_buffer("dt", torch.tensor(float(dt)))
        # index tensors registered as buffers so they move with .to(device)
        self.register_buffer("pos_idx", torch.tensor(layout.pos_indices, dtype=torch.long))
        self.register_buffer("vel_idx", torch.tensor(layout.vel_indices, dtype=torch.long))
        if layout.aux_indices:
            self.register_buffer("aux_idx", torch.tensor(layout.aux_indices, dtype=torch.long))
        else:
            self.aux_idx = None

    def forward(self, x: torch.Tensor, deriv: torch.Tensor) -> torch.Tensor:
        # x: (B, D) ; deriv: (B, n_deriv)
        # Built fully out-of-place (index_copy_ on a clone of an autograd tensor
        # can corrupt the backward graph). We scatter updates into a zeros
        # template and add the untouched components back via a complement mask.
        dt = self.dt
        accel = deriv[:, : self.layout.n_accel]              # (B, n_accel)

        v_old = x.index_select(-1, self.vel_idx)             # (B, n_accel)
        v_new = v_old + accel * dt                           # dv = a*dt
        p_old = x.index_select(-1, self.pos_idx)
        p_new = p_old + v_new * dt                           # dx = v*dt (semi-implicit)

        # scatter the updated pos/vel (and aux) into a zero template
        updated = torch.zeros_like(x)
        updated = updated.index_add(-1, self.vel_idx, v_new)
        updated = updated.index_add(-1, self.pos_idx, p_new)

        # mask marking which columns were updated (1) vs carried over (0)
        mask = torch.zeros_like(x)
        mask = mask.index_fill(-1, self.vel_idx, 1.0)
        mask = mask.index_fill(-1, self.pos_idx, 1.0)

        if self.aux_idx is not None:
            rate = deriv[:, self.layout.n_accel :]           # (B, n_aux)
            a_old = x.index_select(-1, self.aux_idx)
            updated = updated.index_add(-1, self.aux_idx, a_old + rate * dt)
            mask = mask.index_fill(-1, self.aux_idx, 1.0)

        # updated columns take the new value; all others carry x unchanged
        return updated + (1.0 - mask) * x


# ----------------------------------------------------------------------
# Discrete mode-latent gated dynamics
# ----------------------------------------------------------------------
class SwitchingDynamics(nn.Module):
    """
    K mode-specific MLP heads producing derivatives, gated by a Gumbel-Softmax
    categorical drawn from a learned transition network. This is the SLDS /
    switching-dynamics component: each mode is a distinct local vector field,
    and the categorical selects (softly during training, hard at inference)
    which regime is active.

    Inputs:
        feat (B, F)  : conditioning features (RSSM h_t, s_t, current state)
    Returns:
        deriv (B, n_deriv) : gated derivative (accel + aux rate)
        logits (B, K)      : mode logits (for entropy regularisation / logging)
        mode  (B, K)       : the (soft or hard) mode weights actually used
    """

    def __init__(self, feat_dim: int, n_deriv: int, n_modes: int, hidden: int):
        super().__init__()
        self.n_modes = n_modes
        self.n_deriv = n_deriv
        self.mode_logits = nn.Sequential(
            nn.Linear(feat_dim, hidden), nn.SiLU(), nn.Linear(hidden, n_modes)
        )
        # one derivative head per mode
        self.heads = nn.ModuleList(
            [
                nn.Sequential(
                    nn.Linear(feat_dim, hidden),
                    nn.SiLU(),
                    nn.Linear(hidden, hidden),
                    nn.SiLU(),
                    nn.Linear(hidden, n_deriv),
                )
                for _ in range(n_modes)
            ]
        )

    def forward(self, feat: torch.Tensor, tau: float = 1.0, hard: bool = False, sample: bool = True):
        logits = self.mode_logits(feat)                       # (B, K)
        if sample:
            mode = F.gumbel_softmax(logits, tau=tau, hard=hard, dim=-1)
        else:
            # deterministic inference path (ONNX-safe): pick argmax mode
            idx = logits.argmax(dim=-1)
            mode = F.one_hot(idx, num_classes=self.n_modes).to(logits.dtype)
        # stack head outputs: (B, K, n_deriv)
        head_out = torch.stack([h(feat) for h in self.heads], dim=1)
        deriv = (mode.unsqueeze(-1) * head_out).sum(dim=1)     # (B, n_deriv)
        return deriv, logits, mode


# ----------------------------------------------------------------------
# RSSM cell
# ----------------------------------------------------------------------
class RSSMCell(nn.Module):
    """
    One Dreamer/PlaNet-style recurrent state-space step.

    Deterministic recurrence:   h_t = GRU(h_{t-1}, [s_{t-1}, embed(x_{t-1})])
    Stochastic prior:           p(s_t | h_t)              (open-loop)
    Stochastic posterior:       q(s_t | h_t, embed(x_t))  (obs-conditioned)

    The mode-gated SwitchingDynamics consumes [h_t, s_t, x_{t-1}] and emits the
    derivative that the SymplecticIntegrator turns into x_t.
    """

    def __init__(self, state_dim, det_dim, stoch_dim, n_modes, hidden, n_deriv):
        super().__init__()
        self.det_dim = det_dim
        self.stoch_dim = stoch_dim

        self.obs_embed = nn.Sequential(nn.Linear(state_dim, hidden), nn.SiLU())
        self.gru = nn.GRUCell(stoch_dim + hidden, det_dim)

        # prior and posterior produce (mu, logvar) for the stochastic latent
        self.prior_net = nn.Sequential(nn.Linear(det_dim, hidden), nn.SiLU(),
                                       nn.Linear(hidden, 2 * stoch_dim))
        self.post_net = nn.Sequential(nn.Linear(det_dim + hidden, hidden), nn.SiLU(),
                                      nn.Linear(hidden, 2 * stoch_dim))

        feat_dim = det_dim + stoch_dim + state_dim
        self.dynamics = SwitchingDynamics(feat_dim, n_deriv=n_deriv, n_modes=n_modes, hidden=hidden)

    def _split(self, params):
        mu, logvar = params.chunk(2, dim=-1)
        logvar = torch.clamp(logvar, -8.0, 8.0)
        return mu, logvar

    @staticmethod
    def _sample(mu, logvar, sample=True):
        if not sample:
            return mu
        std = torch.exp(0.5 * logvar)
        return mu + std * torch.randn_like(std)

    def forward(self, h_prev, s_prev, x_prev, x_obs=None, tau=1.0, hard=False, sample=True):
        # deterministic recurrence
        gru_in = torch.cat([s_prev, self.obs_embed(x_prev)], dim=-1)
        h = self.gru(gru_in, h_prev)                          # (B, det_dim)

        # prior over stochastic latent
        prior_mu, prior_lv = self._split(self.prior_net(h))

        # posterior (only when an observation is available)
        if x_obs is not None:
            post_in = torch.cat([h, self.obs_embed(x_obs)], dim=-1)
            post_mu, post_lv = self._split(self.post_net(post_in))
            s = self._sample(post_mu, post_lv, sample)
        else:
            post_mu, post_lv = prior_mu, prior_lv
            s = self._sample(prior_mu, prior_lv, sample)

        feat = torch.cat([h, s, x_prev], dim=-1)
        deriv, mode_logits, mode = self.dynamics(feat, tau=tau, hard=hard, sample=sample)
        return h, s, deriv, (prior_mu, prior_lv, post_mu, post_lv, mode_logits, mode)


# ----------------------------------------------------------------------
# Full model
# ----------------------------------------------------------------------
class PhysicsRSSM(nn.Module):
    """
    Physics-constrained switching RSSM trajectory forecaster.

    forward() signature mirrors the LatentNODE contract used in training.py:
    it accepts a tuple so the existing NODEPredictor.fit loop can pass
    (obs_window, t_eval) without modification. Here t_eval is used only to
    infer the rollout length T; the integrator runs at the fixed dt the model
    was constructed with.

    Returns:
        recon  (B, T, D)        : rolled-out normalised physical states
        extras dict             : tensors needed by the loss
                                  (kl, mode_logits, mode, ...)
    """

    def __init__(
        self,
        layout: StateLayout,
        dt: float,
        det_dim: int = 128,
        stoch_dim: int = 32,
        n_modes: int = 5,
        hidden: int = 128,
        obs_window: int = 10,
        ss_prob: float = 0.0,
    ):
        super().__init__()
        self.layout = layout
        self.state_dim = layout.state_dim
        self.det_dim = det_dim
        self.stoch_dim = stoch_dim
        self.obs_window = obs_window
        # scheduled-sampling probability used during training rollouts. Stored
        # on the module so it survives the NODEPredictor.fit() call contract,
        # which invokes forward() with only the (obs, t_eval) tuple. A trainer
        # that can pass targets into forward() will use them; otherwise the
        # rollout is fully open-loop (ss_prob effectively 0), which is the
        # safe, deployment-matching default.
        self.ss_prob = ss_prob

        self.cell = RSSMCell(self.state_dim, det_dim, stoch_dim, n_modes, hidden, layout.n_deriv)
        self.integrator = SymplecticIntegrator(layout, dt)

        # encoder to warm-start (h_0, s_0) from the short observation window
        self.warm_gru = nn.GRU(self.state_dim, det_dim, batch_first=True)
        self.s0_net = nn.Linear(det_dim, 2 * stoch_dim)

    def _init_state(self, obs_window):
        # obs_window: (B, K, D)  -> h0 (B, det_dim), s0 (B, stoch_dim)
        _, h_n = self.warm_gru(obs_window)
        h0 = h_n.squeeze(0)
        mu, logvar = self.s0_net(h0).chunk(2, dim=-1)
        logvar = torch.clamp(logvar, -8.0, 8.0)
        s0 = mu + torch.exp(0.5 * logvar) * torch.randn_like(mu) if self.training else mu
        return h0, s0, mu, logvar

    def rollout(self, obs_window, T, targets=None, ss_prob=0.0, tau=1.0, hard=False, sample=True):
        """
        Open-loop / scheduled-sampling rollout.

        obs_window : (B, K, D)   warm-start window (also supplies x_0)
        T          : int         number of steps to produce (including step 0)
        targets    : (B, T, D)   ground truth, used only for scheduled sampling
        ss_prob    : float       prob. of feeding ground truth instead of the
                                 model's own prediction (0 = fully open-loop)
        """
        B = obs_window.shape[0]
        h, s, _warm_mu, _warm_lv = self._init_state(obs_window)
        x = obs_window[:, -1, :]                              # x_0 = last observed state

        recon = [x]
        priors_mu, priors_lv, posts_mu, posts_lv = [], [], [], []
        mode_logits_seq = []

        for t in range(1, T):
            x_obs = None
            # posterior available only while we are still within the obs window
            if t < obs_window.shape[1]:
                x_obs = obs_window[:, t, :]
            h, s, deriv, aux = self.cell(h, s, x, x_obs=x_obs, tau=tau, hard=hard, sample=sample)
            x_next = self.integrator(x, deriv)
            recon.append(x_next)

            pr_mu, pr_lv, po_mu, po_lv, m_logits, _ = aux
            priors_mu.append(pr_mu); priors_lv.append(pr_lv)
            posts_mu.append(po_mu); posts_lv.append(po_lv)
            mode_logits_seq.append(m_logits)

            # scheduled sampling: optionally replace prediction with truth
            if self.training and targets is not None and ss_prob > 0.0:
                use_truth = (torch.rand(B, 1, device=x.device) < ss_prob).float()
                x = use_truth * targets[:, t, :] + (1.0 - use_truth) * x_next
            else:
                x = x_next

        recon = torch.stack(recon, dim=1)                    # (B, T, D)
        extras = {
            "prior_mu": torch.stack(priors_mu, dim=1) if priors_mu else None,
            "prior_lv": torch.stack(priors_lv, dim=1) if priors_lv else None,
            "post_mu": torch.stack(posts_mu, dim=1) if posts_mu else None,
            "post_lv": torch.stack(posts_lv, dim=1) if posts_lv else None,
            "mode_logits": torch.stack(mode_logits_seq, dim=1) if mode_logits_seq else None,
        }
        return recon, extras

    def forward(self, obs_window_and_times):
        # Accept either (obs, t_eval) or (obs, t_eval, targets). The third
        # element enables scheduled sampling during training; without it the
        # rollout is open-loop (matches deployment and the standard fit() call).
        if len(obs_window_and_times) == 3:
            obs_window, t_eval, targets = obs_window_and_times
        else:
            obs_window, t_eval = obs_window_and_times
            targets = None
        if t_eval is not None:
            T = int(t_eval.shape[0])
        elif targets is not None:
            T = int(targets.shape[1])
        else:
            T = obs_window.shape[1]
        recon, extras = self.rollout(
            obs_window, T,
            targets=targets,
            ss_prob=self.ss_prob if self.training else 0.0,
            tau=1.0,
            hard=not self.training,        # hard mode selection at eval
            sample=self.training,          # no latent noise at eval
        )
        return recon, extras


# ----------------------------------------------------------------------
# Deterministic inference wrapper (ONNX export target)
# ----------------------------------------------------------------------
class PhysicsRSSMInference(nn.Module):
    """
    ONNX-exportable deterministic single-step transition.

    The full training model is stochastic and autoregressive (Gumbel sampling,
    scheduled sampling, Python rollout loop) which does not export cleanly. For
    the downstream tracker we export a pure transition function with the same
    contract the existing ODE export used: given a single state vector, return
    the next state. Mode selection is argmax, latents are taken at their mean,
    no random sampling -> fully deterministic, opset-18 clean.

    Signature matches the TorchdiffeqSolver export path in training.py:
        forward(t, x) -> x_next
    where x is (D,) or (B, D). A persistent (h, s) recurrent state is held as
    buffers so the tracker can step the model one dt at a time.
    """

    def __init__(self, model: PhysicsRSSM):
        super().__init__()
        self.cell = model.cell
        self.integrator = model.integrator
        self.det_dim = model.det_dim
        self.stoch_dim = model.stoch_dim
        # recurrent carry as buffers (batch size 1 default; tracker can reset)
        self.register_buffer("h", torch.zeros(1, model.det_dim))
        self.register_buffer("s", torch.zeros(1, model.stoch_dim))

    def forward(self, t, x):
        single = x.dim() == 1
        if single:
            x = x.unsqueeze(0)
        h, s, deriv, _ = self.cell(
            self.h, self.s, x, x_obs=None, tau=1.0, hard=True, sample=False
        )
        x_next = self.integrator(x, deriv)
        # update carry (detached; this path is eval/ONNX only, no autograd)
        self.h = h.detach()
        self.s = s.detach()
        if single:
            x_next = x_next.squeeze(0)
        return x_next


# ----------------------------------------------------------------------
# Ensemble wrapper for predictive uncertainty (the chaser's "cone")
# ----------------------------------------------------------------------
class RSSMEnsemble(nn.Module):
    """
    Thin ensemble of PhysicsRSSM models. Either trained with different seeds /
    bootstrapped flights, or queried with multiple stochastic-latent samples,
    to give the pursuit controller a distribution (cone) at each horizon rather
    than a single point estimate.
    """

    def __init__(self, models):
        super().__init__()
        self.models = nn.ModuleList(models)

    def forward(self, obs_window_and_times, n_samples: int = 1):
        rollouts = []
        for m in self.models:
            for _ in range(n_samples):
                recon, _ = m(obs_window_and_times)
                rollouts.append(recon)
        stacked = torch.stack(rollouts, dim=0)               # (E*S, B, T, D)
        mean = stacked.mean(dim=0)
        std = stacked.std(dim=0)
        return mean, std, stacked


# ----------------------------------------------------------------------
# Rollout-aware composite loss
# ----------------------------------------------------------------------
def _gaussian_kl(mu_q, lv_q, mu_p, lv_p):
    """KL( q || p ) for diagonal Gaussians, summed over latent dim, mean over (B,T)."""
    var_q = torch.exp(lv_q)
    var_p = torch.exp(lv_p)
    kl = 0.5 * (lv_p - lv_q + (var_q + (mu_q - mu_p) ** 2) / var_p - 1.0)
    return kl.sum(dim=-1).mean()


class RSSMRolloutLoss(nn.Module):
    """
    Composite loss matching the design document:
      - multi-step rollout reconstruction MSE on the physical state
        (position-weighted, since the integrator already ties velocity to it)
      - free-bits KL between posterior and prior on the stochastic latent
      - small mode-usage entropy regulariser to keep modes from collapsing

    `recon_criterion` is the existing WrappedMSELoss instance from training.py,
    so scaling / frame conventions stay identical to the rest of the pipeline.
    """

    def __init__(self, recon_criterion, kl_weight=1.0, free_bits=1.0, entropy_weight=1e-3):
        super().__init__()
        self.recon_criterion = recon_criterion
        self.kl_weight = kl_weight
        self.free_bits = free_bits
        self.entropy_weight = entropy_weight

    def forward(self, pred, target, valid_mask=None):
        """
        pred       : (recon (B,T,D), extras dict)
        target     : (B, T, D) ground truth (NaN-padding already zeroed)
        valid_mask : (B, T) bool, True for real timesteps. When provided,
                     padded timesteps are zeroed in BOTH recon and target so
                     they contribute no error to recon_criterion and no
                     gradient. recon_criterion (WrappedMSELoss) is called with
                     its original (pred, true) signature, unmodified.
        """
        recon, extras = pred

        if valid_mask is not None:
            # align mask to (B, T, 1); recon/target may differ in T by one step
            T = min(recon.shape[1], target.shape[1], valid_mask.shape[1])
            m = valid_mask[:, :T].unsqueeze(-1).to(recon.dtype)
            recon_m = recon[:, :T, :] * m
            target_m = target[:, :T, :] * m
            recon_loss = self.recon_criterion(recon_m, target_m)
        else:
            recon_loss = self.recon_criterion(recon, target)

        kl = recon.new_zeros(())
        if extras.get("post_mu") is not None:
            raw_kl = _gaussian_kl(
                extras["post_mu"], extras["post_lv"],
                extras["prior_mu"], extras["prior_lv"],
            )
            # free bits: don't penalise KL below the floor
            kl = torch.clamp(raw_kl, min=self.free_bits)

        ent = recon.new_zeros(())
        if extras.get("mode_logits") is not None:
            p = torch.softmax(extras["mode_logits"], dim=-1)
            ent = -(p * torch.log(p + 1e-8)).sum(dim=-1).mean()

        # maximise entropy (subtract), minimise recon + KL
        return recon_loss + self.kl_weight * kl - self.entropy_weight * ent
