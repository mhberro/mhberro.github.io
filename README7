def sim_ingress(truth_states, args):
    impact_ecef = deepcopy(truth_states[-1, POS_SLICE])
    impact_time = truth_states[-1, 0]

    # Filters timeline to cleanly capture raw tracking states
    truth_states_sr_cut = np.asarray(
        tuple(x for x in truth_states if x[TIME_INDEX] < 122.0 and not np.allclose(x[VEL_SLICE], [0, 0, 0])),
        dtype=np.float64,
    )

    if truth_states_sr_cut.shape[0] == 0:
        return truth_states, [], []

    firm_track_time = truth_states_sr_cut[0][0]
    sim_time = deepcopy(firm_track_time)
    trajs = []
    truth_trajs = []

    while sim_time <= impact_time - measurement_dt:
        tgt_state_ecef_index = np.where(truth_states_sr_cut[:, 0] == sim_time)
        tgt_state_ecef_index_forward = np.where(truth_states_sr_cut[:, 0] >= sim_time)
        if len(tgt_state_ecef_index[0]) == 0:
            try:
                tgt_state_ecef_index = np.array(tgt_state_ecef_index_forward[0][0])
            except IndexError:
                return truth_states_sr_cut, trajs, truth_trajs
            sim_time = truth_states_sr_cut[tgt_state_ecef_index].squeeze()[0]
        tgt_state_ecef = truth_states_sr_cut[tgt_state_ecef_index]
        truth_traj_forward = truth_states_sr_cut[tgt_state_ecef_index_forward]

        x0 = tgt_state_ecef.squeeze()
        traj = NEXT_tactical_interface(x0[0:7], impact_ecef, extrapolation_dt, max_traj_states, args)
        if traj is not None:
            if isinstance(traj, int) and traj == -1:
                break
            trajs.append(traj)
            truth_trajs.append(truth_traj_forward)
        sim_time += measurement_dt
    return truth_states_sr_cut, trajs, truth_trajs


def bound(low, high, x):
    return max(low, min(high, x))


def round_to(x, base):
    return base * round(x / base)


ort_sess_stash = None


def NEXT_tactical_interface(initial_state_ecef, guide_point_ecef, dt, n_steps, args):
    initial_state_slant_range = np.linalg.norm(initial_state_ecef[POS_SLICE] - guide_point_ecef)
    if initial_state_slant_range < args.sr_min:
        print("target too close", initial_state_slant_range, args.sr_min)
        return -1

    use_grdth = "_grdth_" in os.path.basename(args.model)
    use_geodesic = "_geod_" in os.path.basename(args.model) or "_geodesic_" in os.path.basename(args.model)
    global ort_sess_stash
    
    if use_grdth:
        initial_state_NEXT_frame, initial_point_heading = ecef_to_next_grdth(initial_state_ecef, guide_point_ecef)
        if ort_sess_stash:
            ort_sess = ort_sess_stash
        else:
            ort_sess = onnxruntime.InferenceSession(args.model)
            ort_sess_stash = ort_sess
    elif use_geodesic:
        _, initial_point_heading = ecef_to_next_grdth(initial_state_ecef, guide_point_ecef)
        initial_state_NEXT_frame = ecef_to_local_geodesic_vec(
            np.atleast_2d(initial_state_ecef[POS_SLICE]),
            np.atleast_2d(initial_state_ecef[VEL_SLICE]),
            np.zeros_like(np.atleast_2d(initial_state_ecef[VEL_SLICE])),
            guide_point_ecef,
        )
        initial_state_NEXT_frame = np.hstack([np.atleast_2d(initial_state_ecef[TIME_INDEX]), initial_state_NEXT_frame[:, :6]])[0]
        if ort_sess_stash:
            ort_sess = ort_sess_stash
        else:
            ort_sess = onnxruntime.InferenceSession(args.model)
            ort_sess_stash = ort_sess
    else:
        initial_state_NEXT_frame, initial_point_heading, flip_c = ecef_to_next_dcu(initial_state_ecef, guide_point_ecef)
        initial_state_slant_range = np.linalg.norm(initial_state_NEXT_frame[POS_SLICE])
        bucket_range = 100000
        rounded_sr = int(bound(bucket_range, args.sr_max, round_to(initial_state_slant_range, bucket_range)) / 1e3)
        model_name_to_load = re.sub(r"_\d{1,3}sr_", f"_{rounded_sr}sr_", args.model)
        
        # Adjust scalar paths for DCU buckets dynamically if they match naming structures
        if os.path.exists(model_name_to_load):
            scalar_name_to_load = os.path.join(
                os.path.dirname(args.scalar), re.sub(r"_\d{1,3}sr_", f"_{rounded_sr}sr_", os.path.basename(args.scalar))
            )
            if os.path.exists(scalar_name_to_load):
                args.scalar = scalar_name_to_load
            ort_sess = onnxruntime.InferenceSession(model_name_to_load)
        else:
            ort_sess = onnxruntime.InferenceSession(args.model)

    try:
        NEXT_extrap = NEXT_extrapolation(
            initial_state_NEXT_frame, dt, n_steps, initial_point_heading, use_grdth, args, ort_sess
        )
    except ValueError as e:
        print("Extrap failed", traceback.format_exc())
        return None

    if use_grdth:
        NEXT_extrap_ecef = next_grdth_to_ecef(NEXT_extrap, guide_point_ecef, initial_point_heading)
    elif use_geodesic:
        NEXT_extrap_ecef = np.hstack(
            [
                NEXT_extrap[:, TIME_INDEX][..., np.newaxis],
                local_geodesic_to_ecef_vec(
                    np.hstack([NEXT_extrap[:, 1:], np.zeros_like(NEXT_extrap[:, VEL_SLICE])]), guide_point_ecef
                ),
            ],
        )[:, :7]
    else:
        NEXT_extrap_ecef = next_dcu_to_ecef(NEXT_extrap, guide_point_ecef, initial_point_heading, flip_c)

    a = np.gradient(NEXT_extrap_ecef[:, VEL_SLICE], axis=0)
    NEXT_extrap_ecef = np.hstack([NEXT_extrap_ecef, a])
    return NEXT_extrap_ecef


def NEXT_extrapolation(
    initial_state_next_frame,
    dt: float,
    n_steps: int,
    ref_angle,
    use_grdth: bool,
    args,
    ort_sess: onnxruntime.InferenceSession,
):
    use_scalar = "_scalarOn" in os.path.basename(args.model)
    if use_scalar:
        with open(args.scalar, "rb") as scalar_pickle:
            NEXT_scalar = pickle.load(scalar_pickle)
            
    state_size = 5 if use_grdth else 6

    # --------------------------------------------------------------------
    # Dynamic Hidden Parameter Extraction Matrix
    # --------------------------------------------------------------------
    model_base = os.path.basename(args.model)
    hid_match = re.search(r"_(\d+)hid_", model_base)
    aug_match = re.search(r"_(\d+)aug_", model_base)
    
    hidden_dim = int(hid_match.group(1)) if hid_match else 0
    model_augmentation_dim = int(aug_match.group(1)) if aug_match else 0
    is_gruode = hidden_dim > 0 or "gruode" in args.model.lower()

    extrap = np.array([np.hstack([initial_state_next_frame])])
    validity_time = deepcopy(initial_state_next_frame[0])
    
    # Initialize the hidden memory registry to neutral parameters at t0
    current_hidden_state = np.zeros((1, hidden_dim), dtype=np.float32) if is_gruode else None
    augmentation_state = np.zeros((1, model_augmentation_dim), dtype=np.float32) if model_augmentation_dim > 0 else None

    temp_iter = 0
    while temp_iter < n_steps and float(validity_time) < 122.0:
        temp_iter = temp_iter + 1
        validity_time += dt

        if use_scalar:
            pos_vel = np.asarray([extrap[-1][1 : state_size + 1]])
            scaled_pos_vel = NEXT_scalar.transform(pos_vel).astype(np.float32)
            
            # Pack input matrix configurations based on the evaluated model type
            if is_gruode:
                model_input = np.hstack([scaled_pos_vel, current_hidden_state])
                if model_augmentation_dim > 0:
                    model_input = np.hstack([model_input, augmentation_state])
            else:
                if model_augmentation_dim > 0:
                    model_input = np.hstack([scaled_pos_vel, augmentation_state])
                else:
                    model_input = scaled_pos_vel
            
            # Evaluate vector field derivative arrays via the ONNX Runtime engine
            model_output = ort_sess.run(["output"], {"input": model_input[0].astype(np.float32)})[-1].reshape(1, -1)
            
            if is_gruode:
                # Isolate distinct component derivatives from the continuous state matrix
                dx_dt = model_output[:, :state_size]
                dh_dt = model_output[:, state_size : state_size + hidden_dim]
                
                # Propagate both coordinates and hidden recurrent vector fields simultaneously
                current_hidden_state = current_hidden_state + dh_dt * dt
                scaled_pos_vel_next = scaled_pos_vel + dx_dt * dt
                next_state = NEXT_scalar.inverse_transform(scaled_pos_vel_next)
            else:
                next_state_raw = model_output * dt + model_input[:, :state_size]
                if model_augmentation_dim > 0:
                    augmentation_state = next_state_raw[:, state_size:]
                next_state = NEXT_scalar.inverse_transform(next_state_raw[:, :state_size])
        else:
            pos_vel = np.asarray([extrap[-1][1 : state_size + 1]], dtype=np.float32)
            if is_gruode:
                model_input = np.hstack([pos_vel, current_hidden_state])
                if model_augmentation_dim > 0:
                    model_input = np.hstack([model_input, augmentation_state])
            else:
                model_input = np.hstack([pos_vel, augmentation_state]) if model_augmentation_dim > 0 else pos_vel
                
            model_output = ort_sess.run(["output"], {"input": model_input[0].astype(np.float32)})[-1].reshape(1, -1)
            
            if is_gruode:
                dx_dt = model_output[:, :state_size]
                dh_dt = model_output[:, state_size : state_size + hidden_dim]
                current_hidden_state = current_hidden_state + dh_dt * dt
                next_state = pos_vel + dx_dt * dt
            else:
                next_state = model_output * dt + model_input[:, :state_size]
                if model_augmentation_dim > 0:
                    augmentation_state = next_state[:, state_size:]
                next_state = next_state[:, :state_size]

        next_state = np.insert(next_state, 0, validity_time)
        temp_extrap = np.vstack([extrap, next_state])

        # REMOVED STRATEGIC ICBM CRITERIA: Bypasses the 2,600 km early termination check to protect tactical runs
        extrap = np.vstack([extrap, next_state])

    if extrap.shape[0] < 3:
        raise ValueError(f"Extrap was too short {extrap.shape}")

    return extrap


