class BiasAlignedPhysicsLoss(torch.nn.Module):
    """
    Dictionary-aware Sobolev-style wrapper minimizing the first-moment velocity bias,
    Sobolev position-derivative matching, and multi-step Euler rollout consistency[cite: 7].
    """
    def __init__(
        self, 
        base_loss_func, 
        pos_idx: list[int], 
        vel_indices: list[int], 
        so_ratio: torch.Tensor | None = None, 
        bias_weight: float = 15.0, 
        sobolev_weight: float = 5.0, 
        euler_weight: float = 2.0, 
        k_steps: int = 4, 
        dt: float = 0.1
    ):
        super().__init__()
        self.base_loss_func = base_loss_func
        self.pos_idx = list(pos_idx)
        self.vel_indices = list(vel_indices)
        self.bias_weight = bias_weight
        self.sobolev_weight = sobolev_weight
        self.euler_weight = euler_weight
        self.k_steps = k_steps
        self.dt = dt
        self.model = None  # Bound post-initialization inside train_NEXT
        
        if so_ratio is not None:
            self.register_buffer("so_ratio", torch.as_tensor(so_ratio, dtype=torch.float32))
        else:
            self.so_ratio = None

    def forward(self, pred: torch.Tensor, true: torch.Tensor):
        # 1. Compute baseline dictionary metrics
        base_loss = self.base_loss_func(pred, true)
        
        pred_vel = pred[..., self.vel_indices]
        true_vel = true[..., self.vel_indices]
        
        # Section 3.3: Per-axis physically weighted velocity bias penalty[cite: 7]
        velocity_bias = torch.mean(pred_vel - true_vel, dim=1)
        if self.so_ratio is not None:
            bias_penalty = torch.mean(torch.sum((velocity_bias ** 2) * (self.so_ratio ** 2), dim=-1))
        else:
            bias_penalty = torch.mean(torch.sum(velocity_bias ** 2, dim=-1))
        total_bias_loss = self.bias_weight * bias_penalty
        
        # Section 3.1: Sobolev derivative-matching loss on position error[cite: 7]
        pred_pos = pred[..., self.pos_idx]
        true_pos = true[..., self.pos_idx]
        pos_error_dot = torch.diff(pred_pos - true_pos, dim=1) / self.dt
        sobolev_penalty = torch.mean(pos_error_dot ** 2)
        total_sobolev_loss = self.sobolev_weight * sobolev_penalty
        
        # Section 1.2: Differentiable multi-step Euler rollout consistency loss[cite: 7]
        total_euler_loss = 0.0
        if self.euler_weight > 0.0 and self.model is not None and true.shape[1] > self.k_steps:
            x_rollout = true[:, 0, :].clone()
            euler_rollouts = [x_rollout]
            for step in range(self.k_steps):
                dydt = self.model(0.0, x_rollout)
                x_rollout = x_rollout + dydt * self.dt
                euler_rollouts.append(x_rollout)
            
            pred_rollout = torch.stack(euler_rollouts, dim=1)
            target_rollout = true[:, :self.k_steps+1, :]
            total_euler_loss = torch.mean((pred_rollout - target_rollout) ** 2) * self.euler_weight
        
        if isinstance(base_loss, dict):
            out_dict = base_loss.copy()
            if "loss" in out_dict:
                out_dict["loss"] = out_dict["loss"] + total_bias_loss + total_sobolev_loss + total_euler_loss
            else:
                for k, v in out_dict.items():
                    if isinstance(v, torch.Tensor) and v.requires_grad:
                        out_dict[k] = v + total_bias_loss + total_sobolev_loss + total_euler_loss
                        break
            out_dict["bias_loss"] = total_bias_loss
            out_dict["sobolev_loss"] = total_sobolev_loss
            if isinstance(total_euler_loss, torch.Tensor):
                out_dict["euler_rollout_loss"] = total_euler_loss
            return out_dict
        else:
            return base_loss + total_bias_loss + total_sobolev_loss + total_euler_loss


