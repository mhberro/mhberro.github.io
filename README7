import math
import torch
import torch.nn as nn
from torchdiffeq import odeint

class GRUODEFunc(nn.Module):
    """
    Computes the continuous-time derivative dh(t)/dt for the GRU-ODE hidden state.
    Implements Lipschitz continuous bounded transitions over unobserved gaps.
    """
    def __init__(self, hidden_dim: int):
        super(GRUODEFunc, self).__init__()
        self.hidden_dim = hidden_dim
        
        # Continuous parameterization weights
        self.w_r = nn.Linear(hidden_dim, hidden_dim, bias=True)
        self.w_z = nn.Linear(hidden_dim, hidden_dim, bias=True)
        self.w_h = nn.Linear(hidden_dim, hidden_dim, bias=True)
        
    def forward(self, t, h: torch.Tensor) -> torch.Tensor:
        """
        Autonomous forward pass handling batch dimensions safely.
        h shape: (Batch_Size, Hidden_Dim)
        """
        # Since x(t) = 0 in autonomous tracking, transformations rely solely on h
        r = torch.sigmoid(self.w_r(h))
        z = torch.sigmoid(self.w_z(h))
        g = torch.tanh(self.w_h(r * h))
        
        # Bounded continuous derivative equation
        dhdt = (1.0 - z) * (g - h)
        return dhdt


class GRUBayesUpdate(nn.Module):
    """
    Processes sporadic incoming radar vectors and maps multi-variable constraints
    via an integrated observation error projection layer.
    """
    def __init__(self, input_dim: int, hidden_dim: int):
        super(GRUBayesUpdate, self).__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        
        # Generates predicted mean and log-variance for the feature space
        self.f_obs = nn.Sequential(
            nn.Linear(hidden_dim, 25),
            nn.ReLU(),
            nn.Linear(25, input_dim * 2) # [mean_1, ..., mean_D, logvar_1, ..., logvar_D]
        )
        
        # Per-dimension projection mapping for prep vector q_d
        # q_d size: 2 (theta) + 1 (y_val) + 1 (norm_error) = 4
        self.d_proj = nn.Linear(4, hidden_dim)
        self.gru_cell = nn.GRUCell(hidden_dim * input_dim, hidden_dim)
        
    def forward(self, h_pre: torch.Tensor, y: torch.Tensor, mask: torch.Tensor):
        """
        Executes discrete state updates based on observed values.
        h_pre shape: (B, H), y shape: (B, D), mask shape: (B, D)
        """
        batch_size = h_pre.size(0)
        theta_all = self.f_obs(h_pre)
        mu, logvar = torch.chunk(theta_all, 2, dim=-1)
        sigma = torch.exp(0.5 * logvar) + 1e-6
        
        # Normalized kinematic tracking residuals
        norm_err = (y - mu) / sigma
        
        # Build multi-dimensional feature space transformations safely
        q_elements = []
        for d in range(self.input_dim):
            # Gather attributes for current dimension across batch
            theta_d = torch.stack([mu[:, d], logvar[:, d]], dim=-1) # (B, 2)
            y_d = y[:, d].unsqueeze(-1) # (B, 1)
            err_d = norm_err[:, d].unsqueeze(-1) # (B, 1)
            
            q_d = torch.cat([theta_d, y_d, err_d], dim=-1) # (B, 4)
            proj_d = torch.relu(self.d_proj(q_d)) # (B, H)
            
            # Nullify unobserved channels using the tracking mask
            proj_d = proj_d * mask[:, d].unsqueeze(-1)
            q_elements.append(proj_d)
            
        f_prep = torch.cat(q_elements, dim=-1) # (B, H * D)
        h_post = self.gru_cell(f_prep, h_pre)
        return h_post, mu, sigma


class GRUODEBayesModel(nn.Module):
    """
    Complete System NeXT trajectory forecasting pipeline wrapping continuous flow
    and sequential filtering steps. Conforms to production ONNX requirements.
    """
    def __init__(self, input_dim: int, hidden_dim: int):
        super(GRUODEBayesModel, self).__init__()
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        
        self.ode_flow = GRUODEFunc(hidden_dim)
        self.bayes_update = GRUBayesUpdate(input_dim, hidden_dim)
        
        # Maps latent state space [-1, 1] back out to real-world physical kinematics
        self.decoder = nn.Sequential(
            nn.Linear(hidden_dim, hidden_dim // 2),
            nn.SiLU(),
            nn.Linear(hidden_dim // 2, input_dim)
        )
        
    def forward(self, y_seq: torch.Tensor, mask_seq: torch.Tensor, t_seq: torch.Tensor) -> tuple:
        """
        Executes a trajectory pass over uneven temporal observation steps.
        y_seq/mask_seq shape: (B, T, D) - Target sequence trajectories
        t_seq shape: (T,) or (B, T) - Measurement timestamps
        """
        device = y_seq.device
        batch_size, seq_len, _ = y_seq.size()
        
        # Initialize hidden state within the stable bounded region
        h = torch.zeros((batch_size, self.hidden_dim), device=device)
        
        pred_means = []
        pred_sigmas = []
        
        # Iterate over structural time steps sequentially to allow discrete updates
        for k in range(seq_len):
            if k > 0:
                # Continuous prediction step across variable sensor lookback timelines
                dt_step = t_seq[k] - t_seq[k-1]
                if dt_step > 0:
                    t_span = torch.tensor([0.0, dt_step.item()], device=device)
                    # Integrate hidden dynamics over the variable interval
                    h_integrated = odeint(self.ode_flow, h, t_span, method='rk4', options={'step_size': 0.1})
                    h = h_integrated[-1] # Extract integration endpoint
            
            # Discrete filtering step using incoming observations
            h, mu, sigma = self.bayes_update(h, y_seq[:, k, :], mask_seq[:, k, :])
            pred_means.append(self.decoder(h).unsqueeze(1))
            pred_sigmas.append(sigma.unsqueeze(1))
            
        return torch.cat(pred_means, dim=1), torch.cat(pred_sigmas, dim=1)
