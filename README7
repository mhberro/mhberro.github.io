def main():
    parser = argparse.ArgumentParser(description="System NeXT Tactical Simulation Harness")
    parser.add_argument(
        "truths",
        nargs="+",
        type=str,
        help="list of files to run the sim with. all output will end up in a single directory",
    )
    parser.add_argument("-o", dest="output", required=True, default=None, help="dir to place results")
    parser.add_argument("-m", dest="model", required=True, default=None, help="onnx file")
    parser.add_argument(
        "-s",
        dest="scalar",
        required=True,
        default=None,
        help="this is currently only the pickled scalar.",
    )
    parser.add_argument(
        "--sr-min",
        type=int,
        default=1000,
        help="run the sim until the target gets near this slant range",
    )
    parser.add_argument(
        "--sr-max",
        type=int,
        default=150000,
        help="start the sim no further than this slant range",
    )

    args = parser.parse_args()

    if args.sr_min >= args.sr_max:
        raise ValueError("sr min must be less than sr max")

    if not os.path.exists(args.model):
        raise ValueError(f"There is no model at {args.model}")

    model_path = os.path.dirname(args.model)
    model_name = ".".join(os.path.basename(args.model).split(".")[:-1])

    train_test_split_file = os.path.join(model_path, model_name + "_train_test_split.json")
    train_test_trajs = None
    if os.path.exists(train_test_split_file):
        with open(train_test_split_file) as f:
            train_test_trajs = json.load(f)

    sim_many_truths(args, model_name, train_test_trajs)


def sim_many_truths(args, model_name, train_test_trajs):
    tgt_metric = []
    for p in args.truths:
        print("Running sim for", p, flush=True)
        t = sim_single_truth(p, args.output, args, model_name, train_test_trajs)
        if t is not None:
            tgt_metric.append(t)


def sim_single_truth(path_to_truth, output, args, model_name, train_test_trajs):
    truth = load_single_truth(path_to_truth)
    truth_states_sr_cut, trajs, truth_trajs = sim_ingress(truth, args)

    truth_filename = os.path.basename(path_to_truth)
    if len(trajs) == 0:
        print(f"No extrapolations were created for {truth_filename}")
        return None

    if isinstance(truth_states_sr_cut, int):
        if all((-1 == x for x in (truth_states_sr_cut, trajs, truth_trajs))):
            print("skipping bad truth file", path_to_truth)
            return

    s = f"{model_name}_{truth_filename}"

    if not os.path.exists(output):
        os.makedirs(output, exist_ok=True)
    plot_sim_result(
        truth_states_sr_cut,
        trajs,
        args,
        train_test_trajs,
        model_name,
        traj_number=truth_filename,
        filename=s,
        save=True,
        show=False,
        output=output,
    )
    save_sim_result(output, trajs, truth_filename)
    try:
        traj_metric = calc_sim_metric(output, trajs, truth_trajs, truth_filename)
    except Exception:
        traj_metric = None
    return traj_metric


def calc_sim_metric(output, trajs, truth_trajs, truth_filename):
    ingress_metric = []
    for next_traj, truth_traj in zip(trajs, truth_trajs):
        ingress_metric.append(calc_sim_metric_for_one_pair(truth_traj, next_traj))
    return np.mean(ingress_metric)


def calc_sim_metric_for_one_pair(truth_traj, test_traj):
    t = truth_traj
    if len(truth_traj) != len(test_traj):
        reduction_factor = np.gcd(len(test_traj), len(truth_traj))
        t = resample_poly(
            truth_traj,
            len(test_traj) / reduction_factor,
            len(truth_traj) / reduction_factor,
            padtype="line",
        )
    return mean_absolute_error(t[:, POS_SLICE], test_traj[:, POS_SLICE])


def save_sim_result(output, trajs, truth_filename):
    print(f"Saving {len(trajs)} extrapolations to disk")
    dfs = [None] * len(trajs)
    for i, traj in enumerate(trajs):
        df = pd.DataFrame(
            traj,
            columns=(
                "time",
                "x_pos_ecef",
                "y_pos_ecef",
                "z_pos_ecef",
                "x_vel_ecef",
                "y_vel_ecef",
                "z_vel_ecef",
                "x_acc_ecef",
                "y_acc_ecef",
                "z_acc_ecef",
            ),
        )

        df["curr_time"] = df["time"][0]
        df["pred_num"] = i + 1
        df["validity_time"] = df["time"][0]
        dfs[i] = df

    big_df = pd.concat(dfs)
    big_df["system_track_number"] = 1701
    big_df["threat_id"] = 47
    big_df["true_object_id"] = 31
    big_df["hyp_id"] = 1
    big_df["asset_id"] = 0
    big_df["threat_genre"] = "HGV"
    big_df["eng_status"] = "ELIGIBLE"
    big_df["traj_genre"] = "MRV"
    big_df["traj_genre_score"] = 0
    big_df["reach_assess"] = 0
    big_df["extrap_in_SR"] = "Y"

    s = f"NEXT_extraps_{truth_filename}"
    os.makedirs(os.path.join(output, f"extrap-dt_{extrapolation_dt}"), exist_ok=True)
    big_df.to_csv(os.path.join(output, f"extrap-dt_{extrapolation_dt}", s), index=False)


