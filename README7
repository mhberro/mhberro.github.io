# --------------------------------------------------------------------
    #  GRU ODE model Configuration
    # --------------------------------------------------------------------
    # Force the numerical solver to track and continuously integrate the hidden
    # recurrent memory layers alongside the primary physical coordinates.
    total_solver_aug = aug_dim + nhidden if model_type == "gruode" else aug_dim

    node = NODEPredictor(
        architecture=GRUODEArchitecture(
            state_len=model_states,
            hidden_dim=nhidden,
            aug_dim=aug_dim
        ),
        training_configuration=training_configuration,
        solver=ode_solver,
        logging_interval=5,
        loss_func=loss_func,
        early_stopper=EarlyStopper(10, 0.5, metric_name=early_stop_metric_name),
        checkpoint=ModelCheckpoint(min_epochs=1, directory=model_save_path, model_name=model_name + ".checkpoint"),
        aug_dim=total_solver_aug,  # <-- Hijack the solver registration size
    )

