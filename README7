# loss_functions.py
"""Loss functions for a Neural Ordinary Differential Equation model."""

from __future__ import annotations

from typing import Callable

import torch
from sklearn.preprocessing import MinMaxScaler
from torch import Tensor
from torch.nn import MSELoss
from tslearn.metrics import SoftDTWLossPyTorch


class WrappedMSELoss(MSELoss):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int] | tuple[int, ...],
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
        position_loss_weight: float = 80.0,
        l2_reg: float = 1e-4,
        temporal_weighting: bool = True,
    ) -> None:
        """Initializes WrappedMSELoss with scale-space focus and L2 regularization."""
        super().__init__(reduction="none")
        self.height_idx = height_idx
        self.vel_indices = list(vel_indices)
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        self.position_loss_weight = position_loss_weight
        self.l2_reg = l2_reg
        self.temporal_weighting = temporal_weighting
        self.model_ref = None

    def set_model(self, model: torch.nn.Module) -> None:
        """Saves a structural reference to evaluate explicit parameter decay penalties."""
        self.model_ref = model

    def forward(self, pred: Tensor, target: Tensor) -> dict[str, Tensor]:
        batch_size, n_timesteps, _ = pred.shape
        
        # 1. Generate a broadcastable valid sequence mask to eliminate padding pollution
        valid_mask = (target != 0.0).any(dim=-1, keepdim=True).float()
        
        # 2. Compute elementwise unreduced normalized loss
        elementwise_loss = torch.nn.functional.mse_loss(pred, target, reduction="none")
        
        # 3. Construct the mathematically normalized scale-space weight matrix
        pos_end_idx = self.vel_indices[0]
        weights = torch.ones(self.N_FEATURES, device=pred.device)
        weights[:pos_end_idx] = self.position_loss_weight
        
        # Normalization step: Prevents artificial gradient amplification and directional distortion
        weights = weights / weights.mean()
        weights_view = weights.view(1, 1, -1)
        
        # 4. Generate the linear temporal ramp to penalize late-horizon integration drift
        if self.temporal_weighting:
            t_weights = torch.linspace(1.0, 4.0, n_timesteps, device=pred.device).view(1, -1, 1)
            combined_weights = weights_view * t_weights
        else:
            combined_weights = weights_view
            
        # 5. Compute the final balanced, masked loss metric
        masked_loss = elementwise_loss * combined_weights * valid_mask
        loss_data = masked_loss.sum() / (valid_mask.sum() * self.N_FEATURES + 1e-8)

        # 6. Apply L2 Regularization parameter penalty
        if self.model_ref is not None and self.l2_reg > 0:
            l2_penalty = 0.0
            for param in self.model_ref.parameters():
                if param.requires_grad:
                    l2_penalty += torch.sum(param ** 2)
            loss_data = loss_data + self.l2_reg * l2_penalty

        # Compute metrics.
        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.cpu().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                ).to(pred.device)
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.cpu().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                ).to(target.device)
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            pos_diff = torch.abs(pos_pred - pos_target) * valid_mask
            vel_diff = torch.abs(vel_pred - vel_target) * valid_mask

            avg_pos_diff = pos_diff.sum() / (valid_mask.sum() * pos_pred.shape[-1] + 1e-8)
            avg_vel_diff = vel_diff.sum() / (valid_mask.sum() * vel_pred.shape[-1] + 1e-8)

        return {
            "loss": loss_data,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
        }


class SecondOrderSplitMSELoss(torch.nn.Module):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        vel_weight: float | None = 1.0,
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
        pos_expect: float = "inf",
        vel_expect: float = "inf",
    ) -> None:
        """Initializes SecondOrderSplitMSELoss."""
        super().__init__()
        self.height_idx = height_idx
        self.vel_indices = list(vel_indices)
        self.vel_weight = vel_weight
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        self.pos_expect = pos_expect
        self.vel_expect = vel_expect

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)

        if self.scaler is not None:
            pred_unscaled = torch.from_numpy(
                self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                    -1, n_timesteps, self.N_FEATURES
                )
            )
            target_unscaled = torch.from_numpy(
                self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                    -1, n_timesteps, self.N_FEATURES
                )
            )
        else:
            pred_unscaled = pred.detach()
            target_unscaled = target.detach()

        pos_pred_unscaled = pred_unscaled[..., : self.vel_indices[0]]
        pos_target_unscaled = target_unscaled[..., : self.vel_indices[0]]
        vel_pred_unscaled = pred_unscaled[..., self.vel_indices]
        vel_target_unscaled = target_unscaled[..., self.vel_indices]

        avg_pos_diff = torch.nn.L1Loss().forward(pos_pred_unscaled, pos_target_unscaled)
        avg_vel_diff = torch.nn.L1Loss().forward(vel_pred_unscaled, vel_target_unscaled)

        pos_pred = pred[..., : self.vel_indices[0]]
        pos_target = target[..., : self.vel_indices[0]]
        vel_pred = pred[..., self.vel_indices]
        vel_target = target[..., self.vel_indices]

        pos_ratio = torch.max(torch.Tensor([1.0]), avg_pos_diff / self.pos_expect) ** 2
        vel_ratio = torch.max(torch.Tensor([1.0]), avg_vel_diff / self.vel_expect) ** 2

        pos_loss = torch.nn.MSELoss().forward(pos_pred, pos_target) * pos_ratio
        vel_loss = torch.nn.MSELoss().forward(vel_pred, vel_target) * vel_ratio
        total_loss = pos_loss + vel_loss

        return {
            "loss": total_loss,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
        }


class PhysicsSplitMSELoss(torch.nn.Module):
    """Position/velocity-weighted MSE tied with a cross-target kinematic constraint.
    
    Forces the predicted position derivatives to align directly with the true velocity 
    targets, anchoring velocity features without causing optimization multi-task gridlock.
    """
    def __init__(
        self,
        height_idx: int,
        pos_indices: list[int] | tuple[int, ...],
        vel_indices: list[int] | tuple[int, ...],
        dt: float,
        pos_weight: float = 80.0,
        vel_weight: float = 0.0,
        physics_weight: float = 0.5,
        scaler: StandardScaler | None = None,
        N_FEATURES: int = 6,
        l2_reg: float = 1e-4,
        temporal_weighting: bool = True,
    ) -> None:
        super().__init__()
        self.height_idx = height_idx
        self.register_buffer("pos_indices", torch.tensor(list(pos_indices), dtype=torch.long))
        self.register_buffer("vel_indices", torch.tensor(list(vel_indices), dtype=torch.long))
        self.dt = float(dt)
        self.pos_weight = pos_weight
        self.vel_weight = vel_weight
        self.physics_weight = physics_weight
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        self.l2_reg = l2_reg
        self.temporal_weighting = temporal_weighting
        self.model_ref = None

        if scaler is not None and hasattr(scaler, "scale_"):
            scale = torch.as_tensor(scaler.scale_, dtype=torch.float32)
            self.register_buffer("pos_scale", scale[list(pos_indices)].clone().view(1, 1, -1))
            self.register_buffer("vel_scale", scale[list(vel_indices)].clone().view(1, 1, -1))
        else:
            self.pos_scale = None
            self.vel_scale = None

    def set_model(self, model: torch.nn.Module) -> None:
        self.model_ref = model

    def forward(self, pred: torch.Tensor, target: torch.Tensor) -> dict[str, torch.Tensor]:
        batch_size, n_timesteps, _ = pred.shape
        
        # 1. Generate a broadcastable valid sequence mask to eliminate padding pollution
        valid_mask = (target != 0.0).any(dim=-1, keepdim=True).float()
        
        # 2. Compute elementwise unreduced normalized loss
        elementwise_loss = torch.nn.functional.mse_loss(pred, target, reduction="none")
        
        # 3. Construct mathematically normalized scale-space mapping weights across coordinates
        weights = torch.ones(self.N_FEATURES, device=pred.device)
        weights[self.pos_indices] = self.pos_weight
        weights[self.vel_indices] = self.vel_weight
        
        weights = weights / weights.mean()
        weights_view = weights.view(1, 1, -1)
        
        # 4. Generate the linear temporal ramp to penalize late-horizon integration drift
        if self.temporal_weighting:
            t_weights = torch.linspace(1.0, 4.0, n_timesteps, device=pred.device).view(1, -1, 1)
            combined_weights = weights_view * t_weights
        else:
            combined_weights = weights_view
            
        masked_loss = elementwise_loss * combined_weights * valid_mask
        loss_data = masked_loss.sum() / (valid_mask.sum() * self.N_FEATURES + 1e-8)

        # 5. Cross-Residual Physics: Match predicted position updates against TRUE target velocities
        if self.physics_weight > 0.0 and n_timesteps >= 2:
            pos_pred_phys = pred[..., self.pos_indices]
            vel_true_phys = target[..., self.vel_indices]  # Anchor using the actual target states

            # Convert to physical space variables for valid identity checking
            if self.pos_scale is not None:
                pos_phys = pos_pred_phys * self.pos_scale.to(pred.device)
                vel_phys = vel_true_phys * self.vel_scale.to(pred.device)
            else:
                pos_phys = pos_pred_phys
                vel_phys = vel_true_phys

            # Compute forward finite difference on predictions vs raw target fields
            dpos_dt = (pos_phys[:, 1:, :] - pos_phys[:, :-1, :]) / self.dt
            vel_true_mid = vel_phys[:, :-1, :]

            # Re-normalize residual back to scaled spaces
            if self.pos_scale is not None:
                resid = (dpos_dt - vel_true_mid) / self.pos_scale.to(pred.device)
            else:
                resid = dpos_dt - vel_true_mid

            valid_mask_mid = valid_mask[:, :-1, :]
            physics_loss = (resid ** 2 * valid_mask_mid).sum() / (valid_mask_mid.sum() * len(self.pos_indices) + 1e-8)
            
            loss_data = loss_data + self.physics_weight * physics_loss

        # 6. Apply L2 Regularization parameter decay penalty
        if self.model_ref is not None and self.l2_reg > 0:
            l2_penalty = 0.0
            for param in self.model_ref.parameters():
                if param.requires_grad:
                    l2_penalty += torch.sum(param ** 2)
            loss_data = loss_data + self.l2_reg * l2_penalty

        # 7. Unscaled physical evaluation metrics (No gradients tracked)
        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.cpu().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                ).to(pred.device)
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.cpu().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                ).to(target.device)
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred_u = pred_unscaled[..., self.pos_indices]
            pos_target_u = target_unscaled[..., self.pos_indices]
            vel_pred_u = pred_unscaled[..., self.vel_indices]
            vel_target_u = target_unscaled[..., self.vel_indices]

            pos_diff = torch.abs(pos_pred_u - pos_target_u) * valid_mask
            vel_diff = torch.abs(vel_pred_u - vel_target_u) * valid_mask

            avg_pos_diff = pos_diff.sum() / (valid_mask.sum() * len(self.pos_indices) + 1e-8)
            avg_vel_diff = vel_diff.sum() / (valid_mask.sum() * len(self.vel_indices) + 1e-8)

        return {
            "loss": loss_data,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
        }


class EnergyMSELoss(MSELoss):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        energy_fn: Callable[[Tensor, int, list[int]], Tensor],
        energy_weight: float | None = 1.0,
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
    ) -> None:
        """Initializes EnergyMSELoss."""
        super().__init__()
        self.height_idx = height_idx
        self.vel_indices = list(vel_indices)
        self.energy_fn = energy_fn
        self.energy_weight = energy_weight
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)
        loss_data = super().forward(pred, target)
        energy_pred = self.energy_fn(pred, self.height_idx, self.vel_indices)
        energy_target = self.energy_fn(target, self.height_idx, self.vel_indices)
        loss_energy = super().forward(energy_pred, energy_target) * self.energy_weight

        total_loss = loss_data + loss_energy

        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred, pos_target)
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred, vel_target)

        return {
            "loss": total_loss,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
            "energy_loss": loss_energy,
        }


class ReverseLinearWeightingLoss(torch.nn.modules.loss._Loss):  # noqa: SLF001
    def __init__(self) -> None:
        """Initializes ReverseLinearWeightingLoss."""
        super().__init__()

    def forward(self, pred: torch.Tensor, target: torch.Tensor) -> torch.Tensor:
        batch_size, time_steps, n_features = pred.shape
        reverse_linear_weights: torch.Tensor = torch.arange(time_steps).repeat(batch_size, 1)
        reverse_linear_weights = reverse_linear_weights / reverse_linear_weights.sum(dim=1, keepdim=True) * 100.0
        reverse_linear_weights = torch.stack([reverse_linear_weights for _ in range(n_features)], dim=-1)
        return {"loss": torch.mean(torch.abs(pred - target) * reverse_linear_weights)}


class SoftDTWLossWrapper(SoftDTWLossPyTorch):
    def __init__(
        self,
        height_idx: int,
        vel_indices: list[int],
        scaler: MinMaxScaler | None = None,
        N_FEATURES: int = 6,
        gamma=1,
        normalize=False,
        dist_func=None,
    ):
        super().__init__(gamma, normalize, dist_func)
        self.height_idx = height_idx
        self.vel_indices = list(vel_indices)
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES

    def forward(self, pred: Tensor, target: Tensor) -> Tensor:
        n_timesteps = pred.size(1)
        loss_data = super().forward(pred, target)

        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred, pos_target)
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred, vel_target)

        return {
            "loss": loss_data,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
        }


class WeightedHuberLoss(torch.nn.Module):
    def __init__(
        self,
        delta_pos,
        delta_vel,
        vel_indices: list[int],
        weight_pos=1.0,
        weight_vel=1.0,
        scaler=None,
        N_FEATURES: int = 6,
    ):
        super().__init__()
        self.delta_pos = delta_pos
        self.delta_vel = delta_vel
        self.delta_pos_unsacled = delta_pos
        self.delta_vel_unsacled = delta_vel
        self.vel_indices = list(vel_indices)
        self.wp = weight_pos
        self.wv = weight_vel
        self.scaler = scaler
        self.N_FEATURES = N_FEATURES
        if scaler is not None:
            sigma = scaler.scale_
            self.delta_pos = delta_pos / sigma[: self.vel_indices[0]].mean()
            self.delta_vel = delta_vel / sigma[self.vel_indices[0] :].mean()

    def forward(self, pred, target):
        n_timesteps = pred.size(1)

        pos_pred_scaled = pred[..., : self.vel_indices[0]]
        pos_target_scaled = target[..., : self.vel_indices[0]]
        vel_pred_scaled = pred[..., self.vel_indices]
        vel_target_scaled = target[..., self.vel_indices]

        with torch.no_grad():
            if self.scaler is not None:
                pred_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(pred.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
                target_unscaled = torch.from_numpy(
                    self.scaler.inverse_transform(target.detach().numpy().reshape(-1, self.N_FEATURES)).reshape(
                        -1, n_timesteps, self.N_FEATURES
                    )
                )
            else:
                pred_unscaled = pred.detach()
                target_unscaled = target.detach()

            pos_pred = pred_unscaled[..., : self.vel_indices[0]]
            pos_target = target_unscaled[..., : self.vel_indices[0]]
            vel_pred = pred_unscaled[..., self.vel_indices]
            vel_target = target_unscaled[..., self.vel_indices]

            avg_pos_diff = torch.nn.L1Loss().forward(pos_pred, pos_target)
            avg_vel_diff = torch.nn.L1Loss().forward(vel_pred, vel_target)

            avg_pos_diff_scaled = torch.nn.L1Loss().forward(pos_pred_scaled, pos_target_scaled)
            avg_vel_diff_scaled = torch.nn.L1Loss().forward(vel_pred_scaled, vel_target_scaled)

        loss_pos = torch.nn.HuberLoss(delta=self.delta_pos).forward(pos_pred_scaled, pos_target_scaled) * self.wp
        loss_vel = torch.nn.HuberLoss(delta=self.delta_vel).forward(vel_pred_scaled, vel_target_scaled) * self.wv

        total_loss = (loss_pos * self.wp) + (loss_vel * self.wv)
        total_loss_unweighted = loss_pos + loss_vel
        return {
            "loss": total_loss,
            "loss_unweighted": total_loss_unweighted,
            "pos_err": avg_pos_diff,
            "vel_err": avg_vel_diff,
            "pos_err_scaled": avg_pos_diff_scaled,
            "vel_err_scaled": avg_vel_diff_scaled,
        }
